0031: function summarizeReasoning(input) {
0032:   const raw = String(input || '').trim();
0033:   const lowered = raw.toLowerCase();
0034:   const keywords = raw
0035:     .split(/\s+/)
0036:     .map((w) => w.replace(/[^a-zA-Z0-9_-]/g, ''))
0037:     .filter(Boolean)
0038:     .slice(0, 12);
0039: 
0040:   let intent = 'general_request';
0041:   if (/error|syntax|stack|trace|bug|fix|crash/.test(lowered)) intent = 'debugging';
0042:   else if (/how|what|why|explain|guide|tutorial/.test(lowered)) intent = 'information_lookup';
0043:   else if (/build|create|make|implement|write/.test(lowered)) intent = 'implementation';
0044: 
0045:   let strategy = 'Use local conversation context then query Ollama for a grounded response.';
0046:   if (intent === 'debugging') {
0047:     strategy = 'Focus on likely fault points, propose checks, and request missing runtime details if needed.';
0048:   }
0049: 
0050:   return {
0051:     query: raw,
0052:     intent,
0053:     keywords,
0054:     strategy,
0055:     note: 'Detailed private chain-of-thought is not exposed; this is a concise decision summary.'
0056:   };
0057: }
