1065:   resolvePathInWorkspace(inputPath, expected = 'any') {
1066:     const raw = String(inputPath || '').trim();
1067:     if (!raw) return { error: 'path is required' };
1068:     const normalized = raw === '~' ? os.homedir() : raw;
1069:     const resolved = path.resolve(process.cwd(), normalized);
1070:     const root = path.resolve(this.workspaceRoot);
1071:     const inRoot = resolved === root || resolved.startsWith(`${root}${path.sep}`);
1072:     if (!inRoot) {
1073:       return { error: `path escapes workspace root: ${root}` };
1074:     }
1075: 
1076:     if (expected === 'exists') {
1077:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
1078:     }
1079:     if (expected === 'file' || expected === 'dir') {
1080:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
1081:       let st;
1082:       try {
1083:         st = fs.statSync(resolved);
1084:       } catch (error) {
1085:         return { error: `unable to stat path: ${error.message}` };
1086:       }
1087:       if (expected === 'file' && !st.isFile()) return { error: 'path is not a file' };
1088:       if (expected === 'dir' && !st.isDirectory()) return { error: 'path is not a directory' };
1089:     }
1090: 
1091:     return { path: resolved };
1092:   }
