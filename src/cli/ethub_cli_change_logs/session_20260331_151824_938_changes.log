0329: function summarizeReasoning(input) {
0330:   const raw = String(input || '').trim();
0331:   const lowered = raw.toLowerCase();
0332:   const keywords = raw
0333:     .split(/\s+/)
0334:     .map((w) => w.replace(/[^a-zA-Z0-9_-]/g, ''))
0335:     .filter(Boolean)
0336:     .slice(0, 12);
0337: 
0338:   let intent = 'general_request';
0339:   if (/error|syntax|stack|trace|bug|fix|crash/.test(lowered)) intent = 'debugging';
0340:   else if (/how|what|why|explain|guide|tutorial/.test(lowered)) intent = 'information_lookup';
0341:   else if (/build|create|make|implement|write/.test(lowered)) intent = 'implementation';
0342: 
0343:   let strategy = 'Use local conversation context then query Ollama for a grounded response.';
0344:   if (intent === 'debugging') {
0345:     strategy = 'Focus on likely fault points, propose checks, and request missing runtime details if needed.';
0346:   }
0347: 
0348:   return {
0349:     query: raw,
0350:     intent,
0351:     keywords,
0352:     strategy,
0353:     note: 'Detailed private chain-of-thought is not exposed; this is a concise decision summary.'
0354:   };
0355: }
