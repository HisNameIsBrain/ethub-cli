0754:   validatePathToken(token) {
0755:     const raw = String(token || '').trim();
0756:     if (!raw) return { ok: true };
0757:     if (raw === '-' || raw.startsWith('-')) return { ok: true };
0758:     if (raw.startsWith('/')) return { ok: false, reason: `Absolute paths are blocked (${raw}).` };
0759:     if (raw.includes('..')) return { ok: false, reason: `Parent traversal is blocked (${raw}).` };
0760:     const resolved = path.resolve(process.cwd(), raw);
0761:     if (!isPathInsideRoot(this.workspaceRoot, resolved)) {
0762:       return { ok: false, reason: `Path escapes workspace root (${raw}).` };
0763:     }
0764:     return { ok: true };
0765:   }
0766: 
0767:   validateSkillCommand(snippet) {
0768:     const commandText = normalizeSnippet(snippet);
0769:     if (!commandText) return { ok: false, reason: 'Empty snippet.' };
0770:     const lines = commandText.split('\n').map((l) => l.trim()).filter(Boolean);
0771:     if (lines.length !== 1) return { ok: false, reason: 'Only single-line shell skills are executable.' };
0772:     const line = lines[0];
0773:     if (BLOCKED_COMMAND_PATTERN.test(line)) {
0774:       return { ok: false, reason: 'Command contains blocked shell operators.' };
0775:     }
0776: 
0777:     const parsed = tokenizeCommandLine(line);
0778:     if (parsed.error) return { ok: false, reason: parsed.error };
0779:     const tokens = parsed.tokens || [];
0780:     if (!tokens.length) return { ok: false, reason: 'No command token found.' };
0781: 
0782:     const cmd = tokens[0];
0783:     if (!SAFE_SKILL_COMMANDS.has(cmd)) {
0784:       return { ok: false, reason: `Command '${cmd}' is not allowlisted.` };
0785:     }
0786:     if (cmd === 'git') {
0787:       const sub = (tokens[1] || '').toLowerCase();
0788:       if (!['status', 'diff', 'log', 'show', 'branch', 'rev-parse'].includes(sub)) {
0789:         return { ok: false, reason: `git '${sub || '(none)'}' is blocked.` };
0790:       }
0791:     }
0792: 
0793:     for (let i = 1; i < tokens.length; i += 1) {
0794:       const pathCheck = this.validatePathToken(tokens[i]);
0795:       if (!pathCheck.ok) return pathCheck;
0796:     }
0797:     return { ok: true, command: cmd, tokens };
0798:   }
0799: 
0800:   async runSkillCommand(action) {
0801:     const payload = action && action.payload ? action.payload : {};
0802:     const skillName = payload.skill_name || payload.skill_id || 'unknown';
0803:     const snippet = String(payload.snippet || '');
0804:     const validation = this.validateSkillCommand(snippet);
0805:     if (!validation.ok) {
0806:       this.print(`${style('Skill execution denied:', ANSI.bold, ANSI.red)} ${validation.reason}`);
0807:       this.logger.writeEvent('skill_run_denied', {
0808:         action_id: action.id,
0809:         skill: skillName,
0810:         reason: validation.reason
0811:       });
0812:       return;
0813:     }
0814: 
0815:     const tokens = validation.tokens;
0816:     const cmd = tokens[0];
0817:     const args = tokens.slice(1);
0818:     this.print(style(`[SKILL RUN] ${skillName}: ${snippet}`, ANSI.bold, ANSI.cyan));
0819: 
0820:     const result = await new Promise((resolve) => {
0821:       const child = spawn(cmd, args, {
0822:         cwd: process.cwd(),
0823:         stdio: ['ignore', 'pipe', 'pipe'],
0824:         shell: false
0825:       });
0826: 
0827:       let stdout = '';
0828:       let stderr = '';
0829:       let finished = false;
0830:       const timer = setTimeout(() => {
0831:         if (finished) return;
0832:         child.kill('SIGTERM');
0833:       }, 120000);
0834: 
0835:       child.stdout.on('data', (chunk) => {
0836:         if (stdout.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0837:         stdout += chunk.toString('utf8');
0838:       });
0839:       child.stderr.on('data', (chunk) => {
0840:         if (stderr.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0841:         stderr += chunk.toString('utf8');
0842:       });
0843:       child.on('error', (error) => {
0844:         clearTimeout(timer);
0845:         finished = true;
0846:         resolve({ code: -1, signal: null, stdout, stderr: `${stderr}\n${error.message}`.trim() });
0847:       });
0848:       child.on('close', (code, signal) => {
0849:         clearTimeout(timer);
0850:         finished = true;
0851:         resolve({ code, signal, stdout, stderr });
0852:       });
0853:     });
0854: 
0855:     if (result.stdout) {
0856:       this.print(style('[STDOUT]', ANSI.dim));
0857:       this.print(truncateText(result.stdout, MAX_COMMAND_OUTPUT_BYTES));
0858:     }
0859:     if (result.stderr) {
0860:       this.print(style('[STDERR]', ANSI.dim));
0861:       this.print(truncateText(result.stderr, MAX_COMMAND_OUTPUT_BYTES));
0862:     }
0863:     this.print(style(`[SKILL EXIT] code=${result.code} signal=${result.signal || 'none'}`, ANSI.dim));
0864:     this.logger.writeEvent('skill_run_complete', {
0865:       action_id: action.id,
0866:       skill: skillName,
0867:       code: result.code,
0868:       signal: result.signal,
0869:       stdout_chars: result.stdout.length,
0870:       stderr_chars: result.stderr.length
0871:     });
0872:   }
