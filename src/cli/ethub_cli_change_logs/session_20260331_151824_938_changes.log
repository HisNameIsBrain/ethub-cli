0617:   listArtifactZipFiles() {
0618:     const out = [];
0619:     if (!fs.existsSync(ARTIFACTS_ROOT)) return out;
0620:     const stack = [ARTIFACTS_ROOT];
0621:     while (stack.length) {
0622:       const current = stack.pop();
0623:       let entries = [];
0624:       try {
0625:         entries = fs.readdirSync(current, { withFileTypes: true });
0626:       } catch {
0627:         continue;
0628:       }
0629:       for (const entry of entries) {
0630:         const full = path.join(current, entry.name);
0631:         if (entry.isDirectory()) {
0632:           stack.push(full);
0633:         } else if (entry.isFile() && full.toLowerCase().endsWith('.zip')) {
0634:           out.push(full);
0635:         }
0636:       }
0637:     }
0638:     return out;
0639:   }
