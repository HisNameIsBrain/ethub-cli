1161:   async showSuggestions() {
1162:     this.print('');
1163:     this.print(LEFT_PAD + style('Suggestions (you can just start typing):', ANSI.dim));
1164:     for (const s of SUGGESTIONS) {
1165:       let buf = '';
1166:       for (const ch of s) {
1167:         buf += ch;
1168:         process.stdout.write(`\r${LEFT_PAD}${style(`• ${buf}`, ANSI.dim)}`);
1169:         await new Promise((resolve) => setTimeout(resolve, 12));
1170:       }
1171:       process.stdout.write('\n');
1172:       await new Promise((resolve) => setTimeout(resolve, 80));
1173:     }
1174:     this.print('');
1175:   }
