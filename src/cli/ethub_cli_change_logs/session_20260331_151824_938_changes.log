0641:   collectSkillCandidatesFromArtifacts(limit = 10) {
0642:     const snippets = new Map();
0643:     let scannedSources = 0;
0644:     const cap = Math.max(1, Math.min(MAX_SKILL_CANDIDATES, Number(limit) || 10));
0645:     const addCandidate = (snippetText, sourceLabel, sourceKind) => {
0646:       const normalized = normalizeSnippet(snippetText);
0647:       if (!looksLikeUsefulSnippet(normalized)) return;
0648:       const existing = snippets.get(normalized);
0649:       if (existing) {
0650:         existing.hits += 1;
0651:         existing.sources.add(sourceLabel);
0652:         return;
0653:       }
0654:       snippets.set(normalized, {
0655:         snippet: normalized,
0656:         hits: 1,
0657:         source_kind: sourceKind,
0658:         sources: new Set([sourceLabel])
0659:       });
0660:     };
0661: 
0662:     const zipFiles = this.listArtifactZipFiles();
0663:     for (const zipPath of zipFiles) {
0664:       try {
0665:         const entries = extractTextEntriesFromZip(zipPath, isLikelyTextPath);
0666:         for (const item of entries) {
0667:           scannedSources += 1;
0668:           this.extractSnippetCandidatesFromText(item.text, `${path.basename(zipPath)}:${item.entry}`, addCandidate);
0669:         }
0670:       } catch (error) {
0671:         this.logger.writeEvent('skills_mine_warning', {
0672:           stage: 'zip_read',
0673:           zip: zipPath,
0674:           error: error.message
0675:         });
0676:       }
0677:     }
0678: 
0679:     const directArtifactFiles = [];
0680:     if (fs.existsSync(ARTIFACTS_ROOT)) {
0681:       const stack = [ARTIFACTS_ROOT];
0682:       while (stack.length) {
0683:         const current = stack.pop();
0684:         let entries = [];
0685:         try {
0686:           entries = fs.readdirSync(current, { withFileTypes: true });
0687:         } catch {
0688:           continue;
0689:         }
0690:         for (const entry of entries) {
0691:           const full = path.join(current, entry.name);
0692:           if (entry.isDirectory()) stack.push(full);
0693:           else if (entry.isFile() && !full.toLowerCase().endsWith('.zip') && isLikelyTextPath(full)) directArtifactFiles.push(full);
0694:         }
0695:       }
0696:     }
0697: 
0698:     for (const filePath of directArtifactFiles) {
0699:       let text = '';
0700:       try {
0701:         text = fs.readFileSync(filePath, 'utf8');
0702:       } catch {
0703:         continue;
0704:       }
0705:       scannedSources += 1;
0706:       this.extractSnippetCandidatesFromText(text, this.workspaceRelativePath(filePath), addCandidate);
0707:     }
0708: 
0709:     const ranked = Array.from(snippets.values())
0710:       .sort((a, b) => b.hits - a.hits || b.snippet.length - a.snippet.length)
0711:       .slice(0, cap);
0712: 
0713:     this.skillCandidates = ranked.map((entry, idx) => {
0714:       const snippet = entry.snippet;
0715:       const safety = this.validateSkillCommand(snippet);
0716:       return {
0717:         id: `cand_${idx + 1}`,
0718:         snippet,
0719:         hits: entry.hits,
0720:         source_kind: entry.source_kind,
0721:         sources: Array.from(entry.sources).slice(0, 6),
0722:         executable: safety.ok,
0723:         safety_reason: safety.ok ? '' : safety.reason
0724:       };
0725:     });
0726: 
0727:     this.logger.writeEvent('skills_mined', {
0728:       candidates: this.skillCandidates.length,
0729:       unique_snippets: snippets.size,
0730:       scanned_sources: scannedSources,
0731:       zip_files: zipFiles.length
0732:     });
0733: 
0734:     return {
0735:       candidates: this.skillCandidates.length,
0736:       uniqueSnippets: snippets.size,
0737:       scannedSources,
0738:       zipFiles: zipFiles.length
0739:     };
0740:   }
