0742:   findCandidate(query) {
0743:     const q = String(query || '').trim();
0744:     if (!q) return null;
0745:     return this.skillCandidates.find((c) => c.id === q) || null;
0746:   }
0747: 
0748:   findSkill(query) {
0749:     const q = String(query || '').trim().toLowerCase();
0750:     if (!q) return null;
0751:     return this.skills.find((s) => s.id.toLowerCase() === q || s.name.toLowerCase() === q) || null;
0752:   }
