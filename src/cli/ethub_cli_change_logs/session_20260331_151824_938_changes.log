0569:       if (typeof value === 'string') {
0570:         if (value.trim()) segments.push(value);
0571:         return;
0572:       }
0573:       if (!value || typeof value !== 'object') return;
0574:       if (Array.isArray(value)) {
0575:         for (const item of value) walk(item, depth + 1);
0576:         return;
0577:       }
0578:       if (value.content && Array.isArray(value.content.parts)) {
0579:         for (const part of value.content.parts) {
0580:           if (typeof part === 'string' && part.trim()) segments.push(part);
0581:         }
0582:       }
0583:       if (typeof value.text === 'string' && value.text.trim()) {
0584:         segments.push(value.text);
0585:       }
0586:       for (const key of Object.keys(value)) {
0587:         if (key === 'content' || key === 'text') continue;
0588:         walk(value[key], depth + 1);
0589:       }
0590:     };
0591: 
0592:     if (parsed) {
0593:       walk(parsed);
0594:     } else {
0595:       segments.push(raw);
0596:     }
0597: 
0598:     for (const segment of segments) {
0599:       const fencePattern = /```(?:[^\n`]*)\n([\s\S]*?)```/g;
0600:       let match;
0601:       while ((match = fencePattern.exec(segment)) !== null) {
0602:         addCandidate(match[1], sourceLabel, 'fenced_code');
0603:       }
0604: 
0605:       const lines = segment.split('\n');
0606:       for (const line of lines) {
0607:         const trimmed = line.trim();
0608:         if (!trimmed || trimmed.length > 220) continue;
0609:         const shellLike = trimmed.replace(/^\$\s*/, '');
0610:         if (/^(ls|pwd|cat|head|tail|wc|rg|grep|find|sed|cp|mv|mkdir|touch|echo|git)\b/.test(shellLike)) {
0611:           addCandidate(shellLike, sourceLabel, 'shell_line');
0612:         }
0613:       }
0614:     }
0615:   }
