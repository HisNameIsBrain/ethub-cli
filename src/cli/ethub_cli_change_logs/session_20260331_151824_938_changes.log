1200:   async handleCommand(input) {
1201:     const [cmd, ...args] = input.split(/\s+/);
1202:     const command = cmd.toLowerCase();
1203:     this.logger.writeEvent('subcommand', { command, args });
1204: 
1205:     if (command === '/help') {
1206:       this.print('Commands: /help, /status, /model <name>, /approve changes on|off, /debug, /dashboard, /readfile <path>, /writefile <path> -- <content>, /cd <path>, /skills <mine|candidates|add|list|show|run>, /yes, /no, /exit');
1207:       this.print('Skills flow: /skills mine 10 -> /skills add cand_1 my_skill -> /yes -> /skills run my_skill -> /yes');
1208:       return;
1209:     }
1210: 
1211:     if (command === '/status') {
1212:       this.print(safeJson({
1213:         model: this.model,
1214:         ollama_url: this.ollamaUrl,
1215:         require_approval_for_changes: this.requireApproval,
1216:         skills_count: this.skills.length,
1217:         skill_candidates_count: this.skillCandidates.length,
1218:         dashboard_url: this.dashboardInfo && this.dashboardInfo.dashboard_url ? this.dashboardInfo.dashboard_url : null,
1219:         chat_url: this.dashboardInfo && this.dashboardInfo.chat_url ? this.dashboardInfo.chat_url : null,
1220:         debug_dashboard_pid: this.debugServerProcess && !this.debugServerProcess.killed ? this.debugServerProcess.pid : null,
1221:         history_count: this.history.length,
1222:         pending_action: this.pendingAction ? this.pendingAction.id : null
1223:       }));
1224:       return;
1225:     }
1226: 
1227:     if (command === '/model') {
1228:       const nextModel = args.join(' ').trim();
1229:       if (!nextModel) {
1230:         this.print(`Current model: ${this.model}`);
1231:         return;
1232:       }
1233:       this.model = nextModel;
1234:       this.print(`Model updated: ${this.model}`);
1235:       this.logger.writeEvent('config_update', { key: 'model', value: this.model });
1236:       return;
1237:     }
1238: 
1239:     if (command === '/approve') {
1240:       const target = (args[0] || '').toLowerCase();
1241:       const mode = (args[1] || '').toLowerCase();
1242:       const legacyMode = target;
1243: 
1244:       if (target === 'changes' && (mode === 'on' || mode === 'off')) {
1245:         this.requireApproval = mode === 'on';
1246:         this.print(`Change approval mode: ${mode}`);
1247:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1248:         return;
1249:       }
1250: 
1251:       if (legacyMode === 'on' || legacyMode === 'off') {
1252:         this.requireApproval = legacyMode === 'on';
1253:         this.print(`Change approval mode: ${legacyMode}`);
1254:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1255:         return;
1256:       }
1257: 
1258:       if (!target) {
1259:         this.print(`Change approval mode: ${this.requireApproval ? 'on' : 'off'}`);
1260:         return;
1261:       }
1262: 
1263:       this.print('Usage: /approve changes on|off');
1264:       return;
1265:     }
1266: 
1267:     if (command === '/debug' || command === '/dashboard') {
1268:       const info = await this.startDebugDashboard();
1269:       this.print(style(`Debug dashboard live: ${info.dashboard_url}`, ANSI.cyan));
1270:       this.print(style(`Debug chat live: ${info.chat_url}`, ANSI.cyan));
1271:       this.print(style(`Token length: ${this.debugServerToken.length} (not persisted to file)`, ANSI.dim));
1272:       return;
1273:     }
1274: 
1275:     if (command === '/yes') {
1276:       if (!this.pendingAction) {
1277:         this.print('No pending action to approve.');
1278:         return;
1279:       }
1280:       const action = this.pendingAction;
1281:       this.pendingAction = null;
1282:       this.logger.writeEvent('approval', { action_id: action.id, approved: true });
1283:       this.writeStructuredUpdate(action.id, {
1284:         'Print-approved-by-user?': 'true',
1285:         approved: true
1286:       });
1287:       await this.executePendingAction(action);
1288:       return;
1289:     }
1290: 
1291:     if (command === '/no') {
1292:       if (!this.pendingAction) {
1293:         this.print('No pending action to reject.');
1294:         return;
1295:       }
1296:       const action = this.pendingAction;
1297:       this.pendingAction = null;
1298:       this.logger.writeEvent('approval', { action_id: action.id, approved: false });
1299:       this.writeStructuredUpdate(action.id, {
1300:         'Print-approved-by-user?': 'false',
1301:         approved: false,
1302:         summary: 'Action was rejected by user before runtime execution.',
1303:         'Run runtime look at logs': 'skipped (approval rejected)'
1304:       });
1305:       this.print(`Action ${action.id} skipped.`);
1306:       return;
1307:     }
1308: 
1309:     if (command === '/exit') {
1310:       this.rl.close();
1311:       return;
1312:     }
1313: 
1314:     if (command === '/cd') {
1315:       const rawTarget = input.replace(/^\/cd\s*/i, '').trim();
1316:       if (!rawTarget) {
1317:         this.print(`Current directory: ${process.cwd()}`);
1318:         return;
1319:       }
1320:       const resolved = this.resolvePathInWorkspace(rawTarget, 'dir');
1321:       if (resolved.error) {
1322:         this.print(`${style('cd denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1323:         return;
1324:       }
1325:       process.chdir(resolved.path);
1326:       this.refreshPrompt();
1327:       this.logger.writeEvent('cwd_changed', {
1328:         cwd: process.cwd(),
1329:         workspace_relative: this.workspaceRelativePath()
1330:       });
1331:       this.print(style(`Directory changed to ${this.workspaceRelativePath()}`, ANSI.cyan));
1332:       return;
1333:     }
1334: 
1335:     if (command === '/readfile') {
1336:       const rawPath = input.replace(/^\/readfile\s*/i, '').trim();
1337:       if (!rawPath) {
1338:         this.print('Usage: /readfile <path>');
1339:         return;
1340:       }
1341:       const resolved = this.resolvePathInWorkspace(rawPath, 'file');
1342:       if (resolved.error) {
1343:         this.print(`${style('readfile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1344:         return;
1345:       }
1346:       const action = {
1347:         id: `act_${Date.now()}`,
1348:         type: 'read_file',
1349:         payload: {
1350:           path: resolved.path,
1351:           rel: this.workspaceRelativePath(resolved.path)
1352:         },
1353:         created_at: nowIso()
1354:       };
1355:       this.queueApprovalAction(
1356:         action,
1357:         `${style('Read request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel}`
1358:       );
1359:       return;
1360:     }
1361: 
1362:     if (command === '/writefile') {
1363:       const raw = input.replace(/^\/writefile\s*/i, '');
1364:       const splitIndex = raw.indexOf(' -- ');
1365:       if (splitIndex === -1) {
1366:         this.print('Usage: /writefile <path> -- <content>');
1367:         return;
1368:       }
1369:       const rawPath = raw.slice(0, splitIndex).trim();
1370:       const content = raw.slice(splitIndex + 4);
1371:       if (!rawPath) {
1372:         this.print('Usage: /writefile <path> -- <content>');
1373:         return;
1374:       }
1375:       const resolved = this.resolvePathInWorkspace(rawPath, 'any');
1376:       if (resolved.error) {
1377:         this.print(`${style('writefile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1378:         return;
1379:       }
1380:       const action = {
1381:         id: `act_${Date.now()}`,
1382:         type: 'write_file',
1383:         payload: {
1384:           path: resolved.path,
1385:           rel: this.workspaceRelativePath(resolved.path),
1386:           content
1387:         },
1388:         created_at: nowIso()
1389:       };
1390:       this.queueApprovalAction(
1391:         action,
1392:         `${style('Write request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel} (${content.length} chars)`
1393:       );
1394:       return;
1395:     }
1396: 
1397:     if (command === '/skills') {
1398:       const sub = (args[0] || '').toLowerCase();
1399:       if (!sub || sub === 'help') {
1400:         this.print('Usage:');
1401:         this.print('/skills mine [count]');
1402:         this.print('/skills candidates');
1403:         this.print('/skills add <candidate_id> <skill_name>');
1404:         this.print('/skills list');
1405:         this.print('/skills show <skill_id|skill_name>');
1406:         this.print('/skills run <skill_id|skill_name>');
1407:         return;
1408:       }
1409: 
1410:       if (sub === 'mine') {
1411:         const count = Number(args[1] || 10);
1412:         const result = this.collectSkillCandidatesFromArtifacts(count);
1413:         this.print(style(`Mined ${result.candidates} candidate skill patterns from artifacts (sources scanned: ${result.scannedSources}).`, ANSI.cyan));
1414:         for (const c of this.skillCandidates) {
1415:           this.print(style(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.yellow));
1416:           this.print('```');
1417:           this.print(c.snippet);
1418:           this.print('```');
1419:           if (!c.executable) this.print(style(`reason: ${c.safety_reason}`, ANSI.dim));
1420:         }
1421:         return;
1422:       }
1423: 
1424:       if (sub === 'candidates') {
1425:         if (!this.skillCandidates.length) {
1426:           this.print('No candidates loaded. Run /skills mine first.');
1427:           return;
1428:         }
1429:         for (const c of this.skillCandidates) {
1430:           this.print(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'} source_kind=${c.source_kind}`);
1431:         }
1432:         return;
1433:       }
1434: 
1435:       if (sub === 'add') {
1436:         const candidateId = args[1] || '';
1437:         const skillName = args.slice(2).join(' ').trim();
1438:         if (!candidateId || !skillName) {
1439:           this.print('Usage: /skills add <candidate_id> <skill_name>');
1440:           return;
1441:         }
1442:         const existing = this.findSkill(skillName);
1443:         if (existing) {
1444:           this.print(`Skill already exists: ${existing.name} (${existing.id})`);
1445:           return;
1446:         }
1447:         const candidate = this.findCandidate(candidateId);
1448:         if (!candidate) {
1449:           this.print(`Candidate not found: ${candidateId}`);
1450:           return;
1451:         }
1452:         const action = {
1453:           id: `act_${Date.now()}`,
1454:           type: 'add_skill',
1455:           payload: {
1456:             skill_name: skillName,
1457:             source_candidate: candidate.id,
1458:             snippet: candidate.snippet,
1459:             executable: candidate.executable
1460:           },
1461:           created_at: nowIso()
1462:         };
1463:         this.queueApprovalAction(
1464:           action,
1465:           `${style('Add skill queued:', ANSI.bold, ANSI.yellow)} ${skillName} from ${candidate.id}`
1466:         );
1467:         return;
1468:       }
1469: 
1470:       if (sub === 'list') {
1471:         if (!this.skills.length) {
1472:           this.print(`No approved skills yet. Skills file: ${this.skillsPath}`);
1473:           return;
1474:         }
1475:         for (const skill of this.skills) {
1476:           this.print(`[${skill.id}] ${skill.name} | executable=${skill.executable ? 'yes' : 'no'} | source=${skill.source}`);
1477:         }
1478:         return;
1479:       }
1480: 
1481:       if (sub === 'show') {
1482:         const query = args.slice(1).join(' ').trim();
1483:         if (!query) {
1484:           this.print('Usage: /skills show <skill_id|skill_name>');
1485:           return;
1486:         }
1487:         const skill = this.findSkill(query);
1488:         if (!skill) {
1489:           this.print(`Skill not found: ${query}`);
1490:           return;
1491:         }
1492:         this.print(style(`[${skill.id}] ${skill.name}`, ANSI.bold, ANSI.cyan));
1493:         this.print('```');
1494:         this.print(skill.snippet);
1495:         this.print('```');
1496:         return;
1497:       }
1498: 
1499:       if (sub === 'run') {
1500:         const query = args.slice(1).join(' ').trim();
1501:         if (!query) {
1502:           this.print('Usage: /skills run <skill_id|skill_name>');
1503:           return;
1504:         }
1505:         const skill = this.findSkill(query);
1506:         if (!skill) {
1507:           this.print(`Skill not found: ${query}`);
1508:           return;
1509:         }
1510:         const validation = this.validateSkillCommand(skill.snippet);
1511:         if (!validation.ok) {
1512:           this.print(`${style('Skill is not executable:', ANSI.bold, ANSI.red)} ${validation.reason}`);
1513:           return;
1514:         }
1515:         const action = {
1516:           id: `act_${Date.now()}`,
1517:           type: 'run_skill',
1518:           payload: {
1519:             skill_id: skill.id,
1520:             skill_name: skill.name,
1521:             snippet: skill.snippet
1522:           },
1523:           created_at: nowIso()
1524:         };
1525:         this.queueApprovalAction(
1526:           action,
1527:           `${style('Skill execution queued:', ANSI.bold, ANSI.yellow)} ${skill.name}\n${skill.snippet}`
1528:         );
1529:         return;
1530:       }
1531: 
1532:       this.print(`Unknown skills subcommand: ${sub}`);
1533:       return;
1534:     }
1535: 
1536:     this.print(`Unknown command: ${command}. Use /help.`);
1537:   }
