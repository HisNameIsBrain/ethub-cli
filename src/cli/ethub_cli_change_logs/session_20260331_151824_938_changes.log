1177:   startThinking() {
1178:     if (this.thinkingTimer) return;
1179:     let i = 0;
1180:     this.thinkingTimer = setInterval(() => {
1181:       const dots = '.'.repeat(i % 4);
1182:       process.stdout.write(
1183:         `\r${LEFT_PAD}${style('Thinking', ANSI.cyan)}${dots.padEnd(3, ' ')}${style(' parsing your request', ANSI.dim)}${' '.repeat(20)}`
1184:       );
1185:       i += 1;
1186:     }, 140);
1187:   }
