1539:   async executePendingAction(action) {
1540:     if (!action) return;
1541:     if (action.type === 'ollama_chat') {
1542:       await this.executeAction(action);
1543:       return;
1544:     }
1545:     if (action.type === 'read_file') {
1546:       this.runReadFileAction(action);
1547:       return;
1548:     }
1549:     if (action.type === 'write_file') {
1550:       this.runWriteFileAction(action);
1551:       return;
1552:     }
1553:     if (action.type === 'add_skill') {
1554:       this.runAddSkillAction(action);
1555:       return;
1556:     }
1557:     if (action.type === 'run_skill') {
1558:       await this.runSkillCommand(action);
1559:       return;
1560:     }
1561:     if (action.type === 'todo_plan') {
1562:       const payload = action && action.payload ? action.payload : {};
1563:       await this.executeTodoPlan(payload.plan || [], payload.file || path.resolve(__filename));
1564:       return;
1565:     }
1566:     this.print(`Unsupported pending action type: ${action.type}`);
1567:   }
1568: 
1569:   runReadFileAction(action) {
1570:     const filePath = action && action.payload ? action.payload.path : '';
1571:     if (!filePath || !fs.existsSync(filePath)) {
1572:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} file no longer exists.`);
1573:       return;
1574:     }
1575:     let text;
1576:     try {
1577:       text = fs.readFileSync(filePath, 'utf8');
1578:     } catch (error) {
1579:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1580:       return;
1581:     }
1582:     const shown = truncateText(text, MAX_READFILE_BYTES);
1583:     const rel = action.payload.rel || this.workspaceRelativePath(filePath);
1584:     this.print(style(`[I/O READ] ${rel}`, ANSI.bold, ANSI.cyan));
1585:     this.print(style(`\n[READFILE] ${rel}`, ANSI.bold, ANSI.cyan));
1586:     this.print(style(`bytes: ${Buffer.byteLength(text, 'utf8')} | shown: ${Buffer.byteLength(shown, 'utf8')}`, ANSI.dim));
1587:     this.print(shown);
1588:     this.logger.writeEvent('read_file', {
1589:       action_id: action.id,
1590:       file: filePath,
1591:       bytes: Buffer.byteLength(text, 'utf8'),
1592:       shown_bytes: Buffer.byteLength(shown, 'utf8')
1593:     });
1594:   }
1595: 
1596:   runWriteFileAction(action) {
1597:     const filePath = action && action.payload ? action.payload.path : '';
1598:     const content = action && action.payload ? String(action.payload.content || '') : '';
1599:     if (!filePath) {
1600:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} missing target path.`);
1601:       return;
1602:     }
1603:     try {
1604:       ensureDir(path.dirname(filePath));
1605:       fs.writeFileSync(filePath, content, 'utf8');
1606:     } catch (error) {
1607:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1608:       return;
1609:     }
1610:     this.print(style(`[I/O WRITE] ${action.payload.rel}`, ANSI.bold, ANSI.cyan));
1611:     this.print(style(`[WRITEFILE] wrote ${content.length} chars to ${action.payload.rel}`, ANSI.bold, ANSI.cyan));
1612:     this.logger.writeEvent('write_file', {
1613:       action_id: action.id,
1614:       file: filePath,
1615:       chars: content.length
1616:     });
1617:   }
1618: 
1619:   runAddSkillAction(action) {
1620:     const payload = action && action.payload ? action.payload : {};
1621:     const name = String(payload.skill_name || '').trim();
1622:     const snippet = String(payload.snippet || '');
1623:     if (!name || !snippet) {
1624:       this.print(`${style('Add skill failed:', ANSI.bold, ANSI.red)} missing skill name or snippet.`);
1625:       return;
1626:     }
1627:     const duplicate = this.findSkill(name);
1628:     if (duplicate) {
1629:       this.print(`${style('Add skill skipped:', ANSI.bold, ANSI.red)} skill already exists (${duplicate.id}).`);
1630:       return;
1631:     }
1632: 
1633:     const skill = {
1634:       id: `skill_${Date.now()}`,
1635:       name,
1636:       snippet,
1637:       source: `candidate:${payload.source_candidate || 'unknown'}`,
1638:       executable: Boolean(payload.executable),
1639:       created_at: nowIso()
1640:     };
1641:     this.skills.push(skill);
1642:     this.saveSkills();
1643:     this.print(style(`[SKILL ADDED] ${skill.name} (${skill.id}) executable=${skill.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.cyan));
1644:     this.logger.writeEvent('skill_added', {
1645:       action_id: action.id,
1646:       skill_id: skill.id,
1647:       skill_name: skill.name,
1648:       executable: skill.executable
1649:     });
1650:   }
1651: 
1652:   readFileSafe(filePath) {
1653:     const target = path.resolve(filePath || '');
1654:     if (!target) return '';
1655:     if (!fs.existsSync(target)) return '';
1656:     try {
1657:       return fs.readFileSync(target, 'utf8');
1658:     } catch (error) {
1659:       this.logger.writeEvent('pipeline_read_failed', {
1660:         file: target,
1661:         error: error.message
1662:       });
1663:       return '';
1664:     }
1665:   }
1666: 
1667:   uiBox(msg, color = 'cyan') {
1668:     const c = {
1669:       cyan: '\x1b[36m',
1670:       green: '\x1b[32m',
1671:       red: '\x1b[31m',
1672:       yellow: '\x1b[33m'
1673:     };
1674:     const code = c[color] || c.cyan;
1675:     return `${code}[ ${String(msg || '')} ]\x1b[0m`;
1676:   }
1677: 
1678:   emitUiFrame(lines, clearScreen = false) {
1679:     const rows = Array.isArray(lines) ? lines : [];
1680:     if (clearScreen && process.stdout.isTTY) {
1681:       process.stdout.write('\x1b[2J\x1b[H');
1682:     }
1683:     const text = `${rows.join('\n')}\n`;
1684:     process.stdout.write(text);
1685:     this.logger.writeEvent('stdout', { text: rows.join('\n') });
1686:   }
1687: 
1688:   analyzeContext(code) {
1689:     const text = String(code || '');
1690:     return {
1691:       length: text.length,
1692:       hasDebugLoop: /function\s+debugLoop/.test(text),
1693:       hasPipeline: /runPipeline/.test(text),
1694:       hasTodo: /TODO|TodoManager/.test(text),
1695:       hasANSI: /\x1b\[/.test(text),
1696:       hasCLI: /readline|process\.stdin/.test(text),
1697:       hasFileOps: /fs\./.test(text),
1698:       complexity: (text.match(/function/g) || []).length
1699:     };
1700:   }
1701: 
1702:   classifyContext(ctx) {
1703:     if (!ctx.hasPipeline) return 'bootstrap_pipeline';
1704:     if (!ctx.hasDebugLoop) return 'missing_debug';
1705:     if (!ctx.hasTodo) return 'missing_planning';
1706:     if (ctx.complexity < 10) return 'expand_features';
1707:     if (ctx.length > 150000) return 'optimize';
1708:     return 'stable';
1709:   }
1710: 
1711:   buildPlan(type) {
1712:     switch (type) {
1713:       case 'bootstrap_pipeline':
1714:         return ['add_pipeline_core'];
1715:       case 'missing_debug':
1716:         return ['add_debug_loop'];
1717:       case 'missing_planning':
1718:         return ['add_todo_system'];
1719:       case 'expand_features':
1720:         return ['add_context_router'];
1721:       case 'optimize':
1722:         return ['refactor_large_blocks'];
1723:       default:
1724:         return ['noop'];
1725:     }
1726:   }
1727: 
1728:   routeIntent(input) {
1729:     const text = String(input || '').toLowerCase();
1730:     if (/error|bug/.test(text)) return 'debug';
1731:     if (/summarize/.test(text)) return 'summary';
1732:     if (/build|create/.test(text)) return 'code';
1733:     if (/research|find/.test(text)) return 'research';
1734:     return 'general';
1735:   }
1736: 
1737:   isSafeCommand(commandText) {
1738:     const text = String(commandText || '').trim();
1739:     if (!text) return false;
1740:     if (BLOCKED_COMMAND_PATTERN.test(text)) return false;
1741:     const parsed = tokenizeCommandLine(text);
1742:     if (parsed.error || !parsed.tokens || !parsed.tokens.length) return false;
1743:     const cmd = parsed.tokens[0];
1744:     return /^(ls|cd|cat|grep|rg|sed|cp|mv|tree|echo)$/.test(cmd);
1745:   }
1746: 
1747:   async runShell(commandText) {
1748:     const raw = String(commandText || '').trim();
1749:     const parsed = tokenizeCommandLine(raw);
1750:     if (parsed.error) {
1751:       this.print(this.uiBox(`Shell parse error: ${parsed.error}`, 'red'));
1752:       return;
1753:     }
1754:     const tokens = parsed.tokens || [];
1755:     if (!tokens.length) {
1756:       this.print(this.uiBox('Shell command rejected (empty).', 'red'));
1757:       return;
1758:     }
1759: 
1760:     const cmd = tokens[0];
1761:     const args = tokens.slice(1);
1762: 
1763:     if (cmd === 'cd') {
1764:       const target = args[0] || '.';
1765:       const resolved = this.resolvePathInWorkspace(target, 'dir');
1766:       if (resolved.error) {
1767:         this.print(this.uiBox(`cd denied: ${resolved.error}`, 'red'));
1768:         return;
1769:       }
1770:       process.chdir(resolved.path);
1771:       this.refreshPrompt();
1772:       this.print(this.uiBox(`cwd -> ${this.workspaceRelativePath()}`, 'cyan'));
1773:       return;
1774:     }
1775: 
1776:     await new Promise((resolve) => {
1777:       const proc = spawn(cmd, args, { stdio: ['ignore', 'pipe', 'pipe'], shell: false });
1778:       let out = '';
1779:       proc.stdout.on('data', (d) => {
1780:         out += d.toString();
1781:       });
1782:       proc.stderr.on('data', (d) => {
1783:         out += d.toString();
1784:       });
1785:       proc.on('error', (error) => {
1786:         this.print(this.uiBox(`Command failed: ${error.message}`, 'red'));
1787:         resolve();
1788:       });
1789:       proc.on('close', (code) => {
1790:         const chunk = out.trim() ? out.trim().slice(0, 300) : `(no output, exit=${code})`;
1791:         this.print(this.uiBox(chunk, code === 0 ? 'cyan' : 'yellow'));
1792:         resolve();
1793:       });
1794:     });
1795:   }
1796: 
1797:   generatePatch(plan) {
1798:     const steps = Array.isArray(plan) ? plan : [];
1799:     let out = '\n// === ETHUB AUTO PATCH ===\n';
1800: 
1801:     for (const step of steps) {
1802:       if (step === 'add_pipeline_core') {
1803:         out += `
1804: function runPipelineAuto() {
1805:   console.log("Pipeline ready");
1806: }
1807: `;
1808:       }
1809:       if (step === 'add_debug_loop') {
1810:         out += `
1811: function debugLoopAuto() {
1812:   console.log("Debug loop ready");
1813: }
1814: `;
1815:       }
1816:       if (step === 'add_todo_system') {
1817:         out += `
1818: const TODO = [];
1819: function addTodo(x){ TODO.push(x); }
1820: `;
1821:       }
1822:       if (step === 'add_context_router') {
1823:         out += `
1824: function routeTask(type) {
1825:   if (type === "debug") return debugLoopAuto();
1826: }
1827: `;
1828:       }
1829:     }
1830: 
1831:     return out;
1832:   }
1833: 
1834:   validatePatch(original, patch) {
1835:     const base = String(original || '');
1836:     const candidate = String(patch || '');
1837:     if (!candidate.trim()) return false;
1838:     if (base.includes(candidate.trim())) return false;
1839:     if (base.length + candidate.length > 200000) return false;
1840:     if (candidate.includes('rm -rf')) return false;
1841:     return true;
1842:   }
1843: 
1844:   applyPatchSafe(file, patch) {
1845:     const backup = `${file}.bak`;
1846:     fs.copyFileSync(file, backup);
1847:     try {
1848:       const updated = fs.readFileSync(file, 'utf8') + '\n' + patch;
1849:       fs.writeFileSync(file, updated, 'utf8');
1850:       this.print(this.uiBox('Patch applied successfully', 'green'));
1851:       this.logger.writeEvent('pipeline_patch_applied', { file, backup, patch_chars: patch.length });
1852:     } catch (error) {
1853:       fs.copyFileSync(backup, file);
1854:       this.print(this.uiBox('Patch failed -> rolled back', 'red'));
1855:       this.logger.writeEvent('pipeline_patch_rollback', { file, backup, error: error.message });
1856:     }
1857:   }
1858: 
1859:   async executeTodoPlan(plan, file) {
1860:     const original = this.readFileSafe(file);
1861:     const patch = this.generatePatch(plan);
1862:     if (!this.validatePatch(original, patch)) {
1863:       this.print(this.uiBox('Patch rejected (validation)', 'red'));
1864:       return;
1865:     }
1866:     this.applyPatchSafe(file, patch);
1867:   }
1868: 
1869:   async runPipeline(input) {
1870:     const pipelineEnabled = String(process.env.ETHUB_ENABLE_PIPELINE || '').toLowerCase() === '1'
1871:       || String(process.env.ETHUB_ENABLE_PIPELINE || '').toLowerCase() === 'true';
1872:     if (!pipelineEnabled) return false;
1873: 
1874:     const file = path.resolve(__filename);
1875:     const code = this.readFileSafe(file);
1876:     const context = this.analyzeContext(code);
1877:     const decision = this.classifyContext(context);
1878:     const plan = this.buildPlan(decision);
1879:     const intent = this.routeIntent(input);
1880: 
1881:     this.logger.writeEvent('pipeline_decision', { decision, context, plan, intent, file });
1882:     this.print(this.uiBox(`Pipeline: ${decision} | intent: ${intent} | plan: ${plan.join(', ') || 'noop'}`, 'cyan'));
1883: 
1884:     if (decision === 'stable' || plan.includes('noop')) {
1885:       this.print(this.uiBox('System stable. No patch needed.', 'green'));
1886:       return true;
1887:     }
1888: 
1889:     if (this.requireApproval) {
1890:       const action = {
1891:         id: `todo_${Date.now()}`,
1892:         type: 'todo_plan',
1893:         payload: { plan, decision, file },
1894:         created_at: nowIso()
1895:       };
1896:       this.queueApprovalAction(action, this.uiBox('Awaiting approval for TODO plan (/yes or /no)', 'yellow'));
1897:       return true;
1898:     }
1899: 
1900:     await this.executeTodoPlan(plan, file);
1901:     return true;
1902:   }
1903: 
1904:   async handleUserPrompt(input) {
1905:     const handledByPipeline = await this.runPipeline(input);
1906:     if (handledByPipeline) return;
1907: 
1908:     const reasoning = summarizeReasoning(input);
1909:     const action = {
1910:       id: `act_${Date.now()}`,
1911:       type: 'ollama_chat',
1912:       prompt: input,
1913:       reasoning_summary: reasoning,
1914:       created_at: nowIso()
1915:     };
1916: 
1917:     this.logger.writeTranscript('User', input);
1918:     this.logger.writeEvent('user_prompt', {
1919:       text: input,
1920:       reasoning_summary: reasoning,
1921:       proposed_action: { id: action.id, type: action.type }
1922:     });
1923:     this.actionMeta[action.id] = {
1924:       prompt: input,
1925:       prompt_chars_before: input.length
1926:     };
1927:     const keywordsText = Array.isArray(reasoning.keywords) && reasoning.keywords.length
1928:       ? reasoning.keywords.join(', ')
1929:       : 'none';
1930:     this.print(style(`[Reasoning] intent=${reasoning.intent} | keywords=${keywordsText}`, ANSI.dim));
1931:     this.print(style(`[Reasoning] strategy=${reasoning.strategy}`, ANSI.dim));
1932: 
1933:     this.logger.writeStructuredRecord({
1934:       timestamp: nowIso(),
1935:       query: input,
1936:       reasoning: {
1937:         query: reasoning.query,
1938:         intent: reasoning.intent,
1939:         keywords: reasoning.keywords,
1940:         search_strategy: reasoning.strategy
1941:       },
1942:       actions: {
1943:         action: 'local_ollama_request',
1944:         sources: ['ollama_localhost'],
1945:         Context: 'Analyzing locally via Ollama only; no OpenAI/Gemini/external model APIs.'
1946:       },
1947:       Commands: "ls, grep, nano, cd, nano 'create-new-file-diff-snippet-number+1.sh', regen entire file with changes then save, cp -rf old/path/to/file move/to/backup/path/file, rm old/path/to/file, bash create-new-file-(diff-snippet-line:character)-(number)+1, sed -i 's/old/new' \"$file\"",
1948:       Diff: '+,-',
1949:       Path: 'path/to/file:line:character',
1950:       action_id: action.id,
1951:       'Print-approved-by-user?': 'not_required (run commands)',
1952:       'Run runtime look at logs': 'pending',
1953:       summary: 'pending',
1954:       'Number of characters changed': 'pending'
1955:     });
1956: 
1957:     await this.executeAction(action);
1958:   }
1959: 
1960:   writeStructuredUpdate(actionId, patch) {
1961:     this.logger.writeStructuredRecord({
1962:       timestamp: nowIso(),
1963:       action_id: actionId,
1964:       update: patch
1965:     });
1966:   }
1967: 
1968:   async executeAction(action) {
1969:     if (!action || action.type !== 'ollama_chat') {
1970:       this.logger.writeEvent('action_error', { message: 'Unsupported action type', action });
1971:       this.writeStructuredUpdate(action && action.id ? action.id : 'unknown', {
1972:         'Run runtime look at logs': 'contains error still, unsupported action type',
1973:         summary: 'Unsupported action type encountered before runtime request.',
1974:         'Number of characters changed': 'previous character amount in file before cmd/new total character count added: 0/0'
1975:       });
1976:       this.print('Unsupported action.');
1977:       return;
1978:     }
1979: 
1980:     this.logger.writeEvent('action_start', {
1981:       action_id: action.id,
1982:       type: action.type,
1983:       target: this.ollamaUrl,
1984:       model: this.model,
1985:       prompt_chars: action.prompt.length,
1986:       reasoning_summary: action.reasoning_summary
1987:     });
1988: 
1989:     this.history.push({ role: 'user', content: action.prompt });
1990: 
1991:     const payload = {
1992:       model: this.model,
1993:       messages: this.history,
1994:       stream: false
1995:     };
1996: 
1997:     let response;
1998:     let raw;
1999:     const started = Date.now();
2000:     this.startThinking();
2001: 
2002:     try {
2003:       response = await fetch(this.ollamaUrl, {
2004:         method: 'POST',
2005:         headers: { 'Content-Type': 'application/json' },
2006:         body: JSON.stringify(payload)
2007:       });
2008: 
2009:       raw = await response.text();
2010:     } catch (error) {
2011:       this.stopThinking();
2012:       const message = error && error.message ? error.message : String(error);
2013:       this.logger.writeEvent('action_failure', {
2014:         action_id: action.id,
2015:         duration_ms: Date.now() - started,
2016:         error: message
2017:       });
2018:       this.writeStructuredUpdate(action.id, {
2019:         'Run runtime look at logs': 'contains error still, loop and try again with different results until each individual error is clear.',
2020:         summary: `Runtime request failed. Error: ${message}`,
2021:         'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${action.prompt.length}/0`,
2022:         'Print-approved-by-user?': 'true'
2023:       });
2024:       this.print(`Ollama request failed: ${message}`);
2025:       return;
2026:     }
2027:     this.stopThinking();
2028: 
2029:     let parsed;
2030:     try {
2031:       parsed = JSON.parse(raw);
2032:     } catch {
2033:       parsed = null;
2034:     }
2035: 
2036:     const assistantText = parsed && parsed.message && parsed.message.content
2037:       ? String(parsed.message.content)
2038:       : raw;
2039: 
2040:     this.history.push({ role: 'assistant', content: assistantText });
2041: 
2042:     this.logger.writeEvent('action_result', {
2043:       action_id: action.id,
2044:       duration_ms: Date.now() - started,
2045:       http_status: response.status,
2046:       ok: response.ok,
2047:       response_preview: assistantText.slice(0, 400),
2048:       response_chars: assistantText.length
2049:     });
2050: 
2051:     this.logger.writeTranscript('Assistant', assistantText);
2052:     this.print(assistantText);
2053: 
2054:     const hasRuntimeError = /(syntaxerror|stack overflow|runtime error|error:)/i.test(assistantText);
2055:     const runtimeResult = hasRuntimeError
2056:       ? 'contains error still, retry with different checks until isolated'
2057:       : 'No runtime error anymore = fixed';
2058:     const beforeChars = this.actionMeta[action.id] && this.actionMeta[action.id].prompt_chars_before
2059:       ? this.actionMeta[action.id].prompt_chars_before
2060:       : 0;
2061:     const afterChars = assistantText.length;
2062:     const elapsedMs = Date.now() - started;
2063: 
2064:     this.writeStructuredUpdate(action.id, {
2065:       'Run runtime look at logs': runtimeResult,
2066:       summary: `summarized what just changed, is it fixed: ${hasRuntimeError ? 'No' : 'Yes'}. Runtime error count estimate: ${hasRuntimeError ? 1 : 0}.`,
2067:       'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${beforeChars}/${afterChars}`,
2068:       timing_ms: elapsedMs,
2069:       stop_condition: elapsedMs >= 300000 ? 'Unable to find results or solutions, Try again.' : 'within loop budget'
2070:     });
2071:   }
2072: }
2073: 
2074: const agent = new EthubCliAgent();
2075: agent.start().catch((error) => {
2076:   process.stderr.write(`Fatal startup error: ${error && error.stack ? error.stack : String(error)}\n`);
2077:   process.exit(1);
2078: });
