0884:   stopDebugDashboard(reason = 'stop_requested') {
0885:     const child = this.debugServerProcess;
0886:     if (child && !child.killed) {
0887:       try {
0888:         child.kill('SIGTERM');
0889:       } catch {
0890:         // best effort cleanup
0891:       }
0892:     }
0893:     this.debugServerProcess = null;
0894:     this.debugServerToken = '';
0895:     this.dashboardInfo = null;
0896:     this.logger.writeEvent('debug_dashboard_stop', { reason });
0897:   }
0898: 
0899:   async startDebugDashboard() {
0900:     if (this.debugServerProcess && !this.debugServerProcess.killed && this.dashboardInfo && this.dashboardInfo.dashboard_url) {
0901:       return this.dashboardInfo;
0902:     }
0903:     const serverPath = this.resolveDashboardServerPath();
0904:     if (!serverPath) {
0905:       throw new Error('web_debug/index_server.mjs not found.');
0906:     }
0907: 
0908:     this.stopDebugDashboard('restart_debug_dashboard');
0909:     const token = this.makeDebugToken();
0910:     const startPort = Number(process.env.WEB_DEBUG_PORT || '3000');
0911:     const child = spawn(process.execPath, [serverPath], {
0912:       cwd: this.workspaceRoot,
0913:       stdio: ['ignore', 'pipe', 'pipe'],
0914:       env: {
0915:         ...process.env,
0916:         WEB_DEBUG_PORT: String(startPort),
0917:         WEB_DEBUG_TOKEN: token
0918:       }
0919:     });
0920:     this.debugServerProcess = child;
0921:     this.debugServerToken = token;
0922:     this.dashboardInfo = null;
0923: 
0924:     let outBuf = '';
0925:     let errBuf = '';
0926:     const scanOutput = () => {
0927:       const lines = outBuf.split('\n');
0928:       let base = '';
0929:       let chat = '';
0930:       for (const line of lines) {
0931:         const m1 = line.match(/web_debug running on\s+(http:\/\/127\.0\.0\.1:\d+\/\?token=[^\s]+)/i);
0932:         if (m1) base = m1[1];
0933:         const m2 = line.match(/chat interface:\s+(http:\/\/127\.0\.0\.1:\d+\/chat\?token=[^\s]+)/i);
0934:         if (m2) chat = m2[1];
0935:       }
0936:       if (!base) return;
0937:       const p = Number((base.match(/127\.0\.0\.1:(\d+)/) || [])[1] || 0);
0938:       this.dashboardInfo = {
0939:         pid: child.pid,
0940:         port: p,
0941:         dashboard_url: base,
0942:         chat_url: chat || `http://127.0.0.1:${p}/chat?token=${token}`
0943:       };
0944:     };
0945: 
0946:     child.stdout.on('data', (chunk) => {
0947:       outBuf += chunk.toString('utf8');
0948:       scanOutput();
0949:     });
0950:     child.stderr.on('data', (chunk) => {
0951:       errBuf += chunk.toString('utf8');
0952:     });
0953:     child.on('exit', (code, signal) => {
0954:       this.logger.writeEvent('debug_dashboard_exit', { code, signal, stderr: truncateText(errBuf, 8000) });
0955:       this.debugServerProcess = null;
0956:       this.dashboardInfo = null;
0957:       this.debugServerToken = '';
0958:     });
0959: 
0960:     this.logger.writeEvent('debug_dashboard_start', {
0961:       path: serverPath,
0962:       pid: child.pid,
0963:       requested_port: startPort,
0964:       token_length: token.length
0965:     });
0966: 
0967:     const timeoutAt = Date.now() + 8000;
0968:     while (Date.now() < timeoutAt) {
0969:       if (this.dashboardInfo && this.dashboardInfo.dashboard_url) {
0970:         return this.dashboardInfo;
0971:       }
0972:       if (!this.debugServerProcess || this.debugServerProcess.killed) break;
0973:       await new Promise((resolve) => setTimeout(resolve, 120));
0974:     }
0975: 
0976:     if (errBuf.trim()) {
0977:       throw new Error(`debug dashboard failed to start: ${truncateText(errBuf.trim(), 400)}`);
0978:     }
0979:     throw new Error('debug dashboard did not report readiness in time.');
0980:   }
