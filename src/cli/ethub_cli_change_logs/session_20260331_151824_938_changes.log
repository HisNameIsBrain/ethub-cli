1129:   renderHeaderFrame(frame) {
1130:     const p1 = (frame / 90) % 1;
1131:     const p3 = (p1 + 0.66) % 1;
1132:     const lines = [];
1133:     lines.push(LEFT_PAD + rainbowDivider(HEADER_WIDTH, p1));
1134:     ETHUB_ASCII.forEach((line, row) => {
1135:       lines.push(LEFT_PAD + rainbowAsciiLine(line, row, ETHUB_ASCII.length, frame));
1136:     });
1137:     lines.push(
1138:       LEFT_PAD +
1139:       style(
1140:         `Mode: CHAT | Model: ${this.model} | Approval: ${this.requireApproval ? 'ON' : 'OFF'} | cwd: ${this.workspaceRelativePath()}`,
1141:         ANSI.dim
1142:       )
1143:     );
1144:     lines.push(LEFT_PAD + rainbowDivider(HEADER_WIDTH, p3));
1145:     return lines;
1146:   }
1147: 
1148:   async animateHeader(durationMs = 1200, fps = 20) {
1149:     const frameDelay = Math.max(16, Math.floor(1000 / fps));
1150:     const frames = Math.max(1, Math.floor(durationMs / frameDelay));
1151:     for (let frame = 0; frame < frames; frame += 1) {
1152:       const lines = this.renderHeaderFrame(frame);
1153:       process.stdout.write('\x1b[2J\x1b[H');
1154:       process.stdout.write(`${lines.join('\n')}\n`);
1155:       await new Promise((resolve) => setTimeout(resolve, frameDelay));
1156:     }
1157:     process.stdout.write('\x1b[2J\x1b[H');
1158:     this.drawHeader(frames);
1159:   }
