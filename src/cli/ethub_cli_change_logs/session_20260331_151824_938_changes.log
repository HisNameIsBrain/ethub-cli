0119: function hslToRgb(h, s, l) {
0120:   h /= 360;
0121:   const a = s * Math.min(l, 1 - l);
0122:   const f = (n) => {
0123:     const k = (n + h * 12) % 12;
0124:     const c = l - a * Math.max(Math.min(k - 3, 9 - k, 1), -1);
0125:     return Math.round(c * 255);
0126:   };
0127:   return { r: f(0), g: f(8), b: f(4) };
0128: }
