1688:   runAddSkillAction(action) {
1689:     const payload = action && action.payload ? action.payload : {};
1690:     const name = String(payload.skill_name || '').trim();
1691:     const snippet = String(payload.snippet || '');
1692:     if (!name || !snippet) {
1693:       this.print(`${style('Add skill failed:', ANSI.bold, ANSI.red)} missing skill name or snippet.`);
1694:       return;
1695:     }
1696:     const duplicate = this.findSkill(name);
1697:     if (duplicate) {
1698:       this.print(`${style('Add skill skipped:', ANSI.bold, ANSI.red)} skill already exists (${duplicate.id}).`);
1699:       return;
1700:     }
1701: 
1702:     const skill = {
1703:       id: `skill_${Date.now()}`,
1704:       name,
1705:       snippet,
1706:       source: `candidate:${payload.source_candidate || 'unknown'}`,
1707:       executable: Boolean(payload.executable),
1708:       created_at: nowIso()
1709:     };
1710:     this.skills.push(skill);
1711:     this.saveSkills();
1712:     this.print(style(`[SKILL ADDED] ${skill.name} (${skill.id}) executable=${skill.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.cyan));
1713:     this.logger.writeEvent('skill_added', {
1714:       action_id: action.id,
1715:       skill_id: skill.id,
1716:       skill_name: skill.name,
1717:       executable: skill.executable
1718:     });
1719:   }
