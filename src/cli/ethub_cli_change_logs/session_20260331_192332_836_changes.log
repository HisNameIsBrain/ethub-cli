0143: function rainbowAsciiLine(line, row, totalRows, frame) {
0144:   let out = '';
0145:   const len = Math.max(line.length, 1);
0146: 
0147:   for (let i = 0; i < line.length; i += 1) {
0148:     const ch = line[i];
