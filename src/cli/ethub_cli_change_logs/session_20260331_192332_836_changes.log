1608:   async executePendingAction(action) {
1609:     if (!action) return;
1610:     if (action.type === 'ollama_chat') {
1611:       await this.executeAction(action);
1612:       return;
1613:     }
1614:     if (action.type === 'read_file') {
1615:       this.runReadFileAction(action);
1616:       return;
1617:     }
1618:     if (action.type === 'write_file') {
1619:       this.runWriteFileAction(action);
1620:       return;
1621:     }
1622:     if (action.type === 'add_skill') {
1623:       this.runAddSkillAction(action);
1624:       return;
1625:     }
1626:     if (action.type === 'run_skill') {
1627:       await this.runSkillCommand(action);
1628:       return;
1629:     }
1630:     if (action.type === 'todo_plan') {
1631:       const payload = action && action.payload ? action.payload : {};
1632:       await this.executeTodoPlan(payload.plan || [], payload.file || path.resolve(__filename));
1633:       return;
1634:     }
1635:     this.print(`Unsupported pending action type: ${action.type}`);
1636:   }
1637: 
1638:   runReadFileAction(action) {
1639:     const filePath = action && action.payload ? action.payload.path : '';
1640:     if (!filePath || !fs.existsSync(filePath)) {
1641:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} file no longer exists.`);
1642:       return;
1643:     }
1644:     let text;
1645:     try {
1646:       text = fs.readFileSync(filePath, 'utf8');
1647:     } catch (error) {
1648:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1649:       return;
1650:     }
1651:     const shown = truncateText(text, MAX_READFILE_BYTES);
1652:     const rel = action.payload.rel || this.workspaceRelativePath(filePath);
1653:     this.print(style(`[I/O READ] ${rel}`, ANSI.bold, ANSI.cyan));
1654:     this.print(style(`\n[READFILE] ${rel}`, ANSI.bold, ANSI.cyan));
1655:     this.print(style(`bytes: ${Buffer.byteLength(text, 'utf8')} | shown: ${Buffer.byteLength(shown, 'utf8')}`, ANSI.dim));
1656:     this.print(shown);
1657:     this.logger.writeEvent('read_file', {
1658:       action_id: action.id,
1659:       file: filePath,
1660:       bytes: Buffer.byteLength(text, 'utf8'),
1661:       shown_bytes: Buffer.byteLength(shown, 'utf8')
1662:     });
1663:   }
1664: 
1665:   runWriteFileAction(action) {
1666:     const filePath = action && action.payload ? action.payload.path : '';
1667:     const content = action && action.payload ? String(action.payload.content || '') : '';
1668:     if (!filePath) {
1669:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} missing target path.`);
1670:       return;
1671:     }
1672:     try {
1673:       ensureDir(path.dirname(filePath));
1674:       fs.writeFileSync(filePath, content, 'utf8');
1675:     } catch (error) {
1676:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1677:       return;
1678:     }
1679:     this.print(style(`[I/O WRITE] ${action.payload.rel}`, ANSI.bold, ANSI.cyan));
1680:     this.print(style(`[WRITEFILE] wrote ${content.length} chars to ${action.payload.rel}`, ANSI.bold, ANSI.cyan));
1681:     this.logger.writeEvent('write_file', {
1682:       action_id: action.id,
1683:       file: filePath,
1684:       chars: content.length
1685:     });
1686:   }
