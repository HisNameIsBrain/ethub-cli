1085:   determineIntentWithHopper(input) {
1086:     const reasoning = summarizeReasoning(input);
1087:     const intent = String(reasoning.intent || 'general_request');
1088:     let lane = 'general';
1089:     if (intent === 'debugging') lane = 'debug';
1090:     else if (intent === 'implementation' || intent === 'refactor') lane = 'code';
1091:     else if (intent === 'shell_operation') lane = 'shell';
1092:     else if (intent === 'planning') lane = 'plan';
1093:     else if (intent === 'information_lookup' || intent === 'documentation') lane = 'research';
1094:     else if (intent === 'testing') lane = 'verify';
1095:     return { ...reasoning, hopper_lane: lane };
1096:   }
