1877:   isSafeCommand(commandText) {
1878:     const text = String(commandText || '').trim();
1879:     if (!text) return false;
1880:     if (BLOCKED_COMMAND_PATTERN.test(text)) return false;
1881:     const parsed = tokenizeCommandLine(text);
1882:     if (parsed.error || !parsed.tokens || !parsed.tokens.length) return false;
1883:     const cmd = parsed.tokens[0];
1884:     return /^(ls|cd|cat|grep|rg|sed|cp|mv|tree|echo)$/.test(cmd);
1885:   }
1886: 
1887:   async runShell(commandText) {
1888:     const raw = String(commandText || '').trim();
1889:     const parsed = tokenizeCommandLine(raw);
1890:     if (parsed.error) {
1891:       this.print(this.uiBox(`Shell parse error: ${parsed.error}`, 'red'));
1892:       return;
1893:     }
1894:     const tokens = parsed.tokens || [];
1895:     if (!tokens.length) {
1896:       this.print(this.uiBox('Shell command rejected (empty).', 'red'));
1897:       return;
1898:     }
1899: 
1900:     const cmd = tokens[0];
1901:     const args = tokens.slice(1);
1902: 
1903:     if (cmd === 'cd') {
1904:       const target = args[0] || '.';
1905:       const resolved = this.resolvePathInWorkspace(target, 'dir');
1906:       if (resolved.error) {
1907:         this.print(this.uiBox(`cd denied: ${resolved.error}`, 'red'));
1908:         return;
1909:       }
1910:       process.chdir(resolved.path);
1911:       this.refreshPrompt();
1912:       this.print(this.uiBox(`cwd -> ${this.workspaceRelativePath()}`, 'cyan'));
1913:       return;
1914:     }
1915: 
1916:     await new Promise((resolve) => {
1917:       const proc = spawn(cmd, args, { stdio: ['ignore', 'pipe', 'pipe'], shell: false });
1918:       let out = '';
1919:       proc.stdout.on('data', (d) => {
1920:         out += d.toString();
1921:       });
1922:       proc.stderr.on('data', (d) => {
1923:         out += d.toString();
1924:       });
1925:       proc.on('error', (error) => {
1926:         this.print(this.uiBox(`Command failed: ${error.message}`, 'red'));
1927:         resolve();
1928:       });
1929:       proc.on('close', (code) => {
1930:         const chunk = out.trim() ? out.trim().slice(0, 300) : `(no output, exit=${code})`;
1931:         this.print(this.uiBox(chunk, code === 0 ? 'cyan' : 'yellow'));
1932:         resolve();
1933:       });
1934:     });
1935:   }
1936: 
1937:   generatePatch(type) {
1938:     if (type === 'patch_debug' || type === 'patch_debug_loop') {
1939:       return `
1940: // --- PATCH: DEBUG LOOP ---
1941: function debugLoop() {
1942:   console.log("[debug] scanning...");
1943: }
1944: `;
1945:     }
1946:     if (type === 'patch_pipeline') {
1947:       return `
1948: // --- PATCH: PIPELINE ---
1949: function runPipeline() {
1950:   console.log("[pipeline] active");
1951: }
1952: `;
1953:     }
1954:     if (type === 'patch_ui_marker') {
1955:       return '\n// --- PATCH: ANSI UI MARKER ---\n';
1956:     }
1957:     return '';
1958:   }
1959: 
1960:   validatePatch(original, patch) {
1961:     const base = String(original || '');
1962:     const candidate = String(patch || '');
1963:     if (!candidate.trim()) return false;
1964:     if (base.includes(candidate.trim())) return false;
1965:     if (base.length + candidate.length > 200000) return false;
1966:     return true;
1967:   }
1968: 
1969:   applyPatchSafe(file, patch) {
1970:     const backup = `${file}.bak`;
1971:     fs.copyFileSync(file, backup);
1972:     try {
1973:       const updated = fs.readFileSync(file, 'utf8') + '\n' + patch;
1974:       fs.writeFileSync(file, updated, 'utf8');
1975:       this.print(this.uiBox('Patch applied successfully', 'green'));
1976:       this.logger.writeEvent('pipeline_patch_applied', { file, backup, patch_chars: patch.length });
1977:     } catch (error) {
1978:       fs.copyFileSync(backup, file);
1979:       this.print(this.uiBox('Patch failed -> rolled back', 'red'));
1980:       this.logger.writeEvent('pipeline_patch_rollback', { file, backup, error: error.message });
1981:     }
1982:   }
1983: 
1984:   async executeTodoPlan(plan, file) {
1985:     const steps = Array.isArray(plan) ? plan : [];
1986:     for (const step of steps) {
1987:       if (step.cmd) {
1988:         if (!this.isSafeCommand(step.cmd)) {
1989:           this.print(this.uiBox(`Blocked unsafe command: ${step.cmd}`, 'red'));
1990:           continue;
1991:         }
1992:         await this.runShell(step.cmd);
1993:       }
1994: 
1995:       if (step.action) {
1996:         const patch = this.generatePatch(step.action);
1997:         const original = this.readFileSafe(file);
1998:         if (!this.validatePatch(original, patch)) {
1999:           this.print(this.uiBox('Patch rejected (validation)', 'red'));
2000:           continue;
2001:         }
2002:         this.applyPatchSafe(file, patch);
2003:       }
2004:     }
2005:   }
