1721:   readFileSafe(filePath) {
1722:     const target = path.resolve(filePath || '');
1723:     if (!target) return '';
1724:     if (!fs.existsSync(target)) return '';
1725:     try {
1726:       return fs.readFileSync(target, 'utf8');
1727:     } catch (error) {
1728:       this.logger.writeEvent('pipeline_read_failed', {
1729:         file: target,
1730:         error: error.message
1731:       });
1732:       return '';
1733:     }
1734:   }
1735: 
1736:   detectContext(code, input) {
1737:     const text = String(input || '');
1738:     return {
1739:       hasDebugLoop: code.includes('debugLoop'),
1740:       hasPipeline: code.includes('runPipeline'),
1741:       hasANSI: code.includes('\\x1b['),
1742:       isError: /error|fail|undefined|crash/i.test(text),
1743:       isFeature: /add|implement|feature/i.test(text),
1744:       isRefactor: /refactor|clean/i.test(text)
1745:     };
1746:   }
1747: 
1748:   decide(ctx) {
1749:     if (ctx.isError) return 'debug';
1750:     if (!ctx.hasPipeline) return 'add_pipeline';
1751:     if (!ctx.hasDebugLoop) return 'add_debug';
1752:     if (!ctx.hasANSI) return 'add_ui';
1753:     if (ctx.isFeature) return 'feature';
1754:     return 'stable';
1755:   }
1756: 
1757:   buildTodoPlan(decision) {
1758:     if (decision === 'debug') {
1759:       return [
1760:         { step: 'scan', cmd: 'ls' },
1761:         { step: 'analyze', cmd: 'rg -n "error|fail|undefined|crash" .' },
1762:         { step: 'fix', action: 'patch_debug' }
1763:       ];
1764:     }
1765:     if (decision === 'add_debug') {
1766:       return [{ step: 'patch', action: 'patch_debug_loop' }];
1767:     }
1768:     if (decision === 'add_pipeline') {
1769:       return [{ step: 'patch', action: 'patch_pipeline' }];
1770:     }
1771:     if (decision === 'add_ui') {
1772:       return [{ step: 'patch', action: 'patch_ui_marker' }];
1773:     }
1774:     return [];
1775:   }
1776: 
1777:   uiBox(msg, color = 'cyan') {
1778:     const c = {
1779:       cyan: '\x1b[36m',
1780:       green: '\x1b[32m',
1781:       red: '\x1b[31m',
1782:       yellow: '\x1b[33m'
1783:     };
1784:     const code = c[color] || c.cyan;
1785:     return `${code}[ ${String(msg || '')} ]\x1b[0m`;
1786:   }
