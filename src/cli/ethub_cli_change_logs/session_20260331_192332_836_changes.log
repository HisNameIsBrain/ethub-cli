1838:   async runPipeline(input) {
1839:     // Experimental path is opt-in to avoid intercepting normal prompt handling.
1840:     const pipelineEnabled = String(process.env.ETHUB_ENABLE_PIPELINE || '').toLowerCase() === '1'
1841:       || String(process.env.ETHUB_ENABLE_PIPELINE || '').toLowerCase() === 'true';
1842:     if (!pipelineEnabled) return false;
1843: 
1844:     const file = path.resolve(__filename);
1845:     const code = this.readFileSafe(file);
1846:     const ctx = this.detectContext(code, input);
1847:     const decision = this.decide(ctx);
1848:     this.uiRender(ctx, decision);
1849:     this.logger.writeEvent('pipeline_decision', { decision, context: ctx, file });
1850: 
1851:     if (decision === 'stable') {
1852:       this.print(this.uiBox('System stable. No changes needed.', 'green'));
1853:       return true;
1854:     }
1855: 
1856:     const plan = this.buildTodoPlan(decision);
1857:     if (!plan.length) {
1858:       this.print(this.uiBox(`No TODO plan for decision: ${decision}`, 'yellow'));
1859:       return true;
1860:     }
1861: 
1862:     if (this.requireApproval) {
1863:       const action = {
1864:         id: `todo_${Date.now()}`,
1865:         type: 'todo_plan',
1866:         payload: { plan, decision, file },
1867:         created_at: nowIso()
1868:       };
1869:       this.queueApprovalAction(action, this.uiBox('Awaiting approval for TODO plan (/yes or /no)', 'yellow'));
1870:       return true;
1871:     }
1872: 
1873:     await this.executeTodoPlan(plan, file);
1874:     return true;
1875:   }
