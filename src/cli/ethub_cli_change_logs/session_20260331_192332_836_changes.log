1788:   emitUiFrame(lines, clearScreen = false) {
1789:     const rows = Array.isArray(lines) ? lines : [];
1790:     if (clearScreen && process.stdout.isTTY) {
1791:       process.stdout.write('\x1b[2J\x1b[H');
1792:     }
1793:     const text = `${rows.join('\n')}\n`;
1794:     process.stdout.write(text);
1795:     this.logger.writeEvent('stdout', { text: rows.join('\n') });
1796:   }
