1181:   drawHeader(frame) {
1182:     const p1 = (frame / 90) % 1;
1183:     const p3 = (p1 + 0.66) % 1;
1184:     this.print(LEFT_PAD + rainbowDivider(HEADER_WIDTH, p1));
1185:     ETHUB_ASCII.forEach((line, row) => {
1186:       this.print(LEFT_PAD + rainbowAsciiLine(line, row, ETHUB_ASCII.length, frame));
1187:     });
1188:     this.print(
1189:       LEFT_PAD +
1190:       style(
1191:         `Mode: CHAT | Model: ${this.model} | Change Approval: ${this.requireApproval ? 'ON' : 'OFF'} | cwd: ${this.workspaceRelativePath()}`,
1192:         ANSI.dim
1193:       )
1194:     );
1195:     this.print(LEFT_PAD + rainbowDivider(HEADER_WIDTH, p3));
1196:   }
1197: 
1198:   renderHeaderFrame(frame) {
1199:     const p1 = (frame / 90) % 1;
1200:     const p3 = (p1 + 0.66) % 1;
1201:     const lines = [];
1202:     lines.push(LEFT_PAD + rainbowDivider(HEADER_WIDTH, p1));
1203:     ETHUB_ASCII.forEach((line, row) => {
1204:       lines.push(LEFT_PAD + rainbowAsciiLine(line, row, ETHUB_ASCII.length, frame));
1205:     });
1206:     lines.push(
1207:       LEFT_PAD +
1208:       style(
1209:         `Mode: CHAT | Model: ${this.model} | Approval: ${this.requireApproval ? 'ON' : 'OFF'} | cwd: ${this.workspaceRelativePath()}`,
1210:         ANSI.dim
1211:       )
1212:     );
1213:     lines.push(LEFT_PAD + rainbowDivider(HEADER_WIDTH, p3));
1214:     return lines;
1215:   }
1216: 
1217:   async animateHeader(durationMs = 1200, fps = 20) {
1218:     const frameDelay = Math.max(16, Math.floor(1000 / fps));
1219:     const frames = Math.max(1, Math.floor(durationMs / frameDelay));
1220:     for (let frame = 0; frame < frames; frame += 1) {
1221:       const lines = this.renderHeaderFrame(frame);
1222:       process.stdout.write('\x1b[2J\x1b[H');
1223:       process.stdout.write(`${lines.join('\n')}\n`);
1224:       await new Promise((resolve) => setTimeout(resolve, frameDelay));
1225:     }
1226:     process.stdout.write('\x1b[2J\x1b[H');
1227:     this.drawHeader(frames);
1228:   }
