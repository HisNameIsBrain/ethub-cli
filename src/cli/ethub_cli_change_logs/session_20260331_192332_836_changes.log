0802:   async runSkillCommand(action) {
0803:     const payload = action && action.payload ? action.payload : {};
0804:     const skillName = payload.skill_name || payload.skill_id || 'unknown';
0805:     const snippet = String(payload.snippet || '');
0806:     const validation = this.validateSkillCommand(snippet);
0807:     if (!validation.ok) {
0808:       this.print(`${style('Skill execution denied:', ANSI.bold, ANSI.red)} ${validation.reason}`);
0809:       this.logger.writeEvent('skill_run_denied', {
0810:         action_id: action.id,
0811:         skill: skillName,
0812:         reason: validation.reason
0813:       });
0814:       return;
0815:     }
0816: 
0817:     const tokens = validation.tokens;
0818:     const cmd = tokens[0];
0819:     const args = tokens.slice(1);
0820:     this.print(style(`[SKILL RUN] ${skillName}: ${snippet}`, ANSI.bold, ANSI.cyan));
0821: 
0822:     const result = await new Promise((resolve) => {
0823:       const child = spawn(cmd, args, {
0824:         cwd: process.cwd(),
0825:         stdio: ['ignore', 'pipe', 'pipe'],
0826:         shell: false
0827:       });
0828: 
0829:       let stdout = '';
0830:       let stderr = '';
0831:       let finished = false;
0832:       const timer = setTimeout(() => {
0833:         if (finished) return;
0834:         child.kill('SIGTERM');
0835:       }, 120000);
0836: 
0837:       child.stdout.on('data', (chunk) => {
0838:         if (stdout.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0839:         stdout += chunk.toString('utf8');
0840:       });
0841:       child.stderr.on('data', (chunk) => {
0842:         if (stderr.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0843:         stderr += chunk.toString('utf8');
0844:       });
0845:       child.on('error', (error) => {
0846:         clearTimeout(timer);
0847:         finished = true;
0848:         resolve({ code: -1, signal: null, stdout, stderr: `${stderr}\n${error.message}`.trim() });
0849:       });
0850:       child.on('close', (code, signal) => {
0851:         clearTimeout(timer);
0852:         finished = true;
0853:         resolve({ code, signal, stdout, stderr });
0854:       });
0855:     });
0856: 
0857:     if (result.stdout) {
0858:       this.print(style('[STDOUT]', ANSI.dim));
0859:       this.print(truncateText(result.stdout, MAX_COMMAND_OUTPUT_BYTES));
0860:     }
0861:     if (result.stderr) {
0862:       this.print(style('[STDERR]', ANSI.dim));
0863:       this.print(truncateText(result.stderr, MAX_COMMAND_OUTPUT_BYTES));
0864:     }
0865:     this.print(style(`[SKILL EXIT] code=${result.code} signal=${result.signal || 'none'}`, ANSI.dim));
0866:     this.logger.writeEvent('skill_run_complete', {
0867:       action_id: action.id,
0868:       skill: skillName,
0869:       code: result.code,
0870:       signal: result.signal,
0871:       stdout_chars: result.stdout.length,
0872:       stderr_chars: result.stderr.length
0873:     });
0874:   }
