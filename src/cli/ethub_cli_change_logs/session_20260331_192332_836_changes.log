0972:         this.print(`${style('Error:', ANSI.bold, ANSI.red)} ${message}`);
0973:         this.logger.writeEvent('runtime_error', { message, stack: error && error.stack ? error.stack : null });
0974:       }
0975: 
0976:       this.flushState();
0977:       this.safePrompt();
0978:     });
0979: 
0980:     this.rl.on('close', () => {
0981:       this.isClosed = true;
0982:       this.stopDebugDashboard();
0983:       this.logger.writeEvent('session_end', { ended_at: nowIso() });
