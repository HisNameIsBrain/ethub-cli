0907:   async ensureDashboardRunning() {
0908:     const runtime = this.readDashboardRuntime();
0909:     if (runtime && Number(runtime.port) > 0) {
0910:       const healthy = await this.isDashboardHealthy(runtime.port);
0911:       if (healthy) {
0912:         this.dashboardInfo = runtime;
0913:         return;
0914:       }
0915:     }
0916: 
0917:     const serverPath = this.resolveDashboardServerPath();
0918:     if (!serverPath) return;
0919:     try {
0920:       const child = spawn(process.execPath, [serverPath], {
0921:         cwd: this.workspaceRoot,
0922:         detached: true,
0923:         stdio: 'ignore'
0924:       });
0925:       child.unref();
0926:       this.logger.writeEvent('dashboard_boot', { started: true, path: serverPath });
0927:     } catch (error) {
0928:       this.logger.writeEvent('dashboard_boot', { started: false, error: error.message });
0929:       return;
0930:     }
0931: 
0932:     for (let i = 0; i < 10; i += 1) {
0933:       await new Promise((resolve) => setTimeout(resolve, 300));
0934:       const nextRuntime = this.readDashboardRuntime();
0935:       if (nextRuntime && Number(nextRuntime.port) > 0) {
0936:         this.dashboardInfo = nextRuntime;
0937:         break;
0938:       }
0939:     }
0940:   }
