1134:   resolvePathInWorkspace(inputPath, expected = 'any') {
1135:     const raw = String(inputPath || '').trim();
1136:     if (!raw) return { error: 'path is required' };
1137:     const normalized = raw === '~' ? os.homedir() : raw;
1138:     const resolved = path.resolve(process.cwd(), normalized);
1139:     const root = path.resolve(this.workspaceRoot);
1140:     const inRoot = resolved === root || resolved.startsWith(`${root}${path.sep}`);
1141:     if (!inRoot) {
1142:       return { error: `path escapes workspace root: ${root}` };
1143:     }
1144: 
1145:     if (expected === 'exists') {
1146:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
1147:     }
1148:     if (expected === 'file' || expected === 'dir') {
1149:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
1150:       let st;
1151:       try {
1152:         st = fs.statSync(resolved);
1153:       } catch (error) {
1154:         return { error: `unable to stat path: ${error.message}` };
1155:       }
1156:       if (expected === 'file' && !st.isFile()) return { error: 'path is not a file' };
1157:       if (expected === 'dir' && !st.isDirectory()) return { error: 'path is not a directory' };
1158:     }
1159: 
1160:     return { path: resolved };
1161:   }
1162: 
1163:   queueApprovalAction(action, promptText) {
1164:     if (this.pendingAction) {
1165:       this.print(`Pending action already exists (${this.pendingAction.id}). Resolve with /yes or /no first.`);
1166:       return false;
1167:     }
1168:     this.pendingAction = action;
1169:     this.logger.writeEvent('action_queued', { action_id: action.id, type: action.type, payload: action.payload });
1170:     this.print(promptText);
1171:     this.print(style(`Approve with /yes or reject with /no`, ANSI.yellow));
1172:     return true;
1173:   }
