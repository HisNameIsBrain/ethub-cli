1269:   async handleCommand(input) {
1270:     const [cmd, ...args] = input.split(/\s+/);
1271:     const command = cmd.toLowerCase();
1272:     this.logger.writeEvent('subcommand', { command, args });
1273: 
1274:     if (command === '/help') {
1275:       this.print('Commands: /help, /status, /model <name>, /approve changes on|off, /debug, /dashboard, /readfile <path>, /writefile <path> -- <content>, /cd <path>, /skills <mine|candidates|add|list|show|run>, /yes, /no, /exit');
1276:       this.print('Skills flow: /skills mine 10 -> /skills add cand_1 my_skill -> /yes -> /skills run my_skill -> /yes');
1277:       return;
1278:     }
1279: 
1280:     if (command === '/status') {
1281:       this.print(safeJson({
1282:         model: this.model,
1283:         ollama_url: this.ollamaUrl,
1284:         require_approval_for_changes: this.requireApproval,
1285:         skills_count: this.skills.length,
1286:         skill_candidates_count: this.skillCandidates.length,
1287:         dashboard_url: this.dashboardInfo && this.dashboardInfo.dashboard_url ? this.dashboardInfo.dashboard_url : null,
1288:         chat_url: this.dashboardInfo && this.dashboardInfo.chat_url ? this.dashboardInfo.chat_url : null,
1289:         debug_dashboard_pid: this.debugServerProcess && !this.debugServerProcess.killed ? this.debugServerProcess.pid : null,
1290:         history_count: this.history.length,
1291:         pending_action: this.pendingAction ? this.pendingAction.id : null
1292:       }));
1293:       return;
1294:     }
1295: 
1296:     if (command === '/model') {
1297:       const nextModel = args.join(' ').trim();
1298:       if (!nextModel) {
1299:         this.print(`Current model: ${this.model}`);
1300:         return;
1301:       }
1302:       this.model = nextModel;
1303:       this.print(`Model updated: ${this.model}`);
1304:       this.logger.writeEvent('config_update', { key: 'model', value: this.model });
1305:       return;
1306:     }
1307: 
1308:     if (command === '/approve') {
1309:       const target = (args[0] || '').toLowerCase();
1310:       const mode = (args[1] || '').toLowerCase();
1311:       const legacyMode = target;
1312: 
1313:       if (target === 'changes' && (mode === 'on' || mode === 'off')) {
1314:         this.requireApproval = mode === 'on';
1315:         this.print(`Change approval mode: ${mode}`);
1316:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1317:         return;
1318:       }
1319: 
1320:       if (legacyMode === 'on' || legacyMode === 'off') {
1321:         this.requireApproval = legacyMode === 'on';
1322:         this.print(`Change approval mode: ${legacyMode}`);
1323:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1324:         return;
1325:       }
1326: 
1327:       if (!target) {
1328:         this.print(`Change approval mode: ${this.requireApproval ? 'on' : 'off'}`);
1329:         return;
1330:       }
1331: 
1332:       this.print('Usage: /approve changes on|off');
1333:       return;
1334:     }
1335: 
1336:     if (command === '/debug' || command === '/dashboard') {
1337:       const info = await this.startDebugDashboard();
1338:       this.print(style(`Debug dashboard live: ${info.dashboard_url}`, ANSI.cyan));
1339:       this.print(style(`Debug chat live: ${info.chat_url}`, ANSI.cyan));
1340:       this.print(style(`Token length: ${this.debugServerToken.length} (never written to file)`, ANSI.dim));
1341:       return;
1342:     }
1343: 
1344:     if (command === '/yes') {
1345:       if (!this.pendingAction) {
1346:         this.print('No pending action to approve.');
1347:         return;
1348:       }
1349:       const action = this.pendingAction;
1350:       this.pendingAction = null;
1351:       this.logger.writeEvent('approval', { action_id: action.id, approved: true });
1352:       this.writeStructuredUpdate(action.id, {
1353:         'Print-approved-by-user?': 'true',
1354:         approved: true
1355:       });
1356:       await this.executePendingAction(action);
1357:       return;
1358:     }
1359: 
1360:     if (command === '/no') {
1361:       if (!this.pendingAction) {
1362:         this.print('No pending action to reject.');
1363:         return;
1364:       }
1365:       const action = this.pendingAction;
1366:       this.pendingAction = null;
1367:       this.logger.writeEvent('approval', { action_id: action.id, approved: false });
1368:       this.writeStructuredUpdate(action.id, {
1369:         'Print-approved-by-user?': 'false',
1370:         approved: false,
1371:         summary: 'Action was rejected by user before runtime execution.',
1372:         'Run runtime look at logs': 'skipped (approval rejected)'
1373:       });
1374:       this.print(`Action ${action.id} skipped.`);
1375:       return;
1376:     }
1377: 
1378:     if (command === '/exit') {
1379:       this.rl.close();
1380:       return;
1381:     }
1382: 
1383:     if (command === '/cd') {
1384:       const rawTarget = input.replace(/^\/cd\s*/i, '').trim();
1385:       if (!rawTarget) {
1386:         this.print(`Current directory: ${process.cwd()}`);
1387:         return;
1388:       }
1389:       const resolved = this.resolvePathInWorkspace(rawTarget, 'dir');
1390:       if (resolved.error) {
1391:         this.print(`${style('cd denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1392:         return;
1393:       }
1394:       process.chdir(resolved.path);
1395:       this.refreshPrompt();
1396:       this.logger.writeEvent('cwd_changed', {
1397:         cwd: process.cwd(),
1398:         workspace_relative: this.workspaceRelativePath()
1399:       });
1400:       this.print(style(`Directory changed to ${this.workspaceRelativePath()}`, ANSI.cyan));
1401:       return;
1402:     }
1403: 
1404:     if (command === '/readfile') {
1405:       const rawPath = input.replace(/^\/readfile\s*/i, '').trim();
1406:       if (!rawPath) {
1407:         this.print('Usage: /readfile <path>');
1408:         return;
1409:       }
1410:       const resolved = this.resolvePathInWorkspace(rawPath, 'file');
1411:       if (resolved.error) {
1412:         this.print(`${style('readfile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1413:         return;
1414:       }
1415:       const action = {
1416:         id: `act_${Date.now()}`,
1417:         type: 'read_file',
1418:         payload: {
1419:           path: resolved.path,
1420:           rel: this.workspaceRelativePath(resolved.path)
1421:         },
1422:         created_at: nowIso()
1423:       };
1424:       this.queueApprovalAction(
1425:         action,
1426:         `${style('Read request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel}`
1427:       );
1428:       return;
1429:     }
1430: 
1431:     if (command === '/writefile') {
1432:       const raw = input.replace(/^\/writefile\s*/i, '');
1433:       const splitIndex = raw.indexOf(' -- ');
1434:       if (splitIndex === -1) {
1435:         this.print('Usage: /writefile <path> -- <content>');
1436:         return;
1437:       }
1438:       const rawPath = raw.slice(0, splitIndex).trim();
1439:       const content = raw.slice(splitIndex + 4);
1440:       if (!rawPath) {
1441:         this.print('Usage: /writefile <path> -- <content>');
1442:         return;
1443:       }
1444:       const resolved = this.resolvePathInWorkspace(rawPath, 'any');
1445:       if (resolved.error) {
1446:         this.print(`${style('writefile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1447:         return;
1448:       }
1449:       const action = {
1450:         id: `act_${Date.now()}`,
1451:         type: 'write_file',
1452:         payload: {
1453:           path: resolved.path,
1454:           rel: this.workspaceRelativePath(resolved.path),
1455:           content
1456:         },
1457:         created_at: nowIso()
1458:       };
1459:       this.queueApprovalAction(
1460:         action,
1461:         `${style('Write request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel} (${content.length} chars)`
1462:       );
1463:       return;
1464:     }
1465: 
1466:     if (command === '/skills') {
1467:       const sub = (args[0] || '').toLowerCase();
1468:       if (!sub || sub === 'help') {
1469:         this.print('Usage:');
1470:         this.print('/skills mine [count]');
1471:         this.print('/skills candidates');
1472:         this.print('/skills add <candidate_id> <skill_name>');
1473:         this.print('/skills list');
1474:         this.print('/skills show <skill_id|skill_name>');
1475:         this.print('/skills run <skill_id|skill_name>');
1476:         return;
1477:       }
1478: 
1479:       if (sub === 'mine') {
1480:         const count = Number(args[1] || 10);
1481:         const result = this.collectSkillCandidatesFromArtifacts(count);
1482:         this.print(style(`Mined ${result.candidates} candidate skill patterns from artifacts (sources scanned: ${result.scannedSources}).`, ANSI.cyan));
1483:         for (const c of this.skillCandidates) {
1484:           this.print(style(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.yellow));
1485:           this.print('```');
1486:           this.print(c.snippet);
1487:           this.print('```');
1488:           if (!c.executable) this.print(style(`reason: ${c.safety_reason}`, ANSI.dim));
1489:         }
1490:         return;
1491:       }
1492: 
1493:       if (sub === 'candidates') {
1494:         if (!this.skillCandidates.length) {
1495:           this.print('No candidates loaded. Run /skills mine first.');
1496:           return;
1497:         }
1498:         for (const c of this.skillCandidates) {
1499:           this.print(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'} source_kind=${c.source_kind}`);
1500:         }
1501:         return;
1502:       }
1503: 
1504:       if (sub === 'add') {
1505:         const candidateId = args[1] || '';
1506:         const skillName = args.slice(2).join(' ').trim();
1507:         if (!candidateId || !skillName) {
1508:           this.print('Usage: /skills add <candidate_id> <skill_name>');
1509:           return;
1510:         }
1511:         const existing = this.findSkill(skillName);
1512:         if (existing) {
1513:           this.print(`Skill already exists: ${existing.name} (${existing.id})`);
1514:           return;
1515:         }
1516:         const candidate = this.findCandidate(candidateId);
1517:         if (!candidate) {
1518:           this.print(`Candidate not found: ${candidateId}`);
1519:           return;
1520:         }
1521:         const action = {
1522:           id: `act_${Date.now()}`,
1523:           type: 'add_skill',
1524:           payload: {
1525:             skill_name: skillName,
1526:             source_candidate: candidate.id,
1527:             snippet: candidate.snippet,
1528:             executable: candidate.executable
1529:           },
1530:           created_at: nowIso()
1531:         };
1532:         this.queueApprovalAction(
1533:           action,
1534:           `${style('Add skill queued:', ANSI.bold, ANSI.yellow)} ${skillName} from ${candidate.id}`
1535:         );
1536:         return;
1537:       }
1538: 
1539:       if (sub === 'list') {
1540:         if (!this.skills.length) {
1541:           this.print(`No approved skills yet. Skills file: ${this.skillsPath}`);
1542:           return;
1543:         }
1544:         for (const skill of this.skills) {
1545:           this.print(`[${skill.id}] ${skill.name} | executable=${skill.executable ? 'yes' : 'no'} | source=${skill.source}`);
1546:         }
1547:         return;
1548:       }
1549: 
1550:       if (sub === 'show') {
1551:         const query = args.slice(1).join(' ').trim();
1552:         if (!query) {
1553:           this.print('Usage: /skills show <skill_id|skill_name>');
1554:           return;
1555:         }
1556:         const skill = this.findSkill(query);
1557:         if (!skill) {
1558:           this.print(`Skill not found: ${query}`);
1559:           return;
1560:         }
1561:         this.print(style(`[${skill.id}] ${skill.name}`, ANSI.bold, ANSI.cyan));
1562:         this.print('```');
1563:         this.print(skill.snippet);
1564:         this.print('```');
1565:         return;
1566:       }
1567: 
1568:       if (sub === 'run') {
1569:         const query = args.slice(1).join(' ').trim();
1570:         if (!query) {
1571:           this.print('Usage: /skills run <skill_id|skill_name>');
1572:           return;
1573:         }
1574:         const skill = this.findSkill(query);
1575:         if (!skill) {
1576:           this.print(`Skill not found: ${query}`);
1577:           return;
1578:         }
1579:         const validation = this.validateSkillCommand(skill.snippet);
1580:         if (!validation.ok) {
1581:           this.print(`${style('Skill is not executable:', ANSI.bold, ANSI.red)} ${validation.reason}`);
1582:           return;
1583:         }
1584:         const action = {
1585:           id: `act_${Date.now()}`,
1586:           type: 'run_skill',
1587:           payload: {
1588:             skill_id: skill.id,
1589:             skill_name: skill.name,
1590:             snippet: skill.snippet
1591:           },
1592:           created_at: nowIso()
1593:         };
1594:         this.queueApprovalAction(
1595:           action,
1596:           `${style('Skill execution queued:', ANSI.bold, ANSI.yellow)} ${skill.name}\n${skill.snippet}`
1597:         );
1598:         return;
1599:       }
1600: 
1601:       this.print(`Unknown skills subcommand: ${sub}`);
1602:       return;
1603:     }
1604: 
1605:     this.print(`Unknown command: ${command}. Use /help.`);
1606:   }
