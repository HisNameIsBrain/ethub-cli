0121: function hslToRgb(h, s, l) {
0122:   h /= 360;
0123:   const a = s * Math.min(l, 1 - l);
0124:   const f = (n) => {
0125:     const k = (n + h * 12) % 12;
0126:     const c = l - a * Math.max(Math.min(k - 3, 9 - k, 1), -1);
0127:     return Math.round(c * 255);
0128:   };
0129:   return { r: f(0), g: f(8), b: f(4) };
0130: }
