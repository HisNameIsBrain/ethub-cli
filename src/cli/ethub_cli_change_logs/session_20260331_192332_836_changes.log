2069:   async executeAction(action) {
2070:     if (!action || action.type !== 'ollama_chat') {
2071:       this.logger.writeEvent('action_error', { message: 'Unsupported action type', action });
2072:       this.writeStructuredUpdate(action && action.id ? action.id : 'unknown', {
2073:         'Run runtime look at logs': 'contains error still, unsupported action type',
2074:         summary: 'Unsupported action type encountered before runtime request.',
2075:         'Number of characters changed': 'previous character amount in file before cmd/new total character count added: 0/0'
2076:       });
2077:       this.print('Unsupported action.');
2078:       return;
2079:     }
2080: 
2081:     this.logger.writeEvent('action_start', {
2082:       action_id: action.id,
2083:       type: action.type,
2084:       target: this.ollamaUrl,
2085:       model: this.model,
2086:       prompt_chars: action.prompt.length,
2087:       reasoning_summary: action.reasoning_summary
2088:     });
2089: 
2090:     this.history.push({ role: 'user', content: action.prompt });
2091: 
2092:     const payload = {
2093:       model: this.model,
2094:       messages: this.history,
2095:       stream: false
2096:     };
2097: 
2098:     let response;
2099:     let raw;
2100:     const started = Date.now();
2101:     this.startThinking();
2102: 
2103:     try {
2104:       response = await fetch(this.ollamaUrl, {
2105:         method: 'POST',
2106:         headers: { 'Content-Type': 'application/json' },
2107:         body: JSON.stringify(payload)
2108:       });
2109: 
2110:       raw = await response.text();
2111:     } catch (error) {
2112:       this.stopThinking();
2113:       const message = error && error.message ? error.message : String(error);
2114:       this.logger.writeEvent('action_failure', {
2115:         action_id: action.id,
2116:         duration_ms: Date.now() - started,
2117:         error: message
2118:       });
2119:       this.writeStructuredUpdate(action.id, {
2120:         'Run runtime look at logs': 'contains error still, loop and try again with different results until each individual error is clear.',
2121:         summary: `Runtime request failed. Error: ${message}`,
2122:         'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${action.prompt.length}/0`,
2123:         'Print-approved-by-user?': 'true'
2124:       });
2125:       this.print(`Ollama request failed: ${message}`);
2126:       return;
2127:     }
2128:     this.stopThinking();
2129: 
2130:     let parsed;
2131:     try {
2132:       parsed = JSON.parse(raw);
2133:     } catch {
2134:       parsed = null;
2135:     }
2136: 
2137:     const assistantText = parsed && parsed.message && parsed.message.content
2138:       ? String(parsed.message.content)
2139:       : raw;
2140: 
2141:     this.history.push({ role: 'assistant', content: assistantText });
2142: 
2143:     this.logger.writeEvent('action_result', {
2144:       action_id: action.id,
2145:       duration_ms: Date.now() - started,
2146:       http_status: response.status,
2147:       ok: response.ok,
2148:       response_preview: assistantText.slice(0, 400),
2149:       response_chars: assistantText.length
2150:     });
2151: 
2152:     this.logger.writeTranscript('Assistant', assistantText);
2153:     this.print(assistantText);
2154: 
2155:     const hasRuntimeError = /(syntaxerror|stack overflow|runtime error|error:)/i.test(assistantText);
2156:     const runtimeResult = hasRuntimeError
2157:       ? 'contains error still, retry with different checks until isolated'
2158:       : 'No runtime error anymore = fixed';
2159:     const beforeChars = this.actionMeta[action.id] && this.actionMeta[action.id].prompt_chars_before
2160:       ? this.actionMeta[action.id].prompt_chars_before
2161:       : 0;
2162:     const afterChars = assistantText.length;
2163:     const elapsedMs = Date.now() - started;
2164: 
2165:     this.writeStructuredUpdate(action.id, {
2166:       'Run runtime look at logs': runtimeResult,
2167:       summary: `summarized what just changed, is it fixed: ${hasRuntimeError ? 'No' : 'Yes'}. Runtime error count estimate: ${hasRuntimeError ? 1 : 0}.`,
2168:       'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${beforeChars}/${afterChars}`,
2169:       timing_ms: elapsedMs,
2170:       stop_condition: elapsedMs >= 300000 ? 'Unable to find results or solutions, Try again.' : 'within loop budget'
2171:     });
2172:   }
2173: }
2174: 
2175: const agent = new EthubCliAgent();
2176: agent.start().catch((error) => {
2177:   process.stderr.write(`Fatal startup error: ${error && error.stack ? error.stack : String(error)}\n`);
2178:   process.exit(1);
2179: });
