1798:   uiRender(ctx, decision) {
1799:     const hasReadline = Boolean(this.rl && typeof this.rl.pause === 'function' && typeof this.rl.resume === 'function');
1800:     if (hasReadline) this.rl.pause();
1801: 
1802:     const lines = [];
1803:     lines.push('\x1b[1mAgent v3.1 - Local Debug Shell\x1b[0m');
1804:     lines.push('');
1805:     lines.push('┌──────────────────────────────┐');
1806:     lines.push('│ Live Dashboard               │');
1807:     lines.push('├──────────────────────────────┤');
1808:     lines.push('\x1b[32mINFO\x1b[0m Starting analysis...');
1809:     if (ctx.isError) lines.push('\x1b[31mERROR\x1b[0m Runtime issue detected');
1810:     lines.push('└──────────────────────────────┘');
1811:     lines.push('');
1812:     lines.push('┌──────────────────────────────┐');
1813:     lines.push('│ Debug Loop                   │');
1814:     lines.push('├──────────────────────────────┤');
1815:     lines.push('1. Scan project directory');
1816:     lines.push('2. Analyze logs');
1817:     lines.push('3. Generate fix');
1818:     lines.push(decision === 'debug' ? '\x1b[47m\x1b[30m4. Apply changes & verify\x1b[0m' : '4. Apply changes & verify');
1819:     lines.push('└──────────────────────────────┘');
1820:     lines.push('');
1821:     lines.push('┌──────────────────────────────┐');
1822:     lines.push('│ TODO Plan                    │');
1823:     lines.push('├──────────────────────────────┤');
1824:     lines.push('✔ Scan directory');
1825:     lines.push('✔ Analyze logs');
1826:     if (decision === 'debug') {
1827:       lines.push('✔ Generate fix');
1828:       lines.push('⏳ Applying patch...');
1829:     }
1830:     lines.push('└──────────────────────────────┘');
1831:     lines.push('');
1832:     lines.push(`MODEL: ${this.model} | TASK: ${decision} | STATUS: running`);
1833:     this.emitUiFrame(lines, process.stdout.isTTY);
1834: 
1835:     if (hasReadline) this.rl.resume();
1836:   }
