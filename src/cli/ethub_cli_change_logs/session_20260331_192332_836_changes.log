1003:   async startDebugDashboard() {
1004:     if (this.debugServerProcess && !this.debugServerProcess.killed && this.dashboardInfo) {
1005:       return this.dashboardInfo;
1006:     }
1007: 
1008:     const serverPath = this.resolveDashboardServerPath();
1009:     if (!serverPath) {
1010:       throw new Error('web_debug/index_server.mjs not found');
1011:     }
1012: 
1013:     const token = this.makeDebugToken();
1014:     const env = {
1015:       ...process.env,
1016:       WEB_DEBUG_TOKEN: token
1017:     };
1018: 
1019:     const child = spawn(process.execPath, [serverPath], {
1020:       cwd: this.workspaceRoot,
1021:       env,
1022:       stdio: ['ignore', 'pipe', 'pipe']
1023:     });
1024: 
1025:     this.debugServerProcess = child;
1026:     this.debugServerToken = token;
1027:     let startupOutput = '';
1028: 
1029:     child.stdout.on('data', (chunk) => {
1030:       const text = chunk.toString();
1031:       startupOutput += text;
1032:       this.logger.writeEvent('debug_dashboard_stdout', { text: text.slice(0, 800) });
1033:     });
1034:     child.stderr.on('data', (chunk) => {
1035:       const text = chunk.toString();
1036:       startupOutput += text;
1037:       this.logger.writeEvent('debug_dashboard_stderr', { text: text.slice(0, 800) });
1038:     });
1039:     child.on('exit', (code, signal) => {
1040:       this.logger.writeEvent('debug_dashboard_exit', { code, signal });
1041:       this.debugServerProcess = null;
1042:       this.dashboardInfo = null;
1043:       this.debugServerToken = '';
1044:     });
1045: 
1046:     const deadline = Date.now() + 10000;
1047:     while (Date.now() < deadline) {
1048:       const urlMatch = startupOutput.match(/http:\/\/127\.0\.0\.1:(\d+)/);
1049:       if (urlMatch) {
1050:         const port = Number(urlMatch[1]);
1051:         const base = `http://127.0.0.1:${port}`;
1052:         this.dashboardInfo = {
1053:           pid: child.pid,
1054:           host: '127.0.0.1',
1055:           port,
1056:           dashboard_url: `${base}/?token=${token}`,
1057:           chat_url: `${base}/chat?token=${token}`
1058:         };
1059:         this.logger.writeEvent('debug_dashboard_ready', this.dashboardInfo);
1060:         return this.dashboardInfo;
1061:       }
1062: 
1063:       const runtime = this.readDashboardRuntime();
1064:       if (runtime && Number(runtime.port) > 0) {
1065:         const healthy = await this.isDashboardHealthy(runtime.port);
1066:         if (healthy) {
1067:           const base = `http://127.0.0.1:${runtime.port}`;
1068:           this.dashboardInfo = {
1069:             ...runtime,
1070:             dashboard_url: `${base}/?token=${token}`,
1071:             chat_url: `${base}/chat?token=${token}`
1072:           };
1073:           this.logger.writeEvent('debug_dashboard_ready', this.dashboardInfo);
1074:           return this.dashboardInfo;
1075:         }
1076:       }
1077: 
1078:       await this.sleep(120);
1079:     }
1080: 
1081:     this.stopDebugDashboard();
1082:     throw new Error('debug dashboard failed to start in time');
1083:   }
