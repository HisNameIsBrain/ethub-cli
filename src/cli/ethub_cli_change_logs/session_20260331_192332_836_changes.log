0953:     this.safePrompt();
0954: 
0955:     this.rl.on('line', async (line) => {
0956:       const input = String(line || '').trim();
0957:       this.logger.writeEvent('stdin', { raw: line, trimmed: input });
0958: 
0959:       if (!input) {
0960:         this.safePrompt();
