1293:   buildReasoningTreeLines(reasoning) {
1294:     const keywordsText = Array.isArray(reasoning.keywords) && reasoning.keywords.length
1295:       ? reasoning.keywords.join(', ')
1296:       : 'none';
1297:     return [
1298:       `${LEFT_PAD}${style('thinking...', ANSI.cyan)}`,
1299:       `${LEFT_PAD}${style('├─ intent', ANSI.dim)}: ${reasoning.intent}`,
1300:       `${LEFT_PAD}${style('├─ keywords', ANSI.dim)}: ${keywordsText}`,
1301:       `${LEFT_PAD}${style('├─ strategy', ANSI.dim)}: ${reasoning.strategy}`,
1302:       `${LEFT_PAD}${style('└─ context', ANSI.dim)}: ${reasoning.context || 'general'}`
1303:     ];
1304:   }
1305: 
1306:   buildOllamaReasoningLines(reasoning) {
1307:     return [
1308:       `${LEFT_PAD}${style('reasoning with ollama...', ANSI.cyan)}`,
1309:       `${LEFT_PAD}${style('├─ target', ANSI.dim)}: ${this.ollamaUrl}`,
1310:       `${LEFT_PAD}${style('├─ model', ANSI.dim)}: ${this.model}`,
1311:       `${LEFT_PAD}${style('└─ intent', ANSI.dim)}: ${reasoning.intent}`
1312:     ];
1313:   }
1314: 
1315:   async displayReasoningFlow(reasoning) {
1316:     this.startThinking('mapping intent + strategy');
1317:     await this.sleep(420);
1318:     this.stopThinking({ clearLine: true });
1319: 
1320:     const phaseOne = this.buildReasoningTreeLines(reasoning);
1321:     await this.typewriteLines(phaseOne, 8);
1322:     await this.sleep(180);
1323:     this.clearRecentLines(phaseOne.length);
1324: 
1325:     const phaseTwo = this.buildOllamaReasoningLines(reasoning);
1326:     await this.typewriteLines(phaseTwo, 8);
1327:     this.print('');
1328:   }
