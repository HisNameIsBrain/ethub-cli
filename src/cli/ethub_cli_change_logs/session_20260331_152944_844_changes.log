1801:   uiBox(msg, color = 'cyan') {
1802:     const c = {
1803:       cyan: '\x1b[36m',
1804:       green: '\x1b[32m',
1805:       red: '\x1b[31m',
1806:       yellow: '\x1b[33m'
1807:     };
1808:     const code = c[color] || c.cyan;
1809:     return `${code}[ ${String(msg || '')} ]\x1b[0m`;
1810:   }
1811: 
1812:   emitUiFrame(lines, clearScreen = false) {
1813:     const rows = Array.isArray(lines) ? lines : [];
1814:     if (clearScreen && process.stdout.isTTY) {
1815:       process.stdout.write('\x1b[2J\x1b[H');
1816:     }
1817:     const text = `${rows.join('\n')}\n`;
1818:     process.stdout.write(text);
1819:     this.logger.writeEvent('stdout', { text: rows.join('\n') });
1820:   }
1821: 
1822:   analyzeContext(code) {
1823:     const text = String(code || '');
1824:     return {
1825:       length: text.length,
1826:       hasDebugLoop: /function\s+debugLoop/.test(text),
1827:       hasPipeline: /runPipeline/.test(text),
1828:       hasTodo: /TODO|TodoManager/.test(text),
1829:       hasANSI: /\x1b\[/.test(text),
1830:       hasCLI: /readline|process\.stdin/.test(text),
1831:       hasFileOps: /fs\./.test(text),
1832:       complexity: (text.match(/function/g) || []).length
1833:     };
1834:   }
1835: 
1836:   classifyContext(ctx) {
1837:     if (!ctx.hasPipeline) return 'bootstrap_pipeline';
1838:     if (!ctx.hasDebugLoop) return 'missing_debug';
1839:     if (!ctx.hasTodo) return 'missing_planning';
1840:     if (ctx.complexity < 10) return 'expand_features';
1841:     if (ctx.length > 150000) return 'optimize';
1842:     return 'stable';
1843:   }
1844: 
1845:   buildPlan(type) {
1846:     switch (type) {
1847:       case 'bootstrap_pipeline':
1848:         return ['add_pipeline_core'];
1849:       case 'missing_debug':
1850:         return ['add_debug_loop'];
1851:       case 'missing_planning':
1852:         return ['add_todo_system'];
1853:       case 'expand_features':
1854:         return ['add_context_router'];
1855:       case 'optimize':
1856:         return ['refactor_large_blocks'];
1857:       default:
1858:         return ['noop'];
1859:     }
1860:   }
1861: 
1862:   routeIntent(input) {
1863:     const text = String(input || '').toLowerCase();
1864:     if (/error|bug|trace|failed|exception/.test(text)) return 'debug';
1865:     if (/summarize|summary|tl;dr/.test(text)) return 'summary';
1866:     if (/build|create|implement|write|generate/.test(text)) return 'code';
1867:     if (/refactor|cleanup|optimi[sz]e|simplify/.test(text)) return 'refactor';
1868:     if (/test|coverage|assert|spec/.test(text)) return 'testing';
1869:     if (/docs?|readme|document/.test(text)) return 'documentation';
1870:     if (/plan|roadmap|milestone|timeline|steps/.test(text)) return 'planning';
1871:     if (/research|find|lookup|compare/.test(text)) return 'research';
1872:     return 'general';
1873:   }
1874: 
1875:   isSafeCommand(commandText) {
1876:     const text = String(commandText || '').trim();
1877:     if (!text) return false;
1878:     if (BLOCKED_COMMAND_PATTERN.test(text)) return false;
1879:     const parsed = tokenizeCommandLine(text);
1880:     if (parsed.error || !parsed.tokens || !parsed.tokens.length) return false;
1881:     const cmd = parsed.tokens[0];
1882:     return /^(ls|cd|cat|grep|rg|sed|cp|mv|tree|echo)$/.test(cmd);
1883:   }
1884: 
1885:   async runShell(commandText) {
1886:     const raw = String(commandText || '').trim();
1887:     const parsed = tokenizeCommandLine(raw);
1888:     if (parsed.error) {
1889:       this.print(this.uiBox(`Shell parse error: ${parsed.error}`, 'red'));
1890:       return;
1891:     }
1892:     const tokens = parsed.tokens || [];
1893:     if (!tokens.length) {
1894:       this.print(this.uiBox('Shell command rejected (empty).', 'red'));
1895:       return;
1896:     }
1897: 
1898:     const cmd = tokens[0];
1899:     const args = tokens.slice(1);
1900: 
1901:     if (cmd === 'cd') {
1902:       const target = args[0] || '.';
1903:       const resolved = this.resolvePathInWorkspace(target, 'dir');
1904:       if (resolved.error) {
1905:         this.print(this.uiBox(`cd denied: ${resolved.error}`, 'red'));
1906:         return;
1907:       }
1908:       process.chdir(resolved.path);
1909:       this.refreshPrompt();
1910:       this.print(this.uiBox(`cwd -> ${this.workspaceRelativePath()}`, 'cyan'));
1911:       return;
1912:     }
1913: 
1914:     await new Promise((resolve) => {
1915:       const proc = spawn(cmd, args, { stdio: ['ignore', 'pipe', 'pipe'], shell: false });
1916:       let out = '';
1917:       proc.stdout.on('data', (d) => {
1918:         out += d.toString();
1919:       });
1920:       proc.stderr.on('data', (d) => {
1921:         out += d.toString();
1922:       });
1923:       proc.on('error', (error) => {
1924:         this.print(this.uiBox(`Command failed: ${error.message}`, 'red'));
1925:         resolve();
1926:       });
1927:       proc.on('close', (code) => {
1928:         const chunk = out.trim() ? out.trim().slice(0, 300) : `(no output, exit=${code})`;
1929:         this.print(this.uiBox(chunk, code === 0 ? 'cyan' : 'yellow'));
1930:         resolve();
1931:       });
1932:     });
1933:   }
1934: 
1935:   generatePatch(plan) {
1936:     const steps = Array.isArray(plan) ? plan : [];
1937:     let out = '\n// === ETHUB AUTO PATCH ===\n';
1938: 
1939:     for (const step of steps) {
1940:       if (step === 'add_pipeline_core') {
1941:         out += `
1942: function runPipelineAuto() {
1943:   console.log("Pipeline ready");
1944: }
1945: `;
1946:       }
1947:       if (step === 'add_debug_loop') {
1948:         out += `
1949: function debugLoopAuto() {
1950:   console.log("Debug loop ready");
1951: }
1952: `;
1953:       }
1954:       if (step === 'add_todo_system') {
1955:         out += `
1956: const TODO = [];
1957: function addTodo(x){ TODO.push(x); }
1958: `;
1959:       }
1960:       if (step === 'add_context_router') {
1961:         out += `
1962: function routeTask(type) {
1963:   if (type === "debug") return debugLoopAuto();
1964: }
1965: `;
1966:       }
1967:     }
1968: 
1969:     return out;
1970:   }
1971: 
1972:   validatePatch(original, patch) {
1973:     const base = String(original || '');
1974:     const candidate = String(patch || '');
1975:     if (!candidate.trim()) return false;
1976:     if (base.includes(candidate.trim())) return false;
1977:     if (base.length + candidate.length > 200000) return false;
1978:     if (candidate.includes('rm -rf')) return false;
1979:     return true;
1980:   }
1981: 
1982:   applyPatchSafe(file, patch) {
1983:     const backup = `${file}.bak`;
1984:     fs.copyFileSync(file, backup);
1985:     try {
1986:       const updated = fs.readFileSync(file, 'utf8') + '\n' + patch;
1987:       fs.writeFileSync(file, updated, 'utf8');
1988:       this.print(this.uiBox('Patch applied successfully', 'green'));
1989:       this.logger.writeEvent('pipeline_patch_applied', { file, backup, patch_chars: patch.length });
1990:     } catch (error) {
1991:       fs.copyFileSync(backup, file);
1992:       this.print(this.uiBox('Patch failed -> rolled back', 'red'));
1993:       this.logger.writeEvent('pipeline_patch_rollback', { file, backup, error: error.message });
1994:     }
1995:   }
1996: 
1997:   async executeTodoPlan(plan, file) {
1998:     const original = this.readFileSafe(file);
1999:     const patch = this.generatePatch(plan);
2000:     if (!this.validatePatch(original, patch)) {
2001:       this.print(this.uiBox('Patch rejected (validation)', 'red'));
2002:       return;
2003:     }
2004:     this.applyPatchSafe(file, patch);
2005:   }
