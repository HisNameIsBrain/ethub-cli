1037:     this.print(style('ETHUB CLI Agent started. Ollama only, no external dependencies.', ANSI.bold, ANSI.cyan));
1038:     this.print(style(`Session logs: ${this.logger.sessionDir}`, ANSI.dim));
1039:     this.print(style('Use /debug to launch the session-bound dashboard + chat.', ANSI.dim));
1040:     this.print(style('Type /help for commands.', ANSI.yellow));
1041:     await this.showSuggestions();
1042:     this.safePrompt();
1043: 
