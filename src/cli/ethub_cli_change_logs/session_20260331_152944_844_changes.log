1171:   drawHeader(frame) {
1172:     const p1 = (frame / 90) % 1;
1173:     const p3 = (p1 + 0.66) % 1;
1174:     this.print(LEFT_PAD + rainbowDivider(HEADER_WIDTH, p1));
1175:     ETHUB_ASCII.forEach((line, row) => {
1176:       this.print(LEFT_PAD + rainbowAsciiLine(line, row, ETHUB_ASCII.length, frame));
1177:     });
1178:     this.print(
1179:       LEFT_PAD +
1180:       style(
1181:         `Mode: CHAT | Model: ${this.model} | Change Approval: ${this.requireApproval ? 'ON' : 'OFF'}`,
1182:         ANSI.dim
1183:       )
1184:     );
1185:     this.print(LEFT_PAD + rainbowDivider(HEADER_WIDTH, p3));
1186:   }
1187: 
1188:   renderHeaderFrame(frame) {
1189:     const p1 = (frame / 90) % 1;
1190:     const p3 = (p1 + 0.66) % 1;
1191:     const lines = [];
1192:     lines.push(LEFT_PAD + rainbowDivider(HEADER_WIDTH, p1));
1193:     ETHUB_ASCII.forEach((line, row) => {
1194:       lines.push(LEFT_PAD + rainbowAsciiLine(line, row, ETHUB_ASCII.length, frame));
1195:     });
1196:     lines.push(
1197:       LEFT_PAD +
1198:       style(
1199:         `Mode: CHAT | Model: ${this.model} | Approval: ${this.requireApproval ? 'ON' : 'OFF'}`,
1200:         ANSI.dim
1201:       )
1202:     );
1203:     lines.push(LEFT_PAD + rainbowDivider(HEADER_WIDTH, p3));
1204:     return lines;
1205:   }
1206: 
1207:   async animateHeader(durationMs = 1200, fps = 20) {
1208:     const frameDelay = Math.max(16, Math.floor(1000 / fps));
1209:     const frames = Math.max(1, Math.floor(durationMs / frameDelay));
1210:     for (let frame = 0; frame < frames; frame += 1) {
1211:       const lines = this.renderHeaderFrame(frame);
1212:       process.stdout.write('\x1b[2J\x1b[H');
1213:       process.stdout.write(`${lines.join('\n')}\n`);
1214:       await new Promise((resolve) => setTimeout(resolve, frameDelay));
1215:     }
1216:     process.stdout.write('\x1b[2J\x1b[H');
1217:     this.drawHeader(frames);
1218:   }
