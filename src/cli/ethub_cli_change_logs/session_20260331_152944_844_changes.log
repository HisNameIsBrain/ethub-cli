1124:   resolvePathInWorkspace(inputPath, expected = 'any') {
1125:     const raw = String(inputPath || '').trim();
1126:     if (!raw) return { error: 'path is required' };
1127:     const normalized = raw === '~' ? os.homedir() : raw;
1128:     const resolved = path.resolve(process.cwd(), normalized);
1129:     const root = path.resolve(this.workspaceRoot);
1130:     const inRoot = resolved === root || resolved.startsWith(`${root}${path.sep}`);
1131:     if (!inRoot) {
1132:       return { error: `path escapes workspace root: ${root}` };
1133:     }
1134: 
1135:     if (expected === 'exists') {
1136:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
1137:     }
1138:     if (expected === 'file' || expected === 'dir') {
1139:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
1140:       let st;
1141:       try {
1142:         st = fs.statSync(resolved);
1143:       } catch (error) {
1144:         return { error: `unable to stat path: ${error.message}` };
1145:       }
1146:       if (expected === 'file' && !st.isFile()) return { error: 'path is not a file' };
1147:       if (expected === 'dir' && !st.isDirectory()) return { error: 'path is not a directory' };
1148:     }
1149: 
1150:     return { path: resolved };
1151:   }
