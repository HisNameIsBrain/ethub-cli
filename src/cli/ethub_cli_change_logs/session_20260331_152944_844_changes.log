2107:   async executeAction(action) {
2108:     if (!action || action.type !== 'ollama_chat') {
2109:       this.logger.writeEvent('action_error', { message: 'Unsupported action type', action });
2110:       this.writeStructuredUpdate(action && action.id ? action.id : 'unknown', {
2111:         'Run runtime look at logs': 'contains error still, unsupported action type',
2112:         summary: 'Unsupported action type encountered before runtime request.',
2113:         'Number of characters changed': 'previous character amount in file before cmd/new total character count added: 0/0'
2114:       });
2115:       this.print('Unsupported action.');
2116:       return;
2117:     }
2118: 
2119:     this.logger.writeEvent('action_start', {
2120:       action_id: action.id,
2121:       type: action.type,
2122:       target: this.ollamaUrl,
2123:       model: this.model,
2124:       prompt_chars: action.prompt.length,
2125:       reasoning_summary: action.reasoning_summary
2126:     });
2127: 
2128:     this.history.push({ role: 'user', content: action.prompt });
2129: 
2130:     const payload = {
2131:       model: this.model,
2132:       messages: this.history,
2133:       stream: false
2134:     };
2135: 
2136:     let response;
2137:     let raw;
2138:     const started = Date.now();
2139:     await this.displayReasoningFlow(action.reasoning_summary || summarizeReasoning(action.prompt || ''));
2140:     this.startThinking('waiting for ollama response');
2141: 
2142:     try {
2143:       response = await fetch(this.ollamaUrl, {
2144:         method: 'POST',
2145:         headers: { 'Content-Type': 'application/json' },
2146:         body: JSON.stringify(payload)
2147:       });
2148: 
2149:       raw = await response.text();
2150:     } catch (error) {
2151:       this.stopThinking();
2152:       const message = error && error.message ? error.message : String(error);
2153:       this.logger.writeEvent('action_failure', {
2154:         action_id: action.id,
2155:         duration_ms: Date.now() - started,
2156:         error: message
2157:       });
2158:       this.writeStructuredUpdate(action.id, {
2159:         'Run runtime look at logs': 'contains error still, loop and try again with different results until each individual error is clear.',
2160:         summary: `Runtime request failed. Error: ${message}`,
2161:         'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${action.prompt.length}/0`,
2162:         'Print-approved-by-user?': 'true'
2163:       });
2164:       this.print(`Ollama request failed: ${message}`);
2165:       return;
2166:     }
2167:     this.stopThinking();
2168: 
2169:     let parsed;
2170:     try {
2171:       parsed = JSON.parse(raw);
2172:     } catch {
2173:       parsed = null;
2174:     }
2175: 
2176:     const assistantText = parsed && parsed.message && parsed.message.content
2177:       ? String(parsed.message.content)
2178:       : raw;
2179: 
2180:     this.history.push({ role: 'assistant', content: assistantText });
2181: 
2182:     this.logger.writeEvent('action_result', {
2183:       action_id: action.id,
2184:       duration_ms: Date.now() - started,
2185:       http_status: response.status,
2186:       ok: response.ok,
2187:       response_preview: assistantText.slice(0, 400),
2188:       response_chars: assistantText.length
2189:     });
2190: 
2191:     this.logger.writeTranscript('Assistant', assistantText);
2192:     this.print(assistantText);
2193: 
2194:     const hasRuntimeError = /(syntaxerror|stack overflow|runtime error|error:)/i.test(assistantText);
2195:     const runtimeResult = hasRuntimeError
2196:       ? 'contains error still, retry with different checks until isolated'
2197:       : 'No runtime error anymore = fixed';
2198:     const beforeChars = this.actionMeta[action.id] && this.actionMeta[action.id].prompt_chars_before
2199:       ? this.actionMeta[action.id].prompt_chars_before
2200:       : 0;
2201:     const afterChars = assistantText.length;
2202:     const elapsedMs = Date.now() - started;
2203: 
2204:     this.writeStructuredUpdate(action.id, {
2205:       'Run runtime look at logs': runtimeResult,
2206:       summary: `summarized what just changed, is it fixed: ${hasRuntimeError ? 'No' : 'Yes'}. Runtime error count estimate: ${hasRuntimeError ? 1 : 0}.`,
2207:       'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${beforeChars}/${afterChars}`,
2208:       timing_ms: elapsedMs,
2209:       stop_condition: elapsedMs >= 300000 ? 'Unable to find results or solutions, Try again.' : 'within loop budget'
2210:     });
2211:   }
2212: }
