0265: function extractTextEntriesFromZip(zipPath, shouldInclude) {
0266:   const out = [];
0267:   const data = fs.readFileSync(zipPath);
0268:   const minEocd = 22;
0269:   const maxComment = 0xffff;
0270:   const startSearch = Math.max(0, data.length - (minEocd + maxComment));
0271:   let eocd = -1;
0272:   for (let i = data.length - minEocd; i >= startSearch; i -= 1) {
0273:     if (data.readUInt32LE(i) === 0x06054b50) {
0274:       eocd = i;
0275:       break;
0276:     }
0277:   }
0278:   if (eocd < 0) throw new Error('zip EOCD signature not found');
0279: 
0280:   const centralDirSize = data.readUInt32LE(eocd + 12);
0281:   const centralDirOffset = data.readUInt32LE(eocd + 16);
0282:   const centralDirEnd = centralDirOffset + centralDirSize;
0283:   let cursor = centralDirOffset;
0284: 
0285:   while (cursor + 46 <= centralDirEnd && cursor + 46 <= data.length) {
0286:     const sig = data.readUInt32LE(cursor);
0287:     if (sig !== 0x02014b50) break;
0288:     const compressionMethod = data.readUInt16LE(cursor + 10);
0289:     const compressedSize = data.readUInt32LE(cursor + 20);
0290:     const fileNameLen = data.readUInt16LE(cursor + 28);
0291:     const extraLen = data.readUInt16LE(cursor + 30);
0292:     const commentLen = data.readUInt16LE(cursor + 32);
0293:     const localHeaderOffset = data.readUInt32LE(cursor + 42);
0294:     const nameStart = cursor + 46;
0295:     const nameEnd = nameStart + fileNameLen;
0296:     const entryName = data.slice(nameStart, nameEnd).toString('utf8');
0297:     const next = nameEnd + extraLen + commentLen;
0298:     cursor = next;
0299: 
0300:     if (!shouldInclude(entryName)) continue;
0301:     if (entryName.endsWith('/')) continue;
0302:     if (localHeaderOffset + 30 > data.length) continue;
0303:     if (data.readUInt32LE(localHeaderOffset) !== 0x04034b50) continue;
0304: 
0305:     const localNameLen = data.readUInt16LE(localHeaderOffset + 26);
0306:     const localExtraLen = data.readUInt16LE(localHeaderOffset + 28);
0307:     const payloadStart = localHeaderOffset + 30 + localNameLen + localExtraLen;
0308:     const payloadEnd = payloadStart + compressedSize;
0309:     if (payloadEnd > data.length) continue;
0310: 
0311:     const compressed = data.slice(payloadStart, payloadEnd);
0312:     let decoded;
0313:     if (compressionMethod === 0) {
0314:       decoded = compressed;
0315:     } else if (compressionMethod === 8) {
0316:       decoded = zlib.inflateRawSync(compressed);
0317:     } else {
0318:       continue;
0319:     }
0320: 
0321:     out.push({
0322:       entry: entryName,
0323:       text: decoded.toString('utf8')
0324:     });
0325:   }
0326:   return out;
0327: }
