0442: 
0443:   buildSessionId() {
0444:     const d = new Date();
0445:     const stamp = [
0446:       d.getUTCFullYear(),
0447:       String(d.getUTCMonth() + 1).padStart(2, '0'),
0448:       String(d.getUTCDate()).padStart(2, '0'),
0449:       '_',
0450:       String(d.getUTCHours()).padStart(2, '0'),
0451:       String(d.getUTCMinutes()).padStart(2, '0'),
0452:       String(d.getUTCSeconds()).padStart(2, '0'),
0453:       '_',
0454:       String(d.getUTCMilliseconds()).padStart(3, '0')
0455:     ].join('');
0456:     return `session_${stamp}`;
0457:   }
