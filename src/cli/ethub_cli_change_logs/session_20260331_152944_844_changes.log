1153:   queueApprovalAction(action, promptText) {
1154:     if (this.pendingAction) {
1155:       this.print(`Pending action already exists (${this.pendingAction.id}). Resolve with /yes or /no first.`);
1156:       return false;
1157:     }
1158:     this.pendingAction = action;
1159:     this.logger.writeEvent('action_queued', { action_id: action.id, type: action.type, payload: action.payload });
1160:     this.print(promptText);
1161:     this.print(style(`Approve with /yes or reject with /no`, ANSI.yellow));
1162:     return true;
1163:   }
