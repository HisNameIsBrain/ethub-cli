0483: 
0484:   writeCodeSnapshot() {
0485:     const sourcePath = path.resolve(__filename);
0486:     let sourceText = '';
0487:     try {
0488:       sourceText = fs.readFileSync(sourcePath, 'utf8');
0489:     } catch (error) {
0490:       sourceText = `Unable to read source file: ${error && error.message ? error.message : String(error)}`;
0491:     }
0492: 
0493:     const numbered = sourceText
0494:       .split('\n')
0495:       .map((line, i) => `${String(i + 1).padStart(4, '0')}: ${line}`)
0496:       .join('\n');
0497: 
