0933:   stopDebugDashboard(reason = 'stop_requested') {
0934:     const child = this.debugServerProcess;
0935:     if (child && !child.killed) {
0936:       try {
0937:         child.kill('SIGTERM');
0938:       } catch {
0939:         // best effort cleanup
0940:       }
0941:     }
0942:     this.debugServerProcess = null;
0943:     this.debugServerToken = '';
0944:     this.dashboardInfo = null;
0945:     this.logger.writeEvent('debug_dashboard_stop', { reason });
0946:   }
0947: 
0948:   async startDebugDashboard() {
0949:     if (this.debugServerProcess && !this.debugServerProcess.killed && this.dashboardInfo && this.dashboardInfo.dashboard_url) {
0950:       return this.dashboardInfo;
0951:     }
0952:     const serverPath = this.resolveDashboardServerPath();
0953:     if (!serverPath) {
0954:       throw new Error('web_debug/index_server.mjs not found.');
0955:     }
0956: 
0957:     this.stopDebugDashboard('restart_debug_dashboard');
0958:     const token = this.makeDebugToken();
0959:     const startPort = Number(process.env.WEB_DEBUG_PORT || '3000');
0960:     const child = spawn(process.execPath, [serverPath], {
0961:       cwd: this.workspaceRoot,
0962:       stdio: ['ignore', 'pipe', 'pipe'],
0963:       env: {
0964:         ...process.env,
0965:         WEB_DEBUG_PORT: String(startPort),
0966:         WEB_DEBUG_TOKEN: token
0967:       }
0968:     });
0969:     this.debugServerProcess = child;
0970:     this.debugServerToken = token;
0971:     this.dashboardInfo = null;
0972: 
0973:     let outBuf = '';
0974:     let errBuf = '';
0975:     const scanOutput = () => {
0976:       const lines = outBuf.split('\n');
0977:       let base = '';
0978:       let chat = '';
0979:       for (const line of lines) {
0980:         const m1 = line.match(/web_debug running on\s+(http:\/\/127\.0\.0\.1:\d+\/\?token=[^\s]+)/i);
0981:         if (m1) base = m1[1];
0982:         const m2 = line.match(/chat interface:\s+(http:\/\/127\.0\.0\.1:\d+\/chat\?token=[^\s]+)/i);
0983:         if (m2) chat = m2[1];
0984:       }
0985:       if (!base) return;
0986:       const p = Number((base.match(/127\.0\.0\.1:(\d+)/) || [])[1] || 0);
0987:       this.dashboardInfo = {
0988:         pid: child.pid,
0989:         port: p,
0990:         dashboard_url: base,
0991:         chat_url: chat || `http://127.0.0.1:${p}/chat?token=${token}`
0992:       };
0993:     };
0994: 
0995:     child.stdout.on('data', (chunk) => {
0996:       outBuf += chunk.toString('utf8');
0997:       scanOutput();
0998:     });
0999:     child.stderr.on('data', (chunk) => {
1000:       errBuf += chunk.toString('utf8');
1001:     });
1002:     child.on('exit', (code, signal) => {
1003:       this.logger.writeEvent('debug_dashboard_exit', { code, signal, stderr: truncateText(errBuf, 8000) });
1004:       this.debugServerProcess = null;
1005:       this.dashboardInfo = null;
1006:       this.debugServerToken = '';
1007:     });
1008: 
1009:     this.logger.writeEvent('debug_dashboard_start', {
1010:       path: serverPath,
1011:       pid: child.pid,
1012:       requested_port: startPort,
1013:       token_length: token.length
1014:     });
1015: 
1016:     const timeoutAt = Date.now() + 8000;
1017:     while (Date.now() < timeoutAt) {
1018:       if (this.dashboardInfo && this.dashboardInfo.dashboard_url) {
1019:         return this.dashboardInfo;
1020:       }
1021:       if (!this.debugServerProcess || this.debugServerProcess.killed) break;
1022:       await new Promise((resolve) => setTimeout(resolve, 120));
1023:     }
1024: 
1025:     if (errBuf.trim()) {
1026:       throw new Error(`debug dashboard failed to start: ${truncateText(errBuf.trim(), 400)}`);
1027:     }
1028:     throw new Error('debug dashboard did not report readiness in time.');
1029:   }
