0803:   validatePathToken(token) {
0804:     const raw = String(token || '').trim();
0805:     if (!raw) return { ok: true };
0806:     if (raw === '-' || raw.startsWith('-')) return { ok: true };
0807:     if (raw.startsWith('/')) return { ok: false, reason: `Absolute paths are blocked (${raw}).` };
0808:     if (raw.includes('..')) return { ok: false, reason: `Parent traversal is blocked (${raw}).` };
0809:     const resolved = path.resolve(process.cwd(), raw);
0810:     if (!isPathInsideRoot(this.workspaceRoot, resolved)) {
0811:       return { ok: false, reason: `Path escapes workspace root (${raw}).` };
0812:     }
0813:     return { ok: true };
0814:   }
0815: 
0816:   validateSkillCommand(snippet) {
0817:     const commandText = normalizeSnippet(snippet);
0818:     if (!commandText) return { ok: false, reason: 'Empty snippet.' };
0819:     const lines = commandText.split('\n').map((l) => l.trim()).filter(Boolean);
0820:     if (lines.length !== 1) return { ok: false, reason: 'Only single-line shell skills are executable.' };
0821:     const line = lines[0];
0822:     if (BLOCKED_COMMAND_PATTERN.test(line)) {
0823:       return { ok: false, reason: 'Command contains blocked shell operators.' };
0824:     }
0825: 
0826:     const parsed = tokenizeCommandLine(line);
0827:     if (parsed.error) return { ok: false, reason: parsed.error };
0828:     const tokens = parsed.tokens || [];
0829:     if (!tokens.length) return { ok: false, reason: 'No command token found.' };
0830: 
0831:     const cmd = tokens[0];
0832:     if (!SAFE_SKILL_COMMANDS.has(cmd)) {
0833:       return { ok: false, reason: `Command '${cmd}' is not allowlisted.` };
0834:     }
0835:     if (cmd === 'git') {
0836:       const sub = (tokens[1] || '').toLowerCase();
0837:       if (!['status', 'diff', 'log', 'show', 'branch', 'rev-parse'].includes(sub)) {
0838:         return { ok: false, reason: `git '${sub || '(none)'}' is blocked.` };
0839:       }
0840:     }
0841: 
0842:     for (let i = 1; i < tokens.length; i += 1) {
0843:       const pathCheck = this.validatePathToken(tokens[i]);
0844:       if (!pathCheck.ok) return pathCheck;
0845:     }
0846:     return { ok: true, command: cmd, tokens };
0847:   }
0848: 
0849:   async runSkillCommand(action) {
0850:     const payload = action && action.payload ? action.payload : {};
0851:     const skillName = payload.skill_name || payload.skill_id || 'unknown';
0852:     const snippet = String(payload.snippet || '');
0853:     const validation = this.validateSkillCommand(snippet);
0854:     if (!validation.ok) {
0855:       this.print(`${style('Skill execution denied:', ANSI.bold, ANSI.red)} ${validation.reason}`);
0856:       this.logger.writeEvent('skill_run_denied', {
0857:         action_id: action.id,
0858:         skill: skillName,
0859:         reason: validation.reason
0860:       });
0861:       return;
0862:     }
0863: 
0864:     const tokens = validation.tokens;
0865:     const cmd = tokens[0];
0866:     const args = tokens.slice(1);
0867:     this.print(style(`[SKILL RUN] ${skillName}: ${snippet}`, ANSI.bold, ANSI.cyan));
0868: 
0869:     const result = await new Promise((resolve) => {
0870:       const child = spawn(cmd, args, {
0871:         cwd: process.cwd(),
0872:         stdio: ['ignore', 'pipe', 'pipe'],
0873:         shell: false
0874:       });
0875: 
0876:       let stdout = '';
0877:       let stderr = '';
0878:       let finished = false;
0879:       const timer = setTimeout(() => {
0880:         if (finished) return;
0881:         child.kill('SIGTERM');
0882:       }, 120000);
0883: 
0884:       child.stdout.on('data', (chunk) => {
0885:         if (stdout.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0886:         stdout += chunk.toString('utf8');
0887:       });
0888:       child.stderr.on('data', (chunk) => {
0889:         if (stderr.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0890:         stderr += chunk.toString('utf8');
0891:       });
0892:       child.on('error', (error) => {
0893:         clearTimeout(timer);
0894:         finished = true;
0895:         resolve({ code: -1, signal: null, stdout, stderr: `${stderr}\n${error.message}`.trim() });
0896:       });
0897:       child.on('close', (code, signal) => {
0898:         clearTimeout(timer);
0899:         finished = true;
0900:         resolve({ code, signal, stdout, stderr });
0901:       });
0902:     });
0903: 
0904:     if (result.stdout) {
0905:       this.print(style('[STDOUT]', ANSI.dim));
0906:       this.print(truncateText(result.stdout, MAX_COMMAND_OUTPUT_BYTES));
0907:     }
0908:     if (result.stderr) {
0909:       this.print(style('[STDERR]', ANSI.dim));
0910:       this.print(truncateText(result.stderr, MAX_COMMAND_OUTPUT_BYTES));
0911:     }
0912:     this.print(style(`[SKILL EXIT] code=${result.code} signal=${result.signal || 'none'}`, ANSI.dim));
0913:     this.logger.writeEvent('skill_run_complete', {
0914:       action_id: action.id,
0915:       skill: skillName,
0916:       code: result.code,
0917:       signal: result.signal,
0918:       stdout_chars: result.stdout.length,
0919:       stderr_chars: result.stderr.length
0920:     });
0921:   }
