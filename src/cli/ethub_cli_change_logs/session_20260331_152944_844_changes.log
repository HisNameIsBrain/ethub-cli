0501:       `created_at: ${nowIso()}\n` +
0502:       `source_file: ${sourcePath}\n` +
0503:       `note: New file per session, append-only event/state logs enabled.\n\n` +
0504:       `## Source Snapshot (Line Numbered)\n`;
0505: 
0506:     fs.writeFileSync(this.changeLogPath, `${header}${numbered}\n`, 'utf8');
