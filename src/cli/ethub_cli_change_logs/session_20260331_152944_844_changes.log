1236:   startThinking(label = 'parsing your request') {
1237:     if (this.thinkingTimer) return;
1238:     let i = 0;
1239:     this.thinkingTimer = setInterval(() => {
1240:       const dots = '.'.repeat(i % 4);
1241:       process.stdout.write(
1242:         `\r${LEFT_PAD}${style('Thinking', ANSI.cyan)}${dots.padEnd(3, ' ')}${style(` ${label}`, ANSI.dim)}${' '.repeat(20)}`
1243:       );
1244:       i += 1;
1245:     }, 140);
1246:   }
1247: 
1248:   stopThinking(options = {}) {
1249:     const opts = options || {};
1250:     if (!this.thinkingTimer) return;
1251:     clearInterval(this.thinkingTimer);
1252:     this.thinkingTimer = null;
1253:     if (opts.clearLine && process.stdout.isTTY) {
1254:       process.stdout.write('\r\x1b[2K');
1255:       return;
1256:     }
1257:     process.stdout.write('\n');
1258:   }
1259: 
1260:   sleep(ms) {
1261:     return new Promise((resolve) => setTimeout(resolve, ms));
1262:   }
1263: 
1264:   async typewriteLine(line, delayMs = 12) {
1265:     const text = String(line || '');
1266:     if (!text) {
1267:       process.stdout.write('\n');
1268:       return;
1269:     }
1270:     let buf = '';
1271:     for (const ch of text) {
1272:       buf += ch;
1273:       process.stdout.write(`\r${buf}`);
1274:       await this.sleep(delayMs);
1275:     }
1276:     process.stdout.write('\n');
1277:   }
1278: 
1279:   async typewriteLines(lines, delayMs = 10) {
1280:     for (const line of lines) {
1281:       await this.typewriteLine(line, delayMs);
1282:     }
1283:   }
1284: 
1285:   clearRecentLines(count) {
1286:     if (!process.stdout.isTTY) return;
1287:     const n = Number(count) || 0;
1288:     for (let i = 0; i < n; i += 1) {
1289:       process.stdout.write('\x1b[1A\r\x1b[2K');
1290:     }
1291:   }
