0603:   extractSnippetCandidatesFromText(text, sourceLabel, addCandidate) {
0604:     const raw = String(text || '');
0605:     const segments = [];
0606:     let parsed = null;
0607: 
0608:     if (/^\s*[\[{]/.test(raw)) {
0609:       try {
0610:         parsed = JSON.parse(raw);
0611:       } catch {
0612:         parsed = null;
0613:       }
0614:     }
0615: 
0616:     const walk = (value, depth = 0) => {
0617:       if (depth > 8) return;
0618:       if (typeof value === 'string') {
0619:         if (value.trim()) segments.push(value);
0620:         return;
0621:       }
0622:       if (!value || typeof value !== 'object') return;
0623:       if (Array.isArray(value)) {
0624:         for (const item of value) walk(item, depth + 1);
0625:         return;
0626:       }
0627:       if (value.content && Array.isArray(value.content.parts)) {
0628:         for (const part of value.content.parts) {
0629:           if (typeof part === 'string' && part.trim()) segments.push(part);
0630:         }
0631:       }
0632:       if (typeof value.text === 'string' && value.text.trim()) {
0633:         segments.push(value.text);
0634:       }
0635:       for (const key of Object.keys(value)) {
0636:         if (key === 'content' || key === 'text') continue;
0637:         walk(value[key], depth + 1);
0638:       }
0639:     };
0640: 
0641:     if (parsed) {
0642:       walk(parsed);
0643:     } else {
0644:       segments.push(raw);
0645:     }
0646: 
0647:     for (const segment of segments) {
0648:       const fencePattern = /```(?:[^\n`]*)\n([\s\S]*?)```/g;
0649:       let match;
0650:       while ((match = fencePattern.exec(segment)) !== null) {
0651:         addCandidate(match[1], sourceLabel, 'fenced_code');
0652:       }
0653: 
0654:       const lines = segment.split('\n');
0655:       for (const line of lines) {
0656:         const trimmed = line.trim();
0657:         if (!trimmed || trimmed.length > 220) continue;
0658:         const shellLike = trimmed.replace(/^\$\s*/, '');
0659:         if (/^(ls|pwd|cat|head|tail|wc|rg|grep|find|sed|cp|mv|mkdir|touch|echo|git)\b/.test(shellLike)) {
0660:           addCandidate(shellLike, sourceLabel, 'shell_line');
0661:         }
0662:       }
0663:     }
0664:   }
0665: 
0666:   listArtifactZipFiles() {
0667:     const out = [];
0668:     if (!fs.existsSync(ARTIFACTS_ROOT)) return out;
0669:     const stack = [ARTIFACTS_ROOT];
0670:     while (stack.length) {
0671:       const current = stack.pop();
0672:       let entries = [];
0673:       try {
0674:         entries = fs.readdirSync(current, { withFileTypes: true });
0675:       } catch {
0676:         continue;
0677:       }
0678:       for (const entry of entries) {
0679:         const full = path.join(current, entry.name);
0680:         if (entry.isDirectory()) {
0681:           stack.push(full);
0682:         } else if (entry.isFile() && full.toLowerCase().endsWith('.zip')) {
0683:           out.push(full);
0684:         }
0685:       }
0686:     }
0687:     return out;
0688:   }
0689: 
0690:   collectSkillCandidatesFromArtifacts(limit = 10) {
0691:     const snippets = new Map();
0692:     let scannedSources = 0;
0693:     const cap = Math.max(1, Math.min(MAX_SKILL_CANDIDATES, Number(limit) || 10));
0694:     const addCandidate = (snippetText, sourceLabel, sourceKind) => {
0695:       const normalized = normalizeSnippet(snippetText);
0696:       if (!looksLikeUsefulSnippet(normalized)) return;
0697:       const existing = snippets.get(normalized);
0698:       if (existing) {
0699:         existing.hits += 1;
0700:         existing.sources.add(sourceLabel);
0701:         return;
0702:       }
0703:       snippets.set(normalized, {
0704:         snippet: normalized,
0705:         hits: 1,
0706:         source_kind: sourceKind,
0707:         sources: new Set([sourceLabel])
0708:       });
0709:     };
0710: 
0711:     const zipFiles = this.listArtifactZipFiles();
0712:     for (const zipPath of zipFiles) {
0713:       try {
0714:         const entries = extractTextEntriesFromZip(zipPath, isLikelyTextPath);
0715:         for (const item of entries) {
0716:           scannedSources += 1;
0717:           this.extractSnippetCandidatesFromText(item.text, `${path.basename(zipPath)}:${item.entry}`, addCandidate);
0718:         }
0719:       } catch (error) {
0720:         this.logger.writeEvent('skills_mine_warning', {
0721:           stage: 'zip_read',
0722:           zip: zipPath,
0723:           error: error.message
0724:         });
0725:       }
0726:     }
0727: 
0728:     const directArtifactFiles = [];
0729:     if (fs.existsSync(ARTIFACTS_ROOT)) {
0730:       const stack = [ARTIFACTS_ROOT];
0731:       while (stack.length) {
0732:         const current = stack.pop();
0733:         let entries = [];
0734:         try {
0735:           entries = fs.readdirSync(current, { withFileTypes: true });
0736:         } catch {
0737:           continue;
0738:         }
0739:         for (const entry of entries) {
0740:           const full = path.join(current, entry.name);
0741:           if (entry.isDirectory()) stack.push(full);
0742:           else if (entry.isFile() && !full.toLowerCase().endsWith('.zip') && isLikelyTextPath(full)) directArtifactFiles.push(full);
0743:         }
0744:       }
0745:     }
0746: 
0747:     for (const filePath of directArtifactFiles) {
0748:       let text = '';
0749:       try {
0750:         text = fs.readFileSync(filePath, 'utf8');
0751:       } catch {
0752:         continue;
0753:       }
0754:       scannedSources += 1;
0755:       this.extractSnippetCandidatesFromText(text, this.workspaceRelativePath(filePath), addCandidate);
0756:     }
0757: 
0758:     const ranked = Array.from(snippets.values())
0759:       .sort((a, b) => b.hits - a.hits || b.snippet.length - a.snippet.length)
0760:       .slice(0, cap);
0761: 
0762:     this.skillCandidates = ranked.map((entry, idx) => {
0763:       const snippet = entry.snippet;
0764:       const safety = this.validateSkillCommand(snippet);
0765:       return {
0766:         id: `cand_${idx + 1}`,
0767:         snippet,
0768:         hits: entry.hits,
0769:         source_kind: entry.source_kind,
0770:         sources: Array.from(entry.sources).slice(0, 6),
0771:         executable: safety.ok,
0772:         safety_reason: safety.ok ? '' : safety.reason
0773:       };
0774:     });
0775: 
0776:     this.logger.writeEvent('skills_mined', {
0777:       candidates: this.skillCandidates.length,
0778:       unique_snippets: snippets.size,
0779:       scanned_sources: scannedSources,
0780:       zip_files: zipFiles.length
0781:     });
0782: 
0783:     return {
0784:       candidates: this.skillCandidates.length,
0785:       uniqueSnippets: snippets.size,
0786:       scannedSources,
0787:       zipFiles: zipFiles.length
0788:     };
0789:   }
