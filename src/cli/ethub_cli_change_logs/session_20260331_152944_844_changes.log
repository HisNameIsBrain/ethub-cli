1334:   async handleCommand(input) {
1335:     const [cmd, ...args] = input.split(/\s+/);
1336:     const command = cmd.toLowerCase();
1337:     this.logger.writeEvent('subcommand', { command, args });
1338: 
1339:     if (command === '/help') {
1340:       this.print('Commands: /help, /status, /model <name>, /approve changes on|off, /debug, /dashboard, /readfile <path>, /writefile <path> -- <content>, /cd <path>, /skills <mine|candidates|add|list|show|run>, /yes, /no, /exit');
1341:       this.print('Skills flow: /skills mine 10 -> /skills add cand_1 my_skill -> /yes -> /skills run my_skill -> /yes');
1342:       return;
1343:     }
1344: 
1345:     if (command === '/status') {
1346:       this.print(safeJson({
1347:         model: this.model,
1348:         ollama_url: this.ollamaUrl,
1349:         require_approval_for_changes: this.requireApproval,
1350:         skills_count: this.skills.length,
1351:         skill_candidates_count: this.skillCandidates.length,
1352:         dashboard_url: this.dashboardInfo && this.dashboardInfo.dashboard_url ? this.dashboardInfo.dashboard_url : null,
1353:         chat_url: this.dashboardInfo && this.dashboardInfo.chat_url ? this.dashboardInfo.chat_url : null,
1354:         debug_dashboard_pid: this.debugServerProcess && !this.debugServerProcess.killed ? this.debugServerProcess.pid : null,
1355:         history_count: this.history.length,
1356:         pending_action: this.pendingAction ? this.pendingAction.id : null
1357:       }));
1358:       return;
1359:     }
1360: 
1361:     if (command === '/model') {
1362:       const nextModel = args.join(' ').trim();
1363:       if (!nextModel) {
1364:         this.print(`Current model: ${this.model}`);
1365:         return;
1366:       }
1367:       this.model = nextModel;
1368:       this.print(`Model updated: ${this.model}`);
1369:       this.logger.writeEvent('config_update', { key: 'model', value: this.model });
1370:       return;
1371:     }
1372: 
1373:     if (command === '/approve') {
1374:       const target = (args[0] || '').toLowerCase();
1375:       const mode = (args[1] || '').toLowerCase();
1376:       const legacyMode = target;
1377: 
1378:       if (target === 'changes' && (mode === 'on' || mode === 'off')) {
1379:         this.requireApproval = mode === 'on';
1380:         this.print(`Change approval mode: ${mode}`);
1381:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1382:         return;
1383:       }
1384: 
1385:       if (legacyMode === 'on' || legacyMode === 'off') {
1386:         this.requireApproval = legacyMode === 'on';
1387:         this.print(`Change approval mode: ${legacyMode}`);
1388:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1389:         return;
1390:       }
1391: 
1392:       if (!target) {
1393:         this.print(`Change approval mode: ${this.requireApproval ? 'on' : 'off'}`);
1394:         return;
1395:       }
1396: 
1397:       this.print('Usage: /approve changes on|off');
1398:       return;
1399:     }
1400: 
1401:     if (command === '/debug' || command === '/dashboard') {
1402:       const info = await this.startDebugDashboard();
1403:       this.print(style(`Debug dashboard live: ${info.dashboard_url}`, ANSI.cyan));
1404:       this.print(style(`Debug chat live: ${info.chat_url}`, ANSI.cyan));
1405:       this.print(style(`Token length: ${this.debugServerToken.length} (not persisted to file)`, ANSI.dim));
1406:       return;
1407:     }
1408: 
1409:     if (command === '/yes') {
1410:       if (!this.pendingAction) {
1411:         this.print('No pending action to approve.');
1412:         return;
1413:       }
1414:       const action = this.pendingAction;
1415:       this.pendingAction = null;
1416:       this.logger.writeEvent('approval', { action_id: action.id, approved: true });
1417:       this.writeStructuredUpdate(action.id, {
1418:         'Print-approved-by-user?': 'true',
1419:         approved: true
1420:       });
1421:       await this.executePendingAction(action);
1422:       return;
1423:     }
1424: 
1425:     if (command === '/no') {
1426:       if (!this.pendingAction) {
1427:         this.print('No pending action to reject.');
1428:         return;
1429:       }
1430:       const action = this.pendingAction;
1431:       this.pendingAction = null;
1432:       this.logger.writeEvent('approval', { action_id: action.id, approved: false });
1433:       this.writeStructuredUpdate(action.id, {
1434:         'Print-approved-by-user?': 'false',
1435:         approved: false,
1436:         summary: 'Action was rejected by user before runtime execution.',
1437:         'Run runtime look at logs': 'skipped (approval rejected)'
1438:       });
1439:       this.print(`Action ${action.id} skipped.`);
1440:       return;
1441:     }
1442: 
1443:     if (command === '/exit') {
1444:       this.rl.close();
1445:       return;
1446:     }
1447: 
1448:     if (command === '/cd') {
1449:       const rawTarget = input.replace(/^\/cd\s*/i, '').trim();
1450:       if (!rawTarget) {
1451:         this.print(`Current directory: ${process.cwd()}`);
1452:         return;
1453:       }
1454:       const resolved = this.resolvePathInWorkspace(rawTarget, 'dir');
1455:       if (resolved.error) {
1456:         this.print(`${style('cd denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1457:         return;
1458:       }
1459:       process.chdir(resolved.path);
1460:       this.refreshPrompt();
1461:       this.logger.writeEvent('cwd_changed', {
1462:         cwd: process.cwd(),
1463:         workspace_relative: this.workspaceRelativePath()
1464:       });
1465:       this.print(style(`Directory changed to ${this.workspaceRelativePath()}`, ANSI.cyan));
1466:       return;
1467:     }
1468: 
1469:     if (command === '/readfile') {
1470:       const rawPath = input.replace(/^\/readfile\s*/i, '').trim();
1471:       if (!rawPath) {
1472:         this.print('Usage: /readfile <path>');
1473:         return;
1474:       }
1475:       const resolved = this.resolvePathInWorkspace(rawPath, 'file');
1476:       if (resolved.error) {
1477:         this.print(`${style('readfile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1478:         return;
1479:       }
1480:       const action = {
1481:         id: `act_${Date.now()}`,
1482:         type: 'read_file',
1483:         payload: {
1484:           path: resolved.path,
1485:           rel: this.workspaceRelativePath(resolved.path)
1486:         },
1487:         created_at: nowIso()
1488:       };
1489:       this.queueApprovalAction(
1490:         action,
1491:         `${style('Read request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel}`
1492:       );
1493:       return;
1494:     }
1495: 
1496:     if (command === '/writefile') {
1497:       const raw = input.replace(/^\/writefile\s*/i, '');
1498:       const splitIndex = raw.indexOf(' -- ');
1499:       if (splitIndex === -1) {
1500:         this.print('Usage: /writefile <path> -- <content>');
1501:         return;
1502:       }
1503:       const rawPath = raw.slice(0, splitIndex).trim();
1504:       const content = raw.slice(splitIndex + 4);
1505:       if (!rawPath) {
1506:         this.print('Usage: /writefile <path> -- <content>');
1507:         return;
1508:       }
1509:       const resolved = this.resolvePathInWorkspace(rawPath, 'any');
1510:       if (resolved.error) {
1511:         this.print(`${style('writefile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1512:         return;
1513:       }
1514:       const action = {
1515:         id: `act_${Date.now()}`,
1516:         type: 'write_file',
1517:         payload: {
1518:           path: resolved.path,
1519:           rel: this.workspaceRelativePath(resolved.path),
1520:           content
1521:         },
1522:         created_at: nowIso()
1523:       };
1524:       this.queueApprovalAction(
1525:         action,
1526:         `${style('Write request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel} (${content.length} chars)`
1527:       );
1528:       return;
1529:     }
1530: 
1531:     if (command === '/skills') {
1532:       const sub = (args[0] || '').toLowerCase();
1533:       if (!sub || sub === 'help') {
1534:         this.print('Usage:');
1535:         this.print('/skills mine [count]');
1536:         this.print('/skills candidates');
1537:         this.print('/skills add <candidate_id> <skill_name>');
1538:         this.print('/skills list');
1539:         this.print('/skills show <skill_id|skill_name>');
1540:         this.print('/skills run <skill_id|skill_name>');
1541:         return;
1542:       }
1543: 
1544:       if (sub === 'mine') {
1545:         const count = Number(args[1] || 10);
1546:         const result = this.collectSkillCandidatesFromArtifacts(count);
1547:         this.print(style(`Mined ${result.candidates} candidate skill patterns from artifacts (sources scanned: ${result.scannedSources}).`, ANSI.cyan));
1548:         for (const c of this.skillCandidates) {
1549:           this.print(style(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.yellow));
1550:           this.print('```');
1551:           this.print(c.snippet);
1552:           this.print('```');
1553:           if (!c.executable) this.print(style(`reason: ${c.safety_reason}`, ANSI.dim));
1554:         }
1555:         return;
1556:       }
1557: 
1558:       if (sub === 'candidates') {
1559:         if (!this.skillCandidates.length) {
1560:           this.print('No candidates loaded. Run /skills mine first.');
1561:           return;
1562:         }
1563:         for (const c of this.skillCandidates) {
1564:           this.print(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'} source_kind=${c.source_kind}`);
1565:         }
1566:         return;
1567:       }
1568: 
1569:       if (sub === 'add') {
1570:         const candidateId = args[1] || '';
1571:         const skillName = args.slice(2).join(' ').trim();
1572:         if (!candidateId || !skillName) {
1573:           this.print('Usage: /skills add <candidate_id> <skill_name>');
1574:           return;
1575:         }
1576:         const existing = this.findSkill(skillName);
1577:         if (existing) {
1578:           this.print(`Skill already exists: ${existing.name} (${existing.id})`);
1579:           return;
1580:         }
1581:         const candidate = this.findCandidate(candidateId);
1582:         if (!candidate) {
1583:           this.print(`Candidate not found: ${candidateId}`);
1584:           return;
1585:         }
1586:         const action = {
1587:           id: `act_${Date.now()}`,
1588:           type: 'add_skill',
1589:           payload: {
1590:             skill_name: skillName,
1591:             source_candidate: candidate.id,
1592:             snippet: candidate.snippet,
1593:             executable: candidate.executable
1594:           },
1595:           created_at: nowIso()
1596:         };
1597:         this.queueApprovalAction(
1598:           action,
1599:           `${style('Add skill queued:', ANSI.bold, ANSI.yellow)} ${skillName} from ${candidate.id}`
1600:         );
1601:         return;
1602:       }
1603: 
1604:       if (sub === 'list') {
1605:         if (!this.skills.length) {
1606:           this.print(`No approved skills yet. Skills file: ${this.skillsPath}`);
1607:           return;
1608:         }
1609:         for (const skill of this.skills) {
1610:           this.print(`[${skill.id}] ${skill.name} | executable=${skill.executable ? 'yes' : 'no'} | source=${skill.source}`);
1611:         }
1612:         return;
1613:       }
1614: 
1615:       if (sub === 'show') {
1616:         const query = args.slice(1).join(' ').trim();
1617:         if (!query) {
1618:           this.print('Usage: /skills show <skill_id|skill_name>');
1619:           return;
1620:         }
1621:         const skill = this.findSkill(query);
1622:         if (!skill) {
1623:           this.print(`Skill not found: ${query}`);
1624:           return;
1625:         }
1626:         this.print(style(`[${skill.id}] ${skill.name}`, ANSI.bold, ANSI.cyan));
1627:         this.print('```');
1628:         this.print(skill.snippet);
1629:         this.print('```');
1630:         return;
1631:       }
1632: 
1633:       if (sub === 'run') {
1634:         const query = args.slice(1).join(' ').trim();
1635:         if (!query) {
1636:           this.print('Usage: /skills run <skill_id|skill_name>');
1637:           return;
1638:         }
1639:         const skill = this.findSkill(query);
1640:         if (!skill) {
1641:           this.print(`Skill not found: ${query}`);
1642:           return;
1643:         }
1644:         const validation = this.validateSkillCommand(skill.snippet);
1645:         if (!validation.ok) {
1646:           this.print(`${style('Skill is not executable:', ANSI.bold, ANSI.red)} ${validation.reason}`);
1647:           return;
1648:         }
1649:         const action = {
1650:           id: `act_${Date.now()}`,
1651:           type: 'run_skill',
1652:           payload: {
1653:             skill_id: skill.id,
1654:             skill_name: skill.name,
1655:             snippet: skill.snippet
1656:           },
1657:           created_at: nowIso()
1658:         };
1659:         this.queueApprovalAction(
1660:           action,
1661:           `${style('Skill execution queued:', ANSI.bold, ANSI.yellow)} ${skill.name}\n${skill.snippet}`
1662:         );
1663:         return;
1664:       }
1665: 
1666:       this.print(`Unknown skills subcommand: ${sub}`);
1667:       return;
1668:     }
1669: 
1670:     this.print(`Unknown command: ${command}. Use /help.`);
1671:   }
1672: 
1673:   async executePendingAction(action) {
1674:     if (!action) return;
1675:     if (action.type === 'ollama_chat') {
1676:       await this.executeAction(action);
1677:       return;
1678:     }
1679:     if (action.type === 'read_file') {
1680:       this.runReadFileAction(action);
1681:       return;
1682:     }
1683:     if (action.type === 'write_file') {
1684:       this.runWriteFileAction(action);
1685:       return;
1686:     }
1687:     if (action.type === 'add_skill') {
1688:       this.runAddSkillAction(action);
1689:       return;
1690:     }
1691:     if (action.type === 'run_skill') {
1692:       await this.runSkillCommand(action);
1693:       return;
1694:     }
1695:     if (action.type === 'todo_plan') {
1696:       const payload = action && action.payload ? action.payload : {};
1697:       await this.executeTodoPlan(payload.plan || [], payload.file || path.resolve(__filename));
1698:       return;
1699:     }
1700:     this.print(`Unsupported pending action type: ${action.type}`);
1701:   }
1702: 
1703:   runReadFileAction(action) {
1704:     const filePath = action && action.payload ? action.payload.path : '';
1705:     if (!filePath || !fs.existsSync(filePath)) {
1706:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} file no longer exists.`);
1707:       return;
1708:     }
1709:     let text;
1710:     try {
1711:       text = fs.readFileSync(filePath, 'utf8');
1712:     } catch (error) {
1713:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1714:       return;
1715:     }
1716:     const shown = truncateText(text, MAX_READFILE_BYTES);
1717:     const rel = action.payload.rel || this.workspaceRelativePath(filePath);
1718:     this.print(style(`[I/O READ] ${rel}`, ANSI.bold, ANSI.cyan));
1719:     this.print(style(`\n[READFILE] ${rel}`, ANSI.bold, ANSI.cyan));
1720:     this.print(style(`bytes: ${Buffer.byteLength(text, 'utf8')} | shown: ${Buffer.byteLength(shown, 'utf8')}`, ANSI.dim));
1721:     this.print(shown);
1722:     this.logger.writeEvent('read_file', {
1723:       action_id: action.id,
1724:       file: filePath,
1725:       bytes: Buffer.byteLength(text, 'utf8'),
1726:       shown_bytes: Buffer.byteLength(shown, 'utf8')
1727:     });
1728:   }
1729: 
1730:   runWriteFileAction(action) {
1731:     const filePath = action && action.payload ? action.payload.path : '';
1732:     const content = action && action.payload ? String(action.payload.content || '') : '';
1733:     if (!filePath) {
1734:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} missing target path.`);
1735:       return;
1736:     }
1737:     try {
1738:       ensureDir(path.dirname(filePath));
1739:       fs.writeFileSync(filePath, content, 'utf8');
1740:     } catch (error) {
1741:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1742:       return;
1743:     }
1744:     this.print(style(`[I/O WRITE] ${action.payload.rel}`, ANSI.bold, ANSI.cyan));
1745:     this.print(style(`[WRITEFILE] wrote ${content.length} chars to ${action.payload.rel}`, ANSI.bold, ANSI.cyan));
1746:     this.logger.writeEvent('write_file', {
1747:       action_id: action.id,
1748:       file: filePath,
1749:       chars: content.length
1750:     });
1751:   }
1752: 
1753:   runAddSkillAction(action) {
1754:     const payload = action && action.payload ? action.payload : {};
1755:     const name = String(payload.skill_name || '').trim();
1756:     const snippet = String(payload.snippet || '');
1757:     if (!name || !snippet) {
1758:       this.print(`${style('Add skill failed:', ANSI.bold, ANSI.red)} missing skill name or snippet.`);
1759:       return;
1760:     }
1761:     const duplicate = this.findSkill(name);
1762:     if (duplicate) {
1763:       this.print(`${style('Add skill skipped:', ANSI.bold, ANSI.red)} skill already exists (${duplicate.id}).`);
1764:       return;
1765:     }
1766: 
1767:     const skill = {
1768:       id: `skill_${Date.now()}`,
1769:       name,
1770:       snippet,
1771:       source: `candidate:${payload.source_candidate || 'unknown'}`,
1772:       executable: Boolean(payload.executable),
1773:       created_at: nowIso()
1774:     };
1775:     this.skills.push(skill);
1776:     this.saveSkills();
1777:     this.print(style(`[SKILL ADDED] ${skill.name} (${skill.id}) executable=${skill.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.cyan));
1778:     this.logger.writeEvent('skill_added', {
1779:       action_id: action.id,
1780:       skill_id: skill.id,
1781:       skill_name: skill.name,
1782:       executable: skill.executable
1783:     });
1784:   }
1785: 
1786:   readFileSafe(filePath) {
1787:     const target = path.resolve(filePath || '');
1788:     if (!target) return '';
1789:     if (!fs.existsSync(target)) return '';
1790:     try {
1791:       return fs.readFileSync(target, 'utf8');
1792:     } catch (error) {
1793:       this.logger.writeEvent('pipeline_read_failed', {
1794:         file: target,
1795:         error: error.message
1796:       });
1797:       return '';
1798:     }
1799:   }
