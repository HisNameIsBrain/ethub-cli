0217:   let quote = null;
0218:   let escaping = false;
0219: 
0220:   for (let i = 0; i < text.length; i += 1) {
0221:     const ch = text[i];
0222:     if (escaping) {
0223:       current += ch;
0224:       escaping = false;
0225:       continue;
0226:     }
0227:     if (ch === '\\') {
0228:       escaping = true;
0229:       continue;
0230:     }
0231:     if (quote) {
0232:       if (ch === quote) {
0233:         quote = null;
0234:       } else {
0235:         current += ch;
0236:       }
0237:       continue;
0238:     }
0239:     if (ch === '"' || ch === '\'') {
0240:       quote = ch;
0241:       continue;
0242:     }
0243:     if (/\s/.test(ch)) {
0244:       if (current) {
0245:         tokens.push(current);
0246:         current = '';
0247:       }
0248:       continue;
0249:     }
0250:     current += ch;
0251:   }
0252: 
0253:   if (escaping) return { error: 'Command cannot end with a trailing escape.' };
0254:   if (quote) return { error: 'Unclosed quote in command.' };
0255:   if (current) tokens.push(current);
0256:   return { tokens };
0257: }
