2007:   async runPipeline(input) {
2008:     const pipelineEnabled = String(process.env.ETHUB_ENABLE_PIPELINE || '').toLowerCase() === '1'
2009:       || String(process.env.ETHUB_ENABLE_PIPELINE || '').toLowerCase() === 'true';
2010:     if (!pipelineEnabled) return false;
2011: 
2012:     const file = path.resolve(__filename);
2013:     const code = this.readFileSafe(file);
2014:     const context = this.analyzeContext(code);
2015:     const decision = this.classifyContext(context);
2016:     const plan = this.buildPlan(decision);
2017:     const intent = this.routeIntent(input);
2018: 
2019:     this.logger.writeEvent('pipeline_decision', { decision, context, plan, intent, file });
2020:     this.print(this.uiBox(`Pipeline: ${decision} | intent: ${intent} | plan: ${plan.join(', ') || 'noop'}`, 'cyan'));
2021: 
2022:     if (decision === 'stable' || plan.includes('noop')) {
2023:       this.print(this.uiBox('System stable. No patch needed.', 'green'));
2024:       return true;
2025:     }
2026: 
2027:     if (this.requireApproval) {
2028:       const action = {
2029:         id: `todo_${Date.now()}`,
2030:         type: 'todo_plan',
2031:         payload: { plan, decision, file },
2032:         created_at: nowIso()
2033:       };
2034:       this.queueApprovalAction(action, this.uiBox('Awaiting approval for TODO plan (/yes or /no)', 'yellow'));
2035:       return true;
2036:     }
2037: 
2038:     await this.executeTodoPlan(plan, file);
2039:     return true;
2040:   }
2041: 
2042:   async handleUserPrompt(input) {
2043:     const handledByPipeline = await this.runPipeline(input);
2044:     if (handledByPipeline) return;
2045: 
2046:     const reasoning = summarizeReasoning(input);
2047:     const action = {
2048:       id: `act_${Date.now()}`,
2049:       type: 'ollama_chat',
2050:       prompt: input,
2051:       reasoning_summary: reasoning,
2052:       created_at: nowIso()
2053:     };
2054: 
2055:     this.logger.writeTranscript('User', input);
2056:     this.logger.writeEvent('user_prompt', {
2057:       text: input,
2058:       reasoning_summary: reasoning,
2059:       proposed_action: { id: action.id, type: action.type }
2060:     });
2061:     this.actionMeta[action.id] = {
2062:       prompt: input,
2063:       prompt_chars_before: input.length
2064:     };
2065:     const keywordsText = Array.isArray(reasoning.keywords) && reasoning.keywords.length
2066:       ? reasoning.keywords.join(', ')
2067:       : 'none';
2068:     this.print(style(`[Reasoning] intent=${reasoning.intent} | keywords=${keywordsText}`, ANSI.dim));
2069:     this.print(style(`[Reasoning] strategy=${reasoning.strategy}`, ANSI.dim));
2070:     this.print(style(`[Reasoning] context=${reasoning.context}`, ANSI.dim));
2071: 
2072:     this.logger.writeStructuredRecord({
2073:       timestamp: nowIso(),
2074:       query: input,
2075:       reasoning: {
2076:         query: reasoning.query,
2077:         intent: reasoning.intent,
2078:         keywords: reasoning.keywords,
2079:         search_strategy: reasoning.strategy
2080:       },
2081:       actions: {
2082:         action: 'local_ollama_request',
2083:         sources: ['ollama_localhost'],
2084:         Context: 'Analyzing locally via Ollama only; no OpenAI/Gemini/external model APIs.'
2085:       },
2086:       Commands: "ls, grep, nano, cd, nano 'create-new-file-diff-snippet-number+1.sh', regen entire file with changes then save, cp -rf old/path/to/file move/to/backup/path/file, rm old/path/to/file, bash create-new-file-(diff-snippet-line:character)-(number)+1, sed -i 's/old/new' \"$file\"",
2087:       Diff: '+,-',
2088:       Path: 'path/to/file:line:character',
2089:       action_id: action.id,
2090:       'Print-approved-by-user?': 'not_required (run commands)',
2091:       'Run runtime look at logs': 'pending',
2092:       summary: 'pending',
2093:       'Number of characters changed': 'pending'
2094:     });
2095: 
2096:     await this.executeAction(action);
2097:   }
