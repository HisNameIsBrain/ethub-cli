0130: function rainbowDivider(width, phase) {
0131:   let out = '';
0132:   for (let i = 0; i < width; i += 1) {
0133:     const ch = DIVIDER_CHARS[i % DIVIDER_CHARS.length];
0134:     const p = (i / width + phase) % 1;
0135:     const { r, g, b } = hslToRgb(p * 360, 0.6, 0.65);
0136:     out += rgb(ch, r, g, b);
0137:   }
0138:   return out;
0139: }
0140: 
0141: function rainbowAsciiLine(line, row, totalRows, frame) {
0142:   let out = '';
0143:   const len = Math.max(line.length, 1);
0144: 
0145:   for (let i = 0; i < line.length; i += 1) {
0146:     const ch = line[i];
0147:     if (ch === ' ') {
0148:       out += ' ';
0149:       continue;
0150:     }
0151: 
0152:     const phase = (i / len + row / totalRows + frame * 0.01) % 1;
0153:     const { r, g, b } = hslToRgb(phase * 360, 0.6, 0.65);
0154: 
0155:     let display = ch;
0156:     if ((ch === 'o' || ch === '8') && (frame + i + row) % 47 === 0) {
0157:       display = '+';
0158:     }
0159: 
0160:     out += rgb(display, r, g, b);
0161:   }
0162: 
0163:   return out;
0164: }
