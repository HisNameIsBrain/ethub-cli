1062:         this.print(`${style('Error:', ANSI.bold, ANSI.red)} ${message}`);
1063:         this.logger.writeEvent('runtime_error', { message, stack: error && error.stack ? error.stack : null });
1064:       }
1065: 
1066:       this.flushState();
1067:       this.safePrompt();
1068:     });
1069: 
1070:     this.rl.on('close', () => {
