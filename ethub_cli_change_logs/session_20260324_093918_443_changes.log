0219: 
0220:   writeCodeSnapshot() {
0221:     const sourcePath = path.resolve(__filename);
0222:     let sourceText = '';
0223:     try {
0224:       sourceText = fs.readFileSync(sourcePath, 'utf8');
0225:     } catch (error) {
0226:       sourceText = `Unable to read source file: ${error && error.message ? error.message : String(error)}`;
0227:     }
0228: 
0229:     const numbered = sourceText
0230:       .split('\n')
0231:       .map((line, i) => `${String(i + 1).padStart(4, '0')}: ${line}`)
0232:       .join('\n');
0233: 
0234:     const header =
0235:       `# ETHUB CLI Change Log\n` +
0236:       `session_id: ${this.sessionId}\n` +
0237:       `created_at: ${nowIso()}\n` +
0238:       `source_file: ${sourcePath}\n` +
0239:       `note: New file per session, append-only event/state logs enabled.\n\n` +
0240:       `## Source Snapshot (Line Numbered)\n`;
0241: 
0242:     fs.writeFileSync(this.changeLogPath, `${header}${numbered}\n`, 'utf8');
0243:   }
0244: }
