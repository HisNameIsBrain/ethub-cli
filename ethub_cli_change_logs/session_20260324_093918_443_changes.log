0197:     const event = {
0198:       index: this.counter,
0199:       ts: nowIso(),
0200:       type,
0201:       payload
0202:     };
0203:     fs.appendFileSync(this.eventsPath, `${safeJson(event)}\n`, 'utf8');
0204:   }
0205: 
0206:   writeTranscript(role, content) {
