0423:   async handleCommand(input) {
0424:     const [cmd, ...args] = input.split(/\s+/);
0425:     const command = cmd.toLowerCase();
0426:     this.logger.writeEvent('subcommand', { command, args });
0427: 
0428:     if (command === '/help') {
0429:       this.print('Commands: /help, /status, /model <name>, /approve on, /yes, /no, /exit');
0430:       return;
0431:     }
0432: 
0433:     if (command === '/status') {
0434:       this.print(safeJson({
0435:         model: this.model,
0436:         ollama_url: this.ollamaUrl,
0437:         require_approval: this.requireApproval,
0438:         history_count: this.history.length,
0439:         pending_action: this.pendingAction ? this.pendingAction.id : null
0440:       }));
0441:       return;
0442:     }
0443: 
0444:     if (command === '/model') {
0445:       const nextModel = args.join(' ').trim();
0446:       if (!nextModel) {
0447:         this.print(`Current model: ${this.model}`);
0448:         return;
0449:       }
0450:       this.model = nextModel;
0451:       this.print(`Model updated: ${this.model}`);
0452:       this.logger.writeEvent('config_update', { key: 'model', value: this.model });
0453:       return;
0454:     }
0455: 
0456:     if (command === '/approve') {
0457:       const mode = (args[0] || '').toLowerCase();
0458:       if (mode !== 'on') {
0459:         this.print('Approval is mandatory. Use: /approve on');
0460:         return;
0461:       }
0462:       this.requireApproval = true;
0463:       this.print('Approval mode: on');
0464:       this.logger.writeEvent('config_update', { key: 'require_approval', value: this.requireApproval });
0465:       return;
0466:     }
0467: 
0468:     if (command === '/yes') {
0469:       if (!this.pendingAction) {
0470:         this.print('No pending action to approve.');
0471:         return;
0472:       }
0473:       const action = this.pendingAction;
0474:       this.pendingAction = null;
0475:       this.logger.writeEvent('approval', { action_id: action.id, approved: true });
0476:       this.writeStructuredUpdate(action.id, {
0477:         'Print-approved-by-user?': 'true',
0478:         approved: true
0479:       });
0480:       await this.executeAction(action);
0481:       return;
0482:     }
0483: 
0484:     if (command === '/no') {
0485:       if (!this.pendingAction) {
0486:         this.print('No pending action to reject.');
0487:         return;
0488:       }
0489:       const action = this.pendingAction;
0490:       this.pendingAction = null;
0491:       this.logger.writeEvent('approval', { action_id: action.id, approved: false });
0492:       this.writeStructuredUpdate(action.id, {
0493:         'Print-approved-by-user?': 'false',
0494:         approved: false,
0495:         summary: 'Action was rejected by user before runtime execution.',
0496:         'Run runtime look at logs': 'skipped (approval rejected)'
0497:       });
0498:       this.print(`Action ${action.id} skipped.`);
0499:       return;
0500:     }
0501: 
0502:     if (command === '/exit') {
0503:       this.rl.close();
0504:       return;
0505:     }
0506: 
0507:     this.print(`Unknown command: ${command}. Use /help.`);
