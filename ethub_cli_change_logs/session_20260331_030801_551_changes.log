0769:   async handleUserPrompt(input) {
0770:     const reasoning = summarizeReasoning(input);
0771:     const action = {
0772:       id: `act_${Date.now()}`,
0773:       type: 'ollama_chat',
0774:       prompt: input,
0775:       reasoning_summary: reasoning,
0776:       created_at: nowIso()
0777:     };
0778: 
0779:     this.logger.writeTranscript('User', input);
0780:     this.logger.writeEvent('user_prompt', {
0781:       text: input,
0782:       reasoning_summary: reasoning,
0783:       proposed_action: { id: action.id, type: action.type }
0784:     });
0785:     this.actionMeta[action.id] = {
0786:       prompt: input,
0787:       prompt_chars_before: input.length
0788:     };
0789: 
0790:     this.logger.writeStructuredRecord({
0791:       timestamp: nowIso(),
0792:       query: input,
0793:       reasoning: {
0794:         query: reasoning.query,
0795:         intent: reasoning.intent,
0796:         keywords: reasoning.keywords,
0797:         search_strategy: reasoning.strategy
0798:       },
0799:       actions: {
0800:         action: 'local_ollama_request',
0801:         sources: ['ollama_localhost'],
0802:         Context: 'Analyzing locally via Ollama only; no OpenAI/Gemini/external model APIs.'
0803:       },
0804:       Commands: "ls, grep, nano, cd, nano 'create-new-file-diff-snippet-number+1.sh', regen entire file with changes then save, cp -rf old/path/to/file move/to/backup/path/file, rm old/path/to/file, bash create-new-file-(diff-snippet-line:character)-(number)+1, sed -i 's/old/new' \"$file\"",
0805:       Diff: '+,-',
0806:       Path: 'path/to/file:line:character',
0807:       action_id: action.id,
0808:       'Print-approved-by-user?': 'not_required (run commands)',
0809:       'Run runtime look at logs': 'pending',
0810:       summary: 'pending',
0811:       'Number of characters changed': 'pending'
0812:     });
0813: 
0814:     await this.executeAction(action);
0815:   }
0816: 
0817:   writeStructuredUpdate(actionId, patch) {
0818:     this.logger.writeStructuredRecord({
0819:       timestamp: nowIso(),
0820:       action_id: actionId,
0821:       update: patch
0822:     });
0823:   }
0824: 
0825:   async executeAction(action) {
0826:     if (!action || action.type !== 'ollama_chat') {
0827:       this.logger.writeEvent('action_error', { message: 'Unsupported action type', action });
0828:       this.writeStructuredUpdate(action && action.id ? action.id : 'unknown', {
0829:         'Run runtime look at logs': 'contains error still, unsupported action type',
0830:         summary: 'Unsupported action type encountered before runtime request.',
0831:         'Number of characters changed': 'previous character amount in file before cmd/new total character count added: 0/0'
0832:       });
0833:       this.print('Unsupported action.');
0834:       return;
0835:     }
0836: 
0837:     this.logger.writeEvent('action_start', {
0838:       action_id: action.id,
0839:       type: action.type,
0840:       target: this.ollamaUrl,
0841:       model: this.model,
0842:       prompt_chars: action.prompt.length,
0843:       reasoning_summary: action.reasoning_summary
0844:     });
0845: 
0846:     this.history.push({ role: 'user', content: action.prompt });
0847: 
0848:     const payload = {
0849:       model: this.model,
0850:       messages: this.history,
0851:       stream: false
0852:     };
0853: 
0854:     let response;
0855:     let raw;
0856:     const started = Date.now();
0857:     this.startThinking();
0858: 
0859:     try {
0860:       response = await fetch(this.ollamaUrl, {
0861:         method: 'POST',
0862:         headers: { 'Content-Type': 'application/json' },
0863:         body: JSON.stringify(payload)
0864:       });
0865: 
0866:       raw = await response.text();
0867:     } catch (error) {
0868:       this.stopThinking();
0869:       const message = error && error.message ? error.message : String(error);
0870:       this.logger.writeEvent('action_failure', {
0871:         action_id: action.id,
0872:         duration_ms: Date.now() - started,
0873:         error: message
0874:       });
0875:       this.writeStructuredUpdate(action.id, {
0876:         'Run runtime look at logs': 'contains error still, loop and try again with different results until each individual error is clear.',
0877:         summary: `Runtime request failed. Error: ${message}`,
0878:         'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${action.prompt.length}/0`,
0879:         'Print-approved-by-user?': 'true'
0880:       });
0881:       this.print(`Ollama request failed: ${message}`);
0882:       return;
0883:     }
0884:     this.stopThinking();
0885: 
0886:     let parsed;
0887:     try {
0888:       parsed = JSON.parse(raw);
0889:     } catch {
0890:       parsed = null;
0891:     }
0892: 
0893:     const assistantText = parsed && parsed.message && parsed.message.content
0894:       ? String(parsed.message.content)
0895:       : raw;
0896: 
0897:     this.history.push({ role: 'assistant', content: assistantText });
0898: 
0899:     this.logger.writeEvent('action_result', {
0900:       action_id: action.id,
0901:       duration_ms: Date.now() - started,
0902:       http_status: response.status,
0903:       ok: response.ok,
0904:       response_preview: assistantText.slice(0, 400),
0905:       response_chars: assistantText.length
0906:     });
0907: 
0908:     this.logger.writeTranscript('Assistant', assistantText);
0909:     this.print(assistantText);
0910: 
0911:     const hasRuntimeError = /(syntaxerror|stack overflow|runtime error|error:)/i.test(assistantText);
0912:     const runtimeResult = hasRuntimeError
0913:       ? 'contains error still, retry with different checks until isolated'
0914:       : 'No runtime error anymore = fixed';
0915:     const beforeChars = this.actionMeta[action.id] && this.actionMeta[action.id].prompt_chars_before
0916:       ? this.actionMeta[action.id].prompt_chars_before
0917:       : 0;
0918:     const afterChars = assistantText.length;
0919:     const elapsedMs = Date.now() - started;
0920: 
0921:     this.writeStructuredUpdate(action.id, {
0922:       'Run runtime look at logs': runtimeResult,
0923:       summary: `summarized what just changed, is it fixed: ${hasRuntimeError ? 'No' : 'Yes'}. Runtime error count estimate: ${hasRuntimeError ? 1 : 0}.`,
0924:       'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${beforeChars}/${afterChars}`,
0925:       timing_ms: elapsedMs,
0926:       stop_condition: elapsedMs >= 300000 ? 'Unable to find results or solutions, Try again.' : 'within loop budget'
0927:     });
0928:   }
0929: }
0930: 
0931: const agent = new EthubCliAgent();
0932: agent.start().catch((error) => {
0933:   process.stderr.write(`Fatal startup error: ${error && error.stack ? error.stack : String(error)}\n`);
0934:   process.exit(1);
0935: });
