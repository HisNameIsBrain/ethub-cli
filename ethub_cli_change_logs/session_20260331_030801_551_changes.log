0053: function hslToRgb(h, s, l) {
0054:   h /= 360;
0055:   const a = s * Math.min(l, 1 - l);
0056:   const f = (n) => {
0057:     const k = (n + h * 12) % 12;
0058:     const c = l - a * Math.max(Math.min(k - 3, 9 - k, 1), -1);
0059:     return Math.round(c * 255);
0060:   };
0061:   return { r: f(0), g: f(8), b: f(4) };
0062: }
0063: 
0064: function rainbowDivider(width, phase) {
0065:   let out = '';
0066:   for (let i = 0; i < width; i += 1) {
0067:     const ch = DIVIDER_CHARS[i % DIVIDER_CHARS.length];
0068:     const p = (i / width + phase) % 1;
0069:     const { r, g, b } = hslToRgb(p * 360, 0.6, 0.65);
0070:     out += rgb(ch, r, g, b);
0071:   }
0072:   return out;
0073: }
0074: 
0075: function rainbowAsciiLine(line, row, totalRows, frame) {
0076:   let out = '';
0077:   const len = Math.max(line.length, 1);
0078: 
0079:   for (let i = 0; i < line.length; i += 1) {
0080:     const ch = line[i];
0081:     if (ch === ' ') {
0082:       out += ' ';
0083:       continue;
0084:     }
0085: 
0086:     const phase = (i / len + row / totalRows + frame * 0.01) % 1;
0087:     const { r, g, b } = hslToRgb(phase * 360, 0.6, 0.65);
0088: 
0089:     let display = ch;
0090:     if ((ch === 'o' || ch === '8') && (frame + i + row) % 47 === 0) {
0091:       display = '+';
0092:     }
0093: 
0094:     out += rgb(display, r, g, b);
0095:   }
0096: 
0097:   return out;
0098: }
