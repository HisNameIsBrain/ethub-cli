0122: function summarizeReasoning(input) {
0123:   const raw = String(input || '').trim();
0124:   const lowered = raw.toLowerCase();
0125:   const keywords = raw
0126:     .split(/\s+/)
0127:     .map((w) => w.replace(/[^a-zA-Z0-9_-]/g, ''))
0128:     .filter(Boolean)
0129:     .slice(0, 12);
0130: 
0131:   let intent = 'general_request';
0132:   if (/error|syntax|stack|trace|bug|fix|crash/.test(lowered)) intent = 'debugging';
0133:   else if (/how|what|why|explain|guide|tutorial/.test(lowered)) intent = 'information_lookup';
0134:   else if (/build|create|make|implement|write/.test(lowered)) intent = 'implementation';
0135: 
0136:   let strategy = 'Use local conversation context then query Ollama for a grounded response.';
0137:   if (intent === 'debugging') {
0138:     strategy = 'Focus on likely fault points, propose checks, and request missing runtime details if needed.';
0139:   }
0140: 
0141:   return {
0142:     query: raw,
0143:     intent,
0144:     keywords,
0145:     strategy,
0146:     note: 'Detailed private chain-of-thought is not exposed; this is a concise decision summary.'
0147:   };
0148: }
