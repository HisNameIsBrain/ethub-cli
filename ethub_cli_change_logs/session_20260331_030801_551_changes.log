0551:     if (command === '/approve') {
0552:       const target = (args[0] || '').toLowerCase();
0553:       const mode = (args[1] || '').toLowerCase();
0554:       const legacyMode = target;
0555: 
0556:       if (target === 'changes' && (mode === 'on' || mode === 'off')) {
0557:         this.requireApproval = mode === 'on';
0558:         this.print(`Change approval mode: ${mode}`);
0559:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
0560:         return;
0561:       }
0562: 
0563:       if (legacyMode === 'on' || legacyMode === 'off') {
0564:         this.requireApproval = legacyMode === 'on';
0565:         this.print(`Change approval mode: ${legacyMode}`);
0566:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
0567:         return;
0568:       }
0569: 
0570:       if (!target) {
0571:         this.print(`Change approval mode: ${this.requireApproval ? 'on' : 'off'}`);
0572:         return;
0573:       }
0574: 
0575:       this.print('Usage: /approve changes on|off');
0576:       return;
0577:     }
0578: 
0579:     if (command === '/yes') {
0580:       if (!this.pendingAction) {
0581:         this.print('No pending action to approve.');
0582:         return;
0583:       }
0584:       const action = this.pendingAction;
0585:       this.pendingAction = null;
0586:       this.logger.writeEvent('approval', { action_id: action.id, approved: true });
0587:       this.writeStructuredUpdate(action.id, {
0588:         'Print-approved-by-user?': 'true',
0589:         approved: true
0590:       });
0591:       await this.executePendingAction(action);
0592:       return;
0593:     }
0594: 
0595:     if (command === '/no') {
0596:       if (!this.pendingAction) {
0597:         this.print('No pending action to reject.');
0598:         return;
0599:       }
0600:       const action = this.pendingAction;
0601:       this.pendingAction = null;
0602:       this.logger.writeEvent('approval', { action_id: action.id, approved: false });
0603:       this.writeStructuredUpdate(action.id, {
0604:         'Print-approved-by-user?': 'false',
0605:         approved: false,
0606:         summary: 'Action was rejected by user before runtime execution.',
0607:         'Run runtime look at logs': 'skipped (approval rejected)'
0608:       });
0609:       this.print(`Action ${action.id} skipped.`);
0610:       return;
0611:     }
0612: 
0613:     if (command === '/exit') {
0614:       this.rl.close();
0615:       return;
0616:     }
0617: 
0618:     if (command === '/cd') {
0619:       const rawTarget = input.replace(/^\/cd\s*/i, '').trim();
0620:       if (!rawTarget) {
0621:         this.print(`Current directory: ${process.cwd()}`);
0622:         return;
0623:       }
0624:       const resolved = this.resolvePathInWorkspace(rawTarget, 'dir');
0625:       if (resolved.error) {
0626:         this.print(`${style('cd denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
0627:         return;
0628:       }
0629:       process.chdir(resolved.path);
0630:       this.refreshPrompt();
0631:       this.logger.writeEvent('cwd_changed', {
0632:         cwd: process.cwd(),
0633:         workspace_relative: this.workspaceRelativePath()
0634:       });
0635:       this.print(style(`Directory changed to ${this.workspaceRelativePath()}`, ANSI.cyan));
0636:       return;
0637:     }
0638: 
0639:     if (command === '/readfile') {
0640:       const rawPath = input.replace(/^\/readfile\s*/i, '').trim();
0641:       if (!rawPath) {
0642:         this.print('Usage: /readfile <path>');
0643:         return;
0644:       }
0645:       const resolved = this.resolvePathInWorkspace(rawPath, 'file');
0646:       if (resolved.error) {
0647:         this.print(`${style('readfile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
0648:         return;
0649:       }
0650:       const action = {
0651:         id: `act_${Date.now()}`,
0652:         type: 'read_file',
0653:         payload: {
0654:           path: resolved.path,
0655:           rel: this.workspaceRelativePath(resolved.path)
0656:         },
0657:         created_at: nowIso()
0658:       };
0659:       this.queueApprovalAction(
0660:         action,
0661:         `${style('Read request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel}`
0662:       );
0663:       return;
0664:     }
0665: 
0666:     if (command === '/writefile') {
0667:       const raw = input.replace(/^\/writefile\s*/i, '');
0668:       const splitIndex = raw.indexOf(' -- ');
0669:       if (splitIndex === -1) {
0670:         this.print('Usage: /writefile <path> -- <content>');
0671:         return;
0672:       }
0673:       const rawPath = raw.slice(0, splitIndex).trim();
0674:       const content = raw.slice(splitIndex + 4);
0675:       if (!rawPath) {
0676:         this.print('Usage: /writefile <path> -- <content>');
0677:         return;
0678:       }
0679:       const resolved = this.resolvePathInWorkspace(rawPath, 'any');
0680:       if (resolved.error) {
0681:         this.print(`${style('writefile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
0682:         return;
0683:       }
0684:       const action = {
0685:         id: `act_${Date.now()}`,
0686:         type: 'write_file',
0687:         payload: {
0688:           path: resolved.path,
0689:           rel: this.workspaceRelativePath(resolved.path),
0690:           content
0691:         },
0692:         created_at: nowIso()
0693:       };
0694:       this.queueApprovalAction(
0695:         action,
0696:         `${style('Write request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel} (${content.length} chars)`
0697:       );
0698:       return;
0699:     }
0700: 
0701:     this.print(`Unknown command: ${command}. Use /help.`);
0702:   }
0703: 
0704:   async executePendingAction(action) {
0705:     if (!action) return;
0706:     if (action.type === 'ollama_chat') {
0707:       await this.executeAction(action);
0708:       return;
0709:     }
0710:     if (action.type === 'read_file') {
0711:       this.runReadFileAction(action);
0712:       return;
0713:     }
0714:     if (action.type === 'write_file') {
0715:       this.runWriteFileAction(action);
0716:       return;
0717:     }
0718:     this.print(`Unsupported pending action type: ${action.type}`);
0719:   }
0720: 
0721:   runReadFileAction(action) {
0722:     const filePath = action && action.payload ? action.payload.path : '';
0723:     if (!filePath || !fs.existsSync(filePath)) {
0724:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} file no longer exists.`);
0725:       return;
0726:     }
0727:     let text;
0728:     try {
0729:       text = fs.readFileSync(filePath, 'utf8');
0730:     } catch (error) {
0731:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} ${error.message}`);
0732:       return;
0733:     }
0734:     const shown = truncateText(text, MAX_READFILE_BYTES);
0735:     const rel = action.payload.rel || this.workspaceRelativePath(filePath);
0736:     this.print(style(`\n[READFILE] ${rel}`, ANSI.bold, ANSI.cyan));
0737:     this.print(style(`bytes: ${Buffer.byteLength(text, 'utf8')} | shown: ${Buffer.byteLength(shown, 'utf8')}`, ANSI.dim));
0738:     this.print(shown);
0739:     this.logger.writeEvent('read_file', {
0740:       action_id: action.id,
0741:       file: filePath,
0742:       bytes: Buffer.byteLength(text, 'utf8'),
0743:       shown_bytes: Buffer.byteLength(shown, 'utf8')
0744:     });
0745:   }
0746: 
0747:   runWriteFileAction(action) {
0748:     const filePath = action && action.payload ? action.payload.path : '';
0749:     const content = action && action.payload ? String(action.payload.content || '') : '';
0750:     if (!filePath) {
0751:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} missing target path.`);
0752:       return;
0753:     }
0754:     try {
0755:       ensureDir(path.dirname(filePath));
0756:       fs.writeFileSync(filePath, content, 'utf8');
0757:     } catch (error) {
0758:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} ${error.message}`);
0759:       return;
0760:     }
0761:     this.print(style(`[WRITEFILE] wrote ${content.length} chars to ${action.payload.rel}`, ANSI.bold, ANSI.cyan));
0762:     this.logger.writeEvent('write_file', {
0763:       action_id: action.id,
0764:       file: filePath,
0765:       chars: content.length
0766:     });
0767:   }
