0039: function summarizeReasoning(input) {
0040:   const raw = String(input || '').trim();
0041:   const lowered = raw.toLowerCase();
0042:   const keywords = raw
0043:     .split(/\s+/)
0044:     .map((w) => w.replace(/[^a-zA-Z0-9_-]/g, ''))
0045:     .filter(Boolean)
0046:     .slice(0, 12);
0047: 
0048:   let intent = 'general_request';
0049:   if (/error|syntax|stack|trace|bug|fix|crash/.test(lowered)) intent = 'debugging';
0050:   else if (/how|what|why|explain|guide|tutorial/.test(lowered)) intent = 'information_lookup';
0051:   else if (/build|create|make|implement|write/.test(lowered)) intent = 'implementation';
0052: 
0053:   let strategy = 'Use local conversation context then query Ollama for a grounded response.';
0054:   if (intent === 'debugging') {
0055:     strategy = 'Focus on likely fault points, propose checks, and request missing runtime details if needed.';
0056:   }
0057: 
0058:   return {
0059:     query: raw,
0060:     intent,
0061:     keywords,
0062:     strategy,
0063:     note: 'Detailed private chain-of-thought is not exposed; this is a concise decision summary.'
0064:   };
0065: }
