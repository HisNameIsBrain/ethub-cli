0137:   writeState(state) {
0138:     fs.appendFileSync(this.statePath, `${safeJson(state)}\n`, 'utf8');
0139:   }
0140: 
0141:   writeStructuredRecord(record) {
0142:     fs.appendFileSync(this.structuredPath, `${safeJson(record)}\n`, 'utf8');
0143:   }
0144: 
0145:   writeCodeSnapshot() {
0146:     const sourcePath = path.resolve(__filename);
0147:     let sourceText = '';
0148:     try {
0149:       sourceText = fs.readFileSync(sourcePath, 'utf8');
0150:     } catch (error) {
0151:       sourceText = `Unable to read source file: ${error && error.message ? error.message : String(error)}`;
0152:     }
0153: 
0154:     const numbered = sourceText
0155:       .split('\n')
0156:       .map((line, i) => `${String(i + 1).padStart(4, '0')}: ${line}`)
0157:       .join('\n');
0158: 
0159:     const header =
0160:       `# ETHUB CLI Change Log\n` +
0161:       `session_id: ${this.sessionId}\n` +
0162:       `created_at: ${nowIso()}\n` +
0163:       `source_file: ${sourcePath}\n` +
0164:       `note: New file per session, append-only event/state logs enabled.\n\n` +
0165:       `## Source Snapshot (Line Numbered)\n`;
0166: 
0167:     fs.writeFileSync(this.changeLogPath, `${header}${numbered}\n`, 'utf8');
0168:   }
0169: }
