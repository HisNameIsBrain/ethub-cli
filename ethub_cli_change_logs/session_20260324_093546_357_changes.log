0104:   buildSessionId() {
0105:     const d = new Date();
0106:     const stamp = [
0107:       d.getUTCFullYear(),
0108:       String(d.getUTCMonth() + 1).padStart(2, '0'),
0109:       String(d.getUTCDate()).padStart(2, '0'),
0110:       '_',
0111:       String(d.getUTCHours()).padStart(2, '0'),
0112:       String(d.getUTCMinutes()).padStart(2, '0'),
0113:       String(d.getUTCSeconds()).padStart(2, '0'),
0114:       '_',
0115:       String(d.getUTCMilliseconds()).padStart(3, '0')
0116:     ].join('');
0117:     return `session_${stamp}`;
0118:   }
0119: 
0120:   writeEvent(type, payload) {
0121:     this.counter += 1;
0122:     const event = {
0123:       index: this.counter,
0124:       ts: nowIso(),
0125:       type,
0126:       payload
0127:     };
0128:     fs.appendFileSync(this.eventsPath, `${safeJson(event)}\n`, 'utf8');
0129:   }
0130: 
0131:   writeTranscript(role, content) {
0132:     const text = String(content || '').trimEnd();
0133:     const block = `\n## ${role} @ ${nowIso()}\n\n${text}\n`;
0134:     fs.appendFileSync(this.transcriptPath, block, 'utf8');
0135:   }
