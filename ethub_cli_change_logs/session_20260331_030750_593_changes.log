1404:   async executePendingAction(action) {
1405:     if (!action) return;
1406:     if (action.type === 'ollama_chat') {
1407:       await this.executeAction(action);
1408:       return;
1409:     }
1410:     if (action.type === 'read_file') {
1411:       this.runReadFileAction(action);
1412:       return;
1413:     }
1414:     if (action.type === 'write_file') {
1415:       this.runWriteFileAction(action);
1416:       return;
1417:     }
1418:     if (action.type === 'add_skill') {
1419:       this.runAddSkillAction(action);
1420:       return;
1421:     }
1422:     if (action.type === 'run_skill') {
1423:       await this.runSkillCommand(action);
1424:       return;
1425:     }
1426:     this.print(`Unsupported pending action type: ${action.type}`);
1427:   }
1428: 
1429:   runReadFileAction(action) {
1430:     const filePath = action && action.payload ? action.payload.path : '';
1431:     if (!filePath || !fs.existsSync(filePath)) {
1432:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} file no longer exists.`);
1433:       return;
1434:     }
1435:     let text;
1436:     try {
1437:       text = fs.readFileSync(filePath, 'utf8');
1438:     } catch (error) {
1439:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1440:       return;
1441:     }
1442:     const shown = truncateText(text, MAX_READFILE_BYTES);
1443:     const rel = action.payload.rel || this.workspaceRelativePath(filePath);
1444:     this.print(style(`\n[READFILE] ${rel}`, ANSI.bold, ANSI.cyan));
1445:     this.print(style(`bytes: ${Buffer.byteLength(text, 'utf8')} | shown: ${Buffer.byteLength(shown, 'utf8')}`, ANSI.dim));
1446:     this.print(shown);
1447:     this.logger.writeEvent('read_file', {
1448:       action_id: action.id,
1449:       file: filePath,
1450:       bytes: Buffer.byteLength(text, 'utf8'),
1451:       shown_bytes: Buffer.byteLength(shown, 'utf8')
1452:     });
1453:   }
1454: 
1455:   runWriteFileAction(action) {
1456:     const filePath = action && action.payload ? action.payload.path : '';
1457:     const content = action && action.payload ? String(action.payload.content || '') : '';
1458:     if (!filePath) {
1459:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} missing target path.`);
1460:       return;
1461:     }
1462:     try {
1463:       ensureDir(path.dirname(filePath));
1464:       fs.writeFileSync(filePath, content, 'utf8');
1465:     } catch (error) {
1466:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1467:       return;
1468:     }
1469:     this.print(style(`[WRITEFILE] wrote ${content.length} chars to ${action.payload.rel}`, ANSI.bold, ANSI.cyan));
1470:     this.logger.writeEvent('write_file', {
1471:       action_id: action.id,
1472:       file: filePath,
1473:       chars: content.length
1474:     });
1475:   }
1476: 
1477:   runAddSkillAction(action) {
1478:     const payload = action && action.payload ? action.payload : {};
1479:     const name = String(payload.skill_name || '').trim();
1480:     const snippet = String(payload.snippet || '');
1481:     if (!name || !snippet) {
1482:       this.print(`${style('Add skill failed:', ANSI.bold, ANSI.red)} missing skill name or snippet.`);
1483:       return;
1484:     }
1485:     const duplicate = this.findSkill(name);
1486:     if (duplicate) {
1487:       this.print(`${style('Add skill skipped:', ANSI.bold, ANSI.red)} skill already exists (${duplicate.id}).`);
1488:       return;
1489:     }
1490: 
1491:     const skill = {
1492:       id: `skill_${Date.now()}`,
1493:       name,
1494:       snippet,
1495:       source: `candidate:${payload.source_candidate || 'unknown'}`,
1496:       executable: Boolean(payload.executable),
1497:       created_at: nowIso()
1498:     };
1499:     this.skills.push(skill);
1500:     this.saveSkills();
1501:     this.print(style(`[SKILL ADDED] ${skill.name} (${skill.id}) executable=${skill.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.cyan));
1502:     this.logger.writeEvent('skill_added', {
1503:       action_id: action.id,
1504:       skill_id: skill.id,
1505:       skill_name: skill.name,
1506:       executable: skill.executable
1507:     });
1508:   }
