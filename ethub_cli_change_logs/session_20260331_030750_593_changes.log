1076:   async handleCommand(input) {
1077:     const [cmd, ...args] = input.split(/\s+/);
1078:     const command = cmd.toLowerCase();
1079:     this.logger.writeEvent('subcommand', { command, args });
1080: 
1081:     if (command === '/help') {
1082:       this.print('Commands: /help, /status, /model <name>, /approve changes on|off, /readfile <path>, /writefile <path> -- <content>, /cd <path>, /skills <mine|candidates|add|list|show|run>, /yes, /no, /exit');
1083:       this.print('Skills flow: /skills mine 10 -> /skills add cand_1 my_skill -> /yes -> /skills run my_skill -> /yes');
1084:       return;
1085:     }
1086: 
1087:     if (command === '/status') {
1088:       this.print(safeJson({
1089:         model: this.model,
1090:         ollama_url: this.ollamaUrl,
1091:         require_approval_for_changes: this.requireApproval,
1092:         skills_count: this.skills.length,
1093:         skill_candidates_count: this.skillCandidates.length,
1094:         history_count: this.history.length,
1095:         pending_action: this.pendingAction ? this.pendingAction.id : null
1096:       }));
1097:       return;
1098:     }
1099: 
1100:     if (command === '/model') {
1101:       const nextModel = args.join(' ').trim();
1102:       if (!nextModel) {
1103:         this.print(`Current model: ${this.model}`);
1104:         return;
1105:       }
1106:       this.model = nextModel;
1107:       this.print(`Model updated: ${this.model}`);
1108:       this.logger.writeEvent('config_update', { key: 'model', value: this.model });
1109:       return;
1110:     }
1111: 
1112:     if (command === '/approve') {
1113:       const target = (args[0] || '').toLowerCase();
1114:       const mode = (args[1] || '').toLowerCase();
1115:       const legacyMode = target;
1116: 
1117:       if (target === 'changes' && (mode === 'on' || mode === 'off')) {
1118:         this.requireApproval = mode === 'on';
1119:         this.print(`Change approval mode: ${mode}`);
1120:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1121:         return;
1122:       }
1123: 
1124:       if (legacyMode === 'on' || legacyMode === 'off') {
1125:         this.requireApproval = legacyMode === 'on';
1126:         this.print(`Change approval mode: ${legacyMode}`);
