0114: function hslToRgb(h, s, l) {
0115:   h /= 360;
0116:   const a = s * Math.min(l, 1 - l);
0117:   const f = (n) => {
0118:     const k = (n + h * 12) % 12;
0119:     const c = l - a * Math.max(Math.min(k - 3, 9 - k, 1), -1);
0120:     return Math.round(c * 255);
0121:   };
0122:   return { r: f(0), g: f(8), b: f(4) };
0123: }
