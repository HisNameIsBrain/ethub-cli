0870:     this.print(style('ETHUB CLI Agent started. Ollama only, no external dependencies.', ANSI.bold, ANSI.cyan));
0871:     this.print(style(`Session logs: ${this.logger.sessionDir}`, ANSI.dim));
0872:     this.print(style('Type /help for commands.', ANSI.yellow));
0873:     await this.showSuggestions();
