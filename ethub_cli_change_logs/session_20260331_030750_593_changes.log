0324: function summarizeReasoning(input) {
0325:   const raw = String(input || '').trim();
0326:   const lowered = raw.toLowerCase();
0327:   const keywords = raw
0328:     .split(/\s+/)
0329:     .map((w) => w.replace(/[^a-zA-Z0-9_-]/g, ''))
0330:     .filter(Boolean)
0331:     .slice(0, 12);
0332: 
0333:   let intent = 'general_request';
0334:   if (/error|syntax|stack|trace|bug|fix|crash/.test(lowered)) intent = 'debugging';
0335:   else if (/how|what|why|explain|guide|tutorial/.test(lowered)) intent = 'information_lookup';
0336:   else if (/build|create|make|implement|write/.test(lowered)) intent = 'implementation';
0337: 
0338:   let strategy = 'Use local conversation context then query Ollama for a grounded response.';
0339:   if (intent === 'debugging') {
0340:     strategy = 'Focus on likely fault points, propose checks, and request missing runtime details if needed.';
0341:   }
0342: 
0343:   return {
0344:     query: raw,
0345:     intent,
0346:     keywords,
0347:     strategy,
0348:     note: 'Detailed private chain-of-thought is not exposed; this is a concise decision summary.'
