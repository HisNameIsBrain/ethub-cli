0894:         this.logger.writeEvent('runtime_error', { message, stack: error && error.stack ? error.stack : null });
0895:       }
0896: 
0897:       this.flushState();
0898:       this.safePrompt();
0899:     });
0900: 
0901:     this.rl.on('close', () => {
0902:       this.isClosed = true;
0903:       this.logger.writeEvent('session_end', { ended_at: nowIso() });
0904:       process.stdout.write('\nSession closed.\n');
