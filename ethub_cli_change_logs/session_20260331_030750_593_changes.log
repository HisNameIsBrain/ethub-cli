0260: function extractTextEntriesFromZip(zipPath, shouldInclude) {
0261:   const out = [];
0262:   const data = fs.readFileSync(zipPath);
0263:   const minEocd = 22;
0264:   const maxComment = 0xffff;
0265:   const startSearch = Math.max(0, data.length - (minEocd + maxComment));
0266:   let eocd = -1;
0267:   for (let i = data.length - minEocd; i >= startSearch; i -= 1) {
0268:     if (data.readUInt32LE(i) === 0x06054b50) {
0269:       eocd = i;
0270:       break;
0271:     }
0272:   }
0273:   if (eocd < 0) throw new Error('zip EOCD signature not found');
0274: 
0275:   const centralDirSize = data.readUInt32LE(eocd + 12);
0276:   const centralDirOffset = data.readUInt32LE(eocd + 16);
0277:   const centralDirEnd = centralDirOffset + centralDirSize;
0278:   let cursor = centralDirOffset;
0279: 
0280:   while (cursor + 46 <= centralDirEnd && cursor + 46 <= data.length) {
0281:     const sig = data.readUInt32LE(cursor);
0282:     if (sig !== 0x02014b50) break;
0283:     const compressionMethod = data.readUInt16LE(cursor + 10);
0284:     const compressedSize = data.readUInt32LE(cursor + 20);
0285:     const fileNameLen = data.readUInt16LE(cursor + 28);
0286:     const extraLen = data.readUInt16LE(cursor + 30);
0287:     const commentLen = data.readUInt16LE(cursor + 32);
0288:     const localHeaderOffset = data.readUInt32LE(cursor + 42);
0289:     const nameStart = cursor + 46;
0290:     const nameEnd = nameStart + fileNameLen;
0291:     const entryName = data.slice(nameStart, nameEnd).toString('utf8');
0292:     const next = nameEnd + extraLen + commentLen;
0293:     cursor = next;
0294: 
0295:     if (!shouldInclude(entryName)) continue;
0296:     if (entryName.endsWith('/')) continue;
0297:     if (localHeaderOffset + 30 > data.length) continue;
0298:     if (data.readUInt32LE(localHeaderOffset) !== 0x04034b50) continue;
0299: 
0300:     const localNameLen = data.readUInt16LE(localHeaderOffset + 26);
0301:     const localExtraLen = data.readUInt16LE(localHeaderOffset + 28);
0302:     const payloadStart = localHeaderOffset + 30 + localNameLen + localExtraLen;
0303:     const payloadEnd = payloadStart + compressedSize;
0304:     if (payloadEnd > data.length) continue;
0305: 
0306:     const compressed = data.slice(payloadStart, payloadEnd);
0307:     let decoded;
0308:     if (compressionMethod === 0) {
0309:       decoded = compressed;
0310:     } else if (compressionMethod === 8) {
0311:       decoded = zlib.inflateRawSync(compressed);
0312:     } else {
0313:       continue;
0314:     }
0315: 
0316:     out.push({
0317:       entry: entryName,
0318:       text: decoded.toString('utf8')
0319:     });
0320:   }
0321:   return out;
0322: }
