1031:     for (let frame = 0; frame < frames; frame += 1) {
1032:       const lines = this.renderHeaderFrame(frame);
1033:       process.stdout.write('\x1b[2J\x1b[H');
1034:       process.stdout.write(`${lines.join('\n')}\n`);
1035:       await new Promise((resolve) => setTimeout(resolve, frameDelay));
1036:     }
1037:     process.stdout.write('\x1b[2J\x1b[H');
1038:     this.drawHeader(frames);
