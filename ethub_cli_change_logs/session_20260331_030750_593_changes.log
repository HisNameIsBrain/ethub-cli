0208: function tokenizeCommandLine(input) {
0209:   const text = String(input || '');
0210:   const tokens = [];
0211:   let current = '';
0212:   let quote = null;
0213:   let escaping = false;
0214: 
0215:   for (let i = 0; i < text.length; i += 1) {
0216:     const ch = text[i];
0217:     if (escaping) {
0218:       current += ch;
0219:       escaping = false;
0220:       continue;
0221:     }
0222:     if (ch === '\\') {
0223:       escaping = true;
0224:       continue;
0225:     }
0226:     if (quote) {
0227:       if (ch === quote) {
0228:         quote = null;
0229:       } else {
0230:         current += ch;
0231:       }
0232:       continue;
0233:     }
0234:     if (ch === '"' || ch === '\'') {
0235:       quote = ch;
0236:       continue;
0237:     }
0238:     if (/\s/.test(ch)) {
0239:       if (current) {
0240:         tokens.push(current);
0241:         current = '';
0242:       }
0243:       continue;
0244:     }
0245:     current += ch;
0246:   }
0247: 
0248:   if (escaping) return { error: 'Command cannot end with a trailing escape.' };
0249:   if (quote) return { error: 'Unclosed quote in command.' };
0250:   if (current) tokens.push(current);
0251:   return { tokens };
0252: }
