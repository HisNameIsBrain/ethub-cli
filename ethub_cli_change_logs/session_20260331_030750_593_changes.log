0945:   resolvePathInWorkspace(inputPath, expected = 'any') {
0946:     const raw = String(inputPath || '').trim();
0947:     if (!raw) return { error: 'path is required' };
0948:     const normalized = raw === '~' ? os.homedir() : raw;
0949:     const resolved = path.resolve(process.cwd(), normalized);
0950:     const root = path.resolve(this.workspaceRoot);
0951:     const inRoot = resolved === root || resolved.startsWith(`${root}${path.sep}`);
0952:     if (!inRoot) {
0953:       return { error: `path escapes workspace root: ${root}` };
0954:     }
0955: 
0956:     if (expected === 'exists') {
0957:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
0958:     }
0959:     if (expected === 'file' || expected === 'dir') {
0960:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
0961:       let st;
0962:       try {
0963:         st = fs.statSync(resolved);
0964:       } catch (error) {
0965:         return { error: `unable to stat path: ${error.message}` };
0966:       }
0967:       if (expected === 'file' && !st.isFile()) return { error: 'path is not a file' };
0968:       if (expected === 'dir' && !st.isDirectory()) return { error: 'path is not a directory' };
0969:     }
0970: 
0971:     return { path: resolved };
0972:   }
