1510:   async handleUserPrompt(input) {
1511:     const reasoning = summarizeReasoning(input);
1512:     const action = {
1513:       id: `act_${Date.now()}`,
1514:       type: 'ollama_chat',
1515:       prompt: input,
1516:       reasoning_summary: reasoning,
1517:       created_at: nowIso()
1518:     };
1519: 
1520:     this.logger.writeTranscript('User', input);
1521:     this.logger.writeEvent('user_prompt', {
1522:       text: input,
1523:       reasoning_summary: reasoning,
1524:       proposed_action: { id: action.id, type: action.type }
1525:     });
1526:     this.actionMeta[action.id] = {
1527:       prompt: input,
1528:       prompt_chars_before: input.length
1529:     };
1530: 
1531:     this.logger.writeStructuredRecord({
1532:       timestamp: nowIso(),
1533:       query: input,
1534:       reasoning: {
1535:         query: reasoning.query,
1536:         intent: reasoning.intent,
1537:         keywords: reasoning.keywords,
1538:         search_strategy: reasoning.strategy
1539:       },
1540:       actions: {
1541:         action: 'local_ollama_request',
1542:         sources: ['ollama_localhost'],
1543:         Context: 'Analyzing locally via Ollama only; no OpenAI/Gemini/external model APIs.'
1544:       },
1545:       Commands: "ls, grep, nano, cd, nano 'create-new-file-diff-snippet-number+1.sh', regen entire file with changes then save, cp -rf old/path/to/file move/to/backup/path/file, rm old/path/to/file, bash create-new-file-(diff-snippet-line:character)-(number)+1, sed -i 's/old/new' \"$file\"",
1546:       Diff: '+,-',
1547:       Path: 'path/to/file:line:character',
1548:       action_id: action.id,
1549:       'Print-approved-by-user?': 'not_required (run commands)',
1550:       'Run runtime look at logs': 'pending',
1551:       summary: 'pending',
1552:       'Number of characters changed': 'pending'
1553:     });
1554: 
1555:     await this.executeAction(action);
1556:   }
1557: 
1558:   writeStructuredUpdate(actionId, patch) {
1559:     this.logger.writeStructuredRecord({
1560:       timestamp: nowIso(),
1561:       action_id: actionId,
1562:       update: patch
1563:     });
1564:   }
1565: 
1566:   async executeAction(action) {
1567:     if (!action || action.type !== 'ollama_chat') {
1568:       this.logger.writeEvent('action_error', { message: 'Unsupported action type', action });
1569:       this.writeStructuredUpdate(action && action.id ? action.id : 'unknown', {
1570:         'Run runtime look at logs': 'contains error still, unsupported action type',
1571:         summary: 'Unsupported action type encountered before runtime request.',
1572:         'Number of characters changed': 'previous character amount in file before cmd/new total character count added: 0/0'
1573:       });
1574:       this.print('Unsupported action.');
1575:       return;
1576:     }
1577: 
1578:     this.logger.writeEvent('action_start', {
1579:       action_id: action.id,
1580:       type: action.type,
1581:       target: this.ollamaUrl,
1582:       model: this.model,
1583:       prompt_chars: action.prompt.length,
1584:       reasoning_summary: action.reasoning_summary
1585:     });
1586: 
1587:     this.history.push({ role: 'user', content: action.prompt });
1588: 
1589:     const payload = {
1590:       model: this.model,
1591:       messages: this.history,
1592:       stream: false
1593:     };
1594: 
1595:     let response;
1596:     let raw;
1597:     const started = Date.now();
1598:     this.startThinking();
1599: 
1600:     try {
1601:       response = await fetch(this.ollamaUrl, {
1602:         method: 'POST',
1603:         headers: { 'Content-Type': 'application/json' },
1604:         body: JSON.stringify(payload)
1605:       });
1606: 
1607:       raw = await response.text();
1608:     } catch (error) {
1609:       this.stopThinking();
1610:       const message = error && error.message ? error.message : String(error);
1611:       this.logger.writeEvent('action_failure', {
1612:         action_id: action.id,
1613:         duration_ms: Date.now() - started,
1614:         error: message
1615:       });
1616:       this.writeStructuredUpdate(action.id, {
1617:         'Run runtime look at logs': 'contains error still, loop and try again with different results until each individual error is clear.',
1618:         summary: `Runtime request failed. Error: ${message}`,
1619:         'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${action.prompt.length}/0`,
1620:         'Print-approved-by-user?': 'true'
1621:       });
1622:       this.print(`Ollama request failed: ${message}`);
1623:       return;
1624:     }
1625:     this.stopThinking();
1626: 
1627:     let parsed;
1628:     try {
1629:       parsed = JSON.parse(raw);
1630:     } catch {
1631:       parsed = null;
1632:     }
1633: 
1634:     const assistantText = parsed && parsed.message && parsed.message.content
1635:       ? String(parsed.message.content)
1636:       : raw;
1637: 
1638:     this.history.push({ role: 'assistant', content: assistantText });
1639: 
1640:     this.logger.writeEvent('action_result', {
1641:       action_id: action.id,
1642:       duration_ms: Date.now() - started,
1643:       http_status: response.status,
1644:       ok: response.ok,
1645:       response_preview: assistantText.slice(0, 400),
1646:       response_chars: assistantText.length
1647:     });
1648: 
1649:     this.logger.writeTranscript('Assistant', assistantText);
1650:     this.print(assistantText);
1651: 
1652:     const hasRuntimeError = /(syntaxerror|stack overflow|runtime error|error:)/i.test(assistantText);
1653:     const runtimeResult = hasRuntimeError
1654:       ? 'contains error still, retry with different checks until isolated'
1655:       : 'No runtime error anymore = fixed';
1656:     const beforeChars = this.actionMeta[action.id] && this.actionMeta[action.id].prompt_chars_before
1657:       ? this.actionMeta[action.id].prompt_chars_before
1658:       : 0;
1659:     const afterChars = assistantText.length;
1660:     const elapsedMs = Date.now() - started;
1661: 
1662:     this.writeStructuredUpdate(action.id, {
1663:       'Run runtime look at logs': runtimeResult,
1664:       summary: `summarized what just changed, is it fixed: ${hasRuntimeError ? 'No' : 'Yes'}. Runtime error count estimate: ${hasRuntimeError ? 1 : 0}.`,
1665:       'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${beforeChars}/${afterChars}`,
1666:       timing_ms: elapsedMs,
1667:       stop_condition: elapsedMs >= 300000 ? 'Unable to find results or solutions, Try again.' : 'within loop budget'
1668:     });
1669:   }
1670: }
