0571:         }
0572:       }
0573:       if (typeof value.text === 'string' && value.text.trim()) {
0574:         segments.push(value.text);
0575:       }
0576:       for (const key of Object.keys(value)) {
0577:         if (key === 'content' || key === 'text') continue;
0578:         walk(value[key], depth + 1);
0579:       }
0580:     };
0581: 
0582:     if (parsed) {
0583:       walk(parsed);
0584:     } else {
0585:       segments.push(raw);
0586:     }
0587: 
0588:     for (const segment of segments) {
0589:       const fencePattern = /```(?:[^\n`]*)\n([\s\S]*?)```/g;
0590:       let match;
0591:       while ((match = fencePattern.exec(segment)) !== null) {
0592:         addCandidate(match[1], sourceLabel, 'fenced_code');
0593:       }
0594: 
0595:       const lines = segment.split('\n');
0596:       for (const line of lines) {
0597:         const trimmed = line.trim();
0598:         if (!trimmed || trimmed.length > 220) continue;
0599:         const shellLike = trimmed.replace(/^\$\s*/, '');
0600:         if (/^(ls|pwd|cat|head|tail|wc|rg|grep|find|sed|cp|mv|mkdir|touch|echo|git)\b/.test(shellLike)) {
0601:           addCandidate(shellLike, sourceLabel, 'shell_line');
0602:         }
0603:       }
0604:     }
0605:   }
0606: 
0607:   listArtifactZipFiles() {
0608:     const out = [];
0609:     if (!fs.existsSync(ARTIFACTS_ROOT)) return out;
0610:     const stack = [ARTIFACTS_ROOT];
0611:     while (stack.length) {
0612:       const current = stack.pop();
0613:       let entries = [];
0614:       try {
0615:         entries = fs.readdirSync(current, { withFileTypes: true });
0616:       } catch {
0617:         continue;
0618:       }
0619:       for (const entry of entries) {
0620:         const full = path.join(current, entry.name);
0621:         if (entry.isDirectory()) {
0622:           stack.push(full);
0623:         } else if (entry.isFile() && full.toLowerCase().endsWith('.zip')) {
0624:           out.push(full);
0625:         }
0626:       }
0627:     }
0628:     return out;
0629:   }
0630: 
0631:   collectSkillCandidatesFromArtifacts(limit = 10) {
0632:     const snippets = new Map();
0633:     let scannedSources = 0;
0634:     const cap = Math.max(1, Math.min(MAX_SKILL_CANDIDATES, Number(limit) || 10));
0635:     const addCandidate = (snippetText, sourceLabel, sourceKind) => {
0636:       const normalized = normalizeSnippet(snippetText);
0637:       if (!looksLikeUsefulSnippet(normalized)) return;
0638:       const existing = snippets.get(normalized);
0639:       if (existing) {
0640:         existing.hits += 1;
0641:         existing.sources.add(sourceLabel);
0642:         return;
0643:       }
0644:       snippets.set(normalized, {
0645:         snippet: normalized,
0646:         hits: 1,
0647:         source_kind: sourceKind,
0648:         sources: new Set([sourceLabel])
0649:       });
0650:     };
0651: 
0652:     const zipFiles = this.listArtifactZipFiles();
0653:     for (const zipPath of zipFiles) {
0654:       try {
0655:         const entries = extractTextEntriesFromZip(zipPath, isLikelyTextPath);
0656:         for (const item of entries) {
0657:           scannedSources += 1;
0658:           this.extractSnippetCandidatesFromText(item.text, `${path.basename(zipPath)}:${item.entry}`, addCandidate);
0659:         }
0660:       } catch (error) {
0661:         this.logger.writeEvent('skills_mine_warning', {
0662:           stage: 'zip_read',
0663:           zip: zipPath,
0664:           error: error.message
0665:         });
0666:       }
0667:     }
0668: 
0669:     const directArtifactFiles = [];
0670:     if (fs.existsSync(ARTIFACTS_ROOT)) {
0671:       const stack = [ARTIFACTS_ROOT];
0672:       while (stack.length) {
0673:         const current = stack.pop();
0674:         let entries = [];
0675:         try {
0676:           entries = fs.readdirSync(current, { withFileTypes: true });
0677:         } catch {
0678:           continue;
0679:         }
0680:         for (const entry of entries) {
0681:           const full = path.join(current, entry.name);
0682:           if (entry.isDirectory()) stack.push(full);
0683:           else if (entry.isFile() && !full.toLowerCase().endsWith('.zip') && isLikelyTextPath(full)) directArtifactFiles.push(full);
0684:         }
0685:       }
0686:     }
0687: 
0688:     for (const filePath of directArtifactFiles) {
0689:       let text = '';
0690:       try {
0691:         text = fs.readFileSync(filePath, 'utf8');
0692:       } catch {
0693:         continue;
0694:       }
0695:       scannedSources += 1;
0696:       this.extractSnippetCandidatesFromText(text, this.workspaceRelativePath(filePath), addCandidate);
0697:     }
0698: 
0699:     const ranked = Array.from(snippets.values())
0700:       .sort((a, b) => b.hits - a.hits || b.snippet.length - a.snippet.length)
0701:       .slice(0, cap);
0702: 
0703:     this.skillCandidates = ranked.map((entry, idx) => {
0704:       const snippet = entry.snippet;
0705:       const safety = this.validateSkillCommand(snippet);
0706:       return {
0707:         id: `cand_${idx + 1}`,
0708:         snippet,
0709:         hits: entry.hits,
0710:         source_kind: entry.source_kind,
0711:         sources: Array.from(entry.sources).slice(0, 6),
0712:         executable: safety.ok,
0713:         safety_reason: safety.ok ? '' : safety.reason
0714:       };
0715:     });
0716: 
0717:     this.logger.writeEvent('skills_mined', {
0718:       candidates: this.skillCandidates.length,
0719:       unique_snippets: snippets.size,
0720:       scanned_sources: scannedSources,
0721:       zip_files: zipFiles.length
0722:     });
0723: 
0724:     return {
0725:       candidates: this.skillCandidates.length,
0726:       uniqueSnippets: snippets.size,
0727:       scannedSources,
0728:       zipFiles: zipFiles.length
0729:     };
0730:   }
0731: 
0732:   findCandidate(query) {
0733:     const q = String(query || '').trim();
0734:     if (!q) return null;
0735:     return this.skillCandidates.find((c) => c.id === q) || null;
0736:   }
0737: 
0738:   findSkill(query) {
0739:     const q = String(query || '').trim().toLowerCase();
0740:     if (!q) return null;
0741:     return this.skills.find((s) => s.id.toLowerCase() === q || s.name.toLowerCase() === q) || null;
0742:   }
0743: 
0744:   validatePathToken(token) {
0745:     const raw = String(token || '').trim();
0746:     if (!raw) return { ok: true };
0747:     if (raw === '-' || raw.startsWith('-')) return { ok: true };
0748:     if (raw.startsWith('/')) return { ok: false, reason: `Absolute paths are blocked (${raw}).` };
0749:     if (raw.includes('..')) return { ok: false, reason: `Parent traversal is blocked (${raw}).` };
0750:     const resolved = path.resolve(process.cwd(), raw);
0751:     if (!isPathInsideRoot(this.workspaceRoot, resolved)) {
0752:       return { ok: false, reason: `Path escapes workspace root (${raw}).` };
0753:     }
0754:     return { ok: true };
0755:   }
0756: 
0757:   validateSkillCommand(snippet) {
0758:     const commandText = normalizeSnippet(snippet);
0759:     if (!commandText) return { ok: false, reason: 'Empty snippet.' };
0760:     const lines = commandText.split('\n').map((l) => l.trim()).filter(Boolean);
0761:     if (lines.length !== 1) return { ok: false, reason: 'Only single-line shell skills are executable.' };
0762:     const line = lines[0];
0763:     if (BLOCKED_COMMAND_PATTERN.test(line)) {
0764:       return { ok: false, reason: 'Command contains blocked shell operators.' };
0765:     }
0766: 
0767:     const parsed = tokenizeCommandLine(line);
0768:     if (parsed.error) return { ok: false, reason: parsed.error };
0769:     const tokens = parsed.tokens || [];
0770:     if (!tokens.length) return { ok: false, reason: 'No command token found.' };
0771: 
0772:     const cmd = tokens[0];
0773:     if (!SAFE_SKILL_COMMANDS.has(cmd)) {
0774:       return { ok: false, reason: `Command '${cmd}' is not allowlisted.` };
0775:     }
0776:     if (cmd === 'git') {
0777:       const sub = (tokens[1] || '').toLowerCase();
0778:       if (!['status', 'diff', 'log', 'show', 'branch', 'rev-parse'].includes(sub)) {
0779:         return { ok: false, reason: `git '${sub || '(none)'}' is blocked.` };
0780:       }
0781:     }
0782: 
0783:     for (let i = 1; i < tokens.length; i += 1) {
0784:       const pathCheck = this.validatePathToken(tokens[i]);
0785:       if (!pathCheck.ok) return pathCheck;
0786:     }
0787:     return { ok: true, command: cmd, tokens };
0788:   }
0789: 
0790:   async runSkillCommand(action) {
0791:     const payload = action && action.payload ? action.payload : {};
0792:     const skillName = payload.skill_name || payload.skill_id || 'unknown';
0793:     const snippet = String(payload.snippet || '');
0794:     const validation = this.validateSkillCommand(snippet);
0795:     if (!validation.ok) {
0796:       this.print(`${style('Skill execution denied:', ANSI.bold, ANSI.red)} ${validation.reason}`);
0797:       this.logger.writeEvent('skill_run_denied', {
0798:         action_id: action.id,
0799:         skill: skillName,
0800:         reason: validation.reason
0801:       });
0802:       return;
0803:     }
0804: 
0805:     const tokens = validation.tokens;
0806:     const cmd = tokens[0];
0807:     const args = tokens.slice(1);
0808:     this.print(style(`[SKILL RUN] ${skillName}: ${snippet}`, ANSI.bold, ANSI.cyan));
0809: 
0810:     const result = await new Promise((resolve) => {
0811:       const child = spawn(cmd, args, {
0812:         cwd: process.cwd(),
0813:         stdio: ['ignore', 'pipe', 'pipe'],
0814:         shell: false
0815:       });
0816: 
0817:       let stdout = '';
0818:       let stderr = '';
0819:       let finished = false;
0820:       const timer = setTimeout(() => {
0821:         if (finished) return;
0822:         child.kill('SIGTERM');
0823:       }, 120000);
0824: 
0825:       child.stdout.on('data', (chunk) => {
0826:         if (stdout.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0827:         stdout += chunk.toString('utf8');
0828:       });
0829:       child.stderr.on('data', (chunk) => {
0830:         if (stderr.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0831:         stderr += chunk.toString('utf8');
0832:       });
0833:       child.on('error', (error) => {
0834:         clearTimeout(timer);
0835:         finished = true;
0836:         resolve({ code: -1, signal: null, stdout, stderr: `${stderr}\n${error.message}`.trim() });
0837:       });
0838:       child.on('close', (code, signal) => {
0839:         clearTimeout(timer);
0840:         finished = true;
0841:         resolve({ code, signal, stdout, stderr });
0842:       });
0843:     });
0844: 
0845:     if (result.stdout) {
0846:       this.print(style('[STDOUT]', ANSI.dim));
0847:       this.print(truncateText(result.stdout, MAX_COMMAND_OUTPUT_BYTES));
0848:     }
0849:     if (result.stderr) {
0850:       this.print(style('[STDERR]', ANSI.dim));
0851:       this.print(truncateText(result.stderr, MAX_COMMAND_OUTPUT_BYTES));
0852:     }
0853:     this.print(style(`[SKILL EXIT] code=${result.code} signal=${result.signal || 'none'}`, ANSI.dim));
0854:     this.logger.writeEvent('skill_run_complete', {
0855:       action_id: action.id,
0856:       skill: skillName,
0857:       code: result.code,
0858:       signal: result.signal,
0859:       stdout_chars: result.stdout.length,
0860:       stderr_chars: result.stderr.length
0861:     });
0862:   }
