0510:   collectSkillCandidatesFromArtifacts(limit = 10) {
0511:     const snippets = new Map();
0512:     let scannedSources = 0;
0513:     const cap = Math.max(1, Math.min(MAX_SKILL_CANDIDATES, Number(limit) || 10));
0514:     const addCandidate = (snippetText, sourceLabel, sourceKind) => {
0515:       const normalized = normalizeSnippet(snippetText);
0516:       if (!normalized || normalized.length < 8 || normalized.length > MAX_SKILL_SNIPPET_CHARS) return;
0517:       const existing = snippets.get(normalized);
0518:       if (existing) {
0519:         existing.hits += 1;
0520:         existing.sources.add(sourceLabel);
0521:         return;
0522:       }
0523:       snippets.set(normalized, {
0524:         snippet: normalized,
0525:         hits: 1,
0526:         source_kind: sourceKind,
0527:         sources: new Set([sourceLabel])
0528:       });
0529:     };
0530: 
0531:     const zipFiles = this.listArtifactZipFiles();
0532:     for (const zipPath of zipFiles) {
0533:       let entriesText = '';
0534:       try {
0535:         entriesText = execFileSync('unzip', ['-Z1', zipPath], { encoding: 'utf8', maxBuffer: 8 * 1024 * 1024 });
0536:       } catch (error) {
0537:         this.logger.writeEvent('skills_mine_warning', {
0538:           stage: 'zip_list',
0539:           zip: zipPath,
0540:           error: error.message
0541:         });
0542:         continue;
0543:       }
0544:       const entries = entriesText.split('\n').map((s) => s.trim()).filter(Boolean);
0545:       for (const entry of entries) {
0546:         if (!isLikelyTextPath(entry)) continue;
0547:         let content = '';
0548:         try {
0549:           content = execFileSync('unzip', ['-p', zipPath, entry], { encoding: 'utf8', maxBuffer: 32 * 1024 * 1024 });
0550:         } catch {
0551:           continue;
0552:         }
0553:         scannedSources += 1;
0554:         this.extractSnippetCandidatesFromText(content, `${path.basename(zipPath)}:${entry}`, addCandidate);
0555:       }
0556:     }
0557: 
0558:     const ranked = Array.from(snippets.values())
0559:       .sort((a, b) => b.hits - a.hits || b.snippet.length - a.snippet.length)
0560:       .slice(0, cap);
0561: 
0562:     this.skillCandidates = ranked.map((entry, idx) => {
0563:       const snippet = entry.snippet;
0564:       const safety = this.validateSkillCommand(snippet);
0565:       return {
0566:         id: `cand_${idx + 1}`,
0567:         snippet,
0568:         hits: entry.hits,
0569:         source_kind: entry.source_kind,
0570:         sources: Array.from(entry.sources).slice(0, 6),
0571:         executable: safety.ok,
0572:         safety_reason: safety.ok ? '' : safety.reason
0573:       };
0574:     });
0575: 
0576:     this.logger.writeEvent('skills_mined', {
0577:       candidates: this.skillCandidates.length,
0578:       unique_snippets: snippets.size,
0579:       scanned_sources: scannedSources,
0580:       zip_files: zipFiles.length
0581:     });
