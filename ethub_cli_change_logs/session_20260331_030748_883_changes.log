0603:   validatePathToken(token) {
0604:     const raw = String(token || '').trim();
0605:     if (!raw) return { ok: true };
0606:     if (raw === '-' || raw.startsWith('-')) return { ok: true };
0607:     if (raw.startsWith('/')) return { ok: false, reason: `Absolute paths are blocked (${raw}).` };
0608:     if (raw.includes('..')) return { ok: false, reason: `Parent traversal is blocked (${raw}).` };
0609:     const resolved = path.resolve(process.cwd(), raw);
0610:     if (!isPathInsideRoot(this.workspaceRoot, resolved)) {
0611:       return { ok: false, reason: `Path escapes workspace root (${raw}).` };
0612:     }
0613:     return { ok: true };
0614:   }
0615: 
0616:   validateSkillCommand(snippet) {
0617:     const commandText = normalizeSnippet(snippet);
0618:     if (!commandText) return { ok: false, reason: 'Empty snippet.' };
0619:     const lines = commandText.split('\n').map((l) => l.trim()).filter(Boolean);
0620:     if (lines.length !== 1) return { ok: false, reason: 'Only single-line shell skills are executable.' };
0621:     const line = lines[0];
0622:     if (BLOCKED_COMMAND_PATTERN.test(line)) {
0623:       return { ok: false, reason: 'Command contains blocked shell operators.' };
0624:     }
0625: 
0626:     const parsed = tokenizeCommandLine(line);
0627:     if (parsed.error) return { ok: false, reason: parsed.error };
0628:     const tokens = parsed.tokens || [];
0629:     if (!tokens.length) return { ok: false, reason: 'No command token found.' };
0630: 
0631:     const cmd = tokens[0];
0632:     if (!SAFE_SKILL_COMMANDS.has(cmd)) {
0633:       return { ok: false, reason: `Command '${cmd}' is not allowlisted.` };
0634:     }
0635:     if (cmd === 'git') {
0636:       const sub = (tokens[1] || '').toLowerCase();
0637:       if (!['status', 'diff', 'log', 'show', 'branch', 'rev-parse'].includes(sub)) {
0638:         return { ok: false, reason: `git '${sub || '(none)'}' is blocked.` };
0639:       }
0640:     }
0641: 
0642:     for (let i = 1; i < tokens.length; i += 1) {
0643:       const pathCheck = this.validatePathToken(tokens[i]);
0644:       if (!pathCheck.ok) return pathCheck;
0645:     }
0646:     return { ok: true, command: cmd, tokens };
0647:   }
0648: 
0649:   async runSkillCommand(action) {
0650:     const payload = action && action.payload ? action.payload : {};
0651:     const skillName = payload.skill_name || payload.skill_id || 'unknown';
0652:     const snippet = String(payload.snippet || '');
0653:     const validation = this.validateSkillCommand(snippet);
0654:     if (!validation.ok) {
0655:       this.print(`${style('Skill execution denied:', ANSI.bold, ANSI.red)} ${validation.reason}`);
0656:       this.logger.writeEvent('skill_run_denied', {
0657:         action_id: action.id,
0658:         skill: skillName,
0659:         reason: validation.reason
0660:       });
0661:       return;
0662:     }
0663: 
0664:     const tokens = validation.tokens;
0665:     const cmd = tokens[0];
0666:     const args = tokens.slice(1);
0667:     this.print(style(`[SKILL RUN] ${skillName}: ${snippet}`, ANSI.bold, ANSI.cyan));
0668: 
0669:     const result = await new Promise((resolve) => {
0670:       const child = spawn(cmd, args, {
0671:         cwd: process.cwd(),
0672:         stdio: ['ignore', 'pipe', 'pipe'],
0673:         shell: false
0674:       });
0675: 
0676:       let stdout = '';
0677:       let stderr = '';
0678:       let finished = false;
0679:       const timer = setTimeout(() => {
0680:         if (finished) return;
0681:         child.kill('SIGTERM');
0682:       }, 120000);
0683: 
0684:       child.stdout.on('data', (chunk) => {
0685:         if (stdout.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0686:         stdout += chunk.toString('utf8');
0687:       });
0688:       child.stderr.on('data', (chunk) => {
0689:         if (stderr.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0690:         stderr += chunk.toString('utf8');
0691:       });
0692:       child.on('error', (error) => {
0693:         clearTimeout(timer);
0694:         finished = true;
0695:         resolve({ code: -1, signal: null, stdout, stderr: `${stderr}\n${error.message}`.trim() });
0696:       });
0697:       child.on('close', (code, signal) => {
0698:         clearTimeout(timer);
0699:         finished = true;
0700:         resolve({ code, signal, stdout, stderr });
0701:       });
0702:     });
0703: 
0704:     if (result.stdout) {
0705:       this.print(style('[STDOUT]', ANSI.dim));
0706:       this.print(truncateText(result.stdout, MAX_COMMAND_OUTPUT_BYTES));
0707:     }
0708:     if (result.stderr) {
0709:       this.print(style('[STDERR]', ANSI.dim));
0710:       this.print(truncateText(result.stderr, MAX_COMMAND_OUTPUT_BYTES));
0711:     }
0712:     this.print(style(`[SKILL EXIT] code=${result.code} signal=${result.signal || 'none'}`, ANSI.dim));
0713:     this.logger.writeEvent('skill_run_complete', {
0714:       action_id: action.id,
0715:       skill: skillName,
0716:       code: result.code,
0717:       signal: result.signal,
0718:       stdout_chars: result.stdout.length,
0719:       stderr_chars: result.stderr.length
0720:     });
0721:   }
