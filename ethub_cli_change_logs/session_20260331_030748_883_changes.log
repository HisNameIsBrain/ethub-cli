0195: function tokenizeCommandLine(input) {
0196:   const text = String(input || '');
0197:   const tokens = [];
0198:   let current = '';
0199:   let quote = null;
0200:   let escaping = false;
0201: 
0202:   for (let i = 0; i < text.length; i += 1) {
0203:     const ch = text[i];
0204:     if (escaping) {
0205:       current += ch;
0206:       escaping = false;
0207:       continue;
0208:     }
0209:     if (ch === '\\') {
0210:       escaping = true;
0211:       continue;
0212:     }
0213:     if (quote) {
0214:       if (ch === quote) {
0215:         quote = null;
0216:       } else {
0217:         current += ch;
0218:       }
0219:       continue;
0220:     }
0221:     if (ch === '"' || ch === '\'') {
0222:       quote = ch;
0223:       continue;
0224:     }
0225:     if (/\s/.test(ch)) {
0226:       if (current) {
0227:         tokens.push(current);
0228:         current = '';
0229:       }
0230:       continue;
0231:     }
0232:     current += ch;
0233:   }
0234: 
0235:   if (escaping) return { error: 'Command cannot end with a trailing escape.' };
0236:   if (quote) return { error: 'Unclosed quote in command.' };
0237:   if (current) tokens.push(current);
0238:   return { tokens };
0239: }
