0804:   resolvePathInWorkspace(inputPath, expected = 'any') {
0805:     const raw = String(inputPath || '').trim();
0806:     if (!raw) return { error: 'path is required' };
0807:     const normalized = raw === '~' ? os.homedir() : raw;
0808:     const resolved = path.resolve(process.cwd(), normalized);
0809:     const root = path.resolve(this.workspaceRoot);
0810:     const inRoot = resolved === root || resolved.startsWith(`${root}${path.sep}`);
0811:     if (!inRoot) {
0812:       return { error: `path escapes workspace root: ${root}` };
0813:     }
0814: 
0815:     if (expected === 'exists') {
0816:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
0817:     }
0818:     if (expected === 'file' || expected === 'dir') {
0819:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
0820:       let st;
0821:       try {
0822:         st = fs.statSync(resolved);
0823:       } catch (error) {
0824:         return { error: `unable to stat path: ${error.message}` };
0825:       }
0826:       if (expected === 'file' && !st.isFile()) return { error: 'path is not a file' };
0827:       if (expected === 'dir' && !st.isDirectory()) return { error: 'path is not a directory' };
0828:     }
0829: 
0830:     return { path: resolved };
0831:   }
