0467:   extractSnippetCandidatesFromText(text, sourceLabel, addCandidate) {
0468:     const raw = String(text || '');
0469:     const fencePattern = /```(?:[^\n`]*)\n([\s\S]*?)```/g;
0470:     let match;
0471:     while ((match = fencePattern.exec(raw)) !== null) {
0472:       addCandidate(match[1], sourceLabel, 'fenced_code');
0473:     }
0474: 
0475:     const lines = raw.split('\n');
0476:     for (const line of lines) {
0477:       const trimmed = line.trim();
0478:       if (!trimmed || trimmed.length > 220) continue;
0479:       const shellLike = trimmed.replace(/^\$\s*/, '');
0480:       if (/^(ls|pwd|cat|head|tail|wc|rg|grep|find|sed|cp|mv|mkdir|touch|echo|git)\b/.test(shellLike)) {
0481:         addCandidate(shellLike, sourceLabel, 'shell_line');
0482:       }
0483:     }
0484:   }
