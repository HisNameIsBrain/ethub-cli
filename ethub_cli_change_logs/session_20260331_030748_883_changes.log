0887:   async animateHeader(durationMs = 1200, fps = 20) {
0888:     const frameDelay = Math.max(16, Math.floor(1000 / fps));
0889:     const frames = Math.max(1, Math.floor(durationMs / frameDelay));
0890:     for (let frame = 0; frame < frames; frame += 1) {
0891:       const lines = this.renderHeaderFrame(frame);
0892:       process.stdout.write('\x1b[2J\x1b[H');
0893:       process.stdout.write(`${lines.join('\n')}\n`);
0894:       await new Promise((resolve) => setTimeout(resolve, frameDelay));
0895:     }
0896:     process.stdout.write('\x1b[2J\x1b[H');
0897:     this.drawHeader(frames);
0898:   }
