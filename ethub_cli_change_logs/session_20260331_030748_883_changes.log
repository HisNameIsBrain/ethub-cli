0113: function hslToRgb(h, s, l) {
0114:   h /= 360;
0115:   const a = s * Math.min(l, 1 - l);
0116:   const f = (n) => {
0117:     const k = (n + h * 12) % 12;
0118:     const c = l - a * Math.max(Math.min(k - 3, 9 - k, 1), -1);
0119:     return Math.round(c * 255);
0120:   };
0121:   return { r: f(0), g: f(8), b: f(4) };
0122: }
0123: 
0124: function rainbowDivider(width, phase) {
0125:   let out = '';
0126:   for (let i = 0; i < width; i += 1) {
0127:     const ch = DIVIDER_CHARS[i % DIVIDER_CHARS.length];
0128:     const p = (i / width + phase) % 1;
0129:     const { r, g, b } = hslToRgb(p * 360, 0.6, 0.65);
0130:     out += rgb(ch, r, g, b);
0131:   }
0132:   return out;
0133: }
0134: 
0135: function rainbowAsciiLine(line, row, totalRows, frame) {
0136:   let out = '';
0137:   const len = Math.max(line.length, 1);
0138: 
0139:   for (let i = 0; i < line.length; i += 1) {
0140:     const ch = line[i];
0141:     if (ch === ' ') {
0142:       out += ' ';
0143:       continue;
0144:     }
0145: 
0146:     const phase = (i / len + row / totalRows + frame * 0.01) % 1;
0147:     const { r, g, b } = hslToRgb(phase * 360, 0.6, 0.65);
0148: 
0149:     let display = ch;
0150:     if ((ch === 'o' || ch === '8') && (frame + i + row) % 47 === 0) {
0151:       display = '+';
0152:     }
0153: 
0154:     out += rgb(display, r, g, b);
0155:   }
0156: 
0157:   return out;
0158: }
