0486:   listArtifactZipFiles() {
0487:     const out = [];
0488:     if (!fs.existsSync(ARTIFACTS_ROOT)) return out;
0489:     const stack = [ARTIFACTS_ROOT];
0490:     while (stack.length) {
0491:       const current = stack.pop();
0492:       let entries = [];
0493:       try {
0494:         entries = fs.readdirSync(current, { withFileTypes: true });
0495:       } catch {
0496:         continue;
0497:       }
0498:       for (const entry of entries) {
0499:         const full = path.join(current, entry.name);
0500:         if (entry.isDirectory()) {
0501:           stack.push(full);
0502:         } else if (entry.isFile() && full.toLowerCase().endsWith('.zip')) {
0503:           out.push(full);
0504:         }
0505:       }
0506:     }
0507:     return out;
0508:   }
