0935:   async handleCommand(input) {
0936:     const [cmd, ...args] = input.split(/\s+/);
0937:     const command = cmd.toLowerCase();
0938:     this.logger.writeEvent('subcommand', { command, args });
0939: 
0940:     if (command === '/help') {
0941:       this.print('Commands: /help, /status, /model <name>, /approve changes on|off, /readfile <path>, /writefile <path> -- <content>, /cd <path>, /skills <mine|candidates|add|list|show|run>, /yes, /no, /exit');
0942:       this.print('Skills flow: /skills mine 10 -> /skills add cand_1 my_skill -> /yes -> /skills run my_skill -> /yes');
0943:       return;
0944:     }
0945: 
0946:     if (command === '/status') {
0947:       this.print(safeJson({
0948:         model: this.model,
0949:         ollama_url: this.ollamaUrl,
0950:         require_approval_for_changes: this.requireApproval,
0951:         skills_count: this.skills.length,
0952:         skill_candidates_count: this.skillCandidates.length,
0953:         history_count: this.history.length,
0954:         pending_action: this.pendingAction ? this.pendingAction.id : null
0955:       }));
0956:       return;
0957:     }
0958: 
0959:     if (command === '/model') {
0960:       const nextModel = args.join(' ').trim();
0961:       if (!nextModel) {
0962:         this.print(`Current model: ${this.model}`);
0963:         return;
0964:       }
0965:       this.model = nextModel;
0966:       this.print(`Model updated: ${this.model}`);
0967:       this.logger.writeEvent('config_update', { key: 'model', value: this.model });
0968:       return;
0969:     }
0970: 
0971:     if (command === '/approve') {
0972:       const target = (args[0] || '').toLowerCase();
0973:       const mode = (args[1] || '').toLowerCase();
0974:       const legacyMode = target;
0975: 
0976:       if (target === 'changes' && (mode === 'on' || mode === 'off')) {
0977:         this.requireApproval = mode === 'on';
0978:         this.print(`Change approval mode: ${mode}`);
0979:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
0980:         return;
0981:       }
0982: 
0983:       if (legacyMode === 'on' || legacyMode === 'off') {
0984:         this.requireApproval = legacyMode === 'on';
0985:         this.print(`Change approval mode: ${legacyMode}`);
0986:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
0987:         return;
0988:       }
0989: 
0990:       if (!target) {
0991:         this.print(`Change approval mode: ${this.requireApproval ? 'on' : 'off'}`);
0992:         return;
0993:       }
0994: 
0995:       this.print('Usage: /approve changes on|off');
0996:       return;
0997:     }
0998: 
0999:     if (command === '/yes') {
1000:       if (!this.pendingAction) {
1001:         this.print('No pending action to approve.');
1002:         return;
1003:       }
1004:       const action = this.pendingAction;
1005:       this.pendingAction = null;
1006:       this.logger.writeEvent('approval', { action_id: action.id, approved: true });
1007:       this.writeStructuredUpdate(action.id, {
1008:         'Print-approved-by-user?': 'true',
1009:         approved: true
1010:       });
1011:       await this.executePendingAction(action);
1012:       return;
1013:     }
1014: 
1015:     if (command === '/no') {
1016:       if (!this.pendingAction) {
1017:         this.print('No pending action to reject.');
1018:         return;
1019:       }
1020:       const action = this.pendingAction;
1021:       this.pendingAction = null;
1022:       this.logger.writeEvent('approval', { action_id: action.id, approved: false });
1023:       this.writeStructuredUpdate(action.id, {
1024:         'Print-approved-by-user?': 'false',
1025:         approved: false,
1026:         summary: 'Action was rejected by user before runtime execution.',
1027:         'Run runtime look at logs': 'skipped (approval rejected)'
1028:       });
1029:       this.print(`Action ${action.id} skipped.`);
1030:       return;
1031:     }
1032: 
1033:     if (command === '/exit') {
1034:       this.rl.close();
1035:       return;
1036:     }
1037: 
1038:     if (command === '/cd') {
1039:       const rawTarget = input.replace(/^\/cd\s*/i, '').trim();
1040:       if (!rawTarget) {
1041:         this.print(`Current directory: ${process.cwd()}`);
1042:         return;
1043:       }
1044:       const resolved = this.resolvePathInWorkspace(rawTarget, 'dir');
1045:       if (resolved.error) {
1046:         this.print(`${style('cd denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1047:         return;
1048:       }
1049:       process.chdir(resolved.path);
1050:       this.refreshPrompt();
1051:       this.logger.writeEvent('cwd_changed', {
1052:         cwd: process.cwd(),
1053:         workspace_relative: this.workspaceRelativePath()
1054:       });
1055:       this.print(style(`Directory changed to ${this.workspaceRelativePath()}`, ANSI.cyan));
1056:       return;
1057:     }
1058: 
1059:     if (command === '/readfile') {
1060:       const rawPath = input.replace(/^\/readfile\s*/i, '').trim();
1061:       if (!rawPath) {
1062:         this.print('Usage: /readfile <path>');
1063:         return;
1064:       }
1065:       const resolved = this.resolvePathInWorkspace(rawPath, 'file');
1066:       if (resolved.error) {
1067:         this.print(`${style('readfile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1068:         return;
1069:       }
1070:       const action = {
1071:         id: `act_${Date.now()}`,
1072:         type: 'read_file',
1073:         payload: {
1074:           path: resolved.path,
1075:           rel: this.workspaceRelativePath(resolved.path)
1076:         },
1077:         created_at: nowIso()
1078:       };
1079:       this.queueApprovalAction(
1080:         action,
1081:         `${style('Read request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel}`
1082:       );
1083:       return;
1084:     }
1085: 
1086:     if (command === '/writefile') {
1087:       const raw = input.replace(/^\/writefile\s*/i, '');
1088:       const splitIndex = raw.indexOf(' -- ');
1089:       if (splitIndex === -1) {
1090:         this.print('Usage: /writefile <path> -- <content>');
1091:         return;
1092:       }
1093:       const rawPath = raw.slice(0, splitIndex).trim();
1094:       const content = raw.slice(splitIndex + 4);
1095:       if (!rawPath) {
1096:         this.print('Usage: /writefile <path> -- <content>');
1097:         return;
1098:       }
1099:       const resolved = this.resolvePathInWorkspace(rawPath, 'any');
1100:       if (resolved.error) {
1101:         this.print(`${style('writefile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1102:         return;
1103:       }
1104:       const action = {
1105:         id: `act_${Date.now()}`,
1106:         type: 'write_file',
1107:         payload: {
1108:           path: resolved.path,
1109:           rel: this.workspaceRelativePath(resolved.path),
1110:           content
1111:         },
1112:         created_at: nowIso()
1113:       };
1114:       this.queueApprovalAction(
1115:         action,
1116:         `${style('Write request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel} (${content.length} chars)`
1117:       );
1118:       return;
1119:     }
1120: 
1121:     if (command === '/skills') {
1122:       const sub = (args[0] || '').toLowerCase();
1123:       if (!sub || sub === 'help') {
1124:         this.print('Usage:');
1125:         this.print('/skills mine [count]');
1126:         this.print('/skills candidates');
1127:         this.print('/skills add <candidate_id> <skill_name>');
1128:         this.print('/skills list');
1129:         this.print('/skills show <skill_id|skill_name>');
1130:         this.print('/skills run <skill_id|skill_name>');
1131:         return;
1132:       }
1133: 
1134:       if (sub === 'mine') {
1135:         const count = Number(args[1] || 10);
1136:         const result = this.collectSkillCandidatesFromArtifacts(count);
1137:         this.print(style(`Mined ${result.candidates} candidate skill patterns from artifacts (sources scanned: ${result.scannedSources}).`, ANSI.cyan));
1138:         for (const c of this.skillCandidates) {
1139:           this.print(style(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.yellow));
1140:           this.print('```');
1141:           this.print(c.snippet);
1142:           this.print('```');
1143:           if (!c.executable) this.print(style(`reason: ${c.safety_reason}`, ANSI.dim));
1144:         }
1145:         return;
1146:       }
1147: 
1148:       if (sub === 'candidates') {
1149:         if (!this.skillCandidates.length) {
1150:           this.print('No candidates loaded. Run /skills mine first.');
1151:           return;
1152:         }
1153:         for (const c of this.skillCandidates) {
1154:           this.print(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'} source_kind=${c.source_kind}`);
1155:         }
1156:         return;
1157:       }
1158: 
1159:       if (sub === 'add') {
1160:         const candidateId = args[1] || '';
1161:         const skillName = args.slice(2).join(' ').trim();
1162:         if (!candidateId || !skillName) {
1163:           this.print('Usage: /skills add <candidate_id> <skill_name>');
1164:           return;
1165:         }
1166:         const existing = this.findSkill(skillName);
1167:         if (existing) {
1168:           this.print(`Skill already exists: ${existing.name} (${existing.id})`);
1169:           return;
1170:         }
1171:         const candidate = this.findCandidate(candidateId);
1172:         if (!candidate) {
1173:           this.print(`Candidate not found: ${candidateId}`);
1174:           return;
1175:         }
1176:         const action = {
1177:           id: `act_${Date.now()}`,
1178:           type: 'add_skill',
1179:           payload: {
1180:             skill_name: skillName,
1181:             source_candidate: candidate.id,
1182:             snippet: candidate.snippet,
1183:             executable: candidate.executable
1184:           },
1185:           created_at: nowIso()
1186:         };
1187:         this.queueApprovalAction(
1188:           action,
1189:           `${style('Add skill queued:', ANSI.bold, ANSI.yellow)} ${skillName} from ${candidate.id}`
1190:         );
1191:         return;
1192:       }
1193: 
1194:       if (sub === 'list') {
1195:         if (!this.skills.length) {
1196:           this.print(`No approved skills yet. Skills file: ${this.skillsPath}`);
1197:           return;
1198:         }
1199:         for (const skill of this.skills) {
1200:           this.print(`[${skill.id}] ${skill.name} | executable=${skill.executable ? 'yes' : 'no'} | source=${skill.source}`);
1201:         }
1202:         return;
1203:       }
1204: 
1205:       if (sub === 'show') {
1206:         const query = args.slice(1).join(' ').trim();
1207:         if (!query) {
1208:           this.print('Usage: /skills show <skill_id|skill_name>');
1209:           return;
1210:         }
1211:         const skill = this.findSkill(query);
1212:         if (!skill) {
1213:           this.print(`Skill not found: ${query}`);
1214:           return;
1215:         }
1216:         this.print(style(`[${skill.id}] ${skill.name}`, ANSI.bold, ANSI.cyan));
1217:         this.print('```');
1218:         this.print(skill.snippet);
1219:         this.print('```');
1220:         return;
1221:       }
1222: 
1223:       if (sub === 'run') {
1224:         const query = args.slice(1).join(' ').trim();
1225:         if (!query) {
1226:           this.print('Usage: /skills run <skill_id|skill_name>');
1227:           return;
1228:         }
1229:         const skill = this.findSkill(query);
1230:         if (!skill) {
1231:           this.print(`Skill not found: ${query}`);
1232:           return;
1233:         }
1234:         const validation = this.validateSkillCommand(skill.snippet);
1235:         if (!validation.ok) {
1236:           this.print(`${style('Skill is not executable:', ANSI.bold, ANSI.red)} ${validation.reason}`);
1237:           return;
1238:         }
1239:         const action = {
1240:           id: `act_${Date.now()}`,
1241:           type: 'run_skill',
1242:           payload: {
1243:             skill_id: skill.id,
1244:             skill_name: skill.name,
1245:             snippet: skill.snippet
1246:           },
1247:           created_at: nowIso()
1248:         };
1249:         this.queueApprovalAction(
1250:           action,
1251:           `${style('Skill execution queued:', ANSI.bold, ANSI.yellow)} ${skill.name}\n${skill.snippet}`
1252:         );
1253:         return;
1254:       }
1255: 
1256:       this.print(`Unknown skills subcommand: ${sub}`);
1257:       return;
1258:     }
1259: 
1260:     this.print(`Unknown command: ${command}. Use /help.`);
1261:   }
1262: 
1263:   async executePendingAction(action) {
1264:     if (!action) return;
1265:     if (action.type === 'ollama_chat') {
1266:       await this.executeAction(action);
1267:       return;
1268:     }
1269:     if (action.type === 'read_file') {
1270:       this.runReadFileAction(action);
1271:       return;
1272:     }
1273:     if (action.type === 'write_file') {
1274:       this.runWriteFileAction(action);
1275:       return;
1276:     }
1277:     if (action.type === 'add_skill') {
1278:       this.runAddSkillAction(action);
1279:       return;
1280:     }
1281:     if (action.type === 'run_skill') {
1282:       await this.runSkillCommand(action);
1283:       return;
1284:     }
1285:     this.print(`Unsupported pending action type: ${action.type}`);
1286:   }
1287: 
1288:   runReadFileAction(action) {
1289:     const filePath = action && action.payload ? action.payload.path : '';
1290:     if (!filePath || !fs.existsSync(filePath)) {
1291:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} file no longer exists.`);
1292:       return;
1293:     }
1294:     let text;
1295:     try {
1296:       text = fs.readFileSync(filePath, 'utf8');
1297:     } catch (error) {
1298:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1299:       return;
1300:     }
1301:     const shown = truncateText(text, MAX_READFILE_BYTES);
1302:     const rel = action.payload.rel || this.workspaceRelativePath(filePath);
1303:     this.print(style(`\n[READFILE] ${rel}`, ANSI.bold, ANSI.cyan));
1304:     this.print(style(`bytes: ${Buffer.byteLength(text, 'utf8')} | shown: ${Buffer.byteLength(shown, 'utf8')}`, ANSI.dim));
1305:     this.print(shown);
1306:     this.logger.writeEvent('read_file', {
1307:       action_id: action.id,
1308:       file: filePath,
1309:       bytes: Buffer.byteLength(text, 'utf8'),
1310:       shown_bytes: Buffer.byteLength(shown, 'utf8')
1311:     });
1312:   }
1313: 
1314:   runWriteFileAction(action) {
1315:     const filePath = action && action.payload ? action.payload.path : '';
1316:     const content = action && action.payload ? String(action.payload.content || '') : '';
1317:     if (!filePath) {
1318:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} missing target path.`);
1319:       return;
1320:     }
1321:     try {
1322:       ensureDir(path.dirname(filePath));
1323:       fs.writeFileSync(filePath, content, 'utf8');
1324:     } catch (error) {
1325:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1326:       return;
1327:     }
1328:     this.print(style(`[WRITEFILE] wrote ${content.length} chars to ${action.payload.rel}`, ANSI.bold, ANSI.cyan));
1329:     this.logger.writeEvent('write_file', {
1330:       action_id: action.id,
1331:       file: filePath,
1332:       chars: content.length
1333:     });
1334:   }
1335: 
1336:   runAddSkillAction(action) {
1337:     const payload = action && action.payload ? action.payload : {};
1338:     const name = String(payload.skill_name || '').trim();
1339:     const snippet = String(payload.snippet || '');
1340:     if (!name || !snippet) {
1341:       this.print(`${style('Add skill failed:', ANSI.bold, ANSI.red)} missing skill name or snippet.`);
1342:       return;
1343:     }
1344:     const duplicate = this.findSkill(name);
1345:     if (duplicate) {
1346:       this.print(`${style('Add skill skipped:', ANSI.bold, ANSI.red)} skill already exists (${duplicate.id}).`);
1347:       return;
1348:     }
1349: 
1350:     const skill = {
1351:       id: `skill_${Date.now()}`,
1352:       name,
1353:       snippet,
1354:       source: `candidate:${payload.source_candidate || 'unknown'}`,
1355:       executable: Boolean(payload.executable),
1356:       created_at: nowIso()
1357:     };
1358:     this.skills.push(skill);
1359:     this.saveSkills();
1360:     this.print(style(`[SKILL ADDED] ${skill.name} (${skill.id}) executable=${skill.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.cyan));
1361:     this.logger.writeEvent('skill_added', {
1362:       action_id: action.id,
1363:       skill_id: skill.id,
1364:       skill_name: skill.name,
1365:       executable: skill.executable
1366:     });
1367:   }
1368: 
1369:   async handleUserPrompt(input) {
1370:     const reasoning = summarizeReasoning(input);
1371:     const action = {
1372:       id: `act_${Date.now()}`,
1373:       type: 'ollama_chat',
1374:       prompt: input,
1375:       reasoning_summary: reasoning,
1376:       created_at: nowIso()
1377:     };
1378: 
1379:     this.logger.writeTranscript('User', input);
1380:     this.logger.writeEvent('user_prompt', {
1381:       text: input,
1382:       reasoning_summary: reasoning,
1383:       proposed_action: { id: action.id, type: action.type }
1384:     });
1385:     this.actionMeta[action.id] = {
1386:       prompt: input,
1387:       prompt_chars_before: input.length
1388:     };
1389: 
1390:     this.logger.writeStructuredRecord({
1391:       timestamp: nowIso(),
1392:       query: input,
1393:       reasoning: {
1394:         query: reasoning.query,
1395:         intent: reasoning.intent,
1396:         keywords: reasoning.keywords,
1397:         search_strategy: reasoning.strategy
1398:       },
1399:       actions: {
1400:         action: 'local_ollama_request',
1401:         sources: ['ollama_localhost'],
1402:         Context: 'Analyzing locally via Ollama only; no OpenAI/Gemini/external model APIs.'
1403:       },
1404:       Commands: "ls, grep, nano, cd, nano 'create-new-file-diff-snippet-number+1.sh', regen entire file with changes then save, cp -rf old/path/to/file move/to/backup/path/file, rm old/path/to/file, bash create-new-file-(diff-snippet-line:character)-(number)+1, sed -i 's/old/new' \"$file\"",
1405:       Diff: '+,-',
1406:       Path: 'path/to/file:line:character',
1407:       action_id: action.id,
1408:       'Print-approved-by-user?': 'not_required (run commands)',
1409:       'Run runtime look at logs': 'pending',
1410:       summary: 'pending',
1411:       'Number of characters changed': 'pending'
1412:     });
1413: 
1414:     await this.executeAction(action);
1415:   }
1416: 
1417:   writeStructuredUpdate(actionId, patch) {
1418:     this.logger.writeStructuredRecord({
1419:       timestamp: nowIso(),
1420:       action_id: actionId,
1421:       update: patch
1422:     });
1423:   }
1424: 
1425:   async executeAction(action) {
1426:     if (!action || action.type !== 'ollama_chat') {
1427:       this.logger.writeEvent('action_error', { message: 'Unsupported action type', action });
1428:       this.writeStructuredUpdate(action && action.id ? action.id : 'unknown', {
1429:         'Run runtime look at logs': 'contains error still, unsupported action type',
1430:         summary: 'Unsupported action type encountered before runtime request.',
1431:         'Number of characters changed': 'previous character amount in file before cmd/new total character count added: 0/0'
1432:       });
1433:       this.print('Unsupported action.');
1434:       return;
1435:     }
1436: 
1437:     this.logger.writeEvent('action_start', {
1438:       action_id: action.id,
1439:       type: action.type,
1440:       target: this.ollamaUrl,
1441:       model: this.model,
1442:       prompt_chars: action.prompt.length,
1443:       reasoning_summary: action.reasoning_summary
1444:     });
1445: 
1446:     this.history.push({ role: 'user', content: action.prompt });
1447: 
1448:     const payload = {
1449:       model: this.model,
1450:       messages: this.history,
1451:       stream: false
1452:     };
1453: 
1454:     let response;
1455:     let raw;
1456:     const started = Date.now();
1457:     this.startThinking();
1458: 
1459:     try {
1460:       response = await fetch(this.ollamaUrl, {
1461:         method: 'POST',
1462:         headers: { 'Content-Type': 'application/json' },
1463:         body: JSON.stringify(payload)
1464:       });
1465: 
1466:       raw = await response.text();
1467:     } catch (error) {
1468:       this.stopThinking();
1469:       const message = error && error.message ? error.message : String(error);
1470:       this.logger.writeEvent('action_failure', {
1471:         action_id: action.id,
1472:         duration_ms: Date.now() - started,
1473:         error: message
1474:       });
1475:       this.writeStructuredUpdate(action.id, {
1476:         'Run runtime look at logs': 'contains error still, loop and try again with different results until each individual error is clear.',
1477:         summary: `Runtime request failed. Error: ${message}`,
1478:         'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${action.prompt.length}/0`,
1479:         'Print-approved-by-user?': 'true'
1480:       });
1481:       this.print(`Ollama request failed: ${message}`);
1482:       return;
1483:     }
1484:     this.stopThinking();
1485: 
1486:     let parsed;
1487:     try {
1488:       parsed = JSON.parse(raw);
1489:     } catch {
1490:       parsed = null;
1491:     }
1492: 
1493:     const assistantText = parsed && parsed.message && parsed.message.content
1494:       ? String(parsed.message.content)
1495:       : raw;
1496: 
1497:     this.history.push({ role: 'assistant', content: assistantText });
1498: 
1499:     this.logger.writeEvent('action_result', {
1500:       action_id: action.id,
1501:       duration_ms: Date.now() - started,
1502:       http_status: response.status,
1503:       ok: response.ok,
1504:       response_preview: assistantText.slice(0, 400),
1505:       response_chars: assistantText.length
1506:     });
1507: 
1508:     this.logger.writeTranscript('Assistant', assistantText);
1509:     this.print(assistantText);
1510: 
1511:     const hasRuntimeError = /(syntaxerror|stack overflow|runtime error|error:)/i.test(assistantText);
1512:     const runtimeResult = hasRuntimeError
1513:       ? 'contains error still, retry with different checks until isolated'
1514:       : 'No runtime error anymore = fixed';
1515:     const beforeChars = this.actionMeta[action.id] && this.actionMeta[action.id].prompt_chars_before
1516:       ? this.actionMeta[action.id].prompt_chars_before
1517:       : 0;
1518:     const afterChars = assistantText.length;
1519:     const elapsedMs = Date.now() - started;
1520: 
1521:     this.writeStructuredUpdate(action.id, {
1522:       'Run runtime look at logs': runtimeResult,
1523:       summary: `summarized what just changed, is it fixed: ${hasRuntimeError ? 'No' : 'Yes'}. Runtime error count estimate: ${hasRuntimeError ? 1 : 0}.`,
1524:       'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${beforeChars}/${afterChars}`,
1525:       timing_ms: elapsedMs,
1526:       stop_condition: elapsedMs >= 300000 ? 'Unable to find results or solutions, Try again.' : 'within loop budget'
1527:     });
1528:   }
1529: }
1530: 
1531: const agent = new EthubCliAgent();
1532: agent.start().catch((error) => {
1533:   process.stderr.write(`Fatal startup error: ${error && error.stack ? error.stack : String(error)}\n`);
1534:   process.exit(1);
1535: });
