1076:   determineIntentWithHopper(input) {
1077:     const reasoning = summarizeReasoning(input);
1078:     const intent = String(reasoning.intent || 'general_request');
1079:     let lane = 'general';
1080:     if (intent === 'debugging') lane = 'debug';
1081:     else if (intent === 'implementation' || intent === 'refactor') lane = 'code';
1082:     else if (intent === 'shell_operation') lane = 'shell';
1083:     else if (intent === 'planning') lane = 'plan';
1084:     else if (intent === 'information_lookup' || intent === 'documentation') lane = 'research';
1085:     else if (intent === 'testing') lane = 'verify';
1086:     return { ...reasoning, hopper_lane: lane };
1087:   }
