0565:         parsed = null;
0566:       }
0567:     }
0568: 
0569:     const walk = (value, depth = 0) => {
0570:       if (depth > 8) return;
0571:       if (typeof value === 'string') {
0572:         if (value.trim()) segments.push(value);
0573:         return;
0574:       }
0575:       if (!value || typeof value !== 'object') return;
0576:       if (Array.isArray(value)) {
0577:         for (const item of value) walk(item, depth + 1);
0578:         return;
0579:       }
0580:       if (value.content && Array.isArray(value.content.parts)) {
0581:         for (const part of value.content.parts) {
0582:           if (typeof part === 'string' && part.trim()) segments.push(part);
0583:         }
0584:       }
0585:       if (typeof value.text === 'string' && value.text.trim()) {
0586:         segments.push(value.text);
0587:       }
0588:       for (const key of Object.keys(value)) {
0589:         if (key === 'content' || key === 'text') continue;
0590:         walk(value[key], depth + 1);
0591:       }
0592:     };
0593: 
0594:     if (parsed) {
0595:       walk(parsed);
0596:     } else {
0597:       segments.push(raw);
0598:     }
0599: 
0600:     for (const segment of segments) {
0601:       const fencePattern = /```(?:[^\n`]*)\n([\s\S]*?)```/g;
0602:       let match;
0603:       while ((match = fencePattern.exec(segment)) !== null) {
0604:         addCandidate(match[1], sourceLabel, 'fenced_code');
0605:       }
0606: 
0607:       const lines = segment.split('\n');
0608:       for (const line of lines) {
0609:         const trimmed = line.trim();
0610:         if (!trimmed || trimmed.length > 220) continue;
0611:         const shellLike = trimmed.replace(/^\$\s*/, '');
0612:         if (/^(ls|pwd|cat|head|tail|wc|rg|grep|find|sed|cp|mv|mkdir|touch|echo|git)\b/.test(shellLike)) {
0613:           addCandidate(shellLike, sourceLabel, 'shell_line');
0614:         }
0615:       }
0616:     }
0617:   }
0618: 
0619:   listArtifactZipFiles() {
0620:     const out = [];
0621:     if (!fs.existsSync(ARTIFACTS_ROOT)) return out;
0622:     const stack = [ARTIFACTS_ROOT];
0623:     while (stack.length) {
0624:       const current = stack.pop();
0625:       let entries = [];
0626:       try {
0627:         entries = fs.readdirSync(current, { withFileTypes: true });
0628:       } catch {
0629:         continue;
0630:       }
0631:       for (const entry of entries) {
0632:         const full = path.join(current, entry.name);
0633:         if (entry.isDirectory()) {
0634:           stack.push(full);
0635:         } else if (entry.isFile() && full.toLowerCase().endsWith('.zip')) {
0636:           out.push(full);
0637:         }
0638:       }
0639:     }
0640:     return out;
0641:   }
0642: 
0643:   collectSkillCandidatesFromArtifacts(limit = 10) {
0644:     const snippets = new Map();
0645:     let scannedSources = 0;
0646:     const cap = Math.max(1, Math.min(MAX_SKILL_CANDIDATES, Number(limit) || 10));
0647:     const addCandidate = (snippetText, sourceLabel, sourceKind) => {
0648:       const normalized = normalizeSnippet(snippetText);
0649:       if (!looksLikeUsefulSnippet(normalized)) return;
0650:       const existing = snippets.get(normalized);
0651:       if (existing) {
0652:         existing.hits += 1;
0653:         existing.sources.add(sourceLabel);
0654:         return;
0655:       }
0656:       snippets.set(normalized, {
0657:         snippet: normalized,
0658:         hits: 1,
0659:         source_kind: sourceKind,
0660:         sources: new Set([sourceLabel])
0661:       });
0662:     };
0663: 
0664:     const zipFiles = this.listArtifactZipFiles();
0665:     for (const zipPath of zipFiles) {
0666:       try {
0667:         const entries = extractTextEntriesFromZip(zipPath, isLikelyTextPath);
0668:         for (const item of entries) {
0669:           scannedSources += 1;
0670:           this.extractSnippetCandidatesFromText(item.text, `${path.basename(zipPath)}:${item.entry}`, addCandidate);
0671:         }
0672:       } catch (error) {
0673:         this.logger.writeEvent('skills_mine_warning', {
0674:           stage: 'zip_read',
0675:           zip: zipPath,
0676:           error: error.message
0677:         });
0678:       }
0679:     }
0680: 
0681:     const directArtifactFiles = [];
0682:     if (fs.existsSync(ARTIFACTS_ROOT)) {
0683:       const stack = [ARTIFACTS_ROOT];
0684:       while (stack.length) {
0685:         const current = stack.pop();
0686:         let entries = [];
0687:         try {
0688:           entries = fs.readdirSync(current, { withFileTypes: true });
0689:         } catch {
0690:           continue;
0691:         }
0692:         for (const entry of entries) {
0693:           const full = path.join(current, entry.name);
0694:           if (entry.isDirectory()) stack.push(full);
0695:           else if (entry.isFile() && !full.toLowerCase().endsWith('.zip') && isLikelyTextPath(full)) directArtifactFiles.push(full);
0696:         }
0697:       }
0698:     }
0699: 
0700:     for (const filePath of directArtifactFiles) {
0701:       let text = '';
0702:       try {
0703:         text = fs.readFileSync(filePath, 'utf8');
0704:       } catch {
0705:         continue;
0706:       }
0707:       scannedSources += 1;
0708:       this.extractSnippetCandidatesFromText(text, this.workspaceRelativePath(filePath), addCandidate);
0709:     }
0710: 
0711:     const ranked = Array.from(snippets.values())
0712:       .sort((a, b) => b.hits - a.hits || b.snippet.length - a.snippet.length)
0713:       .slice(0, cap);
0714: 
0715:     this.skillCandidates = ranked.map((entry, idx) => {
0716:       const snippet = entry.snippet;
0717:       const safety = this.validateSkillCommand(snippet);
0718:       return {
0719:         id: `cand_${idx + 1}`,
0720:         snippet,
0721:         hits: entry.hits,
0722:         source_kind: entry.source_kind,
0723:         sources: Array.from(entry.sources).slice(0, 6),
0724:         executable: safety.ok,
0725:         safety_reason: safety.ok ? '' : safety.reason
0726:       };
0727:     });
0728: 
0729:     this.logger.writeEvent('skills_mined', {
0730:       candidates: this.skillCandidates.length,
0731:       unique_snippets: snippets.size,
0732:       scanned_sources: scannedSources,
0733:       zip_files: zipFiles.length
0734:     });
0735: 
0736:     return {
0737:       candidates: this.skillCandidates.length,
0738:       uniqueSnippets: snippets.size,
0739:       scannedSources,
0740:       zipFiles: zipFiles.length
0741:     };
0742:   }
0743: 
0744:   findCandidate(query) {
0745:     const q = String(query || '').trim();
0746:     if (!q) return null;
0747:     return this.skillCandidates.find((c) => c.id === q) || null;
