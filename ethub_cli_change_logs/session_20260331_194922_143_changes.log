1125:   resolvePathInWorkspace(inputPath, expected = 'any') {
1126:     const raw = String(inputPath || '').trim();
1127:     if (!raw) return { error: 'path is required' };
1128:     const normalized = raw === '~' ? os.homedir() : raw;
1129:     const resolved = path.resolve(process.cwd(), normalized);
1130:     const root = path.resolve(this.workspaceRoot);
1131:     const inRoot = resolved === root || resolved.startsWith(`${root}${path.sep}`);
1132:     if (!inRoot) {
1133:       return { error: `path escapes workspace root: ${root}` };
1134:     }
1135: 
1136:     if (expected === 'exists') {
1137:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
1138:     }
1139:     if (expected === 'file' || expected === 'dir') {
1140:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
1141:       let st;
1142:       try {
1143:         st = fs.statSync(resolved);
1144:       } catch (error) {
1145:         return { error: `unable to stat path: ${error.message}` };
1146:       }
1147:       if (expected === 'file' && !st.isFile()) return { error: 'path is not a file' };
1148:       if (expected === 'dir' && !st.isDirectory()) return { error: 'path is not a directory' };
1149:     }
1150: 
1151:     return { path: resolved };
1152:   }
