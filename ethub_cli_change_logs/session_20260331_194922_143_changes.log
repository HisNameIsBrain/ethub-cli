0750:   findSkill(query) {
0751:     const q = String(query || '').trim().toLowerCase();
0752:     if (!q) return null;
0753:     return this.skills.find((s) => s.id.toLowerCase() === q || s.name.toLowerCase() === q) || null;
0754:   }
