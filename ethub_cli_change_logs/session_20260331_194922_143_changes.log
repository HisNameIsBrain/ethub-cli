0756:   validatePathToken(token) {
0757:     const raw = String(token || '').trim();
0758:     if (!raw) return { ok: true };
0759:     if (raw === '-' || raw.startsWith('-')) return { ok: true };
0760:     if (raw.startsWith('/')) return { ok: false, reason: `Absolute paths are blocked (${raw}).` };
0761:     if (raw.includes('..')) return { ok: false, reason: `Parent traversal is blocked (${raw}).` };
0762:     const resolved = path.resolve(process.cwd(), raw);
0763:     if (!isPathInsideRoot(this.workspaceRoot, resolved)) {
0764:       return { ok: false, reason: `Path escapes workspace root (${raw}).` };
0765:     }
0766:     return { ok: true };
0767:   }
0768: 
0769:   validateSkillCommand(snippet) {
0770:     const commandText = normalizeSnippet(snippet);
0771:     if (!commandText) return { ok: false, reason: 'Empty snippet.' };
0772:     const lines = commandText.split('\n').map((l) => l.trim()).filter(Boolean);
0773:     if (lines.length !== 1) return { ok: false, reason: 'Only single-line shell skills are executable.' };
0774:     const line = lines[0];
0775:     if (BLOCKED_COMMAND_PATTERN.test(line)) {
0776:       return { ok: false, reason: 'Command contains blocked shell operators.' };
0777:     }
0778: 
0779:     const parsed = tokenizeCommandLine(line);
0780:     if (parsed.error) return { ok: false, reason: parsed.error };
0781:     const tokens = parsed.tokens || [];
0782:     if (!tokens.length) return { ok: false, reason: 'No command token found.' };
0783: 
0784:     const cmd = tokens[0];
0785:     if (!SAFE_SKILL_COMMANDS.has(cmd)) {
0786:       return { ok: false, reason: `Command '${cmd}' is not allowlisted.` };
0787:     }
0788:     if (cmd === 'git') {
0789:       const sub = (tokens[1] || '').toLowerCase();
0790:       if (!['status', 'diff', 'log', 'show', 'branch', 'rev-parse'].includes(sub)) {
0791:         return { ok: false, reason: `git '${sub || '(none)'}' is blocked.` };
0792:       }
0793:     }
0794: 
0795:     for (let i = 1; i < tokens.length; i += 1) {
0796:       const pathCheck = this.validatePathToken(tokens[i]);
0797:       if (!pathCheck.ok) return pathCheck;
0798:     }
0799:     return { ok: true, command: cmd, tokens };
0800:   }
