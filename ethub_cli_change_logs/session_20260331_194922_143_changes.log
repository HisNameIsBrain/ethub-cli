1154:   queueApprovalAction(action, promptText) {
1155:     if (this.pendingAction) {
1156:       this.print(`Pending action already exists (${this.pendingAction.id}). Resolve with /yes or /no first.`);
1157:       return false;
1158:     }
1159:     this.pendingAction = action;
1160:     this.logger.writeEvent('action_queued', { action_id: action.id, type: action.type, payload: action.payload });
1161:     this.print(promptText);
1162:     this.print(style(`Approve with /yes or reject with /no`, ANSI.yellow));
1163:     return true;
1164:   }
