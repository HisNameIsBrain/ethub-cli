0998:   async startDebugDashboard() {
0999:     if (this.debugServerProcess && !this.debugServerProcess.killed && this.dashboardInfo) {
1000:       return this.dashboardInfo;
1001:     }
1002: 
1003:     const serverPath = this.resolveDashboardServerPath();
1004:     if (!serverPath) {
1005:       throw new Error('web_debug/index_server.mjs not found');
1006:     }
1007: 
1008:     const child = spawn(process.execPath, [serverPath], {
1009:       cwd: this.workspaceRoot,
1010:       env: process.env,
1011:       stdio: ['ignore', 'pipe', 'pipe']
1012:     });
1013: 
1014:     this.debugServerProcess = child;
1015:     this.debugServerToken = '';
1016:     let startupOutput = '';
1017: 
1018:     child.stdout.on('data', (chunk) => {
1019:       const text = chunk.toString();
1020:       startupOutput += text;
1021:       this.logger.writeEvent('debug_dashboard_stdout', { text: text.slice(0, 800) });
1022:     });
1023:     child.stderr.on('data', (chunk) => {
1024:       const text = chunk.toString();
1025:       startupOutput += text;
1026:       this.logger.writeEvent('debug_dashboard_stderr', { text: text.slice(0, 800) });
1027:     });
1028:     child.on('exit', (code, signal) => {
1029:       this.logger.writeEvent('debug_dashboard_exit', { code, signal });
1030:       this.debugServerProcess = null;
1031:       this.dashboardInfo = null;
1032:       this.debugServerToken = '';
1033:     });
1034: 
1035:     const deadline = Date.now() + 10000;
1036:     while (Date.now() < deadline) {
1037:       const urlMatch = startupOutput.match(/http:\/\/127\.0\.0\.1:(\d+)\/\?token=([a-f0-9]+)/i);
1038:       if (urlMatch) {
1039:         const port = Number(urlMatch[1]);
1040:         const token = String(urlMatch[2] || '');
1041:         const base = `http://127.0.0.1:${port}`;
1042:         this.debugServerToken = token;
1043:         this.dashboardInfo = {
1044:           pid: child.pid,
1045:           host: '127.0.0.1',
1046:           port,
1047:           dashboard_url: `${base}/?token=${token}`,
1048:           chat_url: `${base}/chat?token=${token}`
1049:         };
1050:         this.logger.writeEvent('debug_dashboard_ready', this.dashboardInfo);
1051:         return this.dashboardInfo;
1052:       }
1053: 
1054:       const runtime = this.readDashboardRuntime();
1055:       if (runtime && Number(runtime.port) > 0) {
1056:         const healthy = await this.isDashboardHealthy(runtime.port);
1057:         if (healthy && this.debugServerToken) {
1058:           const base = `http://127.0.0.1:${runtime.port}`;
1059:           this.dashboardInfo = {
1060:             ...runtime,
1061:             dashboard_url: `${base}/?token=${this.debugServerToken}`,
1062:             chat_url: `${base}/chat?token=${this.debugServerToken}`
1063:           };
1064:           this.logger.writeEvent('debug_dashboard_ready', this.dashboardInfo);
1065:           return this.dashboardInfo;
1066:         }
1067:       }
1068: 
1069:       await new Promise((resolve) => setTimeout(resolve, 120));
1070:     }
1071: 
1072:     this.stopDebugDashboard();
1073:     throw new Error('debug dashboard failed to start in time');
1074:   }
