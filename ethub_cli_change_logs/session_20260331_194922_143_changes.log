1256:   async handleCommand(input) {
1257:     const [cmd, ...args] = input.split(/\s+/);
1258:     const command = cmd.toLowerCase();
1259:     this.logger.writeEvent('subcommand', { command, args });
1260: 
1261:     if (command === '/help') {
1262:       this.print('Commands: /help, /status, /model <name>, /approve changes on|off, /debug, /dashboard, /readfile <path>, /writefile <path> -- <content>, /cd <path>, /skills <mine|candidates|add|list|show|run>, /yes, /no, /exit');
1263:       this.print('Skills flow: /skills mine 10 -> /skills add cand_1 my_skill -> /yes -> /skills run my_skill -> /yes');
1264:       return;
1265:     }
1266: 
1267:     if (command === '/status') {
1268:       this.print(safeJson({
1269:         model: this.model,
1270:         ollama_url: this.ollamaUrl,
1271:         require_approval_for_changes: this.requireApproval,
1272:         skills_count: this.skills.length,
1273:         skill_candidates_count: this.skillCandidates.length,
1274:         dashboard_url: this.dashboardInfo && this.dashboardInfo.dashboard_url ? this.dashboardInfo.dashboard_url : null,
1275:         chat_url: this.dashboardInfo && this.dashboardInfo.chat_url ? this.dashboardInfo.chat_url : null,
1276:         debug_dashboard_pid: this.debugServerProcess && !this.debugServerProcess.killed ? this.debugServerProcess.pid : null,
1277:         history_count: this.history.length,
1278:         pending_action: this.pendingAction ? this.pendingAction.id : null
1279:       }));
1280:       return;
1281:     }
1282: 
1283:     if (command === '/model') {
1284:       const nextModel = args.join(' ').trim();
1285:       if (!nextModel) {
1286:         this.print(`Current model: ${this.model}`);
1287:         return;
1288:       }
1289:       this.model = nextModel;
1290:       this.print(`Model updated: ${this.model}`);
1291:       this.logger.writeEvent('config_update', { key: 'model', value: this.model });
1292:       return;
1293:     }
1294: 
1295:     if (command === '/approve') {
1296:       const target = (args[0] || '').toLowerCase();
1297:       const mode = (args[1] || '').toLowerCase();
1298:       const legacyMode = target;
1299: 
1300:       if (target === 'changes' && (mode === 'on' || mode === 'off')) {
1301:         this.requireApproval = mode === 'on';
1302:         this.print(`Change approval mode: ${mode}`);
1303:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1304:         return;
1305:       }
1306: 
1307:       if (legacyMode === 'on' || legacyMode === 'off') {
1308:         this.requireApproval = legacyMode === 'on';
1309:         this.print(`Change approval mode: ${legacyMode}`);
1310:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1311:         return;
1312:       }
1313: 
1314:       if (!target) {
1315:         this.print(`Change approval mode: ${this.requireApproval ? 'on' : 'off'}`);
1316:         return;
1317:       }
1318: 
1319:       this.print('Usage: /approve changes on|off');
1320:       return;
1321:     }
1322: 
1323:     if (command === '/debug' || command === '/dashboard') {
1324:       const info = await this.startDebugDashboard();
1325:       this.print(style(`Debug dashboard live: ${info.dashboard_url}`, ANSI.cyan));
1326:       this.print(style(`Debug chat live: ${info.chat_url}`, ANSI.cyan));
1327:       this.print(style(`Token length: ${this.debugServerToken.length} (never written to file)`, ANSI.dim));
1328:       return;
1329:     }
1330: 
1331:     if (command === '/yes') {
1332:       if (!this.pendingAction) {
1333:         this.print('No pending action to approve.');
1334:         return;
1335:       }
1336:       const action = this.pendingAction;
1337:       this.pendingAction = null;
1338:       this.logger.writeEvent('approval', { action_id: action.id, approved: true });
1339:       this.writeStructuredUpdate(action.id, {
1340:         'Print-approved-by-user?': 'true',
1341:         approved: true
1342:       });
1343:       await this.executePendingAction(action);
1344:       return;
1345:     }
1346: 
1347:     if (command === '/no') {
1348:       if (!this.pendingAction) {
1349:         this.print('No pending action to reject.');
1350:         return;
1351:       }
1352:       const action = this.pendingAction;
1353:       this.pendingAction = null;
1354:       this.logger.writeEvent('approval', { action_id: action.id, approved: false });
1355:       this.writeStructuredUpdate(action.id, {
1356:         'Print-approved-by-user?': 'false',
1357:         approved: false,
1358:         summary: 'Action was rejected by user before runtime execution.',
1359:         'Run runtime look at logs': 'skipped (approval rejected)'
1360:       });
1361:       this.print(`Action ${action.id} skipped.`);
1362:       return;
1363:     }
1364: 
1365:     if (command === '/exit') {
1366:       this.rl.close();
1367:       return;
1368:     }
1369: 
1370:     if (command === '/cd') {
1371:       const rawTarget = input.replace(/^\/cd\s*/i, '').trim();
1372:       if (!rawTarget) {
1373:         this.print(`Current directory: ${process.cwd()}`);
1374:         return;
1375:       }
1376:       const resolved = this.resolvePathInWorkspace(rawTarget, 'dir');
1377:       if (resolved.error) {
1378:         this.print(`${style('cd denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1379:         return;
1380:       }
1381:       process.chdir(resolved.path);
1382:       this.refreshPrompt();
1383:       this.logger.writeEvent('cwd_changed', {
1384:         cwd: process.cwd(),
1385:         workspace_relative: this.workspaceRelativePath()
1386:       });
1387:       this.print(style(`Directory changed to ${this.workspaceRelativePath()}`, ANSI.cyan));
1388:       return;
1389:     }
1390: 
1391:     if (command === '/readfile') {
1392:       const rawPath = input.replace(/^\/readfile\s*/i, '').trim();
1393:       if (!rawPath) {
1394:         this.print('Usage: /readfile <path>');
1395:         return;
1396:       }
1397:       const resolved = this.resolvePathInWorkspace(rawPath, 'file');
1398:       if (resolved.error) {
1399:         this.print(`${style('readfile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1400:         return;
1401:       }
1402:       const action = {
1403:         id: `act_${Date.now()}`,
1404:         type: 'read_file',
1405:         payload: {
1406:           path: resolved.path,
1407:           rel: this.workspaceRelativePath(resolved.path)
1408:         },
1409:         created_at: nowIso()
1410:       };
1411:       this.queueApprovalAction(
1412:         action,
1413:         `${style('Read request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel}`
1414:       );
1415:       return;
1416:     }
1417: 
1418:     if (command === '/writefile') {
1419:       const raw = input.replace(/^\/writefile\s*/i, '');
1420:       const splitIndex = raw.indexOf(' -- ');
1421:       if (splitIndex === -1) {
1422:         this.print('Usage: /writefile <path> -- <content>');
1423:         return;
1424:       }
1425:       const rawPath = raw.slice(0, splitIndex).trim();
1426:       const content = raw.slice(splitIndex + 4);
1427:       if (!rawPath) {
1428:         this.print('Usage: /writefile <path> -- <content>');
1429:         return;
1430:       }
1431:       const resolved = this.resolvePathInWorkspace(rawPath, 'any');
1432:       if (resolved.error) {
1433:         this.print(`${style('writefile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1434:         return;
1435:       }
1436:       const action = {
1437:         id: `act_${Date.now()}`,
1438:         type: 'write_file',
1439:         payload: {
1440:           path: resolved.path,
1441:           rel: this.workspaceRelativePath(resolved.path),
1442:           content
1443:         },
1444:         created_at: nowIso()
1445:       };
1446:       this.queueApprovalAction(
1447:         action,
1448:         `${style('Write request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel} (${content.length} chars)`
1449:       );
1450:       return;
1451:     }
1452: 
1453:     if (command === '/skills') {
1454:       const sub = (args[0] || '').toLowerCase();
1455:       if (!sub || sub === 'help') {
1456:         this.print('Usage:');
1457:         this.print('/skills mine [count]');
1458:         this.print('/skills candidates');
1459:         this.print('/skills add <candidate_id> <skill_name>');
1460:         this.print('/skills list');
1461:         this.print('/skills show <skill_id|skill_name>');
1462:         this.print('/skills run <skill_id|skill_name>');
1463:         return;
1464:       }
1465: 
1466:       if (sub === 'mine') {
1467:         const count = Number(args[1] || 10);
1468:         const result = this.collectSkillCandidatesFromArtifacts(count);
1469:         this.print(style(`Mined ${result.candidates} candidate skill patterns from artifacts (sources scanned: ${result.scannedSources}).`, ANSI.cyan));
1470:         for (const c of this.skillCandidates) {
1471:           this.print(style(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.yellow));
1472:           this.print('```');
1473:           this.print(c.snippet);
1474:           this.print('```');
1475:           if (!c.executable) this.print(style(`reason: ${c.safety_reason}`, ANSI.dim));
1476:         }
1477:         return;
1478:       }
1479: 
1480:       if (sub === 'candidates') {
1481:         if (!this.skillCandidates.length) {
1482:           this.print('No candidates loaded. Run /skills mine first.');
1483:           return;
1484:         }
1485:         for (const c of this.skillCandidates) {
1486:           this.print(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'} source_kind=${c.source_kind}`);
1487:         }
1488:         return;
1489:       }
1490: 
1491:       if (sub === 'add') {
1492:         const candidateId = args[1] || '';
1493:         const skillName = args.slice(2).join(' ').trim();
1494:         if (!candidateId || !skillName) {
1495:           this.print('Usage: /skills add <candidate_id> <skill_name>');
1496:           return;
1497:         }
1498:         const existing = this.findSkill(skillName);
1499:         if (existing) {
1500:           this.print(`Skill already exists: ${existing.name} (${existing.id})`);
1501:           return;
1502:         }
1503:         const candidate = this.findCandidate(candidateId);
1504:         if (!candidate) {
1505:           this.print(`Candidate not found: ${candidateId}`);
1506:           return;
1507:         }
1508:         const action = {
1509:           id: `act_${Date.now()}`,
1510:           type: 'add_skill',
1511:           payload: {
1512:             skill_name: skillName,
1513:             source_candidate: candidate.id,
1514:             snippet: candidate.snippet,
1515:             executable: candidate.executable
1516:           },
1517:           created_at: nowIso()
1518:         };
1519:         this.queueApprovalAction(
1520:           action,
1521:           `${style('Add skill queued:', ANSI.bold, ANSI.yellow)} ${skillName} from ${candidate.id}`
1522:         );
1523:         return;
1524:       }
1525: 
1526:       if (sub === 'list') {
1527:         if (!this.skills.length) {
1528:           this.print(`No approved skills yet. Skills file: ${this.skillsPath}`);
1529:           return;
1530:         }
1531:         for (const skill of this.skills) {
1532:           this.print(`[${skill.id}] ${skill.name} | executable=${skill.executable ? 'yes' : 'no'} | source=${skill.source}`);
1533:         }
1534:         return;
1535:       }
1536: 
1537:       if (sub === 'show') {
1538:         const query = args.slice(1).join(' ').trim();
1539:         if (!query) {
1540:           this.print('Usage: /skills show <skill_id|skill_name>');
1541:           return;
1542:         }
1543:         const skill = this.findSkill(query);
1544:         if (!skill) {
1545:           this.print(`Skill not found: ${query}`);
1546:           return;
1547:         }
1548:         this.print(style(`[${skill.id}] ${skill.name}`, ANSI.bold, ANSI.cyan));
1549:         this.print('```');
1550:         this.print(skill.snippet);
1551:         this.print('```');
1552:         return;
1553:       }
1554: 
1555:       if (sub === 'run') {
1556:         const query = args.slice(1).join(' ').trim();
1557:         if (!query) {
1558:           this.print('Usage: /skills run <skill_id|skill_name>');
1559:           return;
1560:         }
1561:         const skill = this.findSkill(query);
1562:         if (!skill) {
1563:           this.print(`Skill not found: ${query}`);
1564:           return;
1565:         }
1566:         const validation = this.validateSkillCommand(skill.snippet);
1567:         if (!validation.ok) {
1568:           this.print(`${style('Skill is not executable:', ANSI.bold, ANSI.red)} ${validation.reason}`);
1569:           return;
1570:         }
1571:         const action = {
1572:           id: `act_${Date.now()}`,
1573:           type: 'run_skill',
1574:           payload: {
1575:             skill_id: skill.id,
1576:             skill_name: skill.name,
1577:             snippet: skill.snippet
1578:           },
1579:           created_at: nowIso()
1580:         };
1581:         this.queueApprovalAction(
1582:           action,
1583:           `${style('Skill execution queued:', ANSI.bold, ANSI.yellow)} ${skill.name}\n${skill.snippet}`
1584:         );
1585:         return;
1586:       }
1587: 
1588:       this.print(`Unknown skills subcommand: ${sub}`);
1589:       return;
1590:     }
1591: 
1592:     this.print(`Unknown command: ${command}. Use /help.`);
1593:   }
