0267: function extractTextEntriesFromZip(zipPath, shouldInclude) {
0268:   const out = [];
0269:   const data = fs.readFileSync(zipPath);
0270:   const minEocd = 22;
0271:   const maxComment = 0xffff;
0272:   const startSearch = Math.max(0, data.length - (minEocd + maxComment));
0273:   let eocd = -1;
0274:   for (let i = data.length - minEocd; i >= startSearch; i -= 1) {
0275:     if (data.readUInt32LE(i) === 0x06054b50) {
0276:       eocd = i;
0277:       break;
0278:     }
0279:   }
0280:   if (eocd < 0) throw new Error('zip EOCD signature not found');
0281: 
0282:   const centralDirSize = data.readUInt32LE(eocd + 12);
0283:   const centralDirOffset = data.readUInt32LE(eocd + 16);
0284:   const centralDirEnd = centralDirOffset + centralDirSize;
0285:   let cursor = centralDirOffset;
0286: 
0287:   while (cursor + 46 <= centralDirEnd && cursor + 46 <= data.length) {
0288:     const sig = data.readUInt32LE(cursor);
0289:     if (sig !== 0x02014b50) break;
0290:     const compressionMethod = data.readUInt16LE(cursor + 10);
0291:     const compressedSize = data.readUInt32LE(cursor + 20);
0292:     const fileNameLen = data.readUInt16LE(cursor + 28);
0293:     const extraLen = data.readUInt16LE(cursor + 30);
0294:     const commentLen = data.readUInt16LE(cursor + 32);
0295:     const localHeaderOffset = data.readUInt32LE(cursor + 42);
0296:     const nameStart = cursor + 46;
0297:     const nameEnd = nameStart + fileNameLen;
0298:     const entryName = data.slice(nameStart, nameEnd).toString('utf8');
0299:     const next = nameEnd + extraLen + commentLen;
0300:     cursor = next;
0301: 
0302:     if (!shouldInclude(entryName)) continue;
0303:     if (entryName.endsWith('/')) continue;
0304:     if (localHeaderOffset + 30 > data.length) continue;
0305:     if (data.readUInt32LE(localHeaderOffset) !== 0x04034b50) continue;
0306: 
0307:     const localNameLen = data.readUInt16LE(localHeaderOffset + 26);
0308:     const localExtraLen = data.readUInt16LE(localHeaderOffset + 28);
0309:     const payloadStart = localHeaderOffset + 30 + localNameLen + localExtraLen;
0310:     const payloadEnd = payloadStart + compressedSize;
0311:     if (payloadEnd > data.length) continue;
0312: 
0313:     const compressed = data.slice(payloadStart, payloadEnd);
0314:     let decoded;
0315:     if (compressionMethod === 0) {
0316:       decoded = compressed;
0317:     } else if (compressionMethod === 8) {
0318:       decoded = zlib.inflateRawSync(compressed);
0319:     } else {
0320:       continue;
0321:     }
0322: 
0323:     out.push({
0324:       entry: entryName,
0325:       text: decoded.toString('utf8')
0326:     });
0327:   }
0328:   return out;
0329: }
