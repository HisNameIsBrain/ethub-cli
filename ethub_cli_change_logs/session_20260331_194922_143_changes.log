1595:   async executePendingAction(action) {
1596:     if (!action) return;
1597:     if (action.type === 'ollama_chat') {
1598:       await this.executeAction(action);
1599:       return;
1600:     }
1601:     if (action.type === 'read_file') {
1602:       this.runReadFileAction(action);
1603:       return;
1604:     }
1605:     if (action.type === 'write_file') {
1606:       this.runWriteFileAction(action);
1607:       return;
1608:     }
1609:     if (action.type === 'add_skill') {
1610:       this.runAddSkillAction(action);
1611:       return;
1612:     }
1613:     if (action.type === 'run_skill') {
1614:       await this.runSkillCommand(action);
1615:       return;
1616:     }
1617:     this.print(`Unsupported pending action type: ${action.type}`);
1618:   }
1619: 
1620:   runReadFileAction(action) {
1621:     const filePath = action && action.payload ? action.payload.path : '';
1622:     if (!filePath || !fs.existsSync(filePath)) {
1623:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} file no longer exists.`);
1624:       return;
1625:     }
1626:     let text;
1627:     try {
1628:       text = fs.readFileSync(filePath, 'utf8');
1629:     } catch (error) {
1630:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1631:       return;
1632:     }
1633:     const shown = truncateText(text, MAX_READFILE_BYTES);
1634:     const rel = action.payload.rel || this.workspaceRelativePath(filePath);
1635:     this.print(style(`[I/O READ] ${rel}`, ANSI.bold, ANSI.cyan));
1636:     this.print(style(`\n[READFILE] ${rel}`, ANSI.bold, ANSI.cyan));
1637:     this.print(style(`bytes: ${Buffer.byteLength(text, 'utf8')} | shown: ${Buffer.byteLength(shown, 'utf8')}`, ANSI.dim));
1638:     this.print(shown);
1639:     this.logger.writeEvent('read_file', {
1640:       action_id: action.id,
1641:       file: filePath,
1642:       bytes: Buffer.byteLength(text, 'utf8'),
1643:       shown_bytes: Buffer.byteLength(shown, 'utf8')
1644:     });
1645:   }
1646: 
1647:   runWriteFileAction(action) {
1648:     const filePath = action && action.payload ? action.payload.path : '';
1649:     const content = action && action.payload ? String(action.payload.content || '') : '';
1650:     if (!filePath) {
1651:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} missing target path.`);
1652:       return;
1653:     }
1654:     try {
1655:       ensureDir(path.dirname(filePath));
1656:       fs.writeFileSync(filePath, content, 'utf8');
1657:     } catch (error) {
1658:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1659:       return;
1660:     }
1661:     this.print(style(`[I/O WRITE] ${action.payload.rel}`, ANSI.bold, ANSI.cyan));
1662:     this.print(style(`[WRITEFILE] wrote ${content.length} chars to ${action.payload.rel}`, ANSI.bold, ANSI.cyan));
1663:     this.logger.writeEvent('write_file', {
1664:       action_id: action.id,
1665:       file: filePath,
1666:       chars: content.length
1667:     });
1668:   }
1669: 
1670:   runAddSkillAction(action) {
1671:     const payload = action && action.payload ? action.payload : {};
1672:     const name = String(payload.skill_name || '').trim();
1673:     const snippet = String(payload.snippet || '');
1674:     if (!name || !snippet) {
1675:       this.print(`${style('Add skill failed:', ANSI.bold, ANSI.red)} missing skill name or snippet.`);
1676:       return;
1677:     }
1678:     const duplicate = this.findSkill(name);
1679:     if (duplicate) {
1680:       this.print(`${style('Add skill skipped:', ANSI.bold, ANSI.red)} skill already exists (${duplicate.id}).`);
1681:       return;
1682:     }
1683: 
1684:     const skill = {
1685:       id: `skill_${Date.now()}`,
1686:       name,
1687:       snippet,
1688:       source: `candidate:${payload.source_candidate || 'unknown'}`,
1689:       executable: Boolean(payload.executable),
1690:       created_at: nowIso()
1691:     };
1692:     this.skills.push(skill);
1693:     this.saveSkills();
1694:     this.print(style(`[SKILL ADDED] ${skill.name} (${skill.id}) executable=${skill.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.cyan));
1695:     this.logger.writeEvent('skill_added', {
1696:       action_id: action.id,
1697:       skill_id: skill.id,
1698:       skill_name: skill.name,
1699:       executable: skill.executable
1700:     });
1701:   }
1702: 
1703:   async handleUserPrompt(input) {
1704:     const reasoning = this.determineIntentWithHopper(input);
1705:     const action = {
1706:       id: `act_${Date.now()}`,
1707:       type: 'ollama_chat',
1708:       prompt: input,
1709:       reasoning_summary: reasoning,
1710:       created_at: nowIso()
1711:     };
1712: 
1713:     this.logger.writeTranscript('User', input);
1714:     this.logger.writeEvent('user_prompt', {
1715:       text: input,
1716:       hopper_lane: reasoning.hopper_lane,
1717:       reasoning_summary: reasoning,
1718:       proposed_action: { id: action.id, type: action.type }
1719:     });
1720:     this.actionMeta[action.id] = {
1721:       prompt: input,
1722:       prompt_chars_before: input.length
1723:     };
1724:     const keywordsText = Array.isArray(reasoning.keywords) && reasoning.keywords.length
1725:       ? reasoning.keywords.join(', ')
1726:       : 'none';
1727:     this.print(style(`[Hopper] lane=${reasoning.hopper_lane} | intent=${reasoning.intent} | keywords=${keywordsText}`, ANSI.dim));
1728:     this.print(style(`[Reasoning] strategy=${reasoning.strategy}`, ANSI.dim));
1729: 
1730:     this.logger.writeStructuredRecord({
1731:       timestamp: nowIso(),
1732:       query: input,
1733:       reasoning: {
1734:         query: reasoning.query,
1735:         intent: reasoning.intent,
1736:         keywords: reasoning.keywords,
1737:         search_strategy: reasoning.strategy
1738:       },
1739:       actions: {
1740:         action: 'local_ollama_request',
1741:         sources: ['ollama_localhost'],
1742:         Context: 'Analyzing locally via Ollama only; no OpenAI/Gemini/external model APIs.'
1743:       },
1744:       Commands: "ls, grep, nano, cd, nano 'create-new-file-diff-snippet-number+1.sh', regen entire file with changes then save, cp -rf old/path/to/file move/to/backup/path/file, rm old/path/to/file, bash create-new-file-(diff-snippet-line:character)-(number)+1, sed -i 's/old/new' \"$file\"",
1745:       Diff: '+,-',
1746:       Path: 'path/to/file:line:character',
1747:       action_id: action.id,
1748:       'Print-approved-by-user?': 'not_required (run commands)',
1749:       'Run runtime look at logs': 'pending',
1750:       summary: 'pending',
1751:       'Number of characters changed': 'pending'
1752:     });
1753: 
1754:     await this.executeAction(action);
1755:   }
1756: 
1757:   writeStructuredUpdate(actionId, patch) {
1758:     this.logger.writeStructuredRecord({
1759:       timestamp: nowIso(),
1760:       action_id: actionId,
1761:       update: patch
1762:     });
1763:   }
1764: 
1765:   async executeAction(action) {
1766:     if (!action || action.type !== 'ollama_chat') {
1767:       this.logger.writeEvent('action_error', { message: 'Unsupported action type', action });
1768:       this.writeStructuredUpdate(action && action.id ? action.id : 'unknown', {
1769:         'Run runtime look at logs': 'contains error still, unsupported action type',
1770:         summary: 'Unsupported action type encountered before runtime request.',
1771:         'Number of characters changed': 'previous character amount in file before cmd/new total character count added: 0/0'
1772:       });
1773:       this.print('Unsupported action.');
1774:       return;
1775:     }
1776: 
1777:     this.logger.writeEvent('action_start', {
1778:       action_id: action.id,
1779:       type: action.type,
1780:       target: this.ollamaUrl,
1781:       model: this.model,
1782:       prompt_chars: action.prompt.length,
1783:       reasoning_summary: action.reasoning_summary
1784:     });
1785: 
1786:     this.history.push({ role: 'user', content: action.prompt });
1787: 
1788:     const payload = {
1789:       model: this.model,
1790:       messages: this.history,
1791:       stream: false
1792:     };
1793: 
1794:     let response;
1795:     let raw;
1796:     const started = Date.now();
1797:     this.startThinking();
1798: 
1799:     try {
1800:       response = await fetch(this.ollamaUrl, {
1801:         method: 'POST',
1802:         headers: { 'Content-Type': 'application/json' },
1803:         body: JSON.stringify(payload)
1804:       });
1805: 
1806:       raw = await response.text();
1807:     } catch (error) {
1808:       this.stopThinking();
1809:       const message = error && error.message ? error.message : String(error);
1810:       this.logger.writeEvent('action_failure', {
1811:         action_id: action.id,
1812:         duration_ms: Date.now() - started,
1813:         error: message
1814:       });
1815:       this.writeStructuredUpdate(action.id, {
1816:         'Run runtime look at logs': 'contains error still, loop and try again with different results until each individual error is clear.',
1817:         summary: `Runtime request failed. Error: ${message}`,
1818:         'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${action.prompt.length}/0`,
1819:         'Print-approved-by-user?': 'true'
1820:       });
1821:       this.print(`Ollama request failed: ${message}`);
1822:       return;
1823:     }
1824:     this.stopThinking();
1825: 
1826:     let parsed;
1827:     try {
1828:       parsed = JSON.parse(raw);
1829:     } catch {
1830:       parsed = null;
1831:     }
1832: 
1833:     const assistantText = parsed && parsed.message && parsed.message.content
1834:       ? String(parsed.message.content)
1835:       : raw;
1836: 
1837:     this.history.push({ role: 'assistant', content: assistantText });
1838: 
1839:     this.logger.writeEvent('action_result', {
1840:       action_id: action.id,
1841:       duration_ms: Date.now() - started,
1842:       http_status: response.status,
1843:       ok: response.ok,
1844:       response_preview: assistantText.slice(0, 400),
1845:       response_chars: assistantText.length
1846:     });
1847: 
1848:     this.logger.writeTranscript('Assistant', assistantText);
1849:     this.print(assistantText);
1850: 
1851:     const hasRuntimeError = /(syntaxerror|stack overflow|runtime error|error:)/i.test(assistantText);
1852:     const runtimeResult = hasRuntimeError
1853:       ? 'contains error still, retry with different checks until isolated'
1854:       : 'No runtime error anymore = fixed';
1855:     const beforeChars = this.actionMeta[action.id] && this.actionMeta[action.id].prompt_chars_before
1856:       ? this.actionMeta[action.id].prompt_chars_before
1857:       : 0;
1858:     const afterChars = assistantText.length;
1859:     const elapsedMs = Date.now() - started;
1860: 
1861:     this.writeStructuredUpdate(action.id, {
1862:       'Run runtime look at logs': runtimeResult,
1863:       summary: `summarized what just changed, is it fixed: ${hasRuntimeError ? 'No' : 'Yes'}. Runtime error count estimate: ${hasRuntimeError ? 1 : 0}.`,
1864:       'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${beforeChars}/${afterChars}`,
1865:       timing_ms: elapsedMs,
1866:       stop_condition: elapsedMs >= 300000 ? 'Unable to find results or solutions, Try again.' : 'within loop budget'
1867:     });
1868:   }
1869: }
1870: 
1871: const agent = new EthubCliAgent();
1872: agent.start().catch((error) => {
1873:   process.stderr.write(`Fatal startup error: ${error && error.stack ? error.stack : String(error)}\n`);
1874:   process.exit(1);
1875: });
