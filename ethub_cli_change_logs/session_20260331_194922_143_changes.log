0331: function summarizeReasoning(input) {
0332:   const raw = String(input || '').trim();
0333:   const lowered = raw.toLowerCase();
0334:   const keywords = raw
0335:     .split(/\s+/)
0336:     .map((w) => w.replace(/[^a-zA-Z0-9_-]/g, ''))
0337:     .filter(Boolean)
0338:     .slice(0, 12);
0339: 
0340:   let intent = 'general_request';
0341:   if (/error|syntax|stack|trace|bug|fix|crash/.test(lowered)) intent = 'debugging';
0342:   else if (/how|what|why|explain|guide|tutorial/.test(lowered)) intent = 'information_lookup';
0343:   else if (/build|create|make|implement|write/.test(lowered)) intent = 'implementation';
0344: 
0345:   let strategy = 'Use local conversation context then query Ollama for a grounded response.';
0346:   if (intent === 'debugging') {
0347:     strategy = 'Focus on likely fault points, propose checks, and request missing runtime details if needed.';
0348:   }
0349: 
0350:   return {
0351:     query: raw,
0352:     intent,
0353:     keywords,
0354:     strategy,
0355:     note: 'Detailed private chain-of-thought is not exposed; this is a concise decision summary.'
0356:   };
0357: }
