1172:   drawHeader(frame) {
1173:     const p1 = (frame / 90) % 1;
1174:     const p3 = (p1 + 0.66) % 1;
1175:     this.print(LEFT_PAD + rainbowDivider(HEADER_WIDTH, p1));
1176:     ETHUB_ASCII.forEach((line, row) => {
1177:       this.print(LEFT_PAD + rainbowAsciiLine(line, row, ETHUB_ASCII.length, frame));
1178:     });
1179:     this.print(
1180:       LEFT_PAD +
1181:       style(
1182:         `Mode: CHAT | Model: ${this.model} | Change Approval: ${this.requireApproval ? 'ON' : 'OFF'} | cwd: ${this.workspaceRelativePath()}`,
1183:         ANSI.dim
1184:       )
1185:     );
1186:     this.print(LEFT_PAD + rainbowDivider(HEADER_WIDTH, p3));
1187:   }
1188: 
1189:   renderHeaderFrame(frame) {
1190:     const p1 = (frame / 90) % 1;
1191:     const p3 = (p1 + 0.66) % 1;
1192:     const lines = [];
1193:     lines.push(LEFT_PAD + rainbowDivider(HEADER_WIDTH, p1));
1194:     ETHUB_ASCII.forEach((line, row) => {
1195:       lines.push(LEFT_PAD + rainbowAsciiLine(line, row, ETHUB_ASCII.length, frame));
1196:     });
1197:     lines.push(
1198:       LEFT_PAD +
1199:       style(
1200:         `Mode: CHAT | Model: ${this.model} | Approval: ${this.requireApproval ? 'ON' : 'OFF'} | cwd: ${this.workspaceRelativePath()}`,
1201:         ANSI.dim
1202:       )
1203:     );
1204:     lines.push(LEFT_PAD + rainbowDivider(HEADER_WIDTH, p3));
1205:     return lines;
1206:   }
1207: 
1208:   async animateHeader(durationMs = 1200, fps = 20) {
1209:     const frameDelay = Math.max(16, Math.floor(1000 / fps));
1210:     const frames = Math.max(1, Math.floor(durationMs / frameDelay));
1211:     for (let frame = 0; frame < frames; frame += 1) {
1212:       const lines = this.renderHeaderFrame(frame);
1213:       process.stdout.write('\x1b[2J\x1b[H');
1214:       process.stdout.write(`${lines.join('\n')}\n`);
1215:       await new Promise((resolve) => setTimeout(resolve, frameDelay));
1216:     }
1217:     process.stdout.write('\x1b[2J\x1b[H');
1218:     this.drawHeader(frames);
1219:   }
