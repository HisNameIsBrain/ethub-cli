0032: function summarizeReasoning(input) {
0033:   const raw = String(input || '').trim();
0034:   const lowered = raw.toLowerCase();
0035:   const keywords = raw
0036:     .split(/\s+/)
0037:     .map((w) => w.replace(/[^a-zA-Z0-9_-]/g, ''))
0038:     .filter(Boolean)
0039:     .slice(0, 12);
0040: 
0041:   let intent = 'general_request';
0042:   if (/error|syntax|stack|trace|bug|fix|crash/.test(lowered)) intent = 'debugging';
0043:   else if (/how|what|why|explain|guide|tutorial/.test(lowered)) intent = 'information_lookup';
0044:   else if (/build|create|make|implement|write/.test(lowered)) intent = 'implementation';
0045: 
0046:   let strategy = 'Use local conversation context then query Ollama for a grounded response.';
0047:   if (intent === 'debugging') {
0048:     strategy = 'Focus on likely fault points, propose checks, and request missing runtime details if needed.';
0049:   }
0050: 
0051:   return {
0052:     query: raw,
0053:     intent,
0054:     keywords,
0055:     strategy,
0056:     note: 'Detailed private chain-of-thought is not exposed; this is a concise decision summary.'
0057:   };
0058: }
