0198:       .map((line, i) => `${String(i + 1).padStart(4, '0')}: ${line}`)
0199:       .join('\n');
0200: 
0201:     const header =
0202:       `# ETHUB CLI Change Log\n` +
0203:       `session_id: ${this.sessionId}\n` +
0204:       `created_at: ${nowIso()}\n` +
0205:       `source_file: ${sourcePath}\n` +
0206:       `note: New file per session, append-only event/state logs enabled.\n\n` +
0207:       `## Source Snapshot (Line Numbered)\n`;
0208: 
