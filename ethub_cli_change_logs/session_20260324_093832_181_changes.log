0561:       messages: this.history,
0562:       stream: false
0563:     };
0564: 
0565:     let response;
0566:     let raw;
0567:     const started = Date.now();
0568:     this.startThinking();
0569: 
0570:     try {
0571:       response = await fetch(this.ollamaUrl, {
0572:         method: 'POST',
