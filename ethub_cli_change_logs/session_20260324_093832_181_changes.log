0041: function style(text, ...codes) {
0042:   if (!ANSI_ENABLED || !codes.length) return String(text);
0043:   return `${codes.join('')}${text}${ANSI.reset}`;
0044: }
0045: 
0046: function rgb(text, r, g, b) {
0047:   if (!ANSI_ENABLED) return String(text);
0048:   return `\x1b[38;2;${r};${g};${b}m${text}${ANSI.reset}`;
0049: }
0050: 
0051: function hslToRgb(h, s, l) {
0052:   h /= 360;
0053:   const a = s * Math.min(l, 1 - l);
0054:   const f = (n) => {
0055:     const k = (n + h * 12) % 12;
0056:     const c = l - a * Math.max(Math.min(k - 3, 9 - k, 1), -1);
0057:     return Math.round(c * 255);
0058:   };
0059:   return { r: f(0), g: f(8), b: f(4) };
0060: }
0061: 
0062: function rainbowDivider(width, phase) {
0063:   let out = '';
0064:   for (let i = 0; i < width; i += 1) {
0065:     const ch = DIVIDER_CHARS[i % DIVIDER_CHARS.length];
0066:     const p = (i / width + phase) % 1;
0067:     const { r, g, b } = hslToRgb(p * 360, 0.6, 0.65);
0068:     out += rgb(ch, r, g, b);
0069:   }
0070:   return out;
0071: }
0072: 
0073: function rainbowAsciiLine(line, row, totalRows, frame) {
0074:   let out = '';
0075:   const len = Math.max(line.length, 1);
0076: 
0077:   for (let i = 0; i < line.length; i += 1) {
0078:     const ch = line[i];
0079:     if (ch === ' ') {
0080:       out += ' ';
0081:       continue;
0082:     }
0083: 
0084:     const phase = (i / len + row / totalRows + frame * 0.01) % 1;
0085:     const { r, g, b } = hslToRgb(phase * 360, 0.6, 0.65);
0086: 
0087:     let display = ch;
0088:     if ((ch === 'o' || ch === '8') && (frame + i + row) % 47 === 0) {
0089:       display = '+';
0090:     }
0091: 
0092:     out += rgb(display, r, g, b);
0093:   }
0094: 
0095:   return out;
0096: }
