0589:         'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${action.prompt.length}/0`,
0590:         'Print-approved-by-user?': 'true'
0591:       });
0592:       this.print(`Ollama request failed: ${message}`);
0593:       return;
0594:     }
0595:     this.stopThinking();
0596: 
0597:     let parsed;
0598:     try {
0599:       parsed = JSON.parse(raw);
0600:     } catch {
0601:       parsed = null;
0602:     }
0603: 
0604:     const assistantText = parsed && parsed.message && parsed.message.content
0605:       ? String(parsed.message.content)
0606:       : raw;
0607: 
0608:     this.history.push({ role: 'assistant', content: assistantText });
0609: 
0610:     this.logger.writeEvent('action_result', {
0611:       action_id: action.id,
0612:       duration_ms: Date.now() - started,
0613:       http_status: response.status,
0614:       ok: response.ok,
0615:       response_preview: assistantText.slice(0, 400),
0616:       response_chars: assistantText.length
0617:     });
0618: 
0619:     this.logger.writeTranscript('Assistant', assistantText);
0620:     this.print(assistantText);
0621: 
0622:     const hasRuntimeError = /(syntaxerror|stack overflow|runtime error|error:)/i.test(assistantText);
0623:     const runtimeResult = hasRuntimeError
0624:       ? 'contains error still, retry with different checks until isolated'
0625:       : 'No runtime error anymore = fixed';
0626:     const beforeChars = this.actionMeta[action.id] && this.actionMeta[action.id].prompt_chars_before
0627:       ? this.actionMeta[action.id].prompt_chars_before
0628:       : 0;
0629:     const afterChars = assistantText.length;
0630:     const elapsedMs = Date.now() - started;
0631: 
0632:     this.writeStructuredUpdate(action.id, {
0633:       'Run runtime look at logs': runtimeResult,
0634:       summary: `summarized what just changed, is it fixed: ${hasRuntimeError ? 'No' : 'Yes'}. Runtime error count estimate: ${hasRuntimeError ? 1 : 0}.`,
0635:       'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${beforeChars}/${afterChars}`,
0636:       timing_ms: elapsedMs,
0637:       stop_condition: elapsedMs >= 300000 ? 'Unable to find results or solutions, Try again.' : 'within loop budget'
0638:     });
0639:   }
