0569:         return;
0570:       }
0571:       if (value.content && Array.isArray(value.content.parts)) {
0572:         for (const part of value.content.parts) {
0573:           if (typeof part === 'string' && part.trim()) segments.push(part);
0574:         }
0575:       }
0576:       if (typeof value.text === 'string' && value.text.trim()) {
0577:         segments.push(value.text);
0578:       }
0579:       for (const key of Object.keys(value)) {
0580:         if (key === 'content' || key === 'text') continue;
0581:         walk(value[key], depth + 1);
0582:       }
0583:     };
0584: 
0585:     if (parsed) {
0586:       walk(parsed);
0587:     } else {
0588:       segments.push(raw);
0589:     }
0590: 
0591:     for (const segment of segments) {
0592:       const fencePattern = /```(?:[^\n`]*)\n([\s\S]*?)```/g;
0593:       let match;
0594:       while ((match = fencePattern.exec(segment)) !== null) {
0595:         addCandidate(match[1], sourceLabel, 'fenced_code');
0596:       }
0597: 
0598:       const lines = segment.split('\n');
0599:       for (const line of lines) {
0600:         const trimmed = line.trim();
0601:         if (!trimmed || trimmed.length > 220) continue;
0602:         const shellLike = trimmed.replace(/^\$\s*/, '');
0603:         if (/^(ls|pwd|cat|head|tail|wc|rg|grep|find|sed|cp|mv|mkdir|touch|echo|git)\b/.test(shellLike)) {
0604:           addCandidate(shellLike, sourceLabel, 'shell_line');
0605:         }
0606:       }
0607:     }
0608:   }
0609: 
0610:   listArtifactZipFiles() {
0611:     const out = [];
0612:     if (!fs.existsSync(ARTIFACTS_ROOT)) return out;
0613:     const stack = [ARTIFACTS_ROOT];
0614:     while (stack.length) {
0615:       const current = stack.pop();
0616:       let entries = [];
0617:       try {
0618:         entries = fs.readdirSync(current, { withFileTypes: true });
0619:       } catch {
0620:         continue;
0621:       }
0622:       for (const entry of entries) {
0623:         const full = path.join(current, entry.name);
0624:         if (entry.isDirectory()) {
0625:           stack.push(full);
0626:         } else if (entry.isFile() && full.toLowerCase().endsWith('.zip')) {
0627:           out.push(full);
0628:         }
0629:       }
0630:     }
0631:     return out;
0632:   }
0633: 
0634:   collectSkillCandidatesFromArtifacts(limit = 10) {
0635:     const snippets = new Map();
0636:     let scannedSources = 0;
0637:     const cap = Math.max(1, Math.min(MAX_SKILL_CANDIDATES, Number(limit) || 10));
0638:     const addCandidate = (snippetText, sourceLabel, sourceKind) => {
0639:       const normalized = normalizeSnippet(snippetText);
0640:       if (!looksLikeUsefulSnippet(normalized)) return;
0641:       const existing = snippets.get(normalized);
0642:       if (existing) {
0643:         existing.hits += 1;
0644:         existing.sources.add(sourceLabel);
0645:         return;
0646:       }
0647:       snippets.set(normalized, {
0648:         snippet: normalized,
0649:         hits: 1,
0650:         source_kind: sourceKind,
0651:         sources: new Set([sourceLabel])
0652:       });
0653:     };
0654: 
0655:     const zipFiles = this.listArtifactZipFiles();
0656:     for (const zipPath of zipFiles) {
0657:       try {
0658:         const entries = extractTextEntriesFromZip(zipPath, isLikelyTextPath);
0659:         for (const item of entries) {
0660:           scannedSources += 1;
0661:           this.extractSnippetCandidatesFromText(item.text, `${path.basename(zipPath)}:${item.entry}`, addCandidate);
0662:         }
0663:       } catch (error) {
0664:         this.logger.writeEvent('skills_mine_warning', {
0665:           stage: 'zip_read',
0666:           zip: zipPath,
0667:           error: error.message
0668:         });
0669:       }
0670:     }
0671: 
0672:     const directArtifactFiles = [];
0673:     if (fs.existsSync(ARTIFACTS_ROOT)) {
0674:       const stack = [ARTIFACTS_ROOT];
0675:       while (stack.length) {
0676:         const current = stack.pop();
0677:         let entries = [];
0678:         try {
0679:           entries = fs.readdirSync(current, { withFileTypes: true });
0680:         } catch {
0681:           continue;
0682:         }
0683:         for (const entry of entries) {
0684:           const full = path.join(current, entry.name);
0685:           if (entry.isDirectory()) stack.push(full);
0686:           else if (entry.isFile() && !full.toLowerCase().endsWith('.zip') && isLikelyTextPath(full)) directArtifactFiles.push(full);
0687:         }
0688:       }
0689:     }
0690: 
0691:     for (const filePath of directArtifactFiles) {
0692:       let text = '';
0693:       try {
0694:         text = fs.readFileSync(filePath, 'utf8');
0695:       } catch {
0696:         continue;
0697:       }
0698:       scannedSources += 1;
0699:       this.extractSnippetCandidatesFromText(text, this.workspaceRelativePath(filePath), addCandidate);
0700:     }
0701: 
0702:     const ranked = Array.from(snippets.values())
0703:       .sort((a, b) => b.hits - a.hits || b.snippet.length - a.snippet.length)
0704:       .slice(0, cap);
0705: 
0706:     this.skillCandidates = ranked.map((entry, idx) => {
0707:       const snippet = entry.snippet;
0708:       const safety = this.validateSkillCommand(snippet);
0709:       return {
0710:         id: `cand_${idx + 1}`,
0711:         snippet,
0712:         hits: entry.hits,
0713:         source_kind: entry.source_kind,
0714:         sources: Array.from(entry.sources).slice(0, 6),
0715:         executable: safety.ok,
0716:         safety_reason: safety.ok ? '' : safety.reason
0717:       };
0718:     });
0719: 
0720:     this.logger.writeEvent('skills_mined', {
0721:       candidates: this.skillCandidates.length,
0722:       unique_snippets: snippets.size,
0723:       scanned_sources: scannedSources,
0724:       zip_files: zipFiles.length
0725:     });
0726: 
0727:     return {
0728:       candidates: this.skillCandidates.length,
0729:       uniqueSnippets: snippets.size,
0730:       scannedSources,
0731:       zipFiles: zipFiles.length
0732:     };
0733:   }
0734: 
0735:   findCandidate(query) {
0736:     const q = String(query || '').trim();
0737:     if (!q) return null;
0738:     return this.skillCandidates.find((c) => c.id === q) || null;
0739:   }
0740: 
0741:   findSkill(query) {
0742:     const q = String(query || '').trim().toLowerCase();
0743:     if (!q) return null;
0744:     return this.skills.find((s) => s.id.toLowerCase() === q || s.name.toLowerCase() === q) || null;
0745:   }
