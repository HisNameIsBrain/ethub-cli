0127: function rainbowDivider(width, phase) {
0128:   let out = '';
0129:   for (let i = 0; i < width; i += 1) {
0130:     const ch = DIVIDER_CHARS[i % DIVIDER_CHARS.length];
0131:     const p = (i / width + phase) % 1;
0132:     const { r, g, b } = hslToRgb(p * 360, 0.6, 0.65);
0133:     out += rgb(ch, r, g, b);
