1004:   resolvePathInWorkspace(inputPath, expected = 'any') {
1005:     const raw = String(inputPath || '').trim();
1006:     if (!raw) return { error: 'path is required' };
1007:     const normalized = raw === '~' ? os.homedir() : raw;
1008:     const resolved = path.resolve(process.cwd(), normalized);
1009:     const root = path.resolve(this.workspaceRoot);
1010:     const inRoot = resolved === root || resolved.startsWith(`${root}${path.sep}`);
1011:     if (!inRoot) {
1012:       return { error: `path escapes workspace root: ${root}` };
1013:     }
1014: 
1015:     if (expected === 'exists') {
1016:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
1017:     }
1018:     if (expected === 'file' || expected === 'dir') {
1019:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
1020:       let st;
1021:       try {
1022:         st = fs.statSync(resolved);
1023:       } catch (error) {
1024:         return { error: `unable to stat path: ${error.message}` };
1025:       }
1026:       if (expected === 'file' && !st.isFile()) return { error: 'path is not a file' };
1027:       if (expected === 'dir' && !st.isDirectory()) return { error: 'path is not a directory' };
1028:     }
1029: 
1030:     return { path: resolved };
1031:   }
