1135:   async handleCommand(input) {
1136:     const [cmd, ...args] = input.split(/\s+/);
1137:     const command = cmd.toLowerCase();
1138:     this.logger.writeEvent('subcommand', { command, args });
1139: 
1140:     if (command === '/help') {
1141:       this.print('Commands: /help, /status, /model <name>, /approve changes on|off, /readfile <path>, /writefile <path> -- <content>, /cd <path>, /skills <mine|candidates|add|list|show|run>, /yes, /no, /exit');
1142:       this.print('Skills flow: /skills mine 10 -> /skills add cand_1 my_skill -> /yes -> /skills run my_skill -> /yes');
1143:       return;
1144:     }
1145: 
1146:     if (command === '/status') {
1147:       this.print(safeJson({
1148:         model: this.model,
1149:         ollama_url: this.ollamaUrl,
1150:         require_approval_for_changes: this.requireApproval,
1151:         skills_count: this.skills.length,
1152:         skill_candidates_count: this.skillCandidates.length,
1153:         dashboard_url: this.dashboardInfo && this.dashboardInfo.dashboard_url ? this.dashboardInfo.dashboard_url : null,
1154:         history_count: this.history.length,
1155:         pending_action: this.pendingAction ? this.pendingAction.id : null
1156:       }));
1157:       return;
1158:     }
1159: 
1160:     if (command === '/model') {
1161:       const nextModel = args.join(' ').trim();
1162:       if (!nextModel) {
1163:         this.print(`Current model: ${this.model}`);
1164:         return;
1165:       }
1166:       this.model = nextModel;
1167:       this.print(`Model updated: ${this.model}`);
1168:       this.logger.writeEvent('config_update', { key: 'model', value: this.model });
1169:       return;
1170:     }
1171: 
1172:     if (command === '/approve') {
1173:       const target = (args[0] || '').toLowerCase();
1174:       const mode = (args[1] || '').toLowerCase();
1175:       const legacyMode = target;
1176: 
1177:       if (target === 'changes' && (mode === 'on' || mode === 'off')) {
1178:         this.requireApproval = mode === 'on';
1179:         this.print(`Change approval mode: ${mode}`);
1180:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1181:         return;
1182:       }
1183: 
1184:       if (legacyMode === 'on' || legacyMode === 'off') {
1185:         this.requireApproval = legacyMode === 'on';
1186:         this.print(`Change approval mode: ${legacyMode}`);
1187:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1188:         return;
1189:       }
1190: 
1191:       if (!target) {
1192:         this.print(`Change approval mode: ${this.requireApproval ? 'on' : 'off'}`);
1193:         return;
1194:       }
1195: 
1196:       this.print('Usage: /approve changes on|off');
1197:       return;
1198:     }
1199: 
1200:     if (command === '/yes') {
1201:       if (!this.pendingAction) {
1202:         this.print('No pending action to approve.');
1203:         return;
1204:       }
1205:       const action = this.pendingAction;
1206:       this.pendingAction = null;
1207:       this.logger.writeEvent('approval', { action_id: action.id, approved: true });
1208:       this.writeStructuredUpdate(action.id, {
1209:         'Print-approved-by-user?': 'true',
1210:         approved: true
1211:       });
1212:       await this.executePendingAction(action);
1213:       return;
1214:     }
1215: 
1216:     if (command === '/no') {
1217:       if (!this.pendingAction) {
1218:         this.print('No pending action to reject.');
1219:         return;
1220:       }
1221:       const action = this.pendingAction;
1222:       this.pendingAction = null;
1223:       this.logger.writeEvent('approval', { action_id: action.id, approved: false });
1224:       this.writeStructuredUpdate(action.id, {
1225:         'Print-approved-by-user?': 'false',
1226:         approved: false,
1227:         summary: 'Action was rejected by user before runtime execution.',
1228:         'Run runtime look at logs': 'skipped (approval rejected)'
1229:       });
1230:       this.print(`Action ${action.id} skipped.`);
1231:       return;
1232:     }
1233: 
1234:     if (command === '/exit') {
1235:       this.rl.close();
1236:       return;
1237:     }
1238: 
1239:     if (command === '/cd') {
1240:       const rawTarget = input.replace(/^\/cd\s*/i, '').trim();
1241:       if (!rawTarget) {
1242:         this.print(`Current directory: ${process.cwd()}`);
1243:         return;
1244:       }
1245:       const resolved = this.resolvePathInWorkspace(rawTarget, 'dir');
1246:       if (resolved.error) {
1247:         this.print(`${style('cd denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1248:         return;
1249:       }
1250:       process.chdir(resolved.path);
1251:       this.refreshPrompt();
1252:       this.logger.writeEvent('cwd_changed', {
1253:         cwd: process.cwd(),
1254:         workspace_relative: this.workspaceRelativePath()
1255:       });
1256:       this.print(style(`Directory changed to ${this.workspaceRelativePath()}`, ANSI.cyan));
1257:       return;
1258:     }
1259: 
1260:     if (command === '/readfile') {
1261:       const rawPath = input.replace(/^\/readfile\s*/i, '').trim();
1262:       if (!rawPath) {
1263:         this.print('Usage: /readfile <path>');
1264:         return;
1265:       }
1266:       const resolved = this.resolvePathInWorkspace(rawPath, 'file');
1267:       if (resolved.error) {
1268:         this.print(`${style('readfile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1269:         return;
1270:       }
1271:       const action = {
1272:         id: `act_${Date.now()}`,
1273:         type: 'read_file',
1274:         payload: {
1275:           path: resolved.path,
1276:           rel: this.workspaceRelativePath(resolved.path)
1277:         },
1278:         created_at: nowIso()
1279:       };
1280:       this.queueApprovalAction(
1281:         action,
1282:         `${style('Read request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel}`
1283:       );
1284:       return;
1285:     }
1286: 
1287:     if (command === '/writefile') {
1288:       const raw = input.replace(/^\/writefile\s*/i, '');
1289:       const splitIndex = raw.indexOf(' -- ');
1290:       if (splitIndex === -1) {
1291:         this.print('Usage: /writefile <path> -- <content>');
1292:         return;
1293:       }
1294:       const rawPath = raw.slice(0, splitIndex).trim();
1295:       const content = raw.slice(splitIndex + 4);
1296:       if (!rawPath) {
1297:         this.print('Usage: /writefile <path> -- <content>');
1298:         return;
1299:       }
1300:       const resolved = this.resolvePathInWorkspace(rawPath, 'any');
1301:       if (resolved.error) {
1302:         this.print(`${style('writefile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1303:         return;
1304:       }
1305:       const action = {
1306:         id: `act_${Date.now()}`,
1307:         type: 'write_file',
1308:         payload: {
1309:           path: resolved.path,
1310:           rel: this.workspaceRelativePath(resolved.path),
1311:           content
1312:         },
1313:         created_at: nowIso()
1314:       };
1315:       this.queueApprovalAction(
1316:         action,
1317:         `${style('Write request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel} (${content.length} chars)`
1318:       );
1319:       return;
1320:     }
1321: 
1322:     if (command === '/skills') {
1323:       const sub = (args[0] || '').toLowerCase();
1324:       if (!sub || sub === 'help') {
1325:         this.print('Usage:');
1326:         this.print('/skills mine [count]');
1327:         this.print('/skills candidates');
1328:         this.print('/skills add <candidate_id> <skill_name>');
1329:         this.print('/skills list');
1330:         this.print('/skills show <skill_id|skill_name>');
1331:         this.print('/skills run <skill_id|skill_name>');
1332:         return;
1333:       }
1334: 
1335:       if (sub === 'mine') {
1336:         const count = Number(args[1] || 10);
1337:         const result = this.collectSkillCandidatesFromArtifacts(count);
1338:         this.print(style(`Mined ${result.candidates} candidate skill patterns from artifacts (sources scanned: ${result.scannedSources}).`, ANSI.cyan));
1339:         for (const c of this.skillCandidates) {
1340:           this.print(style(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.yellow));
1341:           this.print('```');
1342:           this.print(c.snippet);
1343:           this.print('```');
1344:           if (!c.executable) this.print(style(`reason: ${c.safety_reason}`, ANSI.dim));
1345:         }
1346:         return;
1347:       }
1348: 
1349:       if (sub === 'candidates') {
1350:         if (!this.skillCandidates.length) {
1351:           this.print('No candidates loaded. Run /skills mine first.');
1352:           return;
1353:         }
1354:         for (const c of this.skillCandidates) {
1355:           this.print(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'} source_kind=${c.source_kind}`);
1356:         }
1357:         return;
1358:       }
1359: 
1360:       if (sub === 'add') {
1361:         const candidateId = args[1] || '';
1362:         const skillName = args.slice(2).join(' ').trim();
1363:         if (!candidateId || !skillName) {
1364:           this.print('Usage: /skills add <candidate_id> <skill_name>');
1365:           return;
1366:         }
1367:         const existing = this.findSkill(skillName);
1368:         if (existing) {
1369:           this.print(`Skill already exists: ${existing.name} (${existing.id})`);
1370:           return;
1371:         }
1372:         const candidate = this.findCandidate(candidateId);
1373:         if (!candidate) {
1374:           this.print(`Candidate not found: ${candidateId}`);
1375:           return;
1376:         }
1377:         const action = {
1378:           id: `act_${Date.now()}`,
1379:           type: 'add_skill',
1380:           payload: {
1381:             skill_name: skillName,
1382:             source_candidate: candidate.id,
1383:             snippet: candidate.snippet,
1384:             executable: candidate.executable
1385:           },
1386:           created_at: nowIso()
1387:         };
1388:         this.queueApprovalAction(
1389:           action,
1390:           `${style('Add skill queued:', ANSI.bold, ANSI.yellow)} ${skillName} from ${candidate.id}`
1391:         );
1392:         return;
1393:       }
1394: 
1395:       if (sub === 'list') {
1396:         if (!this.skills.length) {
1397:           this.print(`No approved skills yet. Skills file: ${this.skillsPath}`);
1398:           return;
1399:         }
1400:         for (const skill of this.skills) {
1401:           this.print(`[${skill.id}] ${skill.name} | executable=${skill.executable ? 'yes' : 'no'} | source=${skill.source}`);
1402:         }
1403:         return;
1404:       }
1405: 
1406:       if (sub === 'show') {
1407:         const query = args.slice(1).join(' ').trim();
1408:         if (!query) {
1409:           this.print('Usage: /skills show <skill_id|skill_name>');
1410:           return;
1411:         }
1412:         const skill = this.findSkill(query);
1413:         if (!skill) {
1414:           this.print(`Skill not found: ${query}`);
1415:           return;
1416:         }
1417:         this.print(style(`[${skill.id}] ${skill.name}`, ANSI.bold, ANSI.cyan));
1418:         this.print('```');
1419:         this.print(skill.snippet);
1420:         this.print('```');
1421:         return;
1422:       }
1423: 
1424:       if (sub === 'run') {
1425:         const query = args.slice(1).join(' ').trim();
1426:         if (!query) {
1427:           this.print('Usage: /skills run <skill_id|skill_name>');
1428:           return;
1429:         }
1430:         const skill = this.findSkill(query);
1431:         if (!skill) {
1432:           this.print(`Skill not found: ${query}`);
1433:           return;
1434:         }
1435:         const validation = this.validateSkillCommand(skill.snippet);
1436:         if (!validation.ok) {
1437:           this.print(`${style('Skill is not executable:', ANSI.bold, ANSI.red)} ${validation.reason}`);
1438:           return;
1439:         }
1440:         const action = {
1441:           id: `act_${Date.now()}`,
1442:           type: 'run_skill',
1443:           payload: {
1444:             skill_id: skill.id,
1445:             skill_name: skill.name,
1446:             snippet: skill.snippet
1447:           },
1448:           created_at: nowIso()
1449:         };
1450:         this.queueApprovalAction(
1451:           action,
1452:           `${style('Skill execution queued:', ANSI.bold, ANSI.yellow)} ${skill.name}\n${skill.snippet}`
1453:         );
1454:         return;
1455:       }
1456: 
1457:       this.print(`Unknown skills subcommand: ${sub}`);
1458:       return;
1459:     }
1460: 
1461:     this.print(`Unknown command: ${command}. Use /help.`);
1462:   }
