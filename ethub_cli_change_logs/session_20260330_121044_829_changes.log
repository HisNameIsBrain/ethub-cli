0116: function hslToRgb(h, s, l) {
0117:   h /= 360;
0118:   const a = s * Math.min(l, 1 - l);
0119:   const f = (n) => {
0120:     const k = (n + h * 12) % 12;
0121:     const c = l - a * Math.max(Math.min(k - 3, 9 - k, 1), -1);
0122:     return Math.round(c * 255);
0123:   };
0124:   return { r: f(0), g: f(8), b: f(4) };
0125: }
