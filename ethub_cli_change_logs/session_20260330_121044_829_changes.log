0138: function rainbowAsciiLine(line, row, totalRows, frame) {
0139:   let out = '';
0140:   const len = Math.max(line.length, 1);
0141: 
0142:   for (let i = 0; i < line.length; i += 1) {
0143:     const ch = line[i];
0144:     if (ch === ' ') {
0145:       out += ' ';
0146:       continue;
0147:     }
0148: 
0149:     const phase = (i / len + row / totalRows + frame * 0.01) % 1;
0150:     const { r, g, b } = hslToRgb(phase * 360, 0.6, 0.65);
0151: 
0152:     let display = ch;
0153:     if ((ch === 'o' || ch === '8') && (frame + i + row) % 47 === 0) {
0154:       display = '+';
0155:     }
0156: 
0157:     out += rgb(display, r, g, b);
0158:   }
0159: 
0160:   return out;
0161: }
