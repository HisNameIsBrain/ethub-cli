0262: function extractTextEntriesFromZip(zipPath, shouldInclude) {
0263:   const out = [];
0264:   const data = fs.readFileSync(zipPath);
0265:   const minEocd = 22;
0266:   const maxComment = 0xffff;
0267:   const startSearch = Math.max(0, data.length - (minEocd + maxComment));
0268:   let eocd = -1;
0269:   for (let i = data.length - minEocd; i >= startSearch; i -= 1) {
0270:     if (data.readUInt32LE(i) === 0x06054b50) {
0271:       eocd = i;
0272:       break;
0273:     }
0274:   }
0275:   if (eocd < 0) throw new Error('zip EOCD signature not found');
0276: 
0277:   const centralDirSize = data.readUInt32LE(eocd + 12);
0278:   const centralDirOffset = data.readUInt32LE(eocd + 16);
0279:   const centralDirEnd = centralDirOffset + centralDirSize;
0280:   let cursor = centralDirOffset;
0281: 
0282:   while (cursor + 46 <= centralDirEnd && cursor + 46 <= data.length) {
0283:     const sig = data.readUInt32LE(cursor);
0284:     if (sig !== 0x02014b50) break;
0285:     const compressionMethod = data.readUInt16LE(cursor + 10);
0286:     const compressedSize = data.readUInt32LE(cursor + 20);
0287:     const fileNameLen = data.readUInt16LE(cursor + 28);
0288:     const extraLen = data.readUInt16LE(cursor + 30);
0289:     const commentLen = data.readUInt16LE(cursor + 32);
0290:     const localHeaderOffset = data.readUInt32LE(cursor + 42);
0291:     const nameStart = cursor + 46;
0292:     const nameEnd = nameStart + fileNameLen;
0293:     const entryName = data.slice(nameStart, nameEnd).toString('utf8');
0294:     const next = nameEnd + extraLen + commentLen;
0295:     cursor = next;
0296: 
0297:     if (!shouldInclude(entryName)) continue;
0298:     if (entryName.endsWith('/')) continue;
0299:     if (localHeaderOffset + 30 > data.length) continue;
0300:     if (data.readUInt32LE(localHeaderOffset) !== 0x04034b50) continue;
0301: 
0302:     const localNameLen = data.readUInt16LE(localHeaderOffset + 26);
0303:     const localExtraLen = data.readUInt16LE(localHeaderOffset + 28);
0304:     const payloadStart = localHeaderOffset + 30 + localNameLen + localExtraLen;
0305:     const payloadEnd = payloadStart + compressedSize;
0306:     if (payloadEnd > data.length) continue;
0307: 
0308:     const compressed = data.slice(payloadStart, payloadEnd);
0309:     let decoded;
0310:     if (compressionMethod === 0) {
0311:       decoded = compressed;
0312:     } else if (compressionMethod === 8) {
0313:       decoded = zlib.inflateRawSync(compressed);
0314:     } else {
0315:       continue;
0316:     }
0317: 
0318:     out.push({
0319:       entry: entryName,
0320:       text: decoded.toString('utf8')
0321:     });
0322:   }
0323:   return out;
0324: }
