0326: function summarizeReasoning(input) {
0327:   const raw = String(input || '').trim();
0328:   const lowered = raw.toLowerCase();
0329:   const keywords = raw
0330:     .split(/\s+/)
0331:     .map((w) => w.replace(/[^a-zA-Z0-9_-]/g, ''))
0332:     .filter(Boolean)
0333:     .slice(0, 12);
0334: 
0335:   let intent = 'general_request';
0336:   if (/error|syntax|stack|trace|bug|fix|crash/.test(lowered)) intent = 'debugging';
0337:   else if (/how|what|why|explain|guide|tutorial/.test(lowered)) intent = 'information_lookup';
0338:   else if (/build|create|make|implement|write/.test(lowered)) intent = 'implementation';
0339: 
0340:   let strategy = 'Use local conversation context then query Ollama for a grounded response.';
0341:   if (intent === 'debugging') {
0342:     strategy = 'Focus on likely fault points, propose checks, and request missing runtime details if needed.';
0343:   }
0344: 
0345:   return {
0346:     query: raw,
0347:     intent,
0348:     keywords,
0349:     strategy,
0350:     note: 'Detailed private chain-of-thought is not exposed; this is a concise decision summary.'
0351:   };
0352: }
