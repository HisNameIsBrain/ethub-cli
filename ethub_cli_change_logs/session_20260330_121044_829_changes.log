0747:   validatePathToken(token) {
0748:     const raw = String(token || '').trim();
0749:     if (!raw) return { ok: true };
0750:     if (raw === '-' || raw.startsWith('-')) return { ok: true };
0751:     if (raw.startsWith('/')) return { ok: false, reason: `Absolute paths are blocked (${raw}).` };
0752:     if (raw.includes('..')) return { ok: false, reason: `Parent traversal is blocked (${raw}).` };
0753:     const resolved = path.resolve(process.cwd(), raw);
0754:     if (!isPathInsideRoot(this.workspaceRoot, resolved)) {
0755:       return { ok: false, reason: `Path escapes workspace root (${raw}).` };
0756:     }
0757:     return { ok: true };
0758:   }
0759: 
0760:   validateSkillCommand(snippet) {
0761:     const commandText = normalizeSnippet(snippet);
0762:     if (!commandText) return { ok: false, reason: 'Empty snippet.' };
0763:     const lines = commandText.split('\n').map((l) => l.trim()).filter(Boolean);
0764:     if (lines.length !== 1) return { ok: false, reason: 'Only single-line shell skills are executable.' };
0765:     const line = lines[0];
0766:     if (BLOCKED_COMMAND_PATTERN.test(line)) {
0767:       return { ok: false, reason: 'Command contains blocked shell operators.' };
0768:     }
0769: 
0770:     const parsed = tokenizeCommandLine(line);
0771:     if (parsed.error) return { ok: false, reason: parsed.error };
0772:     const tokens = parsed.tokens || [];
0773:     if (!tokens.length) return { ok: false, reason: 'No command token found.' };
0774: 
0775:     const cmd = tokens[0];
0776:     if (!SAFE_SKILL_COMMANDS.has(cmd)) {
0777:       return { ok: false, reason: `Command '${cmd}' is not allowlisted.` };
0778:     }
0779:     if (cmd === 'git') {
0780:       const sub = (tokens[1] || '').toLowerCase();
0781:       if (!['status', 'diff', 'log', 'show', 'branch', 'rev-parse'].includes(sub)) {
0782:         return { ok: false, reason: `git '${sub || '(none)'}' is blocked.` };
0783:       }
0784:     }
0785: 
0786:     for (let i = 1; i < tokens.length; i += 1) {
0787:       const pathCheck = this.validatePathToken(tokens[i]);
0788:       if (!pathCheck.ok) return pathCheck;
0789:     }
0790:     return { ok: true, command: cmd, tokens };
0791:   }
0792: 
0793:   async runSkillCommand(action) {
0794:     const payload = action && action.payload ? action.payload : {};
0795:     const skillName = payload.skill_name || payload.skill_id || 'unknown';
0796:     const snippet = String(payload.snippet || '');
0797:     const validation = this.validateSkillCommand(snippet);
0798:     if (!validation.ok) {
0799:       this.print(`${style('Skill execution denied:', ANSI.bold, ANSI.red)} ${validation.reason}`);
0800:       this.logger.writeEvent('skill_run_denied', {
0801:         action_id: action.id,
0802:         skill: skillName,
0803:         reason: validation.reason
0804:       });
0805:       return;
0806:     }
0807: 
0808:     const tokens = validation.tokens;
0809:     const cmd = tokens[0];
0810:     const args = tokens.slice(1);
0811:     this.print(style(`[SKILL RUN] ${skillName}: ${snippet}`, ANSI.bold, ANSI.cyan));
0812: 
0813:     const result = await new Promise((resolve) => {
0814:       const child = spawn(cmd, args, {
0815:         cwd: process.cwd(),
0816:         stdio: ['ignore', 'pipe', 'pipe'],
0817:         shell: false
0818:       });
0819: 
0820:       let stdout = '';
0821:       let stderr = '';
0822:       let finished = false;
0823:       const timer = setTimeout(() => {
0824:         if (finished) return;
0825:         child.kill('SIGTERM');
0826:       }, 120000);
0827: 
0828:       child.stdout.on('data', (chunk) => {
0829:         if (stdout.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0830:         stdout += chunk.toString('utf8');
0831:       });
0832:       child.stderr.on('data', (chunk) => {
0833:         if (stderr.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0834:         stderr += chunk.toString('utf8');
0835:       });
0836:       child.on('error', (error) => {
0837:         clearTimeout(timer);
0838:         finished = true;
0839:         resolve({ code: -1, signal: null, stdout, stderr: `${stderr}\n${error.message}`.trim() });
0840:       });
0841:       child.on('close', (code, signal) => {
0842:         clearTimeout(timer);
0843:         finished = true;
0844:         resolve({ code, signal, stdout, stderr });
0845:       });
0846:     });
0847: 
0848:     if (result.stdout) {
0849:       this.print(style('[STDOUT]', ANSI.dim));
0850:       this.print(truncateText(result.stdout, MAX_COMMAND_OUTPUT_BYTES));
0851:     }
0852:     if (result.stderr) {
0853:       this.print(style('[STDERR]', ANSI.dim));
0854:       this.print(truncateText(result.stderr, MAX_COMMAND_OUTPUT_BYTES));
0855:     }
0856:     this.print(style(`[SKILL EXIT] code=${result.code} signal=${result.signal || 'none'}`, ANSI.dim));
0857:     this.logger.writeEvent('skill_run_complete', {
0858:       action_id: action.id,
0859:       skill: skillName,
0860:       code: result.code,
0861:       signal: result.signal,
0862:       stdout_chars: result.stdout.length,
0863:       stderr_chars: result.stderr.length
0864:     });
0865:   }
