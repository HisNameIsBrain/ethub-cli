1464:   async executePendingAction(action) {
1465:     if (!action) return;
1466:     if (action.type === 'ollama_chat') {
1467:       await this.executeAction(action);
1468:       return;
1469:     }
1470:     if (action.type === 'read_file') {
1471:       this.runReadFileAction(action);
1472:       return;
1473:     }
1474:     if (action.type === 'write_file') {
1475:       this.runWriteFileAction(action);
1476:       return;
1477:     }
1478:     if (action.type === 'add_skill') {
1479:       this.runAddSkillAction(action);
1480:       return;
1481:     }
1482:     if (action.type === 'run_skill') {
1483:       await this.runSkillCommand(action);
1484:       return;
1485:     }
1486:     this.print(`Unsupported pending action type: ${action.type}`);
1487:   }
1488: 
1489:   runReadFileAction(action) {
1490:     const filePath = action && action.payload ? action.payload.path : '';
1491:     if (!filePath || !fs.existsSync(filePath)) {
1492:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} file no longer exists.`);
1493:       return;
1494:     }
1495:     let text;
1496:     try {
1497:       text = fs.readFileSync(filePath, 'utf8');
1498:     } catch (error) {
1499:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1500:       return;
1501:     }
1502:     const shown = truncateText(text, MAX_READFILE_BYTES);
1503:     const rel = action.payload.rel || this.workspaceRelativePath(filePath);
1504:     this.print(style(`\n[READFILE] ${rel}`, ANSI.bold, ANSI.cyan));
1505:     this.print(style(`bytes: ${Buffer.byteLength(text, 'utf8')} | shown: ${Buffer.byteLength(shown, 'utf8')}`, ANSI.dim));
1506:     this.print(shown);
1507:     this.logger.writeEvent('read_file', {
1508:       action_id: action.id,
1509:       file: filePath,
1510:       bytes: Buffer.byteLength(text, 'utf8'),
1511:       shown_bytes: Buffer.byteLength(shown, 'utf8')
1512:     });
1513:   }
1514: 
1515:   runWriteFileAction(action) {
1516:     const filePath = action && action.payload ? action.payload.path : '';
1517:     const content = action && action.payload ? String(action.payload.content || '') : '';
1518:     if (!filePath) {
1519:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} missing target path.`);
1520:       return;
1521:     }
1522:     try {
1523:       ensureDir(path.dirname(filePath));
1524:       fs.writeFileSync(filePath, content, 'utf8');
1525:     } catch (error) {
1526:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1527:       return;
1528:     }
1529:     this.print(style(`[WRITEFILE] wrote ${content.length} chars to ${action.payload.rel}`, ANSI.bold, ANSI.cyan));
1530:     this.logger.writeEvent('write_file', {
1531:       action_id: action.id,
1532:       file: filePath,
1533:       chars: content.length
1534:     });
1535:   }
1536: 
1537:   runAddSkillAction(action) {
1538:     const payload = action && action.payload ? action.payload : {};
1539:     const name = String(payload.skill_name || '').trim();
1540:     const snippet = String(payload.snippet || '');
1541:     if (!name || !snippet) {
1542:       this.print(`${style('Add skill failed:', ANSI.bold, ANSI.red)} missing skill name or snippet.`);
1543:       return;
1544:     }
1545:     const duplicate = this.findSkill(name);
1546:     if (duplicate) {
1547:       this.print(`${style('Add skill skipped:', ANSI.bold, ANSI.red)} skill already exists (${duplicate.id}).`);
1548:       return;
1549:     }
1550: 
1551:     const skill = {
1552:       id: `skill_${Date.now()}`,
1553:       name,
1554:       snippet,
1555:       source: `candidate:${payload.source_candidate || 'unknown'}`,
1556:       executable: Boolean(payload.executable),
1557:       created_at: nowIso()
1558:     };
1559:     this.skills.push(skill);
1560:     this.saveSkills();
1561:     this.print(style(`[SKILL ADDED] ${skill.name} (${skill.id}) executable=${skill.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.cyan));
1562:     this.logger.writeEvent('skill_added', {
1563:       action_id: action.id,
1564:       skill_id: skill.id,
1565:       skill_name: skill.name,
1566:       executable: skill.executable
1567:     });
1568:   }
1569: 
1570:   async handleUserPrompt(input) {
1571:     const reasoning = summarizeReasoning(input);
1572:     const action = {
1573:       id: `act_${Date.now()}`,
1574:       type: 'ollama_chat',
1575:       prompt: input,
1576:       reasoning_summary: reasoning,
1577:       created_at: nowIso()
1578:     };
1579: 
1580:     this.logger.writeTranscript('User', input);
1581:     this.logger.writeEvent('user_prompt', {
1582:       text: input,
1583:       reasoning_summary: reasoning,
1584:       proposed_action: { id: action.id, type: action.type }
1585:     });
1586:     this.actionMeta[action.id] = {
1587:       prompt: input,
1588:       prompt_chars_before: input.length
1589:     };
1590: 
1591:     this.logger.writeStructuredRecord({
1592:       timestamp: nowIso(),
1593:       query: input,
1594:       reasoning: {
1595:         query: reasoning.query,
1596:         intent: reasoning.intent,
1597:         keywords: reasoning.keywords,
1598:         search_strategy: reasoning.strategy
1599:       },
1600:       actions: {
1601:         action: 'local_ollama_request',
1602:         sources: ['ollama_localhost'],
1603:         Context: 'Analyzing locally via Ollama only; no OpenAI/Gemini/external model APIs.'
1604:       },
1605:       Commands: "ls, grep, nano, cd, nano 'create-new-file-diff-snippet-number+1.sh', regen entire file with changes then save, cp -rf old/path/to/file move/to/backup/path/file, rm old/path/to/file, bash create-new-file-(diff-snippet-line:character)-(number)+1, sed -i 's/old/new' \"$file\"",
1606:       Diff: '+,-',
1607:       Path: 'path/to/file:line:character',
1608:       action_id: action.id,
1609:       'Print-approved-by-user?': 'not_required (run commands)',
1610:       'Run runtime look at logs': 'pending',
1611:       summary: 'pending',
1612:       'Number of characters changed': 'pending'
1613:     });
1614: 
1615:     await this.executeAction(action);
1616:   }
1617: 
1618:   writeStructuredUpdate(actionId, patch) {
1619:     this.logger.writeStructuredRecord({
1620:       timestamp: nowIso(),
1621:       action_id: actionId,
1622:       update: patch
1623:     });
1624:   }
1625: 
1626:   async executeAction(action) {
1627:     if (!action || action.type !== 'ollama_chat') {
1628:       this.logger.writeEvent('action_error', { message: 'Unsupported action type', action });
1629:       this.writeStructuredUpdate(action && action.id ? action.id : 'unknown', {
1630:         'Run runtime look at logs': 'contains error still, unsupported action type',
1631:         summary: 'Unsupported action type encountered before runtime request.',
1632:         'Number of characters changed': 'previous character amount in file before cmd/new total character count added: 0/0'
1633:       });
1634:       this.print('Unsupported action.');
1635:       return;
1636:     }
1637: 
1638:     this.logger.writeEvent('action_start', {
1639:       action_id: action.id,
1640:       type: action.type,
1641:       target: this.ollamaUrl,
1642:       model: this.model,
1643:       prompt_chars: action.prompt.length,
1644:       reasoning_summary: action.reasoning_summary
1645:     });
1646: 
1647:     this.history.push({ role: 'user', content: action.prompt });
1648: 
1649:     const payload = {
1650:       model: this.model,
1651:       messages: this.history,
1652:       stream: false
1653:     };
1654: 
1655:     let response;
1656:     let raw;
1657:     const started = Date.now();
1658:     this.startThinking();
1659: 
1660:     try {
1661:       response = await fetch(this.ollamaUrl, {
1662:         method: 'POST',
1663:         headers: { 'Content-Type': 'application/json' },
1664:         body: JSON.stringify(payload)
1665:       });
1666: 
1667:       raw = await response.text();
1668:     } catch (error) {
1669:       this.stopThinking();
1670:       const message = error && error.message ? error.message : String(error);
1671:       this.logger.writeEvent('action_failure', {
1672:         action_id: action.id,
1673:         duration_ms: Date.now() - started,
1674:         error: message
1675:       });
1676:       this.writeStructuredUpdate(action.id, {
1677:         'Run runtime look at logs': 'contains error still, loop and try again with different results until each individual error is clear.',
1678:         summary: `Runtime request failed. Error: ${message}`,
1679:         'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${action.prompt.length}/0`,
1680:         'Print-approved-by-user?': 'true'
1681:       });
1682:       this.print(`Ollama request failed: ${message}`);
1683:       return;
1684:     }
1685:     this.stopThinking();
1686: 
1687:     let parsed;
1688:     try {
1689:       parsed = JSON.parse(raw);
1690:     } catch {
1691:       parsed = null;
1692:     }
1693: 
1694:     const assistantText = parsed && parsed.message && parsed.message.content
1695:       ? String(parsed.message.content)
