1090:     for (let frame = 0; frame < frames; frame += 1) {
1091:       const lines = this.renderHeaderFrame(frame);
1092:       process.stdout.write('\x1b[2J\x1b[H');
1093:       process.stdout.write(`${lines.join('\n')}\n`);
1094:       await new Promise((resolve) => setTimeout(resolve, frameDelay));
1095:     }
1096:     process.stdout.write('\x1b[2J\x1b[H');
1097:     this.drawHeader(frames);
1098:   }
