0114: function summarizeReasoning(input) {
0115:   const raw = String(input || '').trim();
0116:   const lowered = raw.toLowerCase();
0117:   const keywords = raw
0118:     .split(/\s+/)
0119:     .map((w) => w.replace(/[^a-zA-Z0-9_-]/g, ''))
0120:     .filter(Boolean)
0121:     .slice(0, 12);
0122: 
0123:   let intent = 'general_request';
0124:   if (/error|syntax|stack|trace|bug|fix|crash/.test(lowered)) intent = 'debugging';
0125:   else if (/how|what|why|explain|guide|tutorial/.test(lowered)) intent = 'information_lookup';
0126:   else if (/build|create|make|implement|write/.test(lowered)) intent = 'implementation';
0127: 
0128:   let strategy = 'Use local conversation context then query Ollama for a grounded response.';
0129:   if (intent === 'debugging') {
0130:     strategy = 'Focus on likely fault points, propose checks, and request missing runtime details if needed.';
0131:   }
0132: 
0133:   return {
0134:     query: raw,
0135:     intent,
0136:     keywords,
0137:     strategy,
0138:     note: 'Detailed private chain-of-thought is not exposed; this is a concise decision summary.'
0139:   };
0140: }
