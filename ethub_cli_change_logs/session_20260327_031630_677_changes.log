0432:   async handleCommand(input) {
0433:     const [cmd, ...args] = input.split(/\s+/);
0434:     const command = cmd.toLowerCase();
0435:     this.logger.writeEvent('subcommand', { command, args });
0436: 
0437:     if (command === '/help') {
0438:       this.print('Commands: /help, /status, /model <name>, /approve changes on|off, /yes, /no, /exit');
0439:       return;
0440:     }
0441: 
0442:     if (command === '/status') {
0443:       this.print(safeJson({
0444:         model: this.model,
0445:         ollama_url: this.ollamaUrl,
0446:         require_approval_for_changes: this.requireApproval,
0447:         history_count: this.history.length,
0448:         pending_action: this.pendingAction ? this.pendingAction.id : null
0449:       }));
0450:       return;
0451:     }
0452: 
0453:     if (command === '/model') {
0454:       const nextModel = args.join(' ').trim();
0455:       if (!nextModel) {
0456:         this.print(`Current model: ${this.model}`);
0457:         return;
0458:       }
0459:       this.model = nextModel;
0460:       this.print(`Model updated: ${this.model}`);
0461:       this.logger.writeEvent('config_update', { key: 'model', value: this.model });
0462:       return;
0463:     }
0464: 
0465:     if (command === '/approve') {
0466:       const target = (args[0] || '').toLowerCase();
0467:       const mode = (args[1] || '').toLowerCase();
0468:       const legacyMode = target;
0469: 
0470:       if (target === 'changes' && (mode === 'on' || mode === 'off')) {
0471:         this.requireApproval = mode === 'on';
0472:         this.print(`Change approval mode: ${mode}`);
0473:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
0474:         return;
0475:       }
0476: 
0477:       if (legacyMode === 'on' || legacyMode === 'off') {
0478:         this.requireApproval = legacyMode === 'on';
0479:         this.print(`Change approval mode: ${legacyMode}`);
0480:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
0481:         return;
0482:       }
0483: 
0484:       if (!target) {
0485:         this.print(`Change approval mode: ${this.requireApproval ? 'on' : 'off'}`);
0486:         return;
0487:       }
0488: 
0489:       this.print('Usage: /approve changes on|off');
0490:       return;
0491:     }
0492: 
0493:     if (command === '/yes') {
0494:       if (!this.pendingAction) {
0495:         this.print('No pending action to approve.');
0496:         return;
0497:       }
0498:       const action = this.pendingAction;
0499:       this.pendingAction = null;
0500:       this.logger.writeEvent('approval', { action_id: action.id, approved: true });
0501:       this.writeStructuredUpdate(action.id, {
0502:         'Print-approved-by-user?': 'true',
0503:         approved: true
0504:       });
0505:       await this.executeAction(action);
0506:       return;
0507:     }
0508: 
0509:     if (command === '/no') {
0510:       if (!this.pendingAction) {
0511:         this.print('No pending action to reject.');
0512:         return;
0513:       }
0514:       const action = this.pendingAction;
0515:       this.pendingAction = null;
0516:       this.logger.writeEvent('approval', { action_id: action.id, approved: false });
0517:       this.writeStructuredUpdate(action.id, {
0518:         'Print-approved-by-user?': 'false',
0519:         approved: false,
0520:         summary: 'Action was rejected by user before runtime execution.',
0521:         'Run runtime look at logs': 'skipped (approval rejected)'
0522:       });
0523:       this.print(`Action ${action.id} skipped.`);
0524:       return;
0525:     }
0526: 
0527:     if (command === '/exit') {
0528:       this.rl.close();
0529:       return;
0530:     }
0531: 
0532:     this.print(`Unknown command: ${command}. Use /help.`);
0533:   }
