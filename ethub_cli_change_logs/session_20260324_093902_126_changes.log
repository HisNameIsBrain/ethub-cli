0417:   async handleCommand(input) {
0418:     const [cmd, ...args] = input.split(/\s+/);
0419:     const command = cmd.toLowerCase();
0420:     this.logger.writeEvent('subcommand', { command, args });
0421: 
0422:     if (command === '/help') {
0423:       this.print('Commands: /help, /status, /model <name>, /approve on, /yes, /no, /exit');
0424:       return;
0425:     }
0426: 
0427:     if (command === '/status') {
0428:       this.print(safeJson({
0429:         model: this.model,
0430:         ollama_url: this.ollamaUrl,
0431:         require_approval: this.requireApproval,
0432:         history_count: this.history.length,
0433:         pending_action: this.pendingAction ? this.pendingAction.id : null
0434:       }));
0435:       return;
0436:     }
0437: 
0438:     if (command === '/model') {
0439:       const nextModel = args.join(' ').trim();
0440:       if (!nextModel) {
0441:         this.print(`Current model: ${this.model}`);
0442:         return;
0443:       }
0444:       this.model = nextModel;
0445:       this.print(`Model updated: ${this.model}`);
0446:       this.logger.writeEvent('config_update', { key: 'model', value: this.model });
0447:       return;
0448:     }
0449: 
0450:     if (command === '/approve') {
0451:       const mode = (args[0] || '').toLowerCase();
0452:       if (mode !== 'on') {
0453:         this.print('Approval is mandatory. Use: /approve on');
0454:         return;
0455:       }
0456:       this.requireApproval = true;
0457:       this.print('Approval mode: on');
0458:       this.logger.writeEvent('config_update', { key: 'require_approval', value: this.requireApproval });
0459:       return;
0460:     }
0461: 
0462:     if (command === '/yes') {
0463:       if (!this.pendingAction) {
0464:         this.print('No pending action to approve.');
0465:         return;
0466:       }
0467:       const action = this.pendingAction;
0468:       this.pendingAction = null;
0469:       this.logger.writeEvent('approval', { action_id: action.id, approved: true });
0470:       this.writeStructuredUpdate(action.id, {
0471:         'Print-approved-by-user?': 'true',
0472:         approved: true
0473:       });
0474:       await this.executeAction(action);
0475:       return;
0476:     }
0477: 
0478:     if (command === '/no') {
0479:       if (!this.pendingAction) {
0480:         this.print('No pending action to reject.');
0481:         return;
0482:       }
0483:       const action = this.pendingAction;
0484:       this.pendingAction = null;
0485:       this.logger.writeEvent('approval', { action_id: action.id, approved: false });
0486:       this.writeStructuredUpdate(action.id, {
0487:         'Print-approved-by-user?': 'false',
0488:         approved: false,
0489:         summary: 'Action was rejected by user before runtime execution.',
0490:         'Run runtime look at logs': 'skipped (approval rejected)'
0491:       });
0492:       this.print(`Action ${action.id} skipped.`);
0493:       return;
0494:     }
0495: 
0496:     if (command === '/exit') {
0497:       this.rl.close();
0498:       return;
0499:     }
0500: 
0501:     this.print(`Unknown command: ${command}. Use /help.`);
0502:   }
