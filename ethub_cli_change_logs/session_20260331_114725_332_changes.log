0752:   validatePathToken(token) {
0753:     const raw = String(token || '').trim();
0754:     if (!raw) return { ok: true };
0755:     if (raw === '-' || raw.startsWith('-')) return { ok: true };
0756:     if (raw.startsWith('/')) return { ok: false, reason: `Absolute paths are blocked (${raw}).` };
0757:     if (raw.includes('..')) return { ok: false, reason: `Parent traversal is blocked (${raw}).` };
0758:     const resolved = path.resolve(process.cwd(), raw);
0759:     if (!isPathInsideRoot(this.workspaceRoot, resolved)) {
0760:       return { ok: false, reason: `Path escapes workspace root (${raw}).` };
0761:     }
0762:     return { ok: true };
0763:   }
0764: 
0765:   validateSkillCommand(snippet) {
0766:     const commandText = normalizeSnippet(snippet);
0767:     if (!commandText) return { ok: false, reason: 'Empty snippet.' };
0768:     const lines = commandText.split('\n').map((l) => l.trim()).filter(Boolean);
0769:     if (lines.length !== 1) return { ok: false, reason: 'Only single-line shell skills are executable.' };
0770:     const line = lines[0];
0771:     if (BLOCKED_COMMAND_PATTERN.test(line)) {
0772:       return { ok: false, reason: 'Command contains blocked shell operators.' };
0773:     }
0774: 
0775:     const parsed = tokenizeCommandLine(line);
0776:     if (parsed.error) return { ok: false, reason: parsed.error };
0777:     const tokens = parsed.tokens || [];
0778:     if (!tokens.length) return { ok: false, reason: 'No command token found.' };
0779: 
0780:     const cmd = tokens[0];
0781:     if (!SAFE_SKILL_COMMANDS.has(cmd)) {
0782:       return { ok: false, reason: `Command '${cmd}' is not allowlisted.` };
0783:     }
0784:     if (cmd === 'git') {
0785:       const sub = (tokens[1] || '').toLowerCase();
0786:       if (!['status', 'diff', 'log', 'show', 'branch', 'rev-parse'].includes(sub)) {
0787:         return { ok: false, reason: `git '${sub || '(none)'}' is blocked.` };
0788:       }
0789:     }
0790: 
0791:     for (let i = 1; i < tokens.length; i += 1) {
0792:       const pathCheck = this.validatePathToken(tokens[i]);
0793:       if (!pathCheck.ok) return pathCheck;
0794:     }
0795:     return { ok: true, command: cmd, tokens };
0796:   }
0797: 
0798:   async runSkillCommand(action) {
0799:     const payload = action && action.payload ? action.payload : {};
0800:     const skillName = payload.skill_name || payload.skill_id || 'unknown';
0801:     const snippet = String(payload.snippet || '');
0802:     const validation = this.validateSkillCommand(snippet);
0803:     if (!validation.ok) {
0804:       this.print(`${style('Skill execution denied:', ANSI.bold, ANSI.red)} ${validation.reason}`);
0805:       this.logger.writeEvent('skill_run_denied', {
0806:         action_id: action.id,
0807:         skill: skillName,
0808:         reason: validation.reason
0809:       });
0810:       return;
0811:     }
0812: 
0813:     const tokens = validation.tokens;
0814:     const cmd = tokens[0];
0815:     const args = tokens.slice(1);
0816:     this.print(style(`[SKILL RUN] ${skillName}: ${snippet}`, ANSI.bold, ANSI.cyan));
0817: 
0818:     const result = await new Promise((resolve) => {
0819:       const child = spawn(cmd, args, {
0820:         cwd: process.cwd(),
0821:         stdio: ['ignore', 'pipe', 'pipe'],
0822:         shell: false
0823:       });
0824: 
0825:       let stdout = '';
0826:       let stderr = '';
0827:       let finished = false;
0828:       const timer = setTimeout(() => {
0829:         if (finished) return;
0830:         child.kill('SIGTERM');
0831:       }, 120000);
0832: 
0833:       child.stdout.on('data', (chunk) => {
0834:         if (stdout.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0835:         stdout += chunk.toString('utf8');
0836:       });
0837:       child.stderr.on('data', (chunk) => {
0838:         if (stderr.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0839:         stderr += chunk.toString('utf8');
0840:       });
0841:       child.on('error', (error) => {
0842:         clearTimeout(timer);
0843:         finished = true;
0844:         resolve({ code: -1, signal: null, stdout, stderr: `${stderr}\n${error.message}`.trim() });
0845:       });
0846:       child.on('close', (code, signal) => {
0847:         clearTimeout(timer);
0848:         finished = true;
0849:         resolve({ code, signal, stdout, stderr });
0850:       });
0851:     });
0852: 
0853:     if (result.stdout) {
0854:       this.print(style('[STDOUT]', ANSI.dim));
0855:       this.print(truncateText(result.stdout, MAX_COMMAND_OUTPUT_BYTES));
0856:     }
0857:     if (result.stderr) {
0858:       this.print(style('[STDERR]', ANSI.dim));
0859:       this.print(truncateText(result.stderr, MAX_COMMAND_OUTPUT_BYTES));
0860:     }
0861:     this.print(style(`[SKILL EXIT] code=${result.code} signal=${result.signal || 'none'}`, ANSI.dim));
0862:     this.logger.writeEvent('skill_run_complete', {
0863:       action_id: action.id,
0864:       skill: skillName,
0865:       code: result.code,
0866:       signal: result.signal,
0867:       stdout_chars: result.stdout.length,
0868:       stderr_chars: result.stderr.length
0869:     });
0870:   }
