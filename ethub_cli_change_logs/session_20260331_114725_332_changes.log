1025:   resolvePathInWorkspace(inputPath, expected = 'any') {
1026:     const raw = String(inputPath || '').trim();
1027:     if (!raw) return { error: 'path is required' };
1028:     const normalized = raw === '~' ? os.homedir() : raw;
1029:     const resolved = path.resolve(process.cwd(), normalized);
1030:     const root = path.resolve(this.workspaceRoot);
1031:     const inRoot = resolved === root || resolved.startsWith(`${root}${path.sep}`);
1032:     if (!inRoot) {
1033:       return { error: `path escapes workspace root: ${root}` };
1034:     }
1035: 
1036:     if (expected === 'exists') {
1037:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
1038:     }
1039:     if (expected === 'file' || expected === 'dir') {
1040:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
1041:       let st;
1042:       try {
1043:         st = fs.statSync(resolved);
1044:       } catch (error) {
1045:         return { error: `unable to stat path: ${error.message}` };
1046:       }
1047:       if (expected === 'file' && !st.isFile()) return { error: 'path is not a file' };
1048:       if (expected === 'dir' && !st.isDirectory()) return { error: 'path is not a directory' };
1049:     }
1050: 
1051:     return { path: resolved };
1052:   }
