1108:   async animateHeader(durationMs = 1200, fps = 20) {
1109:     const frameDelay = Math.max(16, Math.floor(1000 / fps));
1110:     const frames = Math.max(1, Math.floor(durationMs / frameDelay));
1111:     for (let frame = 0; frame < frames; frame += 1) {
1112:       const lines = this.renderHeaderFrame(frame);
1113:       process.stdout.write('\x1b[2J\x1b[H');
1114:       process.stdout.write(`${lines.join('\n')}\n`);
1115:       await new Promise((resolve) => setTimeout(resolve, frameDelay));
1116:     }
1117:     process.stdout.write('\x1b[2J\x1b[H');
1118:     this.drawHeader(frames);
1119:   }
