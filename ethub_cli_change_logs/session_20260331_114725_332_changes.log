1137:   startThinking() {
1138:     if (this.thinkingTimer) return;
1139:     let i = 0;
1140:     this.thinkingTimer = setInterval(() => {
1141:       const dots = '.'.repeat(i % 4);
1142:       process.stdout.write(
1143:         `\r${LEFT_PAD}${style('Thinking', ANSI.cyan)}${dots.padEnd(3, ' ')}${style(' parsing your request', ANSI.dim)}${' '.repeat(20)}`
1144:       );
1145:       i += 1;
1146:     }, 140);
1147:   }
1148: 
1149:   stopThinking() {
1150:     if (!this.thinkingTimer) return;
1151:     clearInterval(this.thinkingTimer);
1152:     this.thinkingTimer = null;
1153:     process.stdout.write('\n');
1154:   }
