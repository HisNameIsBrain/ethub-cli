0330: function summarizeReasoning(input) {
0331:   const raw = String(input || '').trim();
0332:   const lowered = raw.toLowerCase();
0333:   const keywords = raw
0334:     .split(/\s+/)
0335:     .map((w) => w.replace(/[^a-zA-Z0-9_-]/g, ''))
0336:     .filter(Boolean)
0337:     .slice(0, 12);
0338: 
0339:   let intent = 'general_request';
0340:   if (/error|syntax|stack|trace|bug|fix|crash/.test(lowered)) intent = 'debugging';
0341:   else if (/how|what|why|explain|guide|tutorial/.test(lowered)) intent = 'information_lookup';
0342:   else if (/build|create|make|implement|write/.test(lowered)) intent = 'implementation';
0343: 
0344:   let strategy = 'Use local conversation context then query Ollama for a grounded response.';
0345:   if (intent === 'debugging') {
0346:     strategy = 'Focus on likely fault points, propose checks, and request missing runtime details if needed.';
0347:   }
0348: 
0349:   return {
0350:     query: raw,
0351:     intent,
0352:     keywords,
0353:     strategy,
0354:     note: 'Detailed private chain-of-thought is not exposed; this is a concise decision summary.'
0355:   };
