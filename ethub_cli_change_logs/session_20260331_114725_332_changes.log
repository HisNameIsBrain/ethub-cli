1502:   async executePendingAction(action) {
1503:     if (!action) return;
1504:     if (action.type === 'ollama_chat') {
1505:       await this.executeAction(action);
1506:       return;
1507:     }
1508:     if (action.type === 'read_file') {
1509:       this.runReadFileAction(action);
1510:       return;
1511:     }
1512:     if (action.type === 'write_file') {
1513:       this.runWriteFileAction(action);
1514:       return;
1515:     }
1516:     if (action.type === 'add_skill') {
1517:       this.runAddSkillAction(action);
1518:       return;
1519:     }
1520:     if (action.type === 'run_skill') {
1521:       await this.runSkillCommand(action);
1522:       return;
1523:     }
1524:     if (action.type === 'todo_plan') {
1525:       const payload = action && action.payload ? action.payload : {};
1526:       await this.executeTodoPlan(payload.plan || [], payload.file || path.resolve(__filename));
1527:       return;
1528:     }
1529:     this.print(`Unsupported pending action type: ${action.type}`);
1530:   }
1531: 
1532:   runReadFileAction(action) {
1533:     const filePath = action && action.payload ? action.payload.path : '';
1534:     if (!filePath || !fs.existsSync(filePath)) {
1535:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} file no longer exists.`);
1536:       return;
1537:     }
1538:     let text;
1539:     try {
1540:       text = fs.readFileSync(filePath, 'utf8');
1541:     } catch (error) {
1542:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1543:       return;
1544:     }
1545:     const shown = truncateText(text, MAX_READFILE_BYTES);
1546:     const rel = action.payload.rel || this.workspaceRelativePath(filePath);
1547:     this.print(style(`[I/O READ] ${rel}`, ANSI.bold, ANSI.cyan));
1548:     this.print(style(`\n[READFILE] ${rel}`, ANSI.bold, ANSI.cyan));
1549:     this.print(style(`bytes: ${Buffer.byteLength(text, 'utf8')} | shown: ${Buffer.byteLength(shown, 'utf8')}`, ANSI.dim));
1550:     this.print(shown);
1551:     this.logger.writeEvent('read_file', {
1552:       action_id: action.id,
1553:       file: filePath,
1554:       bytes: Buffer.byteLength(text, 'utf8'),
1555:       shown_bytes: Buffer.byteLength(shown, 'utf8')
1556:     });
1557:   }
1558: 
1559:   runWriteFileAction(action) {
1560:     const filePath = action && action.payload ? action.payload.path : '';
1561:     const content = action && action.payload ? String(action.payload.content || '') : '';
1562:     if (!filePath) {
1563:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} missing target path.`);
1564:       return;
1565:     }
1566:     try {
1567:       ensureDir(path.dirname(filePath));
1568:       fs.writeFileSync(filePath, content, 'utf8');
1569:     } catch (error) {
1570:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1571:       return;
1572:     }
1573:     this.print(style(`[I/O WRITE] ${action.payload.rel}`, ANSI.bold, ANSI.cyan));
1574:     this.print(style(`[WRITEFILE] wrote ${content.length} chars to ${action.payload.rel}`, ANSI.bold, ANSI.cyan));
1575:     this.logger.writeEvent('write_file', {
1576:       action_id: action.id,
1577:       file: filePath,
1578:       chars: content.length
1579:     });
1580:   }
1581: 
1582:   runAddSkillAction(action) {
1583:     const payload = action && action.payload ? action.payload : {};
1584:     const name = String(payload.skill_name || '').trim();
1585:     const snippet = String(payload.snippet || '');
1586:     if (!name || !snippet) {
1587:       this.print(`${style('Add skill failed:', ANSI.bold, ANSI.red)} missing skill name or snippet.`);
1588:       return;
1589:     }
1590:     const duplicate = this.findSkill(name);
1591:     if (duplicate) {
1592:       this.print(`${style('Add skill skipped:', ANSI.bold, ANSI.red)} skill already exists (${duplicate.id}).`);
1593:       return;
1594:     }
1595: 
1596:     const skill = {
1597:       id: `skill_${Date.now()}`,
1598:       name,
1599:       snippet,
1600:       source: `candidate:${payload.source_candidate || 'unknown'}`,
1601:       executable: Boolean(payload.executable),
1602:       created_at: nowIso()
1603:     };
1604:     this.skills.push(skill);
1605:     this.saveSkills();
1606:     this.print(style(`[SKILL ADDED] ${skill.name} (${skill.id}) executable=${skill.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.cyan));
1607:     this.logger.writeEvent('skill_added', {
1608:       action_id: action.id,
1609:       skill_id: skill.id,
1610:       skill_name: skill.name,
1611:       executable: skill.executable
1612:     });
1613:   }
1614: 
1615:   readFileSafe(filePath) {
1616:     const target = path.resolve(filePath || '');
1617:     if (!target) return '';
1618:     if (!fs.existsSync(target)) return '';
1619:     try {
1620:       return fs.readFileSync(target, 'utf8');
1621:     } catch (error) {
1622:       this.logger.writeEvent('pipeline_read_failed', {
1623:         file: target,
1624:         error: error.message
1625:       });
1626:       return '';
1627:     }
1628:   }
1629: 
1630:   detectContext(code, input) {
1631:     const text = String(input || '');
1632:     return {
1633:       hasDebugLoop: code.includes('debugLoop'),
1634:       hasPipeline: code.includes('runPipeline'),
1635:       hasANSI: code.includes('\\x1b['),
1636:       isError: /error|fail|undefined|crash/i.test(text),
1637:       isFeature: /add|implement|feature/i.test(text),
1638:       isRefactor: /refactor|clean/i.test(text)
1639:     };
1640:   }
1641: 
1642:   decide(ctx) {
1643:     if (ctx.isError) return 'debug';
1644:     if (!ctx.hasPipeline) return 'add_pipeline';
1645:     if (!ctx.hasDebugLoop) return 'add_debug';
1646:     if (!ctx.hasANSI) return 'add_ui';
1647:     if (ctx.isFeature) return 'feature';
1648:     return 'stable';
1649:   }
1650: 
1651:   buildTodoPlan(decision) {
1652:     if (decision === 'debug') {
1653:       return [
1654:         { step: 'scan', cmd: 'ls' },
1655:         { step: 'analyze', cmd: 'rg -n "error|fail|undefined|crash" .' },
1656:         { step: 'fix', action: 'patch_debug' }
1657:       ];
1658:     }
1659:     if (decision === 'add_debug') {
1660:       return [{ step: 'patch', action: 'patch_debug_loop' }];
1661:     }
1662:     if (decision === 'add_pipeline') {
1663:       return [{ step: 'patch', action: 'patch_pipeline' }];
1664:     }
1665:     if (decision === 'add_ui') {
1666:       return [{ step: 'patch', action: 'patch_ui_marker' }];
1667:     }
1668:     return [];
1669:   }
1670: 
1671:   uiBox(msg, color = 'cyan') {
1672:     const c = {
1673:       cyan: '\x1b[36m',
1674:       green: '\x1b[32m',
1675:       red: '\x1b[31m',
1676:       yellow: '\x1b[33m'
1677:     };
1678:     const code = c[color] || c.cyan;
1679:     return `${code}[ ${String(msg || '')} ]\x1b[0m`;
1680:   }
1681: 
1682:   emitUiFrame(lines, clearScreen = false) {
1683:     const rows = Array.isArray(lines) ? lines : [];
1684:     if (clearScreen && process.stdout.isTTY) {
1685:       process.stdout.write('\x1b[2J\x1b[H');
1686:     }
1687:     const text = `${rows.join('\n')}\n`;
1688:     process.stdout.write(text);
1689:     this.logger.writeEvent('stdout', { text: rows.join('\n') });
1690:   }
1691: 
1692:   uiRender(ctx, decision) {
1693:     const hasReadline = Boolean(this.rl && typeof this.rl.pause === 'function' && typeof this.rl.resume === 'function');
1694:     if (hasReadline) this.rl.pause();
1695: 
1696:     const lines = [];
1697:     lines.push('\x1b[1mAgent v3.1 - Local Debug Shell\x1b[0m');
1698:     lines.push('');
1699:     lines.push('┌──────────────────────────────┐');
1700:     lines.push('│ Live Dashboard               │');
1701:     lines.push('├──────────────────────────────┤');
1702:     lines.push('\x1b[32mINFO\x1b[0m Starting analysis...');
1703:     if (ctx.isError) lines.push('\x1b[31mERROR\x1b[0m Runtime issue detected');
1704:     lines.push('└──────────────────────────────┘');
1705:     lines.push('');
1706:     lines.push('┌──────────────────────────────┐');
1707:     lines.push('│ Debug Loop                   │');
1708:     lines.push('├──────────────────────────────┤');
1709:     lines.push('1. Scan project directory');
1710:     lines.push('2. Analyze logs');
1711:     lines.push('3. Generate fix');
1712:     lines.push(decision === 'debug' ? '\x1b[47m\x1b[30m4. Apply changes & verify\x1b[0m' : '4. Apply changes & verify');
1713:     lines.push('└──────────────────────────────┘');
1714:     lines.push('');
1715:     lines.push('┌──────────────────────────────┐');
1716:     lines.push('│ TODO Plan                    │');
1717:     lines.push('├──────────────────────────────┤');
1718:     lines.push('✔ Scan directory');
1719:     lines.push('✔ Analyze logs');
1720:     if (decision === 'debug') {
1721:       lines.push('✔ Generate fix');
1722:       lines.push('⏳ Applying patch...');
1723:     }
1724:     lines.push('└──────────────────────────────┘');
1725:     lines.push('');
1726:     lines.push(`MODEL: ${this.model} | TASK: ${decision} | STATUS: running`);
1727:     this.emitUiFrame(lines, process.stdout.isTTY);
1728: 
1729:     if (hasReadline) this.rl.resume();
1730:   }
1731: 
1732:   async runPipeline(input) {
1733:     const file = path.resolve(__filename);
1734:     const code = this.readFileSafe(file);
1735:     const ctx = this.detectContext(code, input);
1736:     const decision = this.decide(ctx);
1737:     this.uiRender(ctx, decision);
1738:     this.logger.writeEvent('pipeline_decision', { decision, context: ctx, file });
1739: 
1740:     if (decision === 'stable') {
1741:       this.print(this.uiBox('System stable. No changes needed.', 'green'));
1742:       return true;
1743:     }
1744: 
1745:     const plan = this.buildTodoPlan(decision);
1746:     if (!plan.length) {
1747:       this.print(this.uiBox(`No TODO plan for decision: ${decision}`, 'yellow'));
1748:       return true;
1749:     }
1750: 
1751:     if (this.requireApproval) {
1752:       const action = {
1753:         id: `todo_${Date.now()}`,
1754:         type: 'todo_plan',
1755:         payload: { plan, decision, file },
1756:         created_at: nowIso()
1757:       };
1758:       this.queueApprovalAction(action, this.uiBox('Awaiting approval for TODO plan (/yes or /no)', 'yellow'));
1759:       return true;
1760:     }
1761: 
1762:     await this.executeTodoPlan(plan, file);
1763:     return true;
1764:   }
1765: 
1766:   isSafeCommand(commandText) {
1767:     const text = String(commandText || '').trim();
1768:     if (!text) return false;
1769:     if (BLOCKED_COMMAND_PATTERN.test(text)) return false;
1770:     const parsed = tokenizeCommandLine(text);
1771:     if (parsed.error || !parsed.tokens || !parsed.tokens.length) return false;
1772:     const cmd = parsed.tokens[0];
1773:     return /^(ls|cd|cat|grep|rg|sed|cp|mv|tree|echo)$/.test(cmd);
1774:   }
1775: 
1776:   async runShell(commandText) {
1777:     const raw = String(commandText || '').trim();
1778:     const parsed = tokenizeCommandLine(raw);
1779:     if (parsed.error) {
1780:       this.print(this.uiBox(`Shell parse error: ${parsed.error}`, 'red'));
1781:       return;
1782:     }
1783:     const tokens = parsed.tokens || [];
1784:     if (!tokens.length) {
1785:       this.print(this.uiBox('Shell command rejected (empty).', 'red'));
1786:       return;
1787:     }
1788: 
1789:     const cmd = tokens[0];
1790:     const args = tokens.slice(1);
1791: 
1792:     if (cmd === 'cd') {
1793:       const target = args[0] || '.';
1794:       const resolved = this.resolvePathInWorkspace(target, 'dir');
1795:       if (resolved.error) {
1796:         this.print(this.uiBox(`cd denied: ${resolved.error}`, 'red'));
1797:         return;
1798:       }
1799:       process.chdir(resolved.path);
1800:       this.refreshPrompt();
1801:       this.print(this.uiBox(`cwd -> ${this.workspaceRelativePath()}`, 'cyan'));
1802:       return;
1803:     }
1804: 
1805:     await new Promise((resolve) => {
1806:       const proc = spawn(cmd, args, { stdio: ['ignore', 'pipe', 'pipe'], shell: false });
1807:       let out = '';
1808:       proc.stdout.on('data', (d) => {
1809:         out += d.toString();
1810:       });
1811:       proc.stderr.on('data', (d) => {
1812:         out += d.toString();
1813:       });
1814:       proc.on('error', (error) => {
1815:         this.print(this.uiBox(`Command failed: ${error.message}`, 'red'));
1816:         resolve();
1817:       });
1818:       proc.on('close', (code) => {
1819:         const chunk = out.trim() ? out.trim().slice(0, 300) : `(no output, exit=${code})`;
1820:         this.print(this.uiBox(chunk, code === 0 ? 'cyan' : 'yellow'));
1821:         resolve();
1822:       });
1823:     });
1824:   }
1825: 
1826:   generatePatch(type) {
1827:     if (type === 'patch_debug' || type === 'patch_debug_loop') {
1828:       return `
1829: // --- PATCH: DEBUG LOOP ---
1830: function debugLoop() {
1831:   console.log("[debug] scanning...");
1832: }
1833: `;
1834:     }
1835:     if (type === 'patch_pipeline') {
1836:       return `
1837: // --- PATCH: PIPELINE ---
1838: function runPipeline() {
1839:   console.log("[pipeline] active");
1840: }
1841: `;
1842:     }
1843:     if (type === 'patch_ui_marker') {
1844:       return '\n// --- PATCH: ANSI UI MARKER ---\n';
1845:     }
1846:     return '';
1847:   }
1848: 
1849:   validatePatch(original, patch) {
1850:     const base = String(original || '');
1851:     const candidate = String(patch || '');
1852:     if (!candidate.trim()) return false;
1853:     if (base.includes(candidate.trim())) return false;
1854:     if (base.length + candidate.length > 200000) return false;
1855:     return true;
1856:   }
1857: 
1858:   applyPatchSafe(file, patch) {
1859:     const backup = `${file}.bak`;
1860:     fs.copyFileSync(file, backup);
1861:     try {
1862:       const updated = fs.readFileSync(file, 'utf8') + '\n' + patch;
1863:       fs.writeFileSync(file, updated, 'utf8');
1864:       this.print(this.uiBox('Patch applied successfully', 'green'));
1865:       this.logger.writeEvent('pipeline_patch_applied', { file, backup, patch_chars: patch.length });
1866:     } catch (error) {
1867:       fs.copyFileSync(backup, file);
1868:       this.print(this.uiBox('Patch failed -> rolled back', 'red'));
1869:       this.logger.writeEvent('pipeline_patch_rollback', { file, backup, error: error.message });
1870:     }
1871:   }
1872: 
1873:   async executeTodoPlan(plan, file) {
1874:     const steps = Array.isArray(plan) ? plan : [];
1875:     for (const step of steps) {
1876:       if (step.cmd) {
1877:         if (!this.isSafeCommand(step.cmd)) {
1878:           this.print(this.uiBox(`Blocked unsafe command: ${step.cmd}`, 'red'));
1879:           continue;
1880:         }
1881:         await this.runShell(step.cmd);
1882:       }
1883: 
1884:       if (step.action) {
1885:         const patch = this.generatePatch(step.action);
1886:         const original = this.readFileSafe(file);
1887:         if (!this.validatePatch(original, patch)) {
1888:           this.print(this.uiBox('Patch rejected (validation)', 'red'));
1889:           continue;
1890:         }
1891:         this.applyPatchSafe(file, patch);
1892:       }
1893:     }
1894:   }
1895: 
1896:   async handleUserPrompt(input) {
1897:     const handledByPipeline = await this.runPipeline(input);
1898:     if (handledByPipeline) return;
1899: 
1900:     const reasoning = summarizeReasoning(input);
1901:     const action = {
1902:       id: `act_${Date.now()}`,
1903:       type: 'ollama_chat',
1904:       prompt: input,
1905:       reasoning_summary: reasoning,
1906:       created_at: nowIso()
1907:     };
1908: 
1909:     this.logger.writeTranscript('User', input);
1910:     this.logger.writeEvent('user_prompt', {
1911:       text: input,
1912:       reasoning_summary: reasoning,
1913:       proposed_action: { id: action.id, type: action.type }
1914:     });
1915:     this.actionMeta[action.id] = {
1916:       prompt: input,
1917:       prompt_chars_before: input.length
1918:     };
1919:     const keywordsText = Array.isArray(reasoning.keywords) && reasoning.keywords.length
1920:       ? reasoning.keywords.join(', ')
1921:       : 'none';
1922:     this.print(style(`[Reasoning] intent=${reasoning.intent} | keywords=${keywordsText}`, ANSI.dim));
1923:     this.print(style(`[Reasoning] strategy=${reasoning.strategy}`, ANSI.dim));
1924: 
1925:     this.logger.writeStructuredRecord({
1926:       timestamp: nowIso(),
1927:       query: input,
1928:       reasoning: {
1929:         query: reasoning.query,
1930:         intent: reasoning.intent,
1931:         keywords: reasoning.keywords,
1932:         search_strategy: reasoning.strategy
1933:       },
1934:       actions: {
1935:         action: 'local_ollama_request',
1936:         sources: ['ollama_localhost'],
1937:         Context: 'Analyzing locally via Ollama only; no OpenAI/Gemini/external model APIs.'
1938:       },
1939:       Commands: "ls, grep, nano, cd, nano 'create-new-file-diff-snippet-number+1.sh', regen entire file with changes then save, cp -rf old/path/to/file move/to/backup/path/file, rm old/path/to/file, bash create-new-file-(diff-snippet-line:character)-(number)+1, sed -i 's/old/new' \"$file\"",
1940:       Diff: '+,-',
1941:       Path: 'path/to/file:line:character',
1942:       action_id: action.id,
1943:       'Print-approved-by-user?': 'not_required (run commands)',
1944:       'Run runtime look at logs': 'pending',
1945:       summary: 'pending',
1946:       'Number of characters changed': 'pending'
1947:     });
1948: 
1949:     await this.executeAction(action);
1950:   }
1951: 
1952:   writeStructuredUpdate(actionId, patch) {
1953:     this.logger.writeStructuredRecord({
1954:       timestamp: nowIso(),
1955:       action_id: actionId,
1956:       update: patch
1957:     });
1958:   }
1959: 
1960:   async executeAction(action) {
1961:     if (!action || action.type !== 'ollama_chat') {
1962:       this.logger.writeEvent('action_error', { message: 'Unsupported action type', action });
1963:       this.writeStructuredUpdate(action && action.id ? action.id : 'unknown', {
1964:         'Run runtime look at logs': 'contains error still, unsupported action type',
1965:         summary: 'Unsupported action type encountered before runtime request.',
1966:         'Number of characters changed': 'previous character amount in file before cmd/new total character count added: 0/0'
1967:       });
1968:       this.print('Unsupported action.');
1969:       return;
1970:     }
1971: 
1972:     this.logger.writeEvent('action_start', {
1973:       action_id: action.id,
1974:       type: action.type,
1975:       target: this.ollamaUrl,
1976:       model: this.model,
1977:       prompt_chars: action.prompt.length,
1978:       reasoning_summary: action.reasoning_summary
1979:     });
1980: 
1981:     this.history.push({ role: 'user', content: action.prompt });
1982: 
1983:     const payload = {
1984:       model: this.model,
1985:       messages: this.history,
1986:       stream: false
1987:     };
1988: 
1989:     let response;
1990:     let raw;
1991:     const started = Date.now();
1992:     this.startThinking();
1993: 
1994:     try {
1995:       response = await fetch(this.ollamaUrl, {
1996:         method: 'POST',
1997:         headers: { 'Content-Type': 'application/json' },
1998:         body: JSON.stringify(payload)
1999:       });
2000: 
2001:       raw = await response.text();
2002:     } catch (error) {
2003:       this.stopThinking();
2004:       const message = error && error.message ? error.message : String(error);
2005:       this.logger.writeEvent('action_failure', {
2006:         action_id: action.id,
2007:         duration_ms: Date.now() - started,
2008:         error: message
2009:       });
2010:       this.writeStructuredUpdate(action.id, {
2011:         'Run runtime look at logs': 'contains error still, loop and try again with different results until each individual error is clear.',
2012:         summary: `Runtime request failed. Error: ${message}`,
2013:         'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${action.prompt.length}/0`,
2014:         'Print-approved-by-user?': 'true'
2015:       });
2016:       this.print(`Ollama request failed: ${message}`);
2017:       return;
2018:     }
2019:     this.stopThinking();
2020: 
2021:     let parsed;
2022:     try {
2023:       parsed = JSON.parse(raw);
2024:     } catch {
2025:       parsed = null;
2026:     }
2027: 
2028:     const assistantText = parsed && parsed.message && parsed.message.content
2029:       ? String(parsed.message.content)
2030:       : raw;
2031: 
2032:     this.history.push({ role: 'assistant', content: assistantText });
2033: 
2034:     this.logger.writeEvent('action_result', {
2035:       action_id: action.id,
2036:       duration_ms: Date.now() - started,
2037:       http_status: response.status,
2038:       ok: response.ok,
2039:       response_preview: assistantText.slice(0, 400),
2040:       response_chars: assistantText.length
2041:     });
2042: 
2043:     this.logger.writeTranscript('Assistant', assistantText);
2044:     this.print(assistantText);
2045: 
2046:     const hasRuntimeError = /(syntaxerror|stack overflow|runtime error|error:)/i.test(assistantText);
2047:     const runtimeResult = hasRuntimeError
2048:       ? 'contains error still, retry with different checks until isolated'
2049:       : 'No runtime error anymore = fixed';
2050:     const beforeChars = this.actionMeta[action.id] && this.actionMeta[action.id].prompt_chars_before
2051:       ? this.actionMeta[action.id].prompt_chars_before
2052:       : 0;
2053:     const afterChars = assistantText.length;
2054:     const elapsedMs = Date.now() - started;
2055: 
2056:     this.writeStructuredUpdate(action.id, {
2057:       'Run runtime look at logs': runtimeResult,
2058:       summary: `summarized what just changed, is it fixed: ${hasRuntimeError ? 'No' : 'Yes'}. Runtime error count estimate: ${hasRuntimeError ? 1 : 0}.`,
2059:       'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${beforeChars}/${afterChars}`,
2060:       timing_ms: elapsedMs,
2061:       stop_condition: elapsedMs >= 300000 ? 'Unable to find results or solutions, Try again.' : 'within loop budget'
2062:     });
2063:   }
2064: }
2065: 
2066: const agent = new EthubCliAgent();
2067: agent.start().catch((error) => {
2068:   process.stderr.write(`Fatal startup error: ${error && error.stack ? error.stack : String(error)}\n`);
2069:   process.exit(1);
2070: });
