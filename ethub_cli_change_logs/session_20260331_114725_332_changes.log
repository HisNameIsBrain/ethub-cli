1121:   async showSuggestions() {
1122:     this.print('');
1123:     this.print(LEFT_PAD + style('Suggestions (you can just start typing):', ANSI.dim));
1124:     for (const s of SUGGESTIONS) {
1125:       let buf = '';
1126:       for (const ch of s) {
1127:         buf += ch;
1128:         process.stdout.write(`\r${LEFT_PAD}${style(`• ${buf}`, ANSI.dim)}`);
1129:         await new Promise((resolve) => setTimeout(resolve, 12));
1130:       }
1131:       process.stdout.write('\n');
1132:       await new Promise((resolve) => setTimeout(resolve, 80));
1133:     }
1134:     this.print('');
1135:   }
