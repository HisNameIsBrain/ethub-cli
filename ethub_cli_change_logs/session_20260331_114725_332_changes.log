1160:   async handleCommand(input) {
1161:     const [cmd, ...args] = input.split(/\s+/);
1162:     const command = cmd.toLowerCase();
1163:     this.logger.writeEvent('subcommand', { command, args });
1164: 
1165:     if (command === '/help') {
1166:       this.print('Commands: /help, /status, /model <name>, /approve changes on|off, /dashboard, /readfile <path>, /writefile <path> -- <content>, /cd <path>, /skills <mine|candidates|add|list|show|run>, /yes, /no, /exit');
1167:       this.print('Skills flow: /skills mine 10 -> /skills add cand_1 my_skill -> /yes -> /skills run my_skill -> /yes');
1168:       return;
1169:     }
1170: 
1171:     if (command === '/status') {
1172:       this.print(safeJson({
1173:         model: this.model,
1174:         ollama_url: this.ollamaUrl,
1175:         require_approval_for_changes: this.requireApproval,
1176:         skills_count: this.skills.length,
1177:         skill_candidates_count: this.skillCandidates.length,
1178:         dashboard_url: this.dashboardInfo && this.dashboardInfo.dashboard_url ? this.dashboardInfo.dashboard_url : null,
1179:         history_count: this.history.length,
1180:         pending_action: this.pendingAction ? this.pendingAction.id : null
1181:       }));
1182:       return;
1183:     }
1184: 
1185:     if (command === '/model') {
1186:       const nextModel = args.join(' ').trim();
1187:       if (!nextModel) {
1188:         this.print(`Current model: ${this.model}`);
1189:         return;
1190:       }
1191:       this.model = nextModel;
1192:       this.print(`Model updated: ${this.model}`);
1193:       this.logger.writeEvent('config_update', { key: 'model', value: this.model });
1194:       return;
1195:     }
1196: 
1197:     if (command === '/approve') {
1198:       const target = (args[0] || '').toLowerCase();
1199:       const mode = (args[1] || '').toLowerCase();
1200:       const legacyMode = target;
1201: 
1202:       if (target === 'changes' && (mode === 'on' || mode === 'off')) {
1203:         this.requireApproval = mode === 'on';
1204:         this.print(`Change approval mode: ${mode}`);
1205:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1206:         return;
1207:       }
1208: 
1209:       if (legacyMode === 'on' || legacyMode === 'off') {
1210:         this.requireApproval = legacyMode === 'on';
1211:         this.print(`Change approval mode: ${legacyMode}`);
1212:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1213:         return;
1214:       }
1215: 
1216:       if (!target) {
1217:         this.print(`Change approval mode: ${this.requireApproval ? 'on' : 'off'}`);
1218:         return;
1219:       }
1220: 
1221:       this.print('Usage: /approve changes on|off');
1222:       return;
1223:     }
1224: 
1225:     if (command === '/dashboard') {
1226:       await this.ensureDashboardRunning();
1227:       if (this.dashboardInfo && this.dashboardInfo.dashboard_url) {
1228:         this.print(style(`Dashboard live: ${this.dashboardInfo.dashboard_url}`, ANSI.cyan));
1229:         if (this.dashboardInfo.chat_url) {
1230:           this.print(style(`Chat live: ${this.dashboardInfo.chat_url}`, ANSI.cyan));
1231:         }
1232:       } else {
1233:         this.print(style('Dashboard unavailable. Try: node web_debug/index_server.mjs', ANSI.yellow));
1234:       }
1235:       return;
1236:     }
1237: 
1238:     if (command === '/yes') {
1239:       if (!this.pendingAction) {
1240:         this.print('No pending action to approve.');
1241:         return;
1242:       }
1243:       const action = this.pendingAction;
1244:       this.pendingAction = null;
1245:       this.logger.writeEvent('approval', { action_id: action.id, approved: true });
1246:       this.writeStructuredUpdate(action.id, {
1247:         'Print-approved-by-user?': 'true',
1248:         approved: true
1249:       });
1250:       await this.executePendingAction(action);
1251:       return;
1252:     }
1253: 
1254:     if (command === '/no') {
1255:       if (!this.pendingAction) {
1256:         this.print('No pending action to reject.');
1257:         return;
1258:       }
1259:       const action = this.pendingAction;
1260:       this.pendingAction = null;
1261:       this.logger.writeEvent('approval', { action_id: action.id, approved: false });
1262:       this.writeStructuredUpdate(action.id, {
1263:         'Print-approved-by-user?': 'false',
1264:         approved: false,
1265:         summary: 'Action was rejected by user before runtime execution.',
1266:         'Run runtime look at logs': 'skipped (approval rejected)'
1267:       });
1268:       this.print(`Action ${action.id} skipped.`);
1269:       return;
1270:     }
1271: 
1272:     if (command === '/exit') {
1273:       this.rl.close();
1274:       return;
1275:     }
1276: 
1277:     if (command === '/cd') {
1278:       const rawTarget = input.replace(/^\/cd\s*/i, '').trim();
1279:       if (!rawTarget) {
1280:         this.print(`Current directory: ${process.cwd()}`);
1281:         return;
1282:       }
1283:       const resolved = this.resolvePathInWorkspace(rawTarget, 'dir');
1284:       if (resolved.error) {
1285:         this.print(`${style('cd denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1286:         return;
1287:       }
1288:       process.chdir(resolved.path);
1289:       this.refreshPrompt();
1290:       this.logger.writeEvent('cwd_changed', {
1291:         cwd: process.cwd(),
1292:         workspace_relative: this.workspaceRelativePath()
1293:       });
1294:       this.print(style(`Directory changed to ${this.workspaceRelativePath()}`, ANSI.cyan));
1295:       return;
1296:     }
1297: 
1298:     if (command === '/readfile') {
1299:       const rawPath = input.replace(/^\/readfile\s*/i, '').trim();
1300:       if (!rawPath) {
1301:         this.print('Usage: /readfile <path>');
1302:         return;
1303:       }
1304:       const resolved = this.resolvePathInWorkspace(rawPath, 'file');
1305:       if (resolved.error) {
1306:         this.print(`${style('readfile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1307:         return;
1308:       }
1309:       const action = {
1310:         id: `act_${Date.now()}`,
1311:         type: 'read_file',
1312:         payload: {
1313:           path: resolved.path,
1314:           rel: this.workspaceRelativePath(resolved.path)
1315:         },
1316:         created_at: nowIso()
1317:       };
1318:       this.queueApprovalAction(
1319:         action,
1320:         `${style('Read request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel}`
1321:       );
1322:       return;
1323:     }
1324: 
1325:     if (command === '/writefile') {
1326:       const raw = input.replace(/^\/writefile\s*/i, '');
1327:       const splitIndex = raw.indexOf(' -- ');
1328:       if (splitIndex === -1) {
1329:         this.print('Usage: /writefile <path> -- <content>');
1330:         return;
1331:       }
1332:       const rawPath = raw.slice(0, splitIndex).trim();
1333:       const content = raw.slice(splitIndex + 4);
1334:       if (!rawPath) {
1335:         this.print('Usage: /writefile <path> -- <content>');
1336:         return;
1337:       }
1338:       const resolved = this.resolvePathInWorkspace(rawPath, 'any');
1339:       if (resolved.error) {
1340:         this.print(`${style('writefile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1341:         return;
1342:       }
1343:       const action = {
1344:         id: `act_${Date.now()}`,
1345:         type: 'write_file',
1346:         payload: {
1347:           path: resolved.path,
1348:           rel: this.workspaceRelativePath(resolved.path),
1349:           content
1350:         },
1351:         created_at: nowIso()
1352:       };
1353:       this.queueApprovalAction(
1354:         action,
1355:         `${style('Write request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel} (${content.length} chars)`
1356:       );
1357:       return;
1358:     }
1359: 
1360:     if (command === '/skills') {
1361:       const sub = (args[0] || '').toLowerCase();
1362:       if (!sub || sub === 'help') {
1363:         this.print('Usage:');
1364:         this.print('/skills mine [count]');
1365:         this.print('/skills candidates');
1366:         this.print('/skills add <candidate_id> <skill_name>');
1367:         this.print('/skills list');
1368:         this.print('/skills show <skill_id|skill_name>');
1369:         this.print('/skills run <skill_id|skill_name>');
1370:         return;
1371:       }
1372: 
1373:       if (sub === 'mine') {
1374:         const count = Number(args[1] || 10);
1375:         const result = this.collectSkillCandidatesFromArtifacts(count);
1376:         this.print(style(`Mined ${result.candidates} candidate skill patterns from artifacts (sources scanned: ${result.scannedSources}).`, ANSI.cyan));
1377:         for (const c of this.skillCandidates) {
1378:           this.print(style(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.yellow));
1379:           this.print('```');
1380:           this.print(c.snippet);
1381:           this.print('```');
1382:           if (!c.executable) this.print(style(`reason: ${c.safety_reason}`, ANSI.dim));
1383:         }
1384:         return;
1385:       }
1386: 
1387:       if (sub === 'candidates') {
1388:         if (!this.skillCandidates.length) {
1389:           this.print('No candidates loaded. Run /skills mine first.');
1390:           return;
1391:         }
1392:         for (const c of this.skillCandidates) {
1393:           this.print(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'} source_kind=${c.source_kind}`);
1394:         }
1395:         return;
1396:       }
1397: 
1398:       if (sub === 'add') {
1399:         const candidateId = args[1] || '';
1400:         const skillName = args.slice(2).join(' ').trim();
1401:         if (!candidateId || !skillName) {
1402:           this.print('Usage: /skills add <candidate_id> <skill_name>');
1403:           return;
1404:         }
1405:         const existing = this.findSkill(skillName);
1406:         if (existing) {
1407:           this.print(`Skill already exists: ${existing.name} (${existing.id})`);
1408:           return;
1409:         }
1410:         const candidate = this.findCandidate(candidateId);
1411:         if (!candidate) {
1412:           this.print(`Candidate not found: ${candidateId}`);
1413:           return;
1414:         }
1415:         const action = {
1416:           id: `act_${Date.now()}`,
1417:           type: 'add_skill',
1418:           payload: {
1419:             skill_name: skillName,
1420:             source_candidate: candidate.id,
1421:             snippet: candidate.snippet,
1422:             executable: candidate.executable
1423:           },
1424:           created_at: nowIso()
1425:         };
1426:         this.queueApprovalAction(
1427:           action,
1428:           `${style('Add skill queued:', ANSI.bold, ANSI.yellow)} ${skillName} from ${candidate.id}`
1429:         );
1430:         return;
1431:       }
1432: 
1433:       if (sub === 'list') {
1434:         if (!this.skills.length) {
1435:           this.print(`No approved skills yet. Skills file: ${this.skillsPath}`);
1436:           return;
1437:         }
1438:         for (const skill of this.skills) {
1439:           this.print(`[${skill.id}] ${skill.name} | executable=${skill.executable ? 'yes' : 'no'} | source=${skill.source}`);
1440:         }
1441:         return;
1442:       }
1443: 
1444:       if (sub === 'show') {
1445:         const query = args.slice(1).join(' ').trim();
1446:         if (!query) {
1447:           this.print('Usage: /skills show <skill_id|skill_name>');
1448:           return;
1449:         }
1450:         const skill = this.findSkill(query);
1451:         if (!skill) {
1452:           this.print(`Skill not found: ${query}`);
1453:           return;
1454:         }
1455:         this.print(style(`[${skill.id}] ${skill.name}`, ANSI.bold, ANSI.cyan));
1456:         this.print('```');
1457:         this.print(skill.snippet);
1458:         this.print('```');
1459:         return;
1460:       }
1461: 
1462:       if (sub === 'run') {
1463:         const query = args.slice(1).join(' ').trim();
1464:         if (!query) {
1465:           this.print('Usage: /skills run <skill_id|skill_name>');
1466:           return;
1467:         }
1468:         const skill = this.findSkill(query);
1469:         if (!skill) {
1470:           this.print(`Skill not found: ${query}`);
1471:           return;
1472:         }
1473:         const validation = this.validateSkillCommand(skill.snippet);
1474:         if (!validation.ok) {
1475:           this.print(`${style('Skill is not executable:', ANSI.bold, ANSI.red)} ${validation.reason}`);
1476:           return;
1477:         }
1478:         const action = {
1479:           id: `act_${Date.now()}`,
1480:           type: 'run_skill',
1481:           payload: {
1482:             skill_id: skill.id,
1483:             skill_name: skill.name,
1484:             snippet: skill.snippet
1485:           },
1486:           created_at: nowIso()
1487:         };
1488:         this.queueApprovalAction(
1489:           action,
1490:           `${style('Skill execution queued:', ANSI.bold, ANSI.yellow)} ${skill.name}\n${skill.snippet}`
1491:         );
1492:         return;
1493:       }
1494: 
1495:       this.print(`Unknown skills subcommand: ${sub}`);
1496:       return;
1497:     }
1498: 
1499:     this.print(`Unknown command: ${command}. Use /help.`);
1500:   }
