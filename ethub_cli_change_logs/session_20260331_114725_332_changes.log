0120: function hslToRgb(h, s, l) {
0121:   h /= 360;
0122:   const a = s * Math.min(l, 1 - l);
0123:   const f = (n) => {
0124:     const k = (n + h * 12) % 12;
0125:     const c = l - a * Math.max(Math.min(k - 3, 9 - k, 1), -1);
0126:     return Math.round(c * 255);
0127:   };
0128:   return { r: f(0), g: f(8), b: f(4) };
0129: }
