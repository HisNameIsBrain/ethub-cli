0565:     const walk = (value, depth = 0) => {
0566:       if (depth > 8) return;
0567:       if (typeof value === 'string') {
0568:         if (value.trim()) segments.push(value);
0569:         return;
0570:       }
0571:       if (!value || typeof value !== 'object') return;
0572:       if (Array.isArray(value)) {
0573:         for (const item of value) walk(item, depth + 1);
0574:         return;
0575:       }
0576:       if (value.content && Array.isArray(value.content.parts)) {
0577:         for (const part of value.content.parts) {
0578:           if (typeof part === 'string' && part.trim()) segments.push(part);
0579:         }
0580:       }
0581:       if (typeof value.text === 'string' && value.text.trim()) {
0582:         segments.push(value.text);
0583:       }
0584:       for (const key of Object.keys(value)) {
0585:         if (key === 'content' || key === 'text') continue;
0586:         walk(value[key], depth + 1);
0587:       }
0588:     };
0589: 
0590:     if (parsed) {
0591:       walk(parsed);
0592:     } else {
0593:       segments.push(raw);
0594:     }
0595: 
0596:     for (const segment of segments) {
0597:       const fencePattern = /```(?:[^\n`]*)\n([\s\S]*?)```/g;
0598:       let match;
0599:       while ((match = fencePattern.exec(segment)) !== null) {
0600:         addCandidate(match[1], sourceLabel, 'fenced_code');
0601:       }
0602: 
0603:       const lines = segment.split('\n');
0604:       for (const line of lines) {
0605:         const trimmed = line.trim();
0606:         if (!trimmed || trimmed.length > 220) continue;
0607:         const shellLike = trimmed.replace(/^\$\s*/, '');
0608:         if (/^(ls|pwd|cat|head|tail|wc|rg|grep|find|sed|cp|mv|mkdir|touch|echo|git)\b/.test(shellLike)) {
0609:           addCandidate(shellLike, sourceLabel, 'shell_line');
0610:         }
0611:       }
0612:     }
0613:   }
