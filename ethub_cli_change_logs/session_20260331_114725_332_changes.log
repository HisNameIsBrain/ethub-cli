0615:   listArtifactZipFiles() {
0616:     const out = [];
0617:     if (!fs.existsSync(ARTIFACTS_ROOT)) return out;
0618:     const stack = [ARTIFACTS_ROOT];
0619:     while (stack.length) {
0620:       const current = stack.pop();
0621:       let entries = [];
0622:       try {
0623:         entries = fs.readdirSync(current, { withFileTypes: true });
0624:       } catch {
0625:         continue;
0626:       }
0627:       for (const entry of entries) {
0628:         const full = path.join(current, entry.name);
0629:         if (entry.isDirectory()) {
0630:           stack.push(full);
0631:         } else if (entry.isFile() && full.toLowerCase().endsWith('.zip')) {
0632:           out.push(full);
0633:         }
0634:       }
0635:     }
0636:     return out;
0637:   }
0638: 
0639:   collectSkillCandidatesFromArtifacts(limit = 10) {
0640:     const snippets = new Map();
0641:     let scannedSources = 0;
0642:     const cap = Math.max(1, Math.min(MAX_SKILL_CANDIDATES, Number(limit) || 10));
0643:     const addCandidate = (snippetText, sourceLabel, sourceKind) => {
0644:       const normalized = normalizeSnippet(snippetText);
0645:       if (!looksLikeUsefulSnippet(normalized)) return;
0646:       const existing = snippets.get(normalized);
0647:       if (existing) {
0648:         existing.hits += 1;
0649:         existing.sources.add(sourceLabel);
0650:         return;
0651:       }
0652:       snippets.set(normalized, {
0653:         snippet: normalized,
0654:         hits: 1,
0655:         source_kind: sourceKind,
0656:         sources: new Set([sourceLabel])
0657:       });
0658:     };
0659: 
0660:     const zipFiles = this.listArtifactZipFiles();
0661:     for (const zipPath of zipFiles) {
0662:       try {
0663:         const entries = extractTextEntriesFromZip(zipPath, isLikelyTextPath);
0664:         for (const item of entries) {
0665:           scannedSources += 1;
0666:           this.extractSnippetCandidatesFromText(item.text, `${path.basename(zipPath)}:${item.entry}`, addCandidate);
0667:         }
0668:       } catch (error) {
0669:         this.logger.writeEvent('skills_mine_warning', {
0670:           stage: 'zip_read',
0671:           zip: zipPath,
0672:           error: error.message
0673:         });
0674:       }
0675:     }
0676: 
0677:     const directArtifactFiles = [];
0678:     if (fs.existsSync(ARTIFACTS_ROOT)) {
0679:       const stack = [ARTIFACTS_ROOT];
0680:       while (stack.length) {
0681:         const current = stack.pop();
0682:         let entries = [];
0683:         try {
0684:           entries = fs.readdirSync(current, { withFileTypes: true });
0685:         } catch {
0686:           continue;
0687:         }
0688:         for (const entry of entries) {
0689:           const full = path.join(current, entry.name);
0690:           if (entry.isDirectory()) stack.push(full);
0691:           else if (entry.isFile() && !full.toLowerCase().endsWith('.zip') && isLikelyTextPath(full)) directArtifactFiles.push(full);
0692:         }
0693:       }
0694:     }
0695: 
0696:     for (const filePath of directArtifactFiles) {
0697:       let text = '';
0698:       try {
0699:         text = fs.readFileSync(filePath, 'utf8');
0700:       } catch {
0701:         continue;
0702:       }
0703:       scannedSources += 1;
0704:       this.extractSnippetCandidatesFromText(text, this.workspaceRelativePath(filePath), addCandidate);
0705:     }
0706: 
0707:     const ranked = Array.from(snippets.values())
0708:       .sort((a, b) => b.hits - a.hits || b.snippet.length - a.snippet.length)
0709:       .slice(0, cap);
0710: 
0711:     this.skillCandidates = ranked.map((entry, idx) => {
0712:       const snippet = entry.snippet;
0713:       const safety = this.validateSkillCommand(snippet);
0714:       return {
0715:         id: `cand_${idx + 1}`,
0716:         snippet,
0717:         hits: entry.hits,
0718:         source_kind: entry.source_kind,
0719:         sources: Array.from(entry.sources).slice(0, 6),
0720:         executable: safety.ok,
0721:         safety_reason: safety.ok ? '' : safety.reason
0722:       };
0723:     });
0724: 
0725:     this.logger.writeEvent('skills_mined', {
0726:       candidates: this.skillCandidates.length,
0727:       unique_snippets: snippets.size,
0728:       scanned_sources: scannedSources,
0729:       zip_files: zipFiles.length
0730:     });
0731: 
0732:     return {
0733:       candidates: this.skillCandidates.length,
0734:       uniqueSnippets: snippets.size,
0735:       scannedSources,
0736:       zipFiles: zipFiles.length
0737:     };
0738:   }
0739: 
0740:   findCandidate(query) {
0741:     const q = String(query || '').trim();
0742:     if (!q) return null;
0743:     return this.skillCandidates.find((c) => c.id === q) || null;
0744:   }
0745: 
0746:   findSkill(query) {
0747:     const q = String(query || '').trim().toLowerCase();
0748:     if (!q) return null;
0749:     return this.skills.find((s) => s.id.toLowerCase() === q || s.name.toLowerCase() === q) || null;
0750:   }
