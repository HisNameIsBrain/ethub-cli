0266: function extractTextEntriesFromZip(zipPath, shouldInclude) {
0267:   const out = [];
0268:   const data = fs.readFileSync(zipPath);
0269:   const minEocd = 22;
0270:   const maxComment = 0xffff;
0271:   const startSearch = Math.max(0, data.length - (minEocd + maxComment));
0272:   let eocd = -1;
0273:   for (let i = data.length - minEocd; i >= startSearch; i -= 1) {
0274:     if (data.readUInt32LE(i) === 0x06054b50) {
0275:       eocd = i;
0276:       break;
0277:     }
0278:   }
0279:   if (eocd < 0) throw new Error('zip EOCD signature not found');
0280: 
0281:   const centralDirSize = data.readUInt32LE(eocd + 12);
0282:   const centralDirOffset = data.readUInt32LE(eocd + 16);
0283:   const centralDirEnd = centralDirOffset + centralDirSize;
0284:   let cursor = centralDirOffset;
0285: 
0286:   while (cursor + 46 <= centralDirEnd && cursor + 46 <= data.length) {
0287:     const sig = data.readUInt32LE(cursor);
0288:     if (sig !== 0x02014b50) break;
0289:     const compressionMethod = data.readUInt16LE(cursor + 10);
0290:     const compressedSize = data.readUInt32LE(cursor + 20);
0291:     const fileNameLen = data.readUInt16LE(cursor + 28);
0292:     const extraLen = data.readUInt16LE(cursor + 30);
0293:     const commentLen = data.readUInt16LE(cursor + 32);
0294:     const localHeaderOffset = data.readUInt32LE(cursor + 42);
0295:     const nameStart = cursor + 46;
0296:     const nameEnd = nameStart + fileNameLen;
0297:     const entryName = data.slice(nameStart, nameEnd).toString('utf8');
0298:     const next = nameEnd + extraLen + commentLen;
0299:     cursor = next;
0300: 
0301:     if (!shouldInclude(entryName)) continue;
0302:     if (entryName.endsWith('/')) continue;
0303:     if (localHeaderOffset + 30 > data.length) continue;
0304:     if (data.readUInt32LE(localHeaderOffset) !== 0x04034b50) continue;
0305: 
0306:     const localNameLen = data.readUInt16LE(localHeaderOffset + 26);
0307:     const localExtraLen = data.readUInt16LE(localHeaderOffset + 28);
0308:     const payloadStart = localHeaderOffset + 30 + localNameLen + localExtraLen;
0309:     const payloadEnd = payloadStart + compressedSize;
0310:     if (payloadEnd > data.length) continue;
0311: 
0312:     const compressed = data.slice(payloadStart, payloadEnd);
0313:     let decoded;
0314:     if (compressionMethod === 0) {
0315:       decoded = compressed;
0316:     } else if (compressionMethod === 8) {
0317:       decoded = zlib.inflateRawSync(compressed);
0318:     } else {
0319:       continue;
0320:     }
0321: 
0322:     out.push({
0323:       entry: entryName,
0324:       text: decoded.toString('utf8')
0325:     });
0326:   }
0327:   return out;
0328: }
