0903:   async ensureDashboardRunning() {
0904:     const runtime = this.readDashboardRuntime();
0905:     if (runtime && Number(runtime.port) > 0) {
0906:       const healthy = await this.isDashboardHealthy(runtime.port);
0907:       if (healthy) {
0908:         this.dashboardInfo = runtime;
0909:         return;
0910:       }
0911:     }
0912: 
0913:     const serverPath = this.resolveDashboardServerPath();
0914:     if (!serverPath) return;
0915:     try {
0916:       const child = spawn(process.execPath, [serverPath], {
0917:         cwd: this.workspaceRoot,
0918:         detached: true,
0919:         stdio: 'ignore'
0920:       });
0921:       child.unref();
0922:       this.logger.writeEvent('dashboard_boot', { started: true, path: serverPath });
0923:     } catch (error) {
0924:       this.logger.writeEvent('dashboard_boot', { started: false, error: error.message });
0925:       return;
0926:     }
0927: 
0928:     for (let i = 0; i < 10; i += 1) {
0929:       await new Promise((resolve) => setTimeout(resolve, 300));
0930:       const nextRuntime = this.readDashboardRuntime();
0931:       if (nextRuntime && Number(nextRuntime.port) > 0) {
0932:         this.dashboardInfo = nextRuntime;
0933:         break;
0934:       }
0935:     }
0936:   }
