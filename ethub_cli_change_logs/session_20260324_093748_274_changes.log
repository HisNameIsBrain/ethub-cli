0054: function summarizeReasoning(input) {
0055:   const raw = String(input || '').trim();
0056:   const lowered = raw.toLowerCase();
0057:   const keywords = raw
0058:     .split(/\s+/)
0059:     .map((w) => w.replace(/[^a-zA-Z0-9_-]/g, ''))
0060:     .filter(Boolean)
0061:     .slice(0, 12);
0062: 
0063:   let intent = 'general_request';
0064:   if (/error|syntax|stack|trace|bug|fix|crash/.test(lowered)) intent = 'debugging';
0065:   else if (/how|what|why|explain|guide|tutorial/.test(lowered)) intent = 'information_lookup';
0066:   else if (/build|create|make|implement|write/.test(lowered)) intent = 'implementation';
0067: 
0068:   let strategy = 'Use local conversation context then query Ollama for a grounded response.';
0069:   if (intent === 'debugging') {
0070:     strategy = 'Focus on likely fault points, propose checks, and request missing runtime details if needed.';
0071:   }
0072: 
0073:   return {
0074:     query: raw,
0075:     intent,
0076:     keywords,
0077:     strategy,
0078:     note: 'Detailed private chain-of-thought is not exposed; this is a concise decision summary.'
0079:   };
0080: }
