0030: function summarizeReasoning(input) {
0031:   const raw = String(input || '').trim();
0032:   const lowered = raw.toLowerCase();
0033:   const keywords = raw
0034:     .split(/\s+/)
0035:     .map((w) => w.replace(/[^a-zA-Z0-9_-]/g, ''))
0036:     .filter(Boolean)
0037:     .slice(0, 12);
0038: 
0039:   let intent = 'general_request';
0040:   if (/error|syntax|stack|trace|bug|fix|crash/.test(lowered)) intent = 'debugging';
0041:   else if (/how|what|why|explain|guide|tutorial/.test(lowered)) intent = 'information_lookup';
0042:   else if (/build|create|make|implement|write/.test(lowered)) intent = 'implementation';
0043: 
0044:   let strategy = 'Use local conversation context then query Ollama for a grounded response.';
0045:   if (intent === 'debugging') {
0046:     strategy = 'Focus on likely fault points, propose checks, and request missing runtime details if needed.';
0047:   }
0048: 
0049:   return {
0050:     query: raw,
0051:     intent,
0052:     keywords,
0053:     strategy,
0054:     note: 'Detailed private chain-of-thought is not exposed; this is a concise decision summary.'
0055:   };
0056: }
