0394:       this.logger.writeEvent('action_error', { message: 'Unsupported action type', action });
0395:       this.writeStructuredUpdate(action && action.id ? action.id : 'unknown', {
0396:         'Run runtime look at logs': 'contains error still, unsupported action type',
0397:         summary: 'Unsupported action type encountered before runtime request.',
0398:         'Number of characters changed': 'previous character amount in file before cmd/new total character count added: 0/0'
0399:       });
0400:       this.print('Unsupported action.');
0401:       return;
0402:     }
0403: 
0404:     this.logger.writeEvent('action_start', {
0405:       action_id: action.id,
0406:       type: action.type,
0407:       target: this.ollamaUrl,
0408:       model: this.model,
0409:       prompt_chars: action.prompt.length,
0410:       reasoning_summary: action.reasoning_summary
0411:     });
0412: 
0413:     this.history.push({ role: 'user', content: action.prompt });
0414: 
0415:     const payload = {
0416:       model: this.model,
0417:       messages: this.history,
0418:       stream: false
0419:     };
0420: 
0421:     let response;
0422:     let raw;
0423:     const started = Date.now();
0424: 
0425:     try {
0426:       response = await fetch(this.ollamaUrl, {
0427:         method: 'POST',
0428:         headers: { 'Content-Type': 'application/json' },
0429:         body: JSON.stringify(payload)
0430:       });
0431: 
0432:       raw = await response.text();
0433:     } catch (error) {
0434:       const message = error && error.message ? error.message : String(error);
0435:       this.logger.writeEvent('action_failure', {
