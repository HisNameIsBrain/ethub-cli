0094: 
0095:   buildSessionId() {
0096:     const d = new Date();
0097:     const stamp = [
0098:       d.getUTCFullYear(),
0099:       String(d.getUTCMonth() + 1).padStart(2, '0'),
0100:       String(d.getUTCDate()).padStart(2, '0'),
0101:       '_',
0102:       String(d.getUTCHours()).padStart(2, '0'),
0103:       String(d.getUTCMinutes()).padStart(2, '0'),
0104:       String(d.getUTCSeconds()).padStart(2, '0'),
0105:       '_',
0106:       String(d.getUTCMilliseconds()).padStart(3, '0')
0107:     ].join('');
0108:     return `session_${stamp}`;
0109:   }
0110: 
0111:   writeEvent(type, payload) {
0112:     this.counter += 1;
0113:     const event = {
0114:       index: this.counter,
0115:       ts: nowIso(),
0116:       type,
0117:       payload
0118:     };
0119:     fs.appendFileSync(this.eventsPath, `${safeJson(event)}\n`, 'utf8');
0120:   }
0121: 
0122:   writeTranscript(role, content) {
0123:     const text = String(content || '').trimEnd();
0124:     const block = `\n## ${role} @ ${nowIso()}\n\n${text}\n`;
0125:     fs.appendFileSync(this.transcriptPath, block, 'utf8');
0126:   }
0127: 
0128:   writeState(state) {
0129:     fs.appendFileSync(this.statePath, `${safeJson(state)}\n`, 'utf8');
0130:   }
0131: 
0132:   writeStructuredRecord(record) {
0133:     fs.appendFileSync(this.structuredPath, `${safeJson(record)}\n`, 'utf8');
0134:   }
0135: 
0136:   writeCodeSnapshot() {
0137:     const sourcePath = path.resolve(__filename);
0138:     let sourceText = '';
0139:     try {
0140:       sourceText = fs.readFileSync(sourcePath, 'utf8');
0141:     } catch (error) {
0142:       sourceText = `Unable to read source file: ${error && error.message ? error.message : String(error)}`;
0143:     }
0144: 
0145:     const numbered = sourceText
0146:       .split('\n')
0147:       .map((line, i) => `${String(i + 1).padStart(4, '0')}: ${line}`)
0148:       .join('\n');
0149: 
0150:     const header =
0151:       `# ETHUB CLI Change Log\n` +
0152:       `session_id: ${this.sessionId}\n` +
0153:       `created_at: ${nowIso()}\n` +
0154:       `source_file: ${sourcePath}\n` +
0155:       `note: New file per session, append-only event/state logs enabled.\n\n` +
0156:       `## Source Snapshot (Line Numbered)\n`;
0157: 
0158:     fs.writeFileSync(this.changeLogPath, `${header}${numbered}\n`, 'utf8');
0159:   }
0160: }
