1010:   resolvePathInWorkspace(inputPath, expected = 'any') {
1011:     const raw = String(inputPath || '').trim();
1012:     if (!raw) return { error: 'path is required' };
1013:     const normalized = raw === '~' ? os.homedir() : raw;
1014:     const resolved = path.resolve(process.cwd(), normalized);
1015:     const root = path.resolve(this.workspaceRoot);
1016:     const inRoot = resolved === root || resolved.startsWith(`${root}${path.sep}`);
1017:     if (!inRoot) {
1018:       return { error: `path escapes workspace root: ${root}` };
1019:     }
1020: 
1021:     if (expected === 'exists') {
1022:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
1023:     }
1024:     if (expected === 'file' || expected === 'dir') {
1025:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
1026:       let st;
1027:       try {
1028:         st = fs.statSync(resolved);
1029:       } catch (error) {
1030:         return { error: `unable to stat path: ${error.message}` };
1031:       }
1032:       if (expected === 'file' && !st.isFile()) return { error: 'path is not a file' };
1033:       if (expected === 'dir' && !st.isDirectory()) return { error: 'path is not a directory' };
1034:     }
1035: 
1036:     return { path: resolved };
1037:   }
