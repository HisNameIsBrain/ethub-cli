1126:       const dots = '.'.repeat(i % 4);
1127:       process.stdout.write(
1128:         `\r${LEFT_PAD}${style('Thinking', ANSI.cyan)}${dots.padEnd(3, ' ')}${style(' parsing your request', ANSI.dim)}${' '.repeat(20)}`
1129:       );
1130:       i += 1;
1131:     }, 140);
1132:   }
