0794:   async runSkillCommand(action) {
0795:     const payload = action && action.payload ? action.payload : {};
0796:     const skillName = payload.skill_name || payload.skill_id || 'unknown';
0797:     const snippet = String(payload.snippet || '');
0798:     const validation = this.validateSkillCommand(snippet);
0799:     if (!validation.ok) {
0800:       this.print(`${style('Skill execution denied:', ANSI.bold, ANSI.red)} ${validation.reason}`);
0801:       this.logger.writeEvent('skill_run_denied', {
0802:         action_id: action.id,
0803:         skill: skillName,
0804:         reason: validation.reason
0805:       });
0806:       return;
0807:     }
0808: 
0809:     const tokens = validation.tokens;
0810:     const cmd = tokens[0];
0811:     const args = tokens.slice(1);
0812:     this.print(style(`[SKILL RUN] ${skillName}: ${snippet}`, ANSI.bold, ANSI.cyan));
0813: 
0814:     const result = await new Promise((resolve) => {
0815:       const child = spawn(cmd, args, {
0816:         cwd: process.cwd(),
0817:         stdio: ['ignore', 'pipe', 'pipe'],
0818:         shell: false
0819:       });
0820: 
0821:       let stdout = '';
0822:       let stderr = '';
0823:       let finished = false;
0824:       const timer = setTimeout(() => {
0825:         if (finished) return;
0826:         child.kill('SIGTERM');
0827:       }, 120000);
0828: 
0829:       child.stdout.on('data', (chunk) => {
0830:         if (stdout.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0831:         stdout += chunk.toString('utf8');
0832:       });
0833:       child.stderr.on('data', (chunk) => {
0834:         if (stderr.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0835:         stderr += chunk.toString('utf8');
0836:       });
0837:       child.on('error', (error) => {
0838:         clearTimeout(timer);
0839:         finished = true;
0840:         resolve({ code: -1, signal: null, stdout, stderr: `${stderr}\n${error.message}`.trim() });
0841:       });
0842:       child.on('close', (code, signal) => {
0843:         clearTimeout(timer);
0844:         finished = true;
0845:         resolve({ code, signal, stdout, stderr });
0846:       });
0847:     });
0848: 
0849:     if (result.stdout) {
0850:       this.print(style('[STDOUT]', ANSI.dim));
0851:       this.print(truncateText(result.stdout, MAX_COMMAND_OUTPUT_BYTES));
0852:     }
0853:     if (result.stderr) {
0854:       this.print(style('[STDERR]', ANSI.dim));
0855:       this.print(truncateText(result.stderr, MAX_COMMAND_OUTPUT_BYTES));
0856:     }
0857:     this.print(style(`[SKILL EXIT] code=${result.code} signal=${result.signal || 'none'}`, ANSI.dim));
0858:     this.logger.writeEvent('skill_run_complete', {
0859:       action_id: action.id,
0860:       skill: skillName,
0861:       code: result.code,
0862:       signal: result.signal,
0863:       stdout_chars: result.stdout.length,
0864:       stderr_chars: result.stderr.length
0865:     });
0866:   }
