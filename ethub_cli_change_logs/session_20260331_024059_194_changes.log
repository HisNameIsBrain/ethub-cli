0263: function extractTextEntriesFromZip(zipPath, shouldInclude) {
0264:   const out = [];
0265:   const data = fs.readFileSync(zipPath);
0266:   const minEocd = 22;
0267:   const maxComment = 0xffff;
0268:   const startSearch = Math.max(0, data.length - (minEocd + maxComment));
0269:   let eocd = -1;
0270:   for (let i = data.length - minEocd; i >= startSearch; i -= 1) {
0271:     if (data.readUInt32LE(i) === 0x06054b50) {
0272:       eocd = i;
0273:       break;
0274:     }
0275:   }
0276:   if (eocd < 0) throw new Error('zip EOCD signature not found');
0277: 
0278:   const centralDirSize = data.readUInt32LE(eocd + 12);
0279:   const centralDirOffset = data.readUInt32LE(eocd + 16);
0280:   const centralDirEnd = centralDirOffset + centralDirSize;
0281:   let cursor = centralDirOffset;
0282: 
0283:   while (cursor + 46 <= centralDirEnd && cursor + 46 <= data.length) {
0284:     const sig = data.readUInt32LE(cursor);
0285:     if (sig !== 0x02014b50) break;
0286:     const compressionMethod = data.readUInt16LE(cursor + 10);
0287:     const compressedSize = data.readUInt32LE(cursor + 20);
0288:     const fileNameLen = data.readUInt16LE(cursor + 28);
0289:     const extraLen = data.readUInt16LE(cursor + 30);
0290:     const commentLen = data.readUInt16LE(cursor + 32);
0291:     const localHeaderOffset = data.readUInt32LE(cursor + 42);
0292:     const nameStart = cursor + 46;
0293:     const nameEnd = nameStart + fileNameLen;
0294:     const entryName = data.slice(nameStart, nameEnd).toString('utf8');
0295:     const next = nameEnd + extraLen + commentLen;
0296:     cursor = next;
0297: 
0298:     if (!shouldInclude(entryName)) continue;
0299:     if (entryName.endsWith('/')) continue;
0300:     if (localHeaderOffset + 30 > data.length) continue;
0301:     if (data.readUInt32LE(localHeaderOffset) !== 0x04034b50) continue;
0302: 
0303:     const localNameLen = data.readUInt16LE(localHeaderOffset + 26);
0304:     const localExtraLen = data.readUInt16LE(localHeaderOffset + 28);
0305:     const payloadStart = localHeaderOffset + 30 + localNameLen + localExtraLen;
0306:     const payloadEnd = payloadStart + compressedSize;
0307:     if (payloadEnd > data.length) continue;
0308: 
0309:     const compressed = data.slice(payloadStart, payloadEnd);
0310:     let decoded;
0311:     if (compressionMethod === 0) {
0312:       decoded = compressed;
0313:     } else if (compressionMethod === 8) {
0314:       decoded = zlib.inflateRawSync(compressed);
0315:     } else {
0316:       continue;
0317:     }
0318: 
0319:     out.push({
0320:       entry: entryName,
0321:       text: decoded.toString('utf8')
0322:     });
0323:   }
0324:   return out;
0325: }
