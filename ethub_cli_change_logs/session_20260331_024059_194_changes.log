1141:   async handleCommand(input) {
1142:     const [cmd, ...args] = input.split(/\s+/);
1143:     const command = cmd.toLowerCase();
1144:     this.logger.writeEvent('subcommand', { command, args });
1145: 
1146:     if (command === '/help') {
1147:       this.print('Commands: /help, /status, /model <name>, /approve changes on|off, /readfile <path>, /writefile <path> -- <content>, /cd <path>, /skills <mine|candidates|add|list|show|run>, /yes, /no, /exit');
1148:       this.print('Skills flow: /skills mine 10 -> /skills add cand_1 my_skill -> /yes -> /skills run my_skill -> /yes');
1149:       return;
1150:     }
1151: 
1152:     if (command === '/status') {
1153:       this.print(safeJson({
1154:         model: this.model,
1155:         ollama_url: this.ollamaUrl,
1156:         require_approval_for_changes: this.requireApproval,
1157:         skills_count: this.skills.length,
1158:         skill_candidates_count: this.skillCandidates.length,
1159:         dashboard_url: this.dashboardInfo && this.dashboardInfo.dashboard_url ? this.dashboardInfo.dashboard_url : null,
1160:         history_count: this.history.length,
1161:         pending_action: this.pendingAction ? this.pendingAction.id : null
1162:       }));
1163:       return;
1164:     }
1165: 
1166:     if (command === '/model') {
1167:       const nextModel = args.join(' ').trim();
1168:       if (!nextModel) {
1169:         this.print(`Current model: ${this.model}`);
1170:         return;
1171:       }
1172:       this.model = nextModel;
1173:       this.print(`Model updated: ${this.model}`);
1174:       this.logger.writeEvent('config_update', { key: 'model', value: this.model });
1175:       return;
1176:     }
1177: 
1178:     if (command === '/approve') {
1179:       const target = (args[0] || '').toLowerCase();
1180:       const mode = (args[1] || '').toLowerCase();
1181:       const legacyMode = target;
1182: 
1183:       if (target === 'changes' && (mode === 'on' || mode === 'off')) {
1184:         this.requireApproval = mode === 'on';
1185:         this.print(`Change approval mode: ${mode}`);
1186:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1187:         return;
1188:       }
1189: 
1190:       if (legacyMode === 'on' || legacyMode === 'off') {
1191:         this.requireApproval = legacyMode === 'on';
1192:         this.print(`Change approval mode: ${legacyMode}`);
1193:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1194:         return;
1195:       }
1196: 
1197:       if (!target) {
1198:         this.print(`Change approval mode: ${this.requireApproval ? 'on' : 'off'}`);
1199:         return;
1200:       }
1201: 
1202:       this.print('Usage: /approve changes on|off');
1203:       return;
1204:     }
1205: 
1206:     if (command === '/yes') {
1207:       if (!this.pendingAction) {
1208:         this.print('No pending action to approve.');
1209:         return;
1210:       }
1211:       const action = this.pendingAction;
1212:       this.pendingAction = null;
1213:       this.logger.writeEvent('approval', { action_id: action.id, approved: true });
1214:       this.writeStructuredUpdate(action.id, {
1215:         'Print-approved-by-user?': 'true',
1216:         approved: true
1217:       });
1218:       await this.executePendingAction(action);
1219:       return;
1220:     }
1221: 
1222:     if (command === '/no') {
1223:       if (!this.pendingAction) {
1224:         this.print('No pending action to reject.');
1225:         return;
1226:       }
1227:       const action = this.pendingAction;
1228:       this.pendingAction = null;
1229:       this.logger.writeEvent('approval', { action_id: action.id, approved: false });
1230:       this.writeStructuredUpdate(action.id, {
1231:         'Print-approved-by-user?': 'false',
1232:         approved: false,
1233:         summary: 'Action was rejected by user before runtime execution.',
1234:         'Run runtime look at logs': 'skipped (approval rejected)'
1235:       });
1236:       this.print(`Action ${action.id} skipped.`);
1237:       return;
1238:     }
1239: 
1240:     if (command === '/exit') {
1241:       this.rl.close();
1242:       return;
1243:     }
1244: 
1245:     if (command === '/cd') {
1246:       const rawTarget = input.replace(/^\/cd\s*/i, '').trim();
1247:       if (!rawTarget) {
1248:         this.print(`Current directory: ${process.cwd()}`);
1249:         return;
1250:       }
1251:       const resolved = this.resolvePathInWorkspace(rawTarget, 'dir');
1252:       if (resolved.error) {
1253:         this.print(`${style('cd denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1254:         return;
1255:       }
1256:       process.chdir(resolved.path);
1257:       this.refreshPrompt();
1258:       this.logger.writeEvent('cwd_changed', {
1259:         cwd: process.cwd(),
1260:         workspace_relative: this.workspaceRelativePath()
1261:       });
1262:       this.print(style(`Directory changed to ${this.workspaceRelativePath()}`, ANSI.cyan));
1263:       return;
1264:     }
1265: 
1266:     if (command === '/readfile') {
1267:       const rawPath = input.replace(/^\/readfile\s*/i, '').trim();
1268:       if (!rawPath) {
1269:         this.print('Usage: /readfile <path>');
1270:         return;
1271:       }
1272:       const resolved = this.resolvePathInWorkspace(rawPath, 'file');
1273:       if (resolved.error) {
1274:         this.print(`${style('readfile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1275:         return;
1276:       }
1277:       const action = {
1278:         id: `act_${Date.now()}`,
1279:         type: 'read_file',
1280:         payload: {
1281:           path: resolved.path,
1282:           rel: this.workspaceRelativePath(resolved.path)
1283:         },
1284:         created_at: nowIso()
1285:       };
1286:       this.queueApprovalAction(
1287:         action,
1288:         `${style('Read request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel}`
1289:       );
1290:       return;
1291:     }
1292: 
1293:     if (command === '/writefile') {
1294:       const raw = input.replace(/^\/writefile\s*/i, '');
1295:       const splitIndex = raw.indexOf(' -- ');
1296:       if (splitIndex === -1) {
1297:         this.print('Usage: /writefile <path> -- <content>');
1298:         return;
1299:       }
1300:       const rawPath = raw.slice(0, splitIndex).trim();
1301:       const content = raw.slice(splitIndex + 4);
1302:       if (!rawPath) {
1303:         this.print('Usage: /writefile <path> -- <content>');
1304:         return;
1305:       }
1306:       const resolved = this.resolvePathInWorkspace(rawPath, 'any');
1307:       if (resolved.error) {
1308:         this.print(`${style('writefile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1309:         return;
1310:       }
1311:       const action = {
1312:         id: `act_${Date.now()}`,
1313:         type: 'write_file',
1314:         payload: {
1315:           path: resolved.path,
1316:           rel: this.workspaceRelativePath(resolved.path),
1317:           content
1318:         },
1319:         created_at: nowIso()
1320:       };
1321:       this.queueApprovalAction(
1322:         action,
1323:         `${style('Write request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel} (${content.length} chars)`
1324:       );
1325:       return;
1326:     }
1327: 
1328:     if (command === '/skills') {
1329:       const sub = (args[0] || '').toLowerCase();
1330:       if (!sub || sub === 'help') {
1331:         this.print('Usage:');
1332:         this.print('/skills mine [count]');
1333:         this.print('/skills candidates');
1334:         this.print('/skills add <candidate_id> <skill_name>');
1335:         this.print('/skills list');
1336:         this.print('/skills show <skill_id|skill_name>');
1337:         this.print('/skills run <skill_id|skill_name>');
1338:         return;
1339:       }
1340: 
1341:       if (sub === 'mine') {
1342:         const count = Number(args[1] || 10);
1343:         const result = this.collectSkillCandidatesFromArtifacts(count);
1344:         this.print(style(`Mined ${result.candidates} candidate skill patterns from artifacts (sources scanned: ${result.scannedSources}).`, ANSI.cyan));
1345:         for (const c of this.skillCandidates) {
1346:           this.print(style(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.yellow));
1347:           this.print('```');
1348:           this.print(c.snippet);
1349:           this.print('```');
1350:           if (!c.executable) this.print(style(`reason: ${c.safety_reason}`, ANSI.dim));
1351:         }
1352:         return;
1353:       }
1354: 
1355:       if (sub === 'candidates') {
1356:         if (!this.skillCandidates.length) {
1357:           this.print('No candidates loaded. Run /skills mine first.');
1358:           return;
1359:         }
1360:         for (const c of this.skillCandidates) {
1361:           this.print(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'} source_kind=${c.source_kind}`);
1362:         }
1363:         return;
1364:       }
1365: 
1366:       if (sub === 'add') {
1367:         const candidateId = args[1] || '';
1368:         const skillName = args.slice(2).join(' ').trim();
1369:         if (!candidateId || !skillName) {
1370:           this.print('Usage: /skills add <candidate_id> <skill_name>');
1371:           return;
1372:         }
1373:         const existing = this.findSkill(skillName);
1374:         if (existing) {
1375:           this.print(`Skill already exists: ${existing.name} (${existing.id})`);
1376:           return;
1377:         }
1378:         const candidate = this.findCandidate(candidateId);
1379:         if (!candidate) {
1380:           this.print(`Candidate not found: ${candidateId}`);
1381:           return;
1382:         }
1383:         const action = {
1384:           id: `act_${Date.now()}`,
1385:           type: 'add_skill',
1386:           payload: {
1387:             skill_name: skillName,
1388:             source_candidate: candidate.id,
1389:             snippet: candidate.snippet,
1390:             executable: candidate.executable
1391:           },
1392:           created_at: nowIso()
1393:         };
1394:         this.queueApprovalAction(
1395:           action,
1396:           `${style('Add skill queued:', ANSI.bold, ANSI.yellow)} ${skillName} from ${candidate.id}`
1397:         );
1398:         return;
1399:       }
1400: 
1401:       if (sub === 'list') {
1402:         if (!this.skills.length) {
1403:           this.print(`No approved skills yet. Skills file: ${this.skillsPath}`);
1404:           return;
1405:         }
1406:         for (const skill of this.skills) {
1407:           this.print(`[${skill.id}] ${skill.name} | executable=${skill.executable ? 'yes' : 'no'} | source=${skill.source}`);
1408:         }
1409:         return;
1410:       }
1411: 
1412:       if (sub === 'show') {
1413:         const query = args.slice(1).join(' ').trim();
1414:         if (!query) {
1415:           this.print('Usage: /skills show <skill_id|skill_name>');
1416:           return;
1417:         }
1418:         const skill = this.findSkill(query);
1419:         if (!skill) {
1420:           this.print(`Skill not found: ${query}`);
1421:           return;
1422:         }
1423:         this.print(style(`[${skill.id}] ${skill.name}`, ANSI.bold, ANSI.cyan));
1424:         this.print('```');
1425:         this.print(skill.snippet);
1426:         this.print('```');
1427:         return;
1428:       }
1429: 
1430:       if (sub === 'run') {
1431:         const query = args.slice(1).join(' ').trim();
1432:         if (!query) {
1433:           this.print('Usage: /skills run <skill_id|skill_name>');
1434:           return;
1435:         }
1436:         const skill = this.findSkill(query);
1437:         if (!skill) {
1438:           this.print(`Skill not found: ${query}`);
1439:           return;
1440:         }
1441:         const validation = this.validateSkillCommand(skill.snippet);
1442:         if (!validation.ok) {
1443:           this.print(`${style('Skill is not executable:', ANSI.bold, ANSI.red)} ${validation.reason}`);
1444:           return;
1445:         }
1446:         const action = {
1447:           id: `act_${Date.now()}`,
1448:           type: 'run_skill',
1449:           payload: {
1450:             skill_id: skill.id,
1451:             skill_name: skill.name,
1452:             snippet: skill.snippet
1453:           },
1454:           created_at: nowIso()
1455:         };
1456:         this.queueApprovalAction(
1457:           action,
1458:           `${style('Skill execution queued:', ANSI.bold, ANSI.yellow)} ${skill.name}\n${skill.snippet}`
1459:         );
1460:         return;
1461:       }
1462: 
1463:       this.print(`Unknown skills subcommand: ${sub}`);
1464:       return;
1465:     }
1466: 
1467:     this.print(`Unknown command: ${command}. Use /help.`);
1468:   }
