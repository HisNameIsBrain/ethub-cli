1470:   async executePendingAction(action) {
1471:     if (!action) return;
1472:     if (action.type === 'ollama_chat') {
1473:       await this.executeAction(action);
1474:       return;
1475:     }
1476:     if (action.type === 'read_file') {
1477:       this.runReadFileAction(action);
1478:       return;
1479:     }
1480:     if (action.type === 'write_file') {
1481:       this.runWriteFileAction(action);
1482:       return;
1483:     }
1484:     if (action.type === 'add_skill') {
1485:       this.runAddSkillAction(action);
1486:       return;
1487:     }
1488:     if (action.type === 'run_skill') {
1489:       await this.runSkillCommand(action);
1490:       return;
1491:     }
1492:     this.print(`Unsupported pending action type: ${action.type}`);
1493:   }
1494: 
1495:   runReadFileAction(action) {
1496:     const filePath = action && action.payload ? action.payload.path : '';
1497:     if (!filePath || !fs.existsSync(filePath)) {
1498:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} file no longer exists.`);
1499:       return;
1500:     }
1501:     let text;
1502:     try {
1503:       text = fs.readFileSync(filePath, 'utf8');
1504:     } catch (error) {
1505:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1506:       return;
1507:     }
1508:     const shown = truncateText(text, MAX_READFILE_BYTES);
1509:     const rel = action.payload.rel || this.workspaceRelativePath(filePath);
1510:     this.print(style(`\n[READFILE] ${rel}`, ANSI.bold, ANSI.cyan));
1511:     this.print(style(`bytes: ${Buffer.byteLength(text, 'utf8')} | shown: ${Buffer.byteLength(shown, 'utf8')}`, ANSI.dim));
1512:     this.print(shown);
1513:     this.logger.writeEvent('read_file', {
1514:       action_id: action.id,
1515:       file: filePath,
1516:       bytes: Buffer.byteLength(text, 'utf8'),
1517:       shown_bytes: Buffer.byteLength(shown, 'utf8')
1518:     });
1519:   }
1520: 
1521:   runWriteFileAction(action) {
1522:     const filePath = action && action.payload ? action.payload.path : '';
1523:     const content = action && action.payload ? String(action.payload.content || '') : '';
1524:     if (!filePath) {
1525:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} missing target path.`);
1526:       return;
1527:     }
1528:     try {
1529:       ensureDir(path.dirname(filePath));
1530:       fs.writeFileSync(filePath, content, 'utf8');
1531:     } catch (error) {
1532:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1533:       return;
1534:     }
1535:     this.print(style(`[WRITEFILE] wrote ${content.length} chars to ${action.payload.rel}`, ANSI.bold, ANSI.cyan));
1536:     this.logger.writeEvent('write_file', {
1537:       action_id: action.id,
1538:       file: filePath,
1539:       chars: content.length
1540:     });
1541:   }
1542: 
1543:   runAddSkillAction(action) {
1544:     const payload = action && action.payload ? action.payload : {};
1545:     const name = String(payload.skill_name || '').trim();
1546:     const snippet = String(payload.snippet || '');
1547:     if (!name || !snippet) {
1548:       this.print(`${style('Add skill failed:', ANSI.bold, ANSI.red)} missing skill name or snippet.`);
1549:       return;
1550:     }
1551:     const duplicate = this.findSkill(name);
1552:     if (duplicate) {
1553:       this.print(`${style('Add skill skipped:', ANSI.bold, ANSI.red)} skill already exists (${duplicate.id}).`);
1554:       return;
1555:     }
1556: 
1557:     const skill = {
1558:       id: `skill_${Date.now()}`,
1559:       name,
1560:       snippet,
1561:       source: `candidate:${payload.source_candidate || 'unknown'}`,
1562:       executable: Boolean(payload.executable),
1563:       created_at: nowIso()
1564:     };
1565:     this.skills.push(skill);
1566:     this.saveSkills();
1567:     this.print(style(`[SKILL ADDED] ${skill.name} (${skill.id}) executable=${skill.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.cyan));
1568:     this.logger.writeEvent('skill_added', {
1569:       action_id: action.id,
1570:       skill_id: skill.id,
1571:       skill_name: skill.name,
1572:       executable: skill.executable
1573:     });
1574:   }
1575: 
1576:   async handleUserPrompt(input) {
1577:     const reasoning = summarizeReasoning(input);
1578:     const action = {
1579:       id: `act_${Date.now()}`,
1580:       type: 'ollama_chat',
1581:       prompt: input,
1582:       reasoning_summary: reasoning,
1583:       created_at: nowIso()
1584:     };
1585: 
1586:     this.logger.writeTranscript('User', input);
1587:     this.logger.writeEvent('user_prompt', {
1588:       text: input,
1589:       reasoning_summary: reasoning,
1590:       proposed_action: { id: action.id, type: action.type }
1591:     });
1592:     this.actionMeta[action.id] = {
1593:       prompt: input,
1594:       prompt_chars_before: input.length
1595:     };
1596: 
1597:     this.logger.writeStructuredRecord({
1598:       timestamp: nowIso(),
1599:       query: input,
1600:       reasoning: {
1601:         query: reasoning.query,
1602:         intent: reasoning.intent,
1603:         keywords: reasoning.keywords,
1604:         search_strategy: reasoning.strategy
1605:       },
1606:       actions: {
1607:         action: 'local_ollama_request',
1608:         sources: ['ollama_localhost'],
1609:         Context: 'Analyzing locally via Ollama only; no OpenAI/Gemini/external model APIs.'
1610:       },
1611:       Commands: "ls, grep, nano, cd, nano 'create-new-file-diff-snippet-number+1.sh', regen entire file with changes then save, cp -rf old/path/to/file move/to/backup/path/file, rm old/path/to/file, bash create-new-file-(diff-snippet-line:character)-(number)+1, sed -i 's/old/new' \"$file\"",
1612:       Diff: '+,-',
1613:       Path: 'path/to/file:line:character',
1614:       action_id: action.id,
1615:       'Print-approved-by-user?': 'not_required (run commands)',
1616:       'Run runtime look at logs': 'pending',
1617:       summary: 'pending',
1618:       'Number of characters changed': 'pending'
1619:     });
1620: 
1621:     await this.executeAction(action);
1622:   }
1623: 
1624:   writeStructuredUpdate(actionId, patch) {
1625:     this.logger.writeStructuredRecord({
1626:       timestamp: nowIso(),
1627:       action_id: actionId,
1628:       update: patch
1629:     });
1630:   }
1631: 
1632:   async executeAction(action) {
1633:     if (!action || action.type !== 'ollama_chat') {
1634:       this.logger.writeEvent('action_error', { message: 'Unsupported action type', action });
1635:       this.writeStructuredUpdate(action && action.id ? action.id : 'unknown', {
1636:         'Run runtime look at logs': 'contains error still, unsupported action type',
1637:         summary: 'Unsupported action type encountered before runtime request.',
1638:         'Number of characters changed': 'previous character amount in file before cmd/new total character count added: 0/0'
1639:       });
1640:       this.print('Unsupported action.');
1641:       return;
1642:     }
1643: 
1644:     this.logger.writeEvent('action_start', {
1645:       action_id: action.id,
1646:       type: action.type,
1647:       target: this.ollamaUrl,
1648:       model: this.model,
1649:       prompt_chars: action.prompt.length,
1650:       reasoning_summary: action.reasoning_summary
1651:     });
1652: 
1653:     this.history.push({ role: 'user', content: action.prompt });
1654: 
1655:     const payload = {
1656:       model: this.model,
1657:       messages: this.history,
1658:       stream: false
1659:     };
1660: 
1661:     let response;
1662:     let raw;
1663:     const started = Date.now();
1664:     this.startThinking();
1665: 
1666:     try {
1667:       response = await fetch(this.ollamaUrl, {
1668:         method: 'POST',
1669:         headers: { 'Content-Type': 'application/json' },
1670:         body: JSON.stringify(payload)
1671:       });
1672: 
1673:       raw = await response.text();
1674:     } catch (error) {
1675:       this.stopThinking();
1676:       const message = error && error.message ? error.message : String(error);
1677:       this.logger.writeEvent('action_failure', {
1678:         action_id: action.id,
1679:         duration_ms: Date.now() - started,
1680:         error: message
1681:       });
1682:       this.writeStructuredUpdate(action.id, {
1683:         'Run runtime look at logs': 'contains error still, loop and try again with different results until each individual error is clear.',
1684:         summary: `Runtime request failed. Error: ${message}`,
1685:         'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${action.prompt.length}/0`,
1686:         'Print-approved-by-user?': 'true'
1687:       });
1688:       this.print(`Ollama request failed: ${message}`);
1689:       return;
