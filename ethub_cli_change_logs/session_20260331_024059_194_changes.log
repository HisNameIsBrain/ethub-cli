0571:       }
0572:       if (value.content && Array.isArray(value.content.parts)) {
0573:         for (const part of value.content.parts) {
0574:           if (typeof part === 'string' && part.trim()) segments.push(part);
0575:         }
0576:       }
0577:       if (typeof value.text === 'string' && value.text.trim()) {
0578:         segments.push(value.text);
0579:       }
0580:       for (const key of Object.keys(value)) {
0581:         if (key === 'content' || key === 'text') continue;
0582:         walk(value[key], depth + 1);
0583:       }
0584:     };
0585: 
0586:     if (parsed) {
0587:       walk(parsed);
0588:     } else {
0589:       segments.push(raw);
0590:     }
0591: 
0592:     for (const segment of segments) {
0593:       const fencePattern = /```(?:[^\n`]*)\n([\s\S]*?)```/g;
0594:       let match;
0595:       while ((match = fencePattern.exec(segment)) !== null) {
0596:         addCandidate(match[1], sourceLabel, 'fenced_code');
0597:       }
0598: 
0599:       const lines = segment.split('\n');
0600:       for (const line of lines) {
0601:         const trimmed = line.trim();
0602:         if (!trimmed || trimmed.length > 220) continue;
0603:         const shellLike = trimmed.replace(/^\$\s*/, '');
0604:         if (/^(ls|pwd|cat|head|tail|wc|rg|grep|find|sed|cp|mv|mkdir|touch|echo|git)\b/.test(shellLike)) {
0605:           addCandidate(shellLike, sourceLabel, 'shell_line');
0606:         }
0607:       }
0608:     }
0609:   }
