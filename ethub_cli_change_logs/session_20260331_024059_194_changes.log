0635:   collectSkillCandidatesFromArtifacts(limit = 10) {
0636:     const snippets = new Map();
0637:     let scannedSources = 0;
0638:     const cap = Math.max(1, Math.min(MAX_SKILL_CANDIDATES, Number(limit) || 10));
0639:     const addCandidate = (snippetText, sourceLabel, sourceKind) => {
0640:       const normalized = normalizeSnippet(snippetText);
0641:       if (!looksLikeUsefulSnippet(normalized)) return;
0642:       const existing = snippets.get(normalized);
0643:       if (existing) {
0644:         existing.hits += 1;
0645:         existing.sources.add(sourceLabel);
0646:         return;
0647:       }
0648:       snippets.set(normalized, {
0649:         snippet: normalized,
0650:         hits: 1,
0651:         source_kind: sourceKind,
0652:         sources: new Set([sourceLabel])
0653:       });
0654:     };
0655: 
0656:     const zipFiles = this.listArtifactZipFiles();
0657:     for (const zipPath of zipFiles) {
0658:       try {
0659:         const entries = extractTextEntriesFromZip(zipPath, isLikelyTextPath);
0660:         for (const item of entries) {
0661:           scannedSources += 1;
0662:           this.extractSnippetCandidatesFromText(item.text, `${path.basename(zipPath)}:${item.entry}`, addCandidate);
0663:         }
0664:       } catch (error) {
0665:         this.logger.writeEvent('skills_mine_warning', {
0666:           stage: 'zip_read',
0667:           zip: zipPath,
0668:           error: error.message
0669:         });
0670:       }
0671:     }
0672: 
0673:     const directArtifactFiles = [];
0674:     if (fs.existsSync(ARTIFACTS_ROOT)) {
0675:       const stack = [ARTIFACTS_ROOT];
0676:       while (stack.length) {
0677:         const current = stack.pop();
0678:         let entries = [];
0679:         try {
0680:           entries = fs.readdirSync(current, { withFileTypes: true });
0681:         } catch {
0682:           continue;
0683:         }
0684:         for (const entry of entries) {
0685:           const full = path.join(current, entry.name);
0686:           if (entry.isDirectory()) stack.push(full);
0687:           else if (entry.isFile() && !full.toLowerCase().endsWith('.zip') && isLikelyTextPath(full)) directArtifactFiles.push(full);
0688:         }
0689:       }
0690:     }
0691: 
0692:     for (const filePath of directArtifactFiles) {
0693:       let text = '';
0694:       try {
0695:         text = fs.readFileSync(filePath, 'utf8');
0696:       } catch {
0697:         continue;
0698:       }
0699:       scannedSources += 1;
0700:       this.extractSnippetCandidatesFromText(text, this.workspaceRelativePath(filePath), addCandidate);
0701:     }
0702: 
0703:     const ranked = Array.from(snippets.values())
0704:       .sort((a, b) => b.hits - a.hits || b.snippet.length - a.snippet.length)
0705:       .slice(0, cap);
0706: 
0707:     this.skillCandidates = ranked.map((entry, idx) => {
0708:       const snippet = entry.snippet;
0709:       const safety = this.validateSkillCommand(snippet);
0710:       return {
0711:         id: `cand_${idx + 1}`,
0712:         snippet,
0713:         hits: entry.hits,
0714:         source_kind: entry.source_kind,
0715:         sources: Array.from(entry.sources).slice(0, 6),
0716:         executable: safety.ok,
0717:         safety_reason: safety.ok ? '' : safety.reason
0718:       };
0719:     });
0720: 
0721:     this.logger.writeEvent('skills_mined', {
0722:       candidates: this.skillCandidates.length,
0723:       unique_snippets: snippets.size,
0724:       scanned_sources: scannedSources,
0725:       zip_files: zipFiles.length
0726:     });
0727: 
0728:     return {
0729:       candidates: this.skillCandidates.length,
0730:       uniqueSnippets: snippets.size,
0731:       scannedSources,
0732:       zipFiles: zipFiles.length
0733:     };
0734:   }
