0748:   validatePathToken(token) {
0749:     const raw = String(token || '').trim();
0750:     if (!raw) return { ok: true };
0751:     if (raw === '-' || raw.startsWith('-')) return { ok: true };
0752:     if (raw.startsWith('/')) return { ok: false, reason: `Absolute paths are blocked (${raw}).` };
0753:     if (raw.includes('..')) return { ok: false, reason: `Parent traversal is blocked (${raw}).` };
0754:     const resolved = path.resolve(process.cwd(), raw);
0755:     if (!isPathInsideRoot(this.workspaceRoot, resolved)) {
0756:       return { ok: false, reason: `Path escapes workspace root (${raw}).` };
0757:     }
0758:     return { ok: true };
0759:   }
0760: 
0761:   validateSkillCommand(snippet) {
0762:     const commandText = normalizeSnippet(snippet);
0763:     if (!commandText) return { ok: false, reason: 'Empty snippet.' };
0764:     const lines = commandText.split('\n').map((l) => l.trim()).filter(Boolean);
0765:     if (lines.length !== 1) return { ok: false, reason: 'Only single-line shell skills are executable.' };
0766:     const line = lines[0];
0767:     if (BLOCKED_COMMAND_PATTERN.test(line)) {
0768:       return { ok: false, reason: 'Command contains blocked shell operators.' };
0769:     }
0770: 
0771:     const parsed = tokenizeCommandLine(line);
0772:     if (parsed.error) return { ok: false, reason: parsed.error };
0773:     const tokens = parsed.tokens || [];
0774:     if (!tokens.length) return { ok: false, reason: 'No command token found.' };
0775: 
0776:     const cmd = tokens[0];
0777:     if (!SAFE_SKILL_COMMANDS.has(cmd)) {
0778:       return { ok: false, reason: `Command '${cmd}' is not allowlisted.` };
0779:     }
0780:     if (cmd === 'git') {
0781:       const sub = (tokens[1] || '').toLowerCase();
0782:       if (!['status', 'diff', 'log', 'show', 'branch', 'rev-parse'].includes(sub)) {
0783:         return { ok: false, reason: `git '${sub || '(none)'}' is blocked.` };
0784:       }
0785:     }
0786: 
0787:     for (let i = 1; i < tokens.length; i += 1) {
0788:       const pathCheck = this.validatePathToken(tokens[i]);
0789:       if (!pathCheck.ok) return pathCheck;
0790:     }
0791:     return { ok: true, command: cmd, tokens };
0792:   }
