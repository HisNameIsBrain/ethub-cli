0611:   listArtifactZipFiles() {
0612:     const out = [];
0613:     if (!fs.existsSync(ARTIFACTS_ROOT)) return out;
0614:     const stack = [ARTIFACTS_ROOT];
0615:     while (stack.length) {
0616:       const current = stack.pop();
0617:       let entries = [];
0618:       try {
0619:         entries = fs.readdirSync(current, { withFileTypes: true });
0620:       } catch {
0621:         continue;
0622:       }
0623:       for (const entry of entries) {
0624:         const full = path.join(current, entry.name);
0625:         if (entry.isDirectory()) {
0626:           stack.push(full);
0627:         } else if (entry.isFile() && full.toLowerCase().endsWith('.zip')) {
0628:           out.push(full);
0629:         }
0630:       }
0631:     }
0632:     return out;
0633:   }
