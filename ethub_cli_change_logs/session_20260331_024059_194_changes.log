0336:   let intent = 'general_request';
0337:   if (/error|syntax|stack|trace|bug|fix|crash/.test(lowered)) intent = 'debugging';
0338:   else if (/how|what|why|explain|guide|tutorial/.test(lowered)) intent = 'information_lookup';
0339:   else if (/build|create|make|implement|write/.test(lowered)) intent = 'implementation';
0340: 
0341:   let strategy = 'Use local conversation context then query Ollama for a grounded response.';
0342:   if (intent === 'debugging') {
