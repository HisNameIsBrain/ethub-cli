0578:     const cap = Math.max(1, Math.min(MAX_SKILL_CANDIDATES, Number(limit) || 10));
0579:     const addCandidate = (snippetText, sourceLabel, sourceKind) => {
0580:       const normalized = normalizeSnippet(snippetText);
0581:       if (!normalized || normalized.length < 8 || normalized.length > MAX_SKILL_SNIPPET_CHARS) return;
0582:       const existing = snippets.get(normalized);
0583:       if (existing) {
0584:         existing.hits += 1;
0585:         existing.sources.add(sourceLabel);
0586:         return;
0587:       }
0588:       snippets.set(normalized, {
0589:         snippet: normalized,
0590:         hits: 1,
0591:         source_kind: sourceKind,
0592:         sources: new Set([sourceLabel])
0593:       });
0594:     };
0595: 
0596:     const zipFiles = this.listArtifactZipFiles();
0597:     for (const zipPath of zipFiles) {
0598:       try {
0599:         const entries = extractTextEntriesFromZip(zipPath, isLikelyTextPath);
0600:         for (const item of entries) {
0601:           scannedSources += 1;
0602:           this.extractSnippetCandidatesFromText(item.text, `${path.basename(zipPath)}:${item.entry}`, addCandidate);
0603:         }
0604:       } catch (error) {
0605:         this.logger.writeEvent('skills_mine_warning', {
0606:           stage: 'zip_read',
0607:           zip: zipPath,
0608:           error: error.message
0609:         });
0610:       }
0611:     }
0612: 
0613:     const directArtifactFiles = [];
0614:     if (fs.existsSync(ARTIFACTS_ROOT)) {
0615:       const stack = [ARTIFACTS_ROOT];
0616:       while (stack.length) {
0617:         const current = stack.pop();
0618:         let entries = [];
0619:         try {
0620:           entries = fs.readdirSync(current, { withFileTypes: true });
0621:         } catch {
0622:           continue;
0623:         }
0624:         for (const entry of entries) {
0625:           const full = path.join(current, entry.name);
0626:           if (entry.isDirectory()) stack.push(full);
0627:           else if (entry.isFile() && !full.toLowerCase().endsWith('.zip') && isLikelyTextPath(full)) directArtifactFiles.push(full);
0628:         }
0629:       }
0630:     }
0631: 
0632:     for (const filePath of directArtifactFiles) {
0633:       let text = '';
0634:       try {
0635:         text = fs.readFileSync(filePath, 'utf8');
0636:       } catch {
0637:         continue;
0638:       }
0639:       scannedSources += 1;
0640:       this.extractSnippetCandidatesFromText(text, this.workspaceRelativePath(filePath), addCandidate);
0641:     }
0642: 
0643:     const ranked = Array.from(snippets.values())
0644:       .sort((a, b) => b.hits - a.hits || b.snippet.length - a.snippet.length)
0645:       .slice(0, cap);
0646: 
0647:     this.skillCandidates = ranked.map((entry, idx) => {
0648:       const snippet = entry.snippet;
0649:       const safety = this.validateSkillCommand(snippet);
0650:       return {
0651:         id: `cand_${idx + 1}`,
0652:         snippet,
0653:         hits: entry.hits,
0654:         source_kind: entry.source_kind,
0655:         sources: Array.from(entry.sources).slice(0, 6),
0656:         executable: safety.ok,
0657:         safety_reason: safety.ok ? '' : safety.reason
0658:       };
0659:     });
0660: 
0661:     this.logger.writeEvent('skills_mined', {
0662:       candidates: this.skillCandidates.length,
0663:       unique_snippets: snippets.size,
0664:       scanned_sources: scannedSources,
0665:       zip_files: zipFiles.length
0666:     });
0667: 
0668:     return {
0669:       candidates: this.skillCandidates.length,
0670:       uniqueSnippets: snippets.size,
0671:       scannedSources,
0672:       zipFiles: zipFiles.length
0673:     };
0674:   }
