1020:   async handleCommand(input) {
1021:     const [cmd, ...args] = input.split(/\s+/);
1022:     const command = cmd.toLowerCase();
1023:     this.logger.writeEvent('subcommand', { command, args });
1024: 
1025:     if (command === '/help') {
1026:       this.print('Commands: /help, /status, /model <name>, /approve changes on|off, /readfile <path>, /writefile <path> -- <content>, /cd <path>, /skills <mine|candidates|add|list|show|run>, /yes, /no, /exit');
1027:       this.print('Skills flow: /skills mine 10 -> /skills add cand_1 my_skill -> /yes -> /skills run my_skill -> /yes');
1028:       return;
1029:     }
1030: 
1031:     if (command === '/status') {
1032:       this.print(safeJson({
1033:         model: this.model,
1034:         ollama_url: this.ollamaUrl,
1035:         require_approval_for_changes: this.requireApproval,
1036:         skills_count: this.skills.length,
1037:         skill_candidates_count: this.skillCandidates.length,
1038:         history_count: this.history.length,
1039:         pending_action: this.pendingAction ? this.pendingAction.id : null
1040:       }));
1041:       return;
1042:     }
1043: 
1044:     if (command === '/model') {
1045:       const nextModel = args.join(' ').trim();
1046:       if (!nextModel) {
1047:         this.print(`Current model: ${this.model}`);
1048:         return;
1049:       }
1050:       this.model = nextModel;
1051:       this.print(`Model updated: ${this.model}`);
1052:       this.logger.writeEvent('config_update', { key: 'model', value: this.model });
1053:       return;
1054:     }
1055: 
1056:     if (command === '/approve') {
1057:       const target = (args[0] || '').toLowerCase();
1058:       const mode = (args[1] || '').toLowerCase();
1059:       const legacyMode = target;
1060: 
1061:       if (target === 'changes' && (mode === 'on' || mode === 'off')) {
1062:         this.requireApproval = mode === 'on';
1063:         this.print(`Change approval mode: ${mode}`);
1064:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1065:         return;
1066:       }
1067: 
1068:       if (legacyMode === 'on' || legacyMode === 'off') {
1069:         this.requireApproval = legacyMode === 'on';
1070:         this.print(`Change approval mode: ${legacyMode}`);
1071:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1072:         return;
1073:       }
1074: 
1075:       if (!target) {
1076:         this.print(`Change approval mode: ${this.requireApproval ? 'on' : 'off'}`);
1077:         return;
1078:       }
1079: 
1080:       this.print('Usage: /approve changes on|off');
1081:       return;
1082:     }
1083: 
1084:     if (command === '/yes') {
1085:       if (!this.pendingAction) {
1086:         this.print('No pending action to approve.');
1087:         return;
1088:       }
1089:       const action = this.pendingAction;
1090:       this.pendingAction = null;
1091:       this.logger.writeEvent('approval', { action_id: action.id, approved: true });
1092:       this.writeStructuredUpdate(action.id, {
1093:         'Print-approved-by-user?': 'true',
1094:         approved: true
1095:       });
1096:       await this.executePendingAction(action);
1097:       return;
1098:     }
1099: 
1100:     if (command === '/no') {
1101:       if (!this.pendingAction) {
1102:         this.print('No pending action to reject.');
1103:         return;
1104:       }
1105:       const action = this.pendingAction;
1106:       this.pendingAction = null;
1107:       this.logger.writeEvent('approval', { action_id: action.id, approved: false });
1108:       this.writeStructuredUpdate(action.id, {
1109:         'Print-approved-by-user?': 'false',
1110:         approved: false,
1111:         summary: 'Action was rejected by user before runtime execution.',
1112:         'Run runtime look at logs': 'skipped (approval rejected)'
1113:       });
1114:       this.print(`Action ${action.id} skipped.`);
1115:       return;
1116:     }
1117: 
1118:     if (command === '/exit') {
1119:       this.rl.close();
1120:       return;
1121:     }
1122: 
1123:     if (command === '/cd') {
1124:       const rawTarget = input.replace(/^\/cd\s*/i, '').trim();
1125:       if (!rawTarget) {
1126:         this.print(`Current directory: ${process.cwd()}`);
1127:         return;
1128:       }
1129:       const resolved = this.resolvePathInWorkspace(rawTarget, 'dir');
1130:       if (resolved.error) {
1131:         this.print(`${style('cd denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1132:         return;
1133:       }
1134:       process.chdir(resolved.path);
1135:       this.refreshPrompt();
1136:       this.logger.writeEvent('cwd_changed', {
1137:         cwd: process.cwd(),
1138:         workspace_relative: this.workspaceRelativePath()
1139:       });
1140:       this.print(style(`Directory changed to ${this.workspaceRelativePath()}`, ANSI.cyan));
1141:       return;
1142:     }
1143: 
1144:     if (command === '/readfile') {
1145:       const rawPath = input.replace(/^\/readfile\s*/i, '').trim();
1146:       if (!rawPath) {
1147:         this.print('Usage: /readfile <path>');
1148:         return;
1149:       }
1150:       const resolved = this.resolvePathInWorkspace(rawPath, 'file');
1151:       if (resolved.error) {
1152:         this.print(`${style('readfile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1153:         return;
1154:       }
1155:       const action = {
1156:         id: `act_${Date.now()}`,
1157:         type: 'read_file',
1158:         payload: {
1159:           path: resolved.path,
1160:           rel: this.workspaceRelativePath(resolved.path)
1161:         },
1162:         created_at: nowIso()
1163:       };
1164:       this.queueApprovalAction(
1165:         action,
1166:         `${style('Read request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel}`
1167:       );
1168:       return;
1169:     }
1170: 
1171:     if (command === '/writefile') {
1172:       const raw = input.replace(/^\/writefile\s*/i, '');
1173:       const splitIndex = raw.indexOf(' -- ');
1174:       if (splitIndex === -1) {
1175:         this.print('Usage: /writefile <path> -- <content>');
1176:         return;
1177:       }
1178:       const rawPath = raw.slice(0, splitIndex).trim();
1179:       const content = raw.slice(splitIndex + 4);
1180:       if (!rawPath) {
1181:         this.print('Usage: /writefile <path> -- <content>');
1182:         return;
1183:       }
1184:       const resolved = this.resolvePathInWorkspace(rawPath, 'any');
1185:       if (resolved.error) {
1186:         this.print(`${style('writefile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1187:         return;
1188:       }
1189:       const action = {
1190:         id: `act_${Date.now()}`,
1191:         type: 'write_file',
1192:         payload: {
1193:           path: resolved.path,
1194:           rel: this.workspaceRelativePath(resolved.path),
1195:           content
1196:         },
1197:         created_at: nowIso()
1198:       };
1199:       this.queueApprovalAction(
1200:         action,
1201:         `${style('Write request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel} (${content.length} chars)`
1202:       );
1203:       return;
1204:     }
1205: 
1206:     if (command === '/skills') {
1207:       const sub = (args[0] || '').toLowerCase();
1208:       if (!sub || sub === 'help') {
1209:         this.print('Usage:');
1210:         this.print('/skills mine [count]');
1211:         this.print('/skills candidates');
1212:         this.print('/skills add <candidate_id> <skill_name>');
1213:         this.print('/skills list');
1214:         this.print('/skills show <skill_id|skill_name>');
1215:         this.print('/skills run <skill_id|skill_name>');
1216:         return;
1217:       }
1218: 
1219:       if (sub === 'mine') {
1220:         const count = Number(args[1] || 10);
1221:         const result = this.collectSkillCandidatesFromArtifacts(count);
1222:         this.print(style(`Mined ${result.candidates} candidate skill patterns from artifacts (sources scanned: ${result.scannedSources}).`, ANSI.cyan));
1223:         for (const c of this.skillCandidates) {
1224:           this.print(style(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.yellow));
1225:           this.print('```');
1226:           this.print(c.snippet);
1227:           this.print('```');
1228:           if (!c.executable) this.print(style(`reason: ${c.safety_reason}`, ANSI.dim));
1229:         }
1230:         return;
1231:       }
1232: 
1233:       if (sub === 'candidates') {
1234:         if (!this.skillCandidates.length) {
1235:           this.print('No candidates loaded. Run /skills mine first.');
1236:           return;
1237:         }
1238:         for (const c of this.skillCandidates) {
1239:           this.print(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'} source_kind=${c.source_kind}`);
1240:         }
1241:         return;
1242:       }
1243: 
1244:       if (sub === 'add') {
1245:         const candidateId = args[1] || '';
1246:         const skillName = args.slice(2).join(' ').trim();
1247:         if (!candidateId || !skillName) {
1248:           this.print('Usage: /skills add <candidate_id> <skill_name>');
1249:           return;
1250:         }
1251:         const existing = this.findSkill(skillName);
1252:         if (existing) {
1253:           this.print(`Skill already exists: ${existing.name} (${existing.id})`);
1254:           return;
1255:         }
1256:         const candidate = this.findCandidate(candidateId);
1257:         if (!candidate) {
1258:           this.print(`Candidate not found: ${candidateId}`);
1259:           return;
1260:         }
1261:         const action = {
1262:           id: `act_${Date.now()}`,
1263:           type: 'add_skill',
1264:           payload: {
1265:             skill_name: skillName,
1266:             source_candidate: candidate.id,
1267:             snippet: candidate.snippet,
1268:             executable: candidate.executable
1269:           },
1270:           created_at: nowIso()
1271:         };
1272:         this.queueApprovalAction(
1273:           action,
1274:           `${style('Add skill queued:', ANSI.bold, ANSI.yellow)} ${skillName} from ${candidate.id}`
1275:         );
1276:         return;
1277:       }
1278: 
1279:       if (sub === 'list') {
1280:         if (!this.skills.length) {
1281:           this.print(`No approved skills yet. Skills file: ${this.skillsPath}`);
1282:           return;
1283:         }
1284:         for (const skill of this.skills) {
1285:           this.print(`[${skill.id}] ${skill.name} | executable=${skill.executable ? 'yes' : 'no'} | source=${skill.source}`);
1286:         }
1287:         return;
1288:       }
1289: 
1290:       if (sub === 'show') {
1291:         const query = args.slice(1).join(' ').trim();
1292:         if (!query) {
1293:           this.print('Usage: /skills show <skill_id|skill_name>');
1294:           return;
1295:         }
1296:         const skill = this.findSkill(query);
1297:         if (!skill) {
1298:           this.print(`Skill not found: ${query}`);
1299:           return;
1300:         }
1301:         this.print(style(`[${skill.id}] ${skill.name}`, ANSI.bold, ANSI.cyan));
1302:         this.print('```');
1303:         this.print(skill.snippet);
1304:         this.print('```');
1305:         return;
1306:       }
1307: 
1308:       if (sub === 'run') {
1309:         const query = args.slice(1).join(' ').trim();
1310:         if (!query) {
1311:           this.print('Usage: /skills run <skill_id|skill_name>');
1312:           return;
1313:         }
1314:         const skill = this.findSkill(query);
1315:         if (!skill) {
1316:           this.print(`Skill not found: ${query}`);
1317:           return;
1318:         }
1319:         const validation = this.validateSkillCommand(skill.snippet);
1320:         if (!validation.ok) {
1321:           this.print(`${style('Skill is not executable:', ANSI.bold, ANSI.red)} ${validation.reason}`);
1322:           return;
1323:         }
1324:         const action = {
1325:           id: `act_${Date.now()}`,
1326:           type: 'run_skill',
1327:           payload: {
1328:             skill_id: skill.id,
1329:             skill_name: skill.name,
1330:             snippet: skill.snippet
1331:           },
1332:           created_at: nowIso()
1333:         };
1334:         this.queueApprovalAction(
1335:           action,
1336:           `${style('Skill execution queued:', ANSI.bold, ANSI.yellow)} ${skill.name}\n${skill.snippet}`
1337:         );
1338:         return;
1339:       }
1340: 
1341:       this.print(`Unknown skills subcommand: ${sub}`);
1342:       return;
1343:     }
1344: 
1345:     this.print(`Unknown command: ${command}. Use /help.`);
1346:   }
1347: 
1348:   async executePendingAction(action) {
1349:     if (!action) return;
1350:     if (action.type === 'ollama_chat') {
1351:       await this.executeAction(action);
1352:       return;
1353:     }
1354:     if (action.type === 'read_file') {
1355:       this.runReadFileAction(action);
1356:       return;
1357:     }
1358:     if (action.type === 'write_file') {
1359:       this.runWriteFileAction(action);
1360:       return;
1361:     }
1362:     if (action.type === 'add_skill') {
1363:       this.runAddSkillAction(action);
1364:       return;
1365:     }
1366:     if (action.type === 'run_skill') {
1367:       await this.runSkillCommand(action);
1368:       return;
1369:     }
1370:     this.print(`Unsupported pending action type: ${action.type}`);
1371:   }
1372: 
1373:   runReadFileAction(action) {
1374:     const filePath = action && action.payload ? action.payload.path : '';
1375:     if (!filePath || !fs.existsSync(filePath)) {
1376:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} file no longer exists.`);
1377:       return;
1378:     }
1379:     let text;
1380:     try {
1381:       text = fs.readFileSync(filePath, 'utf8');
1382:     } catch (error) {
1383:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1384:       return;
1385:     }
1386:     const shown = truncateText(text, MAX_READFILE_BYTES);
1387:     const rel = action.payload.rel || this.workspaceRelativePath(filePath);
1388:     this.print(style(`\n[READFILE] ${rel}`, ANSI.bold, ANSI.cyan));
1389:     this.print(style(`bytes: ${Buffer.byteLength(text, 'utf8')} | shown: ${Buffer.byteLength(shown, 'utf8')}`, ANSI.dim));
1390:     this.print(shown);
1391:     this.logger.writeEvent('read_file', {
1392:       action_id: action.id,
1393:       file: filePath,
1394:       bytes: Buffer.byteLength(text, 'utf8'),
1395:       shown_bytes: Buffer.byteLength(shown, 'utf8')
1396:     });
1397:   }
1398: 
1399:   runWriteFileAction(action) {
1400:     const filePath = action && action.payload ? action.payload.path : '';
1401:     const content = action && action.payload ? String(action.payload.content || '') : '';
1402:     if (!filePath) {
1403:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} missing target path.`);
1404:       return;
1405:     }
1406:     try {
1407:       ensureDir(path.dirname(filePath));
1408:       fs.writeFileSync(filePath, content, 'utf8');
1409:     } catch (error) {
1410:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1411:       return;
1412:     }
1413:     this.print(style(`[WRITEFILE] wrote ${content.length} chars to ${action.payload.rel}`, ANSI.bold, ANSI.cyan));
1414:     this.logger.writeEvent('write_file', {
1415:       action_id: action.id,
1416:       file: filePath,
1417:       chars: content.length
1418:     });
1419:   }
1420: 
1421:   runAddSkillAction(action) {
1422:     const payload = action && action.payload ? action.payload : {};
1423:     const name = String(payload.skill_name || '').trim();
1424:     const snippet = String(payload.snippet || '');
1425:     if (!name || !snippet) {
1426:       this.print(`${style('Add skill failed:', ANSI.bold, ANSI.red)} missing skill name or snippet.`);
1427:       return;
1428:     }
1429:     const duplicate = this.findSkill(name);
1430:     if (duplicate) {
1431:       this.print(`${style('Add skill skipped:', ANSI.bold, ANSI.red)} skill already exists (${duplicate.id}).`);
1432:       return;
1433:     }
1434: 
1435:     const skill = {
1436:       id: `skill_${Date.now()}`,
1437:       name,
1438:       snippet,
1439:       source: `candidate:${payload.source_candidate || 'unknown'}`,
1440:       executable: Boolean(payload.executable),
1441:       created_at: nowIso()
1442:     };
1443:     this.skills.push(skill);
1444:     this.saveSkills();
1445:     this.print(style(`[SKILL ADDED] ${skill.name} (${skill.id}) executable=${skill.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.cyan));
1446:     this.logger.writeEvent('skill_added', {
1447:       action_id: action.id,
1448:       skill_id: skill.id,
1449:       skill_name: skill.name,
1450:       executable: skill.executable
1451:     });
1452:   }
1453: 
1454:   async handleUserPrompt(input) {
1455:     const reasoning = summarizeReasoning(input);
1456:     const action = {
1457:       id: `act_${Date.now()}`,
1458:       type: 'ollama_chat',
1459:       prompt: input,
1460:       reasoning_summary: reasoning,
1461:       created_at: nowIso()
1462:     };
1463: 
1464:     this.logger.writeTranscript('User', input);
1465:     this.logger.writeEvent('user_prompt', {
1466:       text: input,
1467:       reasoning_summary: reasoning,
1468:       proposed_action: { id: action.id, type: action.type }
1469:     });
1470:     this.actionMeta[action.id] = {
1471:       prompt: input,
1472:       prompt_chars_before: input.length
1473:     };
1474: 
1475:     this.logger.writeStructuredRecord({
1476:       timestamp: nowIso(),
1477:       query: input,
1478:       reasoning: {
1479:         query: reasoning.query,
1480:         intent: reasoning.intent,
1481:         keywords: reasoning.keywords,
1482:         search_strategy: reasoning.strategy
1483:       },
1484:       actions: {
1485:         action: 'local_ollama_request',
1486:         sources: ['ollama_localhost'],
1487:         Context: 'Analyzing locally via Ollama only; no OpenAI/Gemini/external model APIs.'
1488:       },
1489:       Commands: "ls, grep, nano, cd, nano 'create-new-file-diff-snippet-number+1.sh', regen entire file with changes then save, cp -rf old/path/to/file move/to/backup/path/file, rm old/path/to/file, bash create-new-file-(diff-snippet-line:character)-(number)+1, sed -i 's/old/new' \"$file\"",
1490:       Diff: '+,-',
1491:       Path: 'path/to/file:line:character',
1492:       action_id: action.id,
1493:       'Print-approved-by-user?': 'not_required (run commands)',
1494:       'Run runtime look at logs': 'pending',
1495:       summary: 'pending',
1496:       'Number of characters changed': 'pending'
1497:     });
1498: 
1499:     await this.executeAction(action);
1500:   }
1501: 
1502:   writeStructuredUpdate(actionId, patch) {
1503:     this.logger.writeStructuredRecord({
1504:       timestamp: nowIso(),
1505:       action_id: actionId,
1506:       update: patch
1507:     });
1508:   }
1509: 
1510:   async executeAction(action) {
1511:     if (!action || action.type !== 'ollama_chat') {
1512:       this.logger.writeEvent('action_error', { message: 'Unsupported action type', action });
1513:       this.writeStructuredUpdate(action && action.id ? action.id : 'unknown', {
1514:         'Run runtime look at logs': 'contains error still, unsupported action type',
1515:         summary: 'Unsupported action type encountered before runtime request.',
1516:         'Number of characters changed': 'previous character amount in file before cmd/new total character count added: 0/0'
1517:       });
1518:       this.print('Unsupported action.');
1519:       return;
1520:     }
1521: 
1522:     this.logger.writeEvent('action_start', {
1523:       action_id: action.id,
1524:       type: action.type,
1525:       target: this.ollamaUrl,
1526:       model: this.model,
1527:       prompt_chars: action.prompt.length,
1528:       reasoning_summary: action.reasoning_summary
1529:     });
1530: 
1531:     this.history.push({ role: 'user', content: action.prompt });
1532: 
1533:     const payload = {
1534:       model: this.model,
1535:       messages: this.history,
1536:       stream: false
1537:     };
1538: 
1539:     let response;
1540:     let raw;
1541:     const started = Date.now();
1542:     this.startThinking();
1543: 
1544:     try {
1545:       response = await fetch(this.ollamaUrl, {
1546:         method: 'POST',
1547:         headers: { 'Content-Type': 'application/json' },
1548:         body: JSON.stringify(payload)
1549:       });
1550: 
1551:       raw = await response.text();
1552:     } catch (error) {
1553:       this.stopThinking();
1554:       const message = error && error.message ? error.message : String(error);
1555:       this.logger.writeEvent('action_failure', {
1556:         action_id: action.id,
1557:         duration_ms: Date.now() - started,
1558:         error: message
1559:       });
1560:       this.writeStructuredUpdate(action.id, {
1561:         'Run runtime look at logs': 'contains error still, loop and try again with different results until each individual error is clear.',
1562:         summary: `Runtime request failed. Error: ${message}`,
1563:         'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${action.prompt.length}/0`,
1564:         'Print-approved-by-user?': 'true'
1565:       });
1566:       this.print(`Ollama request failed: ${message}`);
1567:       return;
1568:     }
1569:     this.stopThinking();
1570: 
1571:     let parsed;
1572:     try {
1573:       parsed = JSON.parse(raw);
1574:     } catch {
1575:       parsed = null;
1576:     }
1577: 
1578:     const assistantText = parsed && parsed.message && parsed.message.content
1579:       ? String(parsed.message.content)
1580:       : raw;
1581: 
1582:     this.history.push({ role: 'assistant', content: assistantText });
1583: 
1584:     this.logger.writeEvent('action_result', {
1585:       action_id: action.id,
1586:       duration_ms: Date.now() - started,
1587:       http_status: response.status,
1588:       ok: response.ok,
1589:       response_preview: assistantText.slice(0, 400),
1590:       response_chars: assistantText.length
1591:     });
1592: 
1593:     this.logger.writeTranscript('Assistant', assistantText);
1594:     this.print(assistantText);
1595: 
1596:     const hasRuntimeError = /(syntaxerror|stack overflow|runtime error|error:)/i.test(assistantText);
1597:     const runtimeResult = hasRuntimeError
1598:       ? 'contains error still, retry with different checks until isolated'
1599:       : 'No runtime error anymore = fixed';
1600:     const beforeChars = this.actionMeta[action.id] && this.actionMeta[action.id].prompt_chars_before
1601:       ? this.actionMeta[action.id].prompt_chars_before
1602:       : 0;
1603:     const afterChars = assistantText.length;
1604:     const elapsedMs = Date.now() - started;
1605: 
1606:     this.writeStructuredUpdate(action.id, {
1607:       'Run runtime look at logs': runtimeResult,
1608:       summary: `summarized what just changed, is it fixed: ${hasRuntimeError ? 'No' : 'Yes'}. Runtime error count estimate: ${hasRuntimeError ? 1 : 0}.`,
1609:       'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${beforeChars}/${afterChars}`,
1610:       timing_ms: elapsedMs,
1611:       stop_condition: elapsedMs >= 300000 ? 'Unable to find results or solutions, Try again.' : 'within loop budget'
1612:     });
1613:   }
1614: }
1615: 
1616: const agent = new EthubCliAgent();
1617: agent.start().catch((error) => {
1618:   process.stderr.write(`Fatal startup error: ${error && error.stack ? error.stack : String(error)}\n`);
1619:   process.exit(1);
1620: });
