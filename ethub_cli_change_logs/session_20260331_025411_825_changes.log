0125: function rainbowDivider(width, phase) {
0126:   let out = '';
0127:   for (let i = 0; i < width; i += 1) {
0128:     const ch = DIVIDER_CHARS[i % DIVIDER_CHARS.length];
0129:     const p = (i / width + phase) % 1;
0130:     const { r, g, b } = hslToRgb(p * 360, 0.6, 0.65);
0131:     out += rgb(ch, r, g, b);
0132:   }
0133:   return out;
0134: }
