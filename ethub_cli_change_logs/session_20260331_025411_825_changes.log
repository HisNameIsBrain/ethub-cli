0136: function rainbowAsciiLine(line, row, totalRows, frame) {
0137:   let out = '';
0138:   const len = Math.max(line.length, 1);
0139: 
0140:   for (let i = 0; i < line.length; i += 1) {
0141:     const ch = line[i];
0142:     if (ch === ' ') {
0143:       out += ' ';
0144:       continue;
0145:     }
0146: 
0147:     const phase = (i / len + row / totalRows + frame * 0.01) % 1;
0148:     const { r, g, b } = hslToRgb(phase * 360, 0.6, 0.65);
0149: 
0150:     let display = ch;
0151:     if ((ch === 'o' || ch === '8') && (frame + i + row) % 47 === 0) {
