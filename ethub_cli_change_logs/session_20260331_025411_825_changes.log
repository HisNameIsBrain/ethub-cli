0312: function summarizeReasoning(input) {
0313:   const raw = String(input || '').trim();
0314:   const lowered = raw.toLowerCase();
0315:   const keywords = raw
0316:     .split(/\s+/)
0317:     .map((w) => w.replace(/[^a-zA-Z0-9_-]/g, ''))
0318:     .filter(Boolean)
0319:     .slice(0, 12);
0320: 
0321:   let intent = 'general_request';
0322:   if (/error|syntax|stack|trace|bug|fix|crash/.test(lowered)) intent = 'debugging';
0323:   else if (/how|what|why|explain|guide|tutorial/.test(lowered)) intent = 'information_lookup';
0324:   else if (/build|create|make|implement|write/.test(lowered)) intent = 'implementation';
0325: 
0326:   let strategy = 'Use local conversation context then query Ollama for a grounded response.';
0327:   if (intent === 'debugging') {
0328:     strategy = 'Focus on likely fault points, propose checks, and request missing runtime details if needed.';
0329:   }
0330: 
0331:   return {
0332:     query: raw,
0333:     intent,
0334:     keywords,
0335:     strategy,
0336:     note: 'Detailed private chain-of-thought is not exposed; this is a concise decision summary.'
0337:   };
0338: }
