0688:   validatePathToken(token) {
0689:     const raw = String(token || '').trim();
0690:     if (!raw) return { ok: true };
0691:     if (raw === '-' || raw.startsWith('-')) return { ok: true };
0692:     if (raw.startsWith('/')) return { ok: false, reason: `Absolute paths are blocked (${raw}).` };
0693:     if (raw.includes('..')) return { ok: false, reason: `Parent traversal is blocked (${raw}).` };
0694:     const resolved = path.resolve(process.cwd(), raw);
0695:     if (!isPathInsideRoot(this.workspaceRoot, resolved)) {
0696:       return { ok: false, reason: `Path escapes workspace root (${raw}).` };
0697:     }
0698:     return { ok: true };
0699:   }
0700: 
0701:   validateSkillCommand(snippet) {
0702:     const commandText = normalizeSnippet(snippet);
0703:     if (!commandText) return { ok: false, reason: 'Empty snippet.' };
0704:     const lines = commandText.split('\n').map((l) => l.trim()).filter(Boolean);
0705:     if (lines.length !== 1) return { ok: false, reason: 'Only single-line shell skills are executable.' };
0706:     const line = lines[0];
0707:     if (BLOCKED_COMMAND_PATTERN.test(line)) {
0708:       return { ok: false, reason: 'Command contains blocked shell operators.' };
0709:     }
0710: 
0711:     const parsed = tokenizeCommandLine(line);
0712:     if (parsed.error) return { ok: false, reason: parsed.error };
0713:     const tokens = parsed.tokens || [];
0714:     if (!tokens.length) return { ok: false, reason: 'No command token found.' };
0715: 
0716:     const cmd = tokens[0];
0717:     if (!SAFE_SKILL_COMMANDS.has(cmd)) {
0718:       return { ok: false, reason: `Command '${cmd}' is not allowlisted.` };
0719:     }
0720:     if (cmd === 'git') {
0721:       const sub = (tokens[1] || '').toLowerCase();
0722:       if (!['status', 'diff', 'log', 'show', 'branch', 'rev-parse'].includes(sub)) {
0723:         return { ok: false, reason: `git '${sub || '(none)'}' is blocked.` };
0724:       }
0725:     }
0726: 
0727:     for (let i = 1; i < tokens.length; i += 1) {
0728:       const pathCheck = this.validatePathToken(tokens[i]);
0729:       if (!pathCheck.ok) return pathCheck;
0730:     }
0731:     return { ok: true, command: cmd, tokens };
0732:   }
0733: 
0734:   async runSkillCommand(action) {
0735:     const payload = action && action.payload ? action.payload : {};
0736:     const skillName = payload.skill_name || payload.skill_id || 'unknown';
0737:     const snippet = String(payload.snippet || '');
0738:     const validation = this.validateSkillCommand(snippet);
0739:     if (!validation.ok) {
0740:       this.print(`${style('Skill execution denied:', ANSI.bold, ANSI.red)} ${validation.reason}`);
0741:       this.logger.writeEvent('skill_run_denied', {
0742:         action_id: action.id,
0743:         skill: skillName,
0744:         reason: validation.reason
0745:       });
0746:       return;
0747:     }
0748: 
0749:     const tokens = validation.tokens;
0750:     const cmd = tokens[0];
0751:     const args = tokens.slice(1);
0752:     this.print(style(`[SKILL RUN] ${skillName}: ${snippet}`, ANSI.bold, ANSI.cyan));
0753: 
0754:     const result = await new Promise((resolve) => {
0755:       const child = spawn(cmd, args, {
0756:         cwd: process.cwd(),
0757:         stdio: ['ignore', 'pipe', 'pipe'],
0758:         shell: false
0759:       });
0760: 
0761:       let stdout = '';
0762:       let stderr = '';
0763:       let finished = false;
0764:       const timer = setTimeout(() => {
0765:         if (finished) return;
0766:         child.kill('SIGTERM');
0767:       }, 120000);
0768: 
0769:       child.stdout.on('data', (chunk) => {
0770:         if (stdout.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0771:         stdout += chunk.toString('utf8');
0772:       });
0773:       child.stderr.on('data', (chunk) => {
0774:         if (stderr.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0775:         stderr += chunk.toString('utf8');
0776:       });
0777:       child.on('error', (error) => {
0778:         clearTimeout(timer);
0779:         finished = true;
0780:         resolve({ code: -1, signal: null, stdout, stderr: `${stderr}\n${error.message}`.trim() });
0781:       });
0782:       child.on('close', (code, signal) => {
0783:         clearTimeout(timer);
0784:         finished = true;
0785:         resolve({ code, signal, stdout, stderr });
0786:       });
0787:     });
0788: 
0789:     if (result.stdout) {
0790:       this.print(style('[STDOUT]', ANSI.dim));
0791:       this.print(truncateText(result.stdout, MAX_COMMAND_OUTPUT_BYTES));
0792:     }
0793:     if (result.stderr) {
0794:       this.print(style('[STDERR]', ANSI.dim));
0795:       this.print(truncateText(result.stderr, MAX_COMMAND_OUTPUT_BYTES));
0796:     }
0797:     this.print(style(`[SKILL EXIT] code=${result.code} signal=${result.signal || 'none'}`, ANSI.dim));
0798:     this.logger.writeEvent('skill_run_complete', {
0799:       action_id: action.id,
0800:       skill: skillName,
0801:       code: result.code,
0802:       signal: result.signal,
0803:       stdout_chars: result.stdout.length,
0804:       stderr_chars: result.stderr.length
0805:     });
0806:   }
