0975:     for (let frame = 0; frame < frames; frame += 1) {
0976:       const lines = this.renderHeaderFrame(frame);
0977:       process.stdout.write('\x1b[2J\x1b[H');
0978:       process.stdout.write(`${lines.join('\n')}\n`);
0979:       await new Promise((resolve) => setTimeout(resolve, frameDelay));
0980:     }
0981:     process.stdout.write('\x1b[2J\x1b[H');
0982:     this.drawHeader(frames);
0983:   }
