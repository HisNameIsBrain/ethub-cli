0889:   resolvePathInWorkspace(inputPath, expected = 'any') {
0890:     const raw = String(inputPath || '').trim();
0891:     if (!raw) return { error: 'path is required' };
0892:     const normalized = raw === '~' ? os.homedir() : raw;
0893:     const resolved = path.resolve(process.cwd(), normalized);
0894:     const root = path.resolve(this.workspaceRoot);
0895:     const inRoot = resolved === root || resolved.startsWith(`${root}${path.sep}`);
0896:     if (!inRoot) {
0897:       return { error: `path escapes workspace root: ${root}` };
0898:     }
0899: 
0900:     if (expected === 'exists') {
0901:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
0902:     }
0903:     if (expected === 'file' || expected === 'dir') {
0904:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
0905:       let st;
0906:       try {
0907:         st = fs.statSync(resolved);
0908:       } catch (error) {
0909:         return { error: `unable to stat path: ${error.message}` };
0910:       }
0911:       if (expected === 'file' && !st.isFile()) return { error: 'path is not a file' };
0912:       if (expected === 'dir' && !st.isDirectory()) return { error: 'path is not a directory' };
0913:     }
0914: 
0915:     return { path: resolved };
0916:   }
