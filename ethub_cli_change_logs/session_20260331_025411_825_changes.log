0544:       const shellLike = trimmed.replace(/^\$\s*/, '');
0545:       if (/^(ls|pwd|cat|head|tail|wc|rg|grep|find|sed|cp|mv|mkdir|touch|echo|git)\b/.test(shellLike)) {
0546:         addCandidate(shellLike, sourceLabel, 'shell_line');
0547:       }
0548:     }
0549:   }
