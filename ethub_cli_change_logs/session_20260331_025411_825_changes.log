0248: function extractTextEntriesFromZip(zipPath, shouldInclude) {
0249:   const out = [];
0250:   const data = fs.readFileSync(zipPath);
0251:   const minEocd = 22;
0252:   const maxComment = 0xffff;
0253:   const startSearch = Math.max(0, data.length - (minEocd + maxComment));
0254:   let eocd = -1;
0255:   for (let i = data.length - minEocd; i >= startSearch; i -= 1) {
0256:     if (data.readUInt32LE(i) === 0x06054b50) {
0257:       eocd = i;
0258:       break;
0259:     }
0260:   }
0261:   if (eocd < 0) throw new Error('zip EOCD signature not found');
0262: 
0263:   const centralDirSize = data.readUInt32LE(eocd + 12);
0264:   const centralDirOffset = data.readUInt32LE(eocd + 16);
0265:   const centralDirEnd = centralDirOffset + centralDirSize;
0266:   let cursor = centralDirOffset;
0267: 
0268:   while (cursor + 46 <= centralDirEnd && cursor + 46 <= data.length) {
0269:     const sig = data.readUInt32LE(cursor);
0270:     if (sig !== 0x02014b50) break;
0271:     const compressionMethod = data.readUInt16LE(cursor + 10);
0272:     const compressedSize = data.readUInt32LE(cursor + 20);
0273:     const fileNameLen = data.readUInt16LE(cursor + 28);
0274:     const extraLen = data.readUInt16LE(cursor + 30);
0275:     const commentLen = data.readUInt16LE(cursor + 32);
0276:     const localHeaderOffset = data.readUInt32LE(cursor + 42);
0277:     const nameStart = cursor + 46;
0278:     const nameEnd = nameStart + fileNameLen;
0279:     const entryName = data.slice(nameStart, nameEnd).toString('utf8');
0280:     const next = nameEnd + extraLen + commentLen;
0281:     cursor = next;
0282: 
0283:     if (!shouldInclude(entryName)) continue;
0284:     if (entryName.endsWith('/')) continue;
0285:     if (localHeaderOffset + 30 > data.length) continue;
0286:     if (data.readUInt32LE(localHeaderOffset) !== 0x04034b50) continue;
0287: 
0288:     const localNameLen = data.readUInt16LE(localHeaderOffset + 26);
0289:     const localExtraLen = data.readUInt16LE(localHeaderOffset + 28);
0290:     const payloadStart = localHeaderOffset + 30 + localNameLen + localExtraLen;
0291:     const payloadEnd = payloadStart + compressedSize;
0292:     if (payloadEnd > data.length) continue;
0293: 
0294:     const compressed = data.slice(payloadStart, payloadEnd);
0295:     let decoded;
0296:     if (compressionMethod === 0) {
0297:       decoded = compressed;
0298:     } else if (compressionMethod === 8) {
0299:       decoded = zlib.inflateRawSync(compressed);
0300:     } else {
0301:       continue;
0302:     }
0303: 
0304:     out.push({
0305:       entry: entryName,
0306:       text: decoded.toString('utf8')
0307:     });
0308:   }
0309:   return out;
0310: }
