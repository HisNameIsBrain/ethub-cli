0970:           await this.handleUserPrompt(input);
0971:         }
0972:       } catch (error) {
0973:         const message = error && error.message ? error.message : String(error);
0974:         this.print(`${style('Error:', ANSI.bold, ANSI.red)} ${message}`);
0975:         this.logger.writeEvent('runtime_error', { message, stack: error && error.stack ? error.stack : null });
0976:       }
0977: 
0978:       this.flushState();
0979:       this.safePrompt();
0980:     });
0981: 
0982:     this.rl.on('close', () => {
0983:       this.isClosed = true;
0984:       this.stopDebugDashboard();
0985:       this.logger.writeEvent('session_end', { ended_at: nowIso() });
