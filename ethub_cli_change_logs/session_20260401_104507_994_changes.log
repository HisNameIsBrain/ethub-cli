0269: function extractTextEntriesFromZip(zipPath, shouldInclude) {
0270:   const out = [];
0271:   const data = fs.readFileSync(zipPath);
0272:   const minEocd = 22;
0273:   const maxComment = 0xffff;
0274:   const startSearch = Math.max(0, data.length - (minEocd + maxComment));
0275:   let eocd = -1;
0276:   for (let i = data.length - minEocd; i >= startSearch; i -= 1) {
0277:     if (data.readUInt32LE(i) === 0x06054b50) {
0278:       eocd = i;
0279:       break;
0280:     }
0281:   }
0282:   if (eocd < 0) throw new Error('zip EOCD signature not found');
0283: 
0284:   const centralDirSize = data.readUInt32LE(eocd + 12);
0285:   const centralDirOffset = data.readUInt32LE(eocd + 16);
0286:   const centralDirEnd = centralDirOffset + centralDirSize;
0287:   let cursor = centralDirOffset;
0288: 
0289:   while (cursor + 46 <= centralDirEnd && cursor + 46 <= data.length) {
0290:     const sig = data.readUInt32LE(cursor);
0291:     if (sig !== 0x02014b50) break;
0292:     const compressionMethod = data.readUInt16LE(cursor + 10);
0293:     const compressedSize = data.readUInt32LE(cursor + 20);
0294:     const fileNameLen = data.readUInt16LE(cursor + 28);
0295:     const extraLen = data.readUInt16LE(cursor + 30);
0296:     const commentLen = data.readUInt16LE(cursor + 32);
0297:     const localHeaderOffset = data.readUInt32LE(cursor + 42);
0298:     const nameStart = cursor + 46;
0299:     const nameEnd = nameStart + fileNameLen;
0300:     const entryName = data.slice(nameStart, nameEnd).toString('utf8');
0301:     const next = nameEnd + extraLen + commentLen;
0302:     cursor = next;
0303: 
0304:     if (!shouldInclude(entryName)) continue;
0305:     if (entryName.endsWith('/')) continue;
0306:     if (localHeaderOffset + 30 > data.length) continue;
0307:     if (data.readUInt32LE(localHeaderOffset) !== 0x04034b50) continue;
0308: 
0309:     const localNameLen = data.readUInt16LE(localHeaderOffset + 26);
0310:     const localExtraLen = data.readUInt16LE(localHeaderOffset + 28);
0311:     const payloadStart = localHeaderOffset + 30 + localNameLen + localExtraLen;
0312:     const payloadEnd = payloadStart + compressedSize;
0313:     if (payloadEnd > data.length) continue;
0314: 
0315:     const compressed = data.slice(payloadStart, payloadEnd);
0316:     let decoded;
0317:     if (compressionMethod === 0) {
0318:       decoded = compressed;
0319:     } else if (compressionMethod === 8) {
0320:       decoded = zlib.inflateRawSync(compressed);
0321:     } else {
0322:       continue;
0323:     }
0324: 
0325:     out.push({
0326:       entry: entryName,
0327:       text: decoded.toString('utf8')
0328:     });
0329:   }
0330:   return out;
0331: }
