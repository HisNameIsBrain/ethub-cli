0909:   async ensureDashboardRunning() {
0910:     const runtime = this.readDashboardRuntime();
0911:     if (runtime && Number(runtime.port) > 0) {
0912:       const healthy = await this.isDashboardHealthy(runtime.port);
0913:       if (healthy) {
0914:         this.dashboardInfo = runtime;
0915:         return;
0916:       }
0917:     }
0918: 
0919:     const serverPath = this.resolveDashboardServerPath();
0920:     if (!serverPath) return;
0921:     try {
0922:       const child = spawn(process.execPath, [serverPath], {
0923:         cwd: this.workspaceRoot,
0924:         detached: true,
0925:         stdio: 'ignore'
0926:       });
0927:       child.unref();
0928:       this.logger.writeEvent('dashboard_boot', { started: true, path: serverPath });
0929:     } catch (error) {
0930:       this.logger.writeEvent('dashboard_boot', { started: false, error: error.message });
0931:       return;
0932:     }
0933: 
0934:     for (let i = 0; i < 10; i += 1) {
0935:       await new Promise((resolve) => setTimeout(resolve, 300));
0936:       const nextRuntime = this.readDashboardRuntime();
0937:       if (nextRuntime && Number(nextRuntime.port) > 0) {
0938:         this.dashboardInfo = nextRuntime;
0939:         break;
0940:       }
0941:     }
0942:   }
