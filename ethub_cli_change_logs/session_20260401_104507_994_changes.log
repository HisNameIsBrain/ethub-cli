0333: function summarizeReasoning(input) {
0334:   const raw = String(input || '').trim();
0335:   const lowered = raw.toLowerCase();
0336:   const keywords = raw
0337:     .split(/\s+/)
0338:     .map((w) => w.replace(/[^a-zA-Z0-9_-]/g, ''))
0339:     .filter(Boolean)
0340:     .slice(0, 12);
0341: 
0342:   let intent = 'general_request';
0343:   if (/error|syntax|stack|trace|bug|fix|crash/.test(lowered)) intent = 'debugging';
0344:   else if (/how|what|why|explain|guide|tutorial/.test(lowered)) intent = 'information_lookup';
0345:   else if (/build|create|make|implement|write/.test(lowered)) intent = 'implementation';
0346: 
0347:   let strategy = 'Use local conversation context then query Ollama for a grounded response.';
0348:   if (intent === 'debugging') {
0349:     strategy = 'Focus on likely fault points, propose checks, and request missing runtime details if needed.';
0350:   }
0351: 
0352:   return {
0353:     query: raw,
0354:     intent,
0355:     keywords,
0356:     strategy,
0357:     note: 'Detailed private chain-of-thought is not exposed; this is a concise decision summary.'
0358:   };
0359: }
