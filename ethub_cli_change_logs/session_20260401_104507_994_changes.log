1113:   renderDebugDashboard(reasoning, context = {}) {
1114:     const width = DEBUG_PANEL_WIDTH;
1115:     const horizontal = DEBUG_HORIZONTAL.repeat(width);
1116:     const header = 'Agent v3.1 - Local Debug Shell';
1117:     const hasError = Boolean(context.error) || /error|crash|exception/i.test(reasoning.intent || '');
1118:     const liveLines = [
1119:       `INFO  cwd=${context.cwd || process.cwd()}`,
1120:       `INFO  target=${context.target || './src'}`,
1121:       `INFO  model=${this.model}`,
1122:       `ERROR ${context.error || (hasError ? "TypeError: Cannot read property 'foo' of undefined" : 'no faults detected')}`,
1123:       '',
1124:       `ctx.intent=${context.intent || reasoning.intent || 'unknown'}`,
1125:       `ctx.signal=${context.signal || (hasError ? 'runtime_exception' : 'idle')}`
1126:     ];
1127:     const debugLines = [
1128:       `step=${context.step || 'analyze_error'}`,
1129:       `input="${context.input || 'ethub fix ./src --auto-apply'}"`,
1130:       '',
1131:       'reasoning:',
1132:       `• classified → ${reasoning.intent || 'general_request'}`,
1133:       `• detected → ${context.detected || 'undefined property access'}`,
1134:       `• mapped → ${context.mapped || 'src/index.js:42'}`,
1135:       '',
1136:       `next=${context.next || 'generate_fix'}`
1137:     ];
1138:     const planTasks = context.plan || [
1139:       { label: 'scan_directory', done: true },
1140:       { label: 'extract_stack', done: true },
1141:       { label: 'map_error_to_ast', done: true },
1142:       { label: 'generate_patch', done: false }
1143:     ];
1144:     const planLines = planTasks.map((task) => `${task.done ? '✔' : '⏳'} ${task.label}`);
1145:     planLines.push('');
1146:     planLines.push(`ctx.strategy=${context.strategy || reasoning.strategy || 'optional_chaining'}`);
1147:     planLines.push(`ctx.target=${context.targetExpression || context.target || 'data.foo'}`);
1148: 
1149:     const statusLine = `ollama > ${context.commandLabel || 'generating fix'} (strategy=${context.strategy || reasoning.strategy || 'optional_chaining'})`;
1150:     const modelStatus = `MODEL: ${this.model} | STATUS: ${context.status || (hasError ? 'generating_fix' : 'idle')} | TASK: ${context.task || 'src/index.js'}`;
1151: 
1152:     const layout = [
1153:       header,
1154:       horizontal,
1155:       '',
1156:       this.buildBox('Live Dashboard', liveLines),
1157:       '',
1158:       this.buildBox('Debug Loop', debugLines),
1159:       '',
1160:       this.buildBox('TODO Plan', planLines),
1161:       '',
1162:       horizontal,
1163:       statusLine,
1164:       '',
1165:       horizontal,
1166:       modelStatus
1167:     ].join('\n');
1168: 
1169:     process.stdout.write('\x1b[2J\x1b[H');
1170:     process.stdout.write(`${layout}\n`);
