0145: function rainbowAsciiLine(line, row, totalRows, frame) {
0146:   let out = '';
0147:   const len = Math.max(line.length, 1);
0148: 
0149:   for (let i = 0; i < line.length; i += 1) {
0150:     const ch = line[i];
0151:     if (ch === ' ') {
0152:       out += ' ';
0153:       continue;
0154:     }
0155: 
0156:     const phase = (i / len + row / totalRows + frame * 0.01) % 1;
0157:     const { r, g, b } = hslToRgb(phase * 360, 0.6, 0.65);
0158: 
0159:     let display = ch;
0160:     if ((ch === 'o' || ch === '8') && (frame + i + row) % 47 === 0) {
0161:       display = '+';
0162:     }
0163: 
0164:     out += rgb(display, r, g, b);
0165:   }
0166: 
0167:   return out;
0168: }
