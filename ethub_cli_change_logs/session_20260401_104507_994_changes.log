0123: function hslToRgb(h, s, l) {
0124:   h /= 360;
0125:   const a = s * Math.min(l, 1 - l);
0126:   const f = (n) => {
0127:     const k = (n + h * 12) % 12;
0128:     const c = l - a * Math.max(Math.min(k - 3, 9 - k, 1), -1);
0129:     return Math.round(c * 255);
0130:   };
0131:   return { r: f(0), g: f(8), b: f(4) };
0132: }
