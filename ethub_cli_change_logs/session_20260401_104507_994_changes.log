1078:   determineIntentWithHopper(input) {
1079:     const reasoning = summarizeReasoning(input);
1080:     const intent = String(reasoning.intent || 'general_request');
1081:     let lane = 'general';
1082:     if (intent === 'debugging') lane = 'debug';
1083:     else if (intent === 'implementation' || intent === 'refactor') lane = 'code';
1084:     else if (intent === 'shell_operation') lane = 'shell';
1085:     else if (intent === 'planning') lane = 'plan';
1086:     else if (intent === 'information_lookup' || intent === 'documentation') lane = 'research';
1087:     else if (intent === 'testing') lane = 'verify';
1088:     return { ...reasoning, hopper_lane: lane };
1089:   }
