1191:   workspaceRelativePath(targetPath = process.cwd()) {
1192:     const rel = path.relative(this.workspaceRoot, targetPath);
1193:     if (!rel || rel === '') return '.';
1194:     if (rel.startsWith('..')) return targetPath;
1195:     return rel;
1196:   }
1197: 
1198:   refreshPrompt() {
1199:     const rel = this.workspaceRelativePath();
1200:     this.rl.setPrompt(style(`ethub:${rel}> `, ANSI.bold, ANSI.cyan));
1201:   }
1202: 
1203:   printFooter() {
1204:     const cwdDisplay = this.workspaceRelativePath();
1205:     this.print(LEFT_PAD + style(`cwd: ${cwdDisplay}`, ANSI.dim));
1206:   }
1207: 
1208:   resolvePathInWorkspace(inputPath, expected = 'any') {
1209:     const raw = String(inputPath || '').trim();
1210:     if (!raw) return { error: 'path is required' };
1211:     const normalized = raw === '~' ? os.homedir() : raw;
1212:     const resolved = path.resolve(process.cwd(), normalized);
1213:     const root = path.resolve(this.workspaceRoot);
1214:     const inRoot = resolved === root || resolved.startsWith(`${root}${path.sep}`);
1215:     if (!inRoot) {
1216:       return { error: `path escapes workspace root: ${root}` };
1217:     }
1218: 
1219:     if (expected === 'exists') {
1220:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
1221:     }
1222:     if (expected === 'file' || expected === 'dir') {
1223:       if (!fs.existsSync(resolved)) return { error: 'path does not exist' };
1224:       let st;
1225:       try {
1226:         st = fs.statSync(resolved);
1227:       } catch (error) {
1228:         return { error: `unable to stat path: ${error.message}` };
1229:       }
1230:       if (expected === 'file' && !st.isFile()) return { error: 'path is not a file' };
1231:       if (expected === 'dir' && !st.isDirectory()) return { error: 'path is not a directory' };
1232:     }
1233: 
1234:     return { path: resolved };
1235:   }
