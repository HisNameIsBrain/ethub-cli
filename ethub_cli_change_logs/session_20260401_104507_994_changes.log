1339:   async handleCommand(input) {
1340:     const [cmd, ...args] = input.split(/\s+/);
1341:     const command = cmd.toLowerCase();
1342:     this.logger.writeEvent('subcommand', { command, args });
1343: 
1344:     if (command === '/help') {
1345:       this.print('Commands: /help, /status, /model <name>, /approve changes on|off, /debug, /dashboard, /readfile <path>, /writefile <path> -- <content>, /cd <path>, /skills <mine|candidates|add|list|show|run>, /yes, /no, /exit');
1346:       this.print('Skills flow: /skills mine 10 -> /skills add cand_1 my_skill -> /yes -> /skills run my_skill -> /yes');
1347:       return;
1348:     }
1349: 
1350:     if (command === '/status') {
1351:       this.print(safeJson({
1352:         model: this.model,
1353:         ollama_url: this.ollamaUrl,
1354:         require_approval_for_changes: this.requireApproval,
1355:         skills_count: this.skills.length,
1356:         skill_candidates_count: this.skillCandidates.length,
1357:         dashboard_url: this.dashboardInfo && this.dashboardInfo.dashboard_url ? this.dashboardInfo.dashboard_url : null,
1358:         chat_url: this.dashboardInfo && this.dashboardInfo.chat_url ? this.dashboardInfo.chat_url : null,
1359:         debug_dashboard_pid: this.debugServerProcess && !this.debugServerProcess.killed ? this.debugServerProcess.pid : null,
1360:         history_count: this.history.length,
1361:         pending_action: this.pendingAction ? this.pendingAction.id : null
1362:       }));
1363:       return;
1364:     }
1365: 
1366:     if (command === '/model') {
1367:       const nextModel = args.join(' ').trim();
1368:       if (!nextModel) {
1369:         this.print(`Current model: ${this.model}`);
1370:         return;
1371:       }
1372:       this.model = nextModel;
1373:       this.print(`Model updated: ${this.model}`);
1374:       this.logger.writeEvent('config_update', { key: 'model', value: this.model });
1375:       return;
1376:     }
1377: 
1378:     if (command === '/approve') {
1379:       const target = (args[0] || '').toLowerCase();
1380:       const mode = (args[1] || '').toLowerCase();
1381:       const legacyMode = target;
1382: 
1383:       if (target === 'changes' && (mode === 'on' || mode === 'off')) {
1384:         this.requireApproval = mode === 'on';
1385:         this.print(`Change approval mode: ${mode}`);
1386:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1387:         return;
1388:       }
1389: 
1390:       if (legacyMode === 'on' || legacyMode === 'off') {
1391:         this.requireApproval = legacyMode === 'on';
1392:         this.print(`Change approval mode: ${legacyMode}`);
1393:         this.logger.writeEvent('config_update', { key: 'require_approval_for_changes', value: this.requireApproval });
1394:         return;
1395:       }
1396: 
1397:       if (!target) {
1398:         this.print(`Change approval mode: ${this.requireApproval ? 'on' : 'off'}`);
1399:         return;
1400:       }
1401: 
1402:       this.print('Usage: /approve changes on|off');
1403:       return;
1404:     }
1405: 
1406:     if (command === '/debug' || command === '/dashboard') {
1407:       const info = await this.startDebugDashboard();
1408:       this.print(style(`Debug dashboard live: ${info.dashboard_url}`, ANSI.cyan));
1409:       this.print(style(`Debug chat live: ${info.chat_url}`, ANSI.cyan));
1410:       this.print(style(`Token length: ${this.debugServerToken.length} (never written to file)`, ANSI.dim));
1411:       return;
1412:     }
1413: 
1414:     if (command === '/yes') {
1415:       if (!this.pendingAction) {
1416:         this.print('No pending action to approve.');
1417:         return;
1418:       }
1419:       const action = this.pendingAction;
1420:       this.pendingAction = null;
1421:       this.logger.writeEvent('approval', { action_id: action.id, approved: true });
1422:       this.writeStructuredUpdate(action.id, {
1423:         'Print-approved-by-user?': 'true',
1424:         approved: true
1425:       });
1426:       await this.executePendingAction(action);
1427:       return;
1428:     }
1429: 
1430:     if (command === '/no') {
1431:       if (!this.pendingAction) {
1432:         this.print('No pending action to reject.');
1433:         return;
1434:       }
1435:       const action = this.pendingAction;
1436:       this.pendingAction = null;
1437:       this.logger.writeEvent('approval', { action_id: action.id, approved: false });
1438:       this.writeStructuredUpdate(action.id, {
1439:         'Print-approved-by-user?': 'false',
1440:         approved: false,
1441:         summary: 'Action was rejected by user before runtime execution.',
1442:         'Run runtime look at logs': 'skipped (approval rejected)'
1443:       });
1444:       this.print(`Action ${action.id} skipped.`);
1445:       return;
1446:     }
1447: 
1448:     if (command === '/exit') {
1449:       this.rl.close();
1450:       return;
1451:     }
1452: 
1453:     if (command === '/cd') {
1454:       const rawTarget = input.replace(/^\/cd\s*/i, '').trim();
1455:       if (!rawTarget) {
1456:         this.print(`Current directory: ${process.cwd()}`);
1457:         return;
1458:       }
1459:       const resolved = this.resolvePathInWorkspace(rawTarget, 'dir');
1460:       if (resolved.error) {
1461:         this.print(`${style('cd denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1462:         return;
1463:       }
1464:       process.chdir(resolved.path);
1465:       this.refreshPrompt();
1466:       this.logger.writeEvent('cwd_changed', {
1467:         cwd: process.cwd(),
1468:         workspace_relative: this.workspaceRelativePath()
1469:       });
1470:       this.print(style(`Directory changed to ${this.workspaceRelativePath()}`, ANSI.cyan));
1471:       return;
1472:     }
1473: 
1474:     if (command === '/readfile') {
1475:       const rawPath = input.replace(/^\/readfile\s*/i, '').trim();
1476:       if (!rawPath) {
1477:         this.print('Usage: /readfile <path>');
1478:         return;
1479:       }
1480:       const resolved = this.resolvePathInWorkspace(rawPath, 'file');
1481:       if (resolved.error) {
1482:         this.print(`${style('readfile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1483:         return;
1484:       }
1485:       const action = {
1486:         id: `act_${Date.now()}`,
1487:         type: 'read_file',
1488:         payload: {
1489:           path: resolved.path,
1490:           rel: this.workspaceRelativePath(resolved.path)
1491:         },
1492:         created_at: nowIso()
1493:       };
1494:       this.queueApprovalAction(
1495:         action,
1496:         `${style('Read request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel}`
1497:       );
1498:       return;
1499:     }
1500: 
1501:     if (command === '/writefile') {
1502:       const raw = input.replace(/^\/writefile\s*/i, '');
1503:       const splitIndex = raw.indexOf(' -- ');
1504:       if (splitIndex === -1) {
1505:         this.print('Usage: /writefile <path> -- <content>');
1506:         return;
1507:       }
1508:       const rawPath = raw.slice(0, splitIndex).trim();
1509:       const content = raw.slice(splitIndex + 4);
1510:       if (!rawPath) {
1511:         this.print('Usage: /writefile <path> -- <content>');
1512:         return;
1513:       }
1514:       const resolved = this.resolvePathInWorkspace(rawPath, 'any');
1515:       if (resolved.error) {
1516:         this.print(`${style('writefile denied:', ANSI.bold, ANSI.red)} ${resolved.error}`);
1517:         return;
1518:       }
1519:       const action = {
1520:         id: `act_${Date.now()}`,
1521:         type: 'write_file',
1522:         payload: {
1523:           path: resolved.path,
1524:           rel: this.workspaceRelativePath(resolved.path),
1525:           content
1526:         },
1527:         created_at: nowIso()
1528:       };
1529:       this.queueApprovalAction(
1530:         action,
1531:         `${style('Write request queued:', ANSI.bold, ANSI.yellow)} ${action.payload.rel} (${content.length} chars)`
1532:       );
1533:       return;
1534:     }
1535: 
1536:     if (command === '/skills') {
1537:       const sub = (args[0] || '').toLowerCase();
1538:       if (!sub || sub === 'help') {
1539:         this.print('Usage:');
1540:         this.print('/skills mine [count]');
1541:         this.print('/skills candidates');
1542:         this.print('/skills add <candidate_id> <skill_name>');
1543:         this.print('/skills list');
1544:         this.print('/skills show <skill_id|skill_name>');
1545:         this.print('/skills run <skill_id|skill_name>');
1546:         return;
1547:       }
1548: 
1549:       if (sub === 'mine') {
1550:         const count = Number(args[1] || 10);
1551:         const result = this.collectSkillCandidatesFromArtifacts(count);
1552:         this.print(style(`Mined ${result.candidates} candidate skill patterns from artifacts (sources scanned: ${result.scannedSources}).`, ANSI.cyan));
1553:         for (const c of this.skillCandidates) {
1554:           this.print(style(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.yellow));
1555:           this.print('```');
1556:           this.print(c.snippet);
1557:           this.print('```');
1558:           if (!c.executable) this.print(style(`reason: ${c.safety_reason}`, ANSI.dim));
1559:         }
1560:         return;
1561:       }
1562: 
1563:       if (sub === 'candidates') {
1564:         if (!this.skillCandidates.length) {
1565:           this.print('No candidates loaded. Run /skills mine first.');
1566:           return;
1567:         }
1568:         for (const c of this.skillCandidates) {
1569:           this.print(`[${c.id}] hits=${c.hits} executable=${c.executable ? 'yes' : 'no'} source_kind=${c.source_kind}`);
1570:         }
1571:         return;
1572:       }
1573: 
1574:       if (sub === 'add') {
1575:         const candidateId = args[1] || '';
1576:         const skillName = args.slice(2).join(' ').trim();
1577:         if (!candidateId || !skillName) {
1578:           this.print('Usage: /skills add <candidate_id> <skill_name>');
1579:           return;
1580:         }
1581:         const existing = this.findSkill(skillName);
1582:         if (existing) {
1583:           this.print(`Skill already exists: ${existing.name} (${existing.id})`);
1584:           return;
1585:         }
1586:         const candidate = this.findCandidate(candidateId);
1587:         if (!candidate) {
1588:           this.print(`Candidate not found: ${candidateId}`);
1589:           return;
1590:         }
1591:         const action = {
1592:           id: `act_${Date.now()}`,
1593:           type: 'add_skill',
1594:           payload: {
1595:             skill_name: skillName,
1596:             source_candidate: candidate.id,
1597:             snippet: candidate.snippet,
1598:             executable: candidate.executable
1599:           },
1600:           created_at: nowIso()
1601:         };
1602:         this.queueApprovalAction(
1603:           action,
1604:           `${style('Add skill queued:', ANSI.bold, ANSI.yellow)} ${skillName} from ${candidate.id}`
1605:         );
1606:         return;
1607:       }
1608: 
1609:       if (sub === 'list') {
1610:         if (!this.skills.length) {
1611:           this.print(`No approved skills yet. Skills file: ${this.skillsPath}`);
1612:           return;
1613:         }
1614:         for (const skill of this.skills) {
1615:           this.print(`[${skill.id}] ${skill.name} | executable=${skill.executable ? 'yes' : 'no'} | source=${skill.source}`);
1616:         }
1617:         return;
1618:       }
1619: 
1620:       if (sub === 'show') {
1621:         const query = args.slice(1).join(' ').trim();
1622:         if (!query) {
1623:           this.print('Usage: /skills show <skill_id|skill_name>');
1624:           return;
1625:         }
1626:         const skill = this.findSkill(query);
1627:         if (!skill) {
1628:           this.print(`Skill not found: ${query}`);
1629:           return;
1630:         }
1631:         this.print(style(`[${skill.id}] ${skill.name}`, ANSI.bold, ANSI.cyan));
1632:         this.print('```');
1633:         this.print(skill.snippet);
1634:         this.print('```');
1635:         return;
1636:       }
1637: 
1638:       if (sub === 'run') {
1639:         const query = args.slice(1).join(' ').trim();
1640:         if (!query) {
1641:           this.print('Usage: /skills run <skill_id|skill_name>');
1642:           return;
1643:         }
1644:         const skill = this.findSkill(query);
1645:         if (!skill) {
1646:           this.print(`Skill not found: ${query}`);
1647:           return;
1648:         }
1649:         const validation = this.validateSkillCommand(skill.snippet);
1650:         if (!validation.ok) {
1651:           this.print(`${style('Skill is not executable:', ANSI.bold, ANSI.red)} ${validation.reason}`);
1652:           return;
1653:         }
1654:         const action = {
1655:           id: `act_${Date.now()}`,
1656:           type: 'run_skill',
1657:           payload: {
1658:             skill_id: skill.id,
1659:             skill_name: skill.name,
1660:             snippet: skill.snippet
1661:           },
1662:           created_at: nowIso()
1663:         };
1664:         this.queueApprovalAction(
1665:           action,
1666:           `${style('Skill execution queued:', ANSI.bold, ANSI.yellow)} ${skill.name}\n${skill.snippet}`
1667:         );
1668:         return;
1669:       }
1670: 
1671:       this.print(`Unknown skills subcommand: ${sub}`);
1672:       return;
1673:     }
1674: 
1675:     this.print(`Unknown command: ${command}. Use /help.`);
1676:   }
1677: 
1678:   async executePendingAction(action) {
1679:     if (!action) return;
1680:     if (action.type === 'ollama_chat') {
1681:       await this.executeAction(action);
1682:       return;
1683:     }
1684:     if (action.type === 'read_file') {
1685:       this.runReadFileAction(action);
1686:       return;
1687:     }
1688:     if (action.type === 'write_file') {
1689:       this.runWriteFileAction(action);
1690:       return;
1691:     }
1692:     if (action.type === 'add_skill') {
1693:       this.runAddSkillAction(action);
1694:       return;
1695:     }
1696:     if (action.type === 'run_skill') {
1697:       await this.runSkillCommand(action);
1698:       return;
1699:     }
1700:     this.print(`Unsupported pending action type: ${action.type}`);
1701:   }
1702: 
1703:   runReadFileAction(action) {
1704:     const filePath = action && action.payload ? action.payload.path : '';
1705:     if (!filePath || !fs.existsSync(filePath)) {
1706:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} file no longer exists.`);
1707:       return;
1708:     }
1709:     let text;
1710:     try {
1711:       text = fs.readFileSync(filePath, 'utf8');
1712:     } catch (error) {
1713:       this.print(`${style('Read failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1714:       return;
1715:     }
1716:     const shown = truncateText(text, MAX_READFILE_BYTES);
1717:     const rel = action.payload.rel || this.workspaceRelativePath(filePath);
1718:     this.print(style(`[I/O READ] ${rel}`, ANSI.bold, ANSI.cyan));
1719:     this.print(style(`\n[READFILE] ${rel}`, ANSI.bold, ANSI.cyan));
1720:     this.print(style(`bytes: ${Buffer.byteLength(text, 'utf8')} | shown: ${Buffer.byteLength(shown, 'utf8')}`, ANSI.dim));
1721:     this.print(shown);
1722:     this.logger.writeEvent('read_file', {
1723:       action_id: action.id,
1724:       file: filePath,
1725:       bytes: Buffer.byteLength(text, 'utf8'),
1726:       shown_bytes: Buffer.byteLength(shown, 'utf8')
1727:     });
1728:   }
1729: 
1730:   runWriteFileAction(action) {
1731:     const filePath = action && action.payload ? action.payload.path : '';
1732:     const content = action && action.payload ? String(action.payload.content || '') : '';
1733:     if (!filePath) {
1734:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} missing target path.`);
1735:       return;
1736:     }
1737:     try {
1738:       ensureDir(path.dirname(filePath));
1739:       fs.writeFileSync(filePath, content, 'utf8');
1740:     } catch (error) {
1741:       this.print(`${style('Write failed:', ANSI.bold, ANSI.red)} ${error.message}`);
1742:       return;
1743:     }
1744:     this.print(style(`[I/O WRITE] ${action.payload.rel}`, ANSI.bold, ANSI.cyan));
1745:     this.print(style(`[WRITEFILE] wrote ${content.length} chars to ${action.payload.rel}`, ANSI.bold, ANSI.cyan));
1746:     this.logger.writeEvent('write_file', {
1747:       action_id: action.id,
1748:       file: filePath,
1749:       chars: content.length
1750:     });
1751:   }
1752: 
1753:   runAddSkillAction(action) {
1754:     const payload = action && action.payload ? action.payload : {};
1755:     const name = String(payload.skill_name || '').trim();
1756:     const snippet = String(payload.snippet || '');
1757:     if (!name || !snippet) {
1758:       this.print(`${style('Add skill failed:', ANSI.bold, ANSI.red)} missing skill name or snippet.`);
1759:       return;
1760:     }
1761:     const duplicate = this.findSkill(name);
1762:     if (duplicate) {
1763:       this.print(`${style('Add skill skipped:', ANSI.bold, ANSI.red)} skill already exists (${duplicate.id}).`);
1764:       return;
1765:     }
1766: 
1767:     const skill = {
1768:       id: `skill_${Date.now()}`,
1769:       name,
1770:       snippet,
1771:       source: `candidate:${payload.source_candidate || 'unknown'}`,
1772:       executable: Boolean(payload.executable),
1773:       created_at: nowIso()
1774:     };
1775:     this.skills.push(skill);
1776:     this.saveSkills();
1777:     this.print(style(`[SKILL ADDED] ${skill.name} (${skill.id}) executable=${skill.executable ? 'yes' : 'no'}`, ANSI.bold, ANSI.cyan));
1778:     this.logger.writeEvent('skill_added', {
1779:       action_id: action.id,
1780:       skill_id: skill.id,
1781:       skill_name: skill.name,
1782:       executable: skill.executable
1783:     });
1784:   }
1785: 
1786:   async handleUserPrompt(input) {
1787:     const reasoning = this.determineIntentWithHopper(input);
1788:     const action = {
1789:       id: `act_${Date.now()}`,
1790:       type: 'ollama_chat',
1791:       prompt: input,
1792:       reasoning_summary: reasoning,
1793:       created_at: nowIso()
1794:     };
1795: 
1796:     this.logger.writeTranscript('User', input);
1797:     this.logger.writeEvent('user_prompt', {
1798:       text: input,
1799:       hopper_lane: reasoning.hopper_lane,
1800:       reasoning_summary: reasoning,
1801:       proposed_action: { id: action.id, type: action.type }
1802:     });
1803:     this.actionMeta[action.id] = {
1804:       prompt: input,
1805:       prompt_chars_before: input.length
1806:     };
1807:     await this.showReasoningFlow(reasoning, input);
1808: 
1809:     this.logger.writeStructuredRecord({
1810:       timestamp: nowIso(),
1811:       query: input,
1812:       reasoning: {
1813:         query: reasoning.query,
1814:         intent: reasoning.intent,
1815:         keywords: reasoning.keywords,
1816:         search_strategy: reasoning.strategy
1817:       },
1818:       actions: {
1819:         action: 'local_ollama_request',
1820:         sources: ['ollama_localhost'],
1821:         Context: 'Analyzing locally via Ollama only; no OpenAI/Gemini/external model APIs.'
1822:       },
1823:       Commands: "ls, grep, nano, cd, nano 'create-new-file-diff-snippet-number+1.sh', regen entire file with changes then save, cp -rf old/path/to/file move/to/backup/path/file, rm old/path/to/file, bash create-new-file-(diff-snippet-line:character)-(number)+1, sed -i 's/old/new' \"$file\"",
1824:       Diff: '+,-',
1825:       Path: 'path/to/file:line:character',
1826:       action_id: action.id,
1827:       'Print-approved-by-user?': 'not_required (run commands)',
1828:       'Run runtime look at logs': 'pending',
1829:       summary: 'pending',
1830:       'Number of characters changed': 'pending'
1831:     });
1832: 
1833:     await this.executeAction(action);
1834:   }
1835: 
1836:   writeStructuredUpdate(actionId, patch) {
1837:     this.logger.writeStructuredRecord({
1838:       timestamp: nowIso(),
1839:       action_id: actionId,
1840:       update: patch
1841:     });
1842:   }
1843: 
1844:   async executeAction(action) {
1845:     if (!action || action.type !== 'ollama_chat') {
1846:       this.logger.writeEvent('action_error', { message: 'Unsupported action type', action });
1847:       this.writeStructuredUpdate(action && action.id ? action.id : 'unknown', {
1848:         'Run runtime look at logs': 'contains error still, unsupported action type',
1849:         summary: 'Unsupported action type encountered before runtime request.',
1850:         'Number of characters changed': 'previous character amount in file before cmd/new total character count added: 0/0'
1851:       });
1852:       this.print('Unsupported action.');
1853:       return;
1854:     }
1855: 
1856:     this.logger.writeEvent('action_start', {
1857:       action_id: action.id,
1858:       type: action.type,
1859:       target: this.ollamaUrl,
1860:       model: this.model,
1861:       prompt_chars: action.prompt.length,
1862:       reasoning_summary: action.reasoning_summary
1863:     });
1864: 
1865:     this.history.push({ role: 'user', content: action.prompt });
1866: 
1867:     const payload = {
1868:       model: this.model,
1869:       messages: this.history,
1870:       stream: false
1871:     };
1872: 
1873:     let response;
1874:     let raw;
1875:     const started = Date.now();
1876:     this.startThinking();
1877: 
1878:     try {
1879:       response = await fetch(this.ollamaUrl, {
1880:         method: 'POST',
1881:         headers: { 'Content-Type': 'application/json' },
1882:         body: JSON.stringify(payload)
1883:       });
1884: 
1885:       raw = await response.text();
1886:     } catch (error) {
1887:       this.stopThinking();
1888:       const message = error && error.message ? error.message : String(error);
1889:       this.logger.writeEvent('action_failure', {
1890:         action_id: action.id,
1891:         duration_ms: Date.now() - started,
1892:         error: message
1893:       });
1894:       this.writeStructuredUpdate(action.id, {
1895:         'Run runtime look at logs': 'contains error still, loop and try again with different results until each individual error is clear.',
1896:         summary: `Runtime request failed. Error: ${message}`,
1897:         'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${action.prompt.length}/0`,
1898:         'Print-approved-by-user?': 'true'
1899:       });
1900:       this.print(`Ollama request failed: ${message}`);
1901:       return;
1902:     }
1903:     this.stopThinking();
1904: 
1905:     let parsed;
1906:     try {
1907:       parsed = JSON.parse(raw);
1908:     } catch {
1909:       parsed = null;
1910:     }
1911: 
1912:     const assistantText = parsed && parsed.message && parsed.message.content
1913:       ? String(parsed.message.content)
1914:       : raw;
1915: 
1916:     this.history.push({ role: 'assistant', content: assistantText });
1917: 
1918:     this.logger.writeEvent('action_result', {
1919:       action_id: action.id,
1920:       duration_ms: Date.now() - started,
1921:       http_status: response.status,
1922:       ok: response.ok,
1923:       response_preview: assistantText.slice(0, 400),
1924:       response_chars: assistantText.length
1925:     });
1926: 
1927:     this.logger.writeTranscript('Assistant', assistantText);
1928:     this.print(assistantText);
1929: 
1930:     const hasRuntimeError = /(syntaxerror|stack overflow|runtime error|error:)/i.test(assistantText);
1931:     const runtimeResult = hasRuntimeError
1932:       ? 'contains error still, retry with different checks until isolated'
1933:       : 'No runtime error anymore = fixed';
1934:     const beforeChars = this.actionMeta[action.id] && this.actionMeta[action.id].prompt_chars_before
1935:       ? this.actionMeta[action.id].prompt_chars_before
1936:       : 0;
1937:     const afterChars = assistantText.length;
1938:     const elapsedMs = Date.now() - started;
1939: 
1940:     this.writeStructuredUpdate(action.id, {
1941:       'Run runtime look at logs': runtimeResult,
1942:       summary: `summarized what just changed, is it fixed: ${hasRuntimeError ? 'No' : 'Yes'}. Runtime error count estimate: ${hasRuntimeError ? 1 : 0}.`,
1943:       'Number of characters changed': `previous character amount in file before cmd/new total character count added: ${beforeChars}/${afterChars}`,
1944:       timing_ms: elapsedMs,
1945:       stop_condition: elapsedMs >= 300000 ? 'Unable to find results or solutions, Try again.' : 'within loop budget'
1946:     });
1947:   }
1948: }
