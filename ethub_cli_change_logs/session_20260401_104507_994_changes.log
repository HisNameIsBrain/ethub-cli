1237:   queueApprovalAction(action, promptText) {
1238:     if (this.pendingAction) {
1239:       this.print(`Pending action already exists (${this.pendingAction.id}). Resolve with /yes or /no first.`);
1240:       return false;
1241:     }
1242:     this.pendingAction = action;
1243:     this.logger.writeEvent('action_queued', { action_id: action.id, type: action.type, payload: action.payload });
1244:     this.print(promptText);
1245:     this.print(style(`Approve with /yes or reject with /no`, ANSI.yellow));
1246:     return true;
1247:   }
