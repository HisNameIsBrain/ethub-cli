0134: function rainbowDivider(width, phase) {
0135:   let out = '';
0136:   for (let i = 0; i < width; i += 1) {
0137:     const ch = DIVIDER_CHARS[i % DIVIDER_CHARS.length];
0138:     const p = (i / width + phase) % 1;
0139:     const { r, g, b } = hslToRgb(p * 360, 0.6, 0.65);
0140:     out += rgb(ch, r, g, b);
