1000:   async startDebugDashboard() {
1001:     if (this.debugServerProcess && !this.debugServerProcess.killed && this.dashboardInfo) {
1002:       return this.dashboardInfo;
1003:     }
1004: 
1005:     const serverPath = this.resolveDashboardServerPath();
1006:     if (!serverPath) {
1007:       throw new Error('web_debug/index_server.mjs not found');
1008:     }
1009: 
1010:     const child = spawn(process.execPath, [serverPath], {
1011:       cwd: this.workspaceRoot,
1012:       env: process.env,
1013:       stdio: ['ignore', 'pipe', 'pipe']
1014:     });
1015: 
1016:     this.debugServerProcess = child;
1017:     this.debugServerToken = '';
1018:     let startupOutput = '';
1019: 
1020:     child.stdout.on('data', (chunk) => {
1021:       const text = chunk.toString();
1022:       startupOutput += text;
1023:       this.logger.writeEvent('debug_dashboard_stdout', { text: text.slice(0, 800) });
1024:     });
1025:     child.stderr.on('data', (chunk) => {
1026:       const text = chunk.toString();
1027:       startupOutput += text;
1028:       this.logger.writeEvent('debug_dashboard_stderr', { text: text.slice(0, 800) });
1029:     });
1030:     child.on('exit', (code, signal) => {
1031:       this.logger.writeEvent('debug_dashboard_exit', { code, signal });
1032:       this.debugServerProcess = null;
1033:       this.dashboardInfo = null;
1034:       this.debugServerToken = '';
1035:     });
1036: 
1037:     const deadline = Date.now() + 10000;
1038:     while (Date.now() < deadline) {
1039:       const urlMatch = startupOutput.match(/http:\/\/127\.0\.0\.1:(\d+)\/\?token=([a-f0-9]+)/i);
1040:       if (urlMatch) {
1041:         const port = Number(urlMatch[1]);
1042:         const token = String(urlMatch[2] || '');
1043:         const base = `http://127.0.0.1:${port}`;
1044:         this.debugServerToken = token;
1045:         this.dashboardInfo = {
1046:           pid: child.pid,
1047:           host: '127.0.0.1',
1048:           port,
1049:           dashboard_url: `${base}/?token=${token}`,
1050:           chat_url: `${base}/chat?token=${token}`
1051:         };
1052:         this.logger.writeEvent('debug_dashboard_ready', this.dashboardInfo);
1053:         return this.dashboardInfo;
1054:       }
1055: 
1056:       const runtime = this.readDashboardRuntime();
1057:       if (runtime && Number(runtime.port) > 0) {
1058:         const healthy = await this.isDashboardHealthy(runtime.port);
1059:         if (healthy && this.debugServerToken) {
1060:           const base = `http://127.0.0.1:${runtime.port}`;
1061:           this.dashboardInfo = {
1062:             ...runtime,
1063:             dashboard_url: `${base}/?token=${this.debugServerToken}`,
1064:             chat_url: `${base}/chat?token=${this.debugServerToken}`
1065:           };
1066:           this.logger.writeEvent('debug_dashboard_ready', this.dashboardInfo);
1067:           return this.dashboardInfo;
1068:         }
1069:       }
1070: 
1071:       await new Promise((resolve) => setTimeout(resolve, 120));
1072:     }
1073: 
1074:     this.stopDebugDashboard();
1075:     throw new Error('debug dashboard failed to start in time');
1076:   }
