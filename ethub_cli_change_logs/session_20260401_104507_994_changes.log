1102:   buildBox(title, rows) {
1103:     const width = DEBUG_PANEL_WIDTH;
1104:     const prefix = `┌─ ${title} `;
1105:     const fillerCount = Math.max(0, width - prefix.length - 1);
1106:     const top = `${prefix}${DEBUG_HORIZONTAL.repeat(fillerCount)}┐`;
1107:     const bottom = `└${DEBUG_HORIZONTAL.repeat(width - 2)}┘`;
1108:     const innerWidth = width - 4;
1109:     const body = rows.map((row) => `│ ${this.padLineForBox(row, innerWidth)} │`);
1110:     return [top, ...body, bottom].join('\n');
1111:   }
