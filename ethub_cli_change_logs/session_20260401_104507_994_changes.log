1255:   drawHeader(frame) {
1256:     const p1 = (frame / 90) % 1;
1257:     const p3 = (p1 + 0.66) % 1;
1258:     this.print(LEFT_PAD + rainbowDivider(HEADER_WIDTH, p1));
1259:     ETHUB_ASCII.forEach((line, row) => {
1260:       this.print(LEFT_PAD + rainbowAsciiLine(line, row, ETHUB_ASCII.length, frame));
1261:     });
1262:     this.print(
1263:       LEFT_PAD +
1264:       style(
1265:         `Mode: CHAT | Model: ${this.model} | Change Approval: ${this.requireApproval ? 'ON' : 'OFF'} | cwd: ${this.workspaceRelativePath()}`,
1266:         ANSI.dim
1267:       )
1268:     );
1269:     this.print(LEFT_PAD + rainbowDivider(HEADER_WIDTH, p3));
1270:   }
1271: 
1272:   renderHeaderFrame(frame) {
1273:     const p1 = (frame / 90) % 1;
1274:     const p3 = (p1 + 0.66) % 1;
1275:     const lines = [];
1276:     lines.push(LEFT_PAD + rainbowDivider(HEADER_WIDTH, p1));
1277:     ETHUB_ASCII.forEach((line, row) => {
1278:       lines.push(LEFT_PAD + rainbowAsciiLine(line, row, ETHUB_ASCII.length, frame));
1279:     });
1280:     lines.push(
1281:       LEFT_PAD +
1282:       style(
1283:         `Mode: CHAT | Model: ${this.model} | Approval: ${this.requireApproval ? 'ON' : 'OFF'} | cwd: ${this.workspaceRelativePath()}`,
1284:         ANSI.dim
1285:       )
1286:     );
1287:     lines.push(LEFT_PAD + rainbowDivider(HEADER_WIDTH, p3));
1288:     return lines;
1289:   }
1290: 
1291:   async animateHeader(durationMs = 1200, fps = 20) {
1292:     const frameDelay = Math.max(16, Math.floor(1000 / fps));
1293:     const frames = Math.max(1, Math.floor(durationMs / frameDelay));
1294:     for (let frame = 0; frame < frames; frame += 1) {
1295:       const lines = this.renderHeaderFrame(frame);
1296:       process.stdout.write('\x1b[2J\x1b[H');
1297:       process.stdout.write(`${lines.join('\n')}\n`);
1298:       await new Promise((resolve) => setTimeout(resolve, frameDelay));
1299:     }
1300:     process.stdout.write('\x1b[2J\x1b[H');
1301:     this.drawHeader(frames);
1302:   }
