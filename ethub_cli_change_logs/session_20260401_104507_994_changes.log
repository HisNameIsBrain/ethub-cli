0944:   async start() {
0945:     if (ANSI_ENABLED && process.stdout.isTTY) {
0946:       await this.animateHeader(1200, 20);
0947:     } else {
0948:       this.drawHeader(0);
0949:     }
0950:     this.print(style('ETHUB CLI Agent started. Ollama only, no external dependencies.', ANSI.bold, ANSI.cyan));
0951:     this.print(style(`Session logs: ${this.logger.sessionDir}`, ANSI.dim));
0952:     this.print(style('Use /debug to launch a session-bound web dashboard + chat.', ANSI.dim));
0953:     this.print(style('Type /help for commands.', ANSI.yellow));
0954:     await this.showSuggestions();
0955:     this.safePrompt();
0956: 
0957:     this.rl.on('line', async (line) => {
0958:       const input = String(line || '').trim();
0959:       this.logger.writeEvent('stdin', { raw: line, trimmed: input });
0960: 
0961:       if (!input) {
0962:         this.safePrompt();
0963:         return;
0964:       }
0965: 
0966:       try {
0967:         if (input.startsWith('/')) {
0968:           await this.handleCommand(input);
