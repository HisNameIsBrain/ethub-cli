0564:       try {
0565:         parsed = JSON.parse(raw);
0566:       } catch {
0567:         parsed = null;
0568:       }
0569:     }
0570: 
0571:     const walk = (value, depth = 0) => {
0572:       if (depth > 8) return;
0573:       if (typeof value === 'string') {
0574:         if (value.trim()) segments.push(value);
0575:         return;
0576:       }
0577:       if (!value || typeof value !== 'object') return;
0578:       if (Array.isArray(value)) {
0579:         for (const item of value) walk(item, depth + 1);
0580:         return;
0581:       }
0582:       if (value.content && Array.isArray(value.content.parts)) {
0583:         for (const part of value.content.parts) {
0584:           if (typeof part === 'string' && part.trim()) segments.push(part);
0585:         }
0586:       }
0587:       if (typeof value.text === 'string' && value.text.trim()) {
0588:         segments.push(value.text);
0589:       }
0590:       for (const key of Object.keys(value)) {
0591:         if (key === 'content' || key === 'text') continue;
0592:         walk(value[key], depth + 1);
0593:       }
0594:     };
0595: 
0596:     if (parsed) {
0597:       walk(parsed);
0598:     } else {
0599:       segments.push(raw);
0600:     }
0601: 
0602:     for (const segment of segments) {
0603:       const fencePattern = /```(?:[^\n`]*)\n([\s\S]*?)```/g;
0604:       let match;
0605:       while ((match = fencePattern.exec(segment)) !== null) {
0606:         addCandidate(match[1], sourceLabel, 'fenced_code');
0607:       }
0608: 
0609:       const lines = segment.split('\n');
0610:       for (const line of lines) {
0611:         const trimmed = line.trim();
0612:         if (!trimmed || trimmed.length > 220) continue;
0613:         const shellLike = trimmed.replace(/^\$\s*/, '');
0614:         if (/^(ls|pwd|cat|head|tail|wc|rg|grep|find|sed|cp|mv|mkdir|touch|echo|git)\b/.test(shellLike)) {
0615:           addCandidate(shellLike, sourceLabel, 'shell_line');
0616:         }
0617:       }
0618:     }
0619:   }
0620: 
0621:   listArtifactZipFiles() {
0622:     const out = [];
0623:     if (!fs.existsSync(ARTIFACTS_ROOT)) return out;
0624:     const stack = [ARTIFACTS_ROOT];
0625:     while (stack.length) {
0626:       const current = stack.pop();
0627:       let entries = [];
0628:       try {
0629:         entries = fs.readdirSync(current, { withFileTypes: true });
0630:       } catch {
0631:         continue;
0632:       }
0633:       for (const entry of entries) {
0634:         const full = path.join(current, entry.name);
0635:         if (entry.isDirectory()) {
0636:           stack.push(full);
0637:         } else if (entry.isFile() && full.toLowerCase().endsWith('.zip')) {
0638:           out.push(full);
0639:         }
0640:       }
0641:     }
0642:     return out;
0643:   }
0644: 
0645:   collectSkillCandidatesFromArtifacts(limit = 10) {
0646:     const snippets = new Map();
0647:     let scannedSources = 0;
0648:     const cap = Math.max(1, Math.min(MAX_SKILL_CANDIDATES, Number(limit) || 10));
0649:     const addCandidate = (snippetText, sourceLabel, sourceKind) => {
0650:       const normalized = normalizeSnippet(snippetText);
0651:       if (!looksLikeUsefulSnippet(normalized)) return;
0652:       const existing = snippets.get(normalized);
0653:       if (existing) {
0654:         existing.hits += 1;
0655:         existing.sources.add(sourceLabel);
0656:         return;
0657:       }
0658:       snippets.set(normalized, {
0659:         snippet: normalized,
0660:         hits: 1,
0661:         source_kind: sourceKind,
0662:         sources: new Set([sourceLabel])
0663:       });
0664:     };
0665: 
0666:     const zipFiles = this.listArtifactZipFiles();
0667:     for (const zipPath of zipFiles) {
0668:       try {
0669:         const entries = extractTextEntriesFromZip(zipPath, isLikelyTextPath);
0670:         for (const item of entries) {
0671:           scannedSources += 1;
0672:           this.extractSnippetCandidatesFromText(item.text, `${path.basename(zipPath)}:${item.entry}`, addCandidate);
0673:         }
0674:       } catch (error) {
0675:         this.logger.writeEvent('skills_mine_warning', {
0676:           stage: 'zip_read',
0677:           zip: zipPath,
0678:           error: error.message
0679:         });
0680:       }
0681:     }
0682: 
0683:     const directArtifactFiles = [];
0684:     if (fs.existsSync(ARTIFACTS_ROOT)) {
0685:       const stack = [ARTIFACTS_ROOT];
0686:       while (stack.length) {
0687:         const current = stack.pop();
0688:         let entries = [];
0689:         try {
0690:           entries = fs.readdirSync(current, { withFileTypes: true });
0691:         } catch {
0692:           continue;
0693:         }
0694:         for (const entry of entries) {
0695:           const full = path.join(current, entry.name);
0696:           if (entry.isDirectory()) stack.push(full);
0697:           else if (entry.isFile() && !full.toLowerCase().endsWith('.zip') && isLikelyTextPath(full)) directArtifactFiles.push(full);
0698:         }
0699:       }
0700:     }
0701: 
0702:     for (const filePath of directArtifactFiles) {
0703:       let text = '';
0704:       try {
0705:         text = fs.readFileSync(filePath, 'utf8');
0706:       } catch {
0707:         continue;
0708:       }
0709:       scannedSources += 1;
0710:       this.extractSnippetCandidatesFromText(text, this.workspaceRelativePath(filePath), addCandidate);
0711:     }
0712: 
0713:     const ranked = Array.from(snippets.values())
0714:       .sort((a, b) => b.hits - a.hits || b.snippet.length - a.snippet.length)
0715:       .slice(0, cap);
0716: 
0717:     this.skillCandidates = ranked.map((entry, idx) => {
0718:       const snippet = entry.snippet;
0719:       const safety = this.validateSkillCommand(snippet);
0720:       return {
0721:         id: `cand_${idx + 1}`,
0722:         snippet,
0723:         hits: entry.hits,
0724:         source_kind: entry.source_kind,
0725:         sources: Array.from(entry.sources).slice(0, 6),
0726:         executable: safety.ok,
0727:         safety_reason: safety.ok ? '' : safety.reason
0728:       };
0729:     });
0730: 
0731:     this.logger.writeEvent('skills_mined', {
0732:       candidates: this.skillCandidates.length,
0733:       unique_snippets: snippets.size,
0734:       scanned_sources: scannedSources,
0735:       zip_files: zipFiles.length
0736:     });
0737: 
0738:     return {
0739:       candidates: this.skillCandidates.length,
0740:       uniqueSnippets: snippets.size,
0741:       scannedSources,
0742:       zipFiles: zipFiles.length
0743:     };
0744:   }
0745: 
0746:   findCandidate(query) {
0747:     const q = String(query || '').trim();
0748:     if (!q) return null;
0749:     return this.skillCandidates.find((c) => c.id === q) || null;
0750:   }
0751: 
0752:   findSkill(query) {
0753:     const q = String(query || '').trim().toLowerCase();
0754:     if (!q) return null;
0755:     return this.skills.find((s) => s.id.toLowerCase() === q || s.name.toLowerCase() === q) || null;
0756:   }
0757: 
0758:   validatePathToken(token) {
0759:     const raw = String(token || '').trim();
0760:     if (!raw) return { ok: true };
0761:     if (raw === '-' || raw.startsWith('-')) return { ok: true };
0762:     if (raw.startsWith('/')) return { ok: false, reason: `Absolute paths are blocked (${raw}).` };
0763:     if (raw.includes('..')) return { ok: false, reason: `Parent traversal is blocked (${raw}).` };
0764:     const resolved = path.resolve(process.cwd(), raw);
0765:     if (!isPathInsideRoot(this.workspaceRoot, resolved)) {
0766:       return { ok: false, reason: `Path escapes workspace root (${raw}).` };
0767:     }
0768:     return { ok: true };
0769:   }
0770: 
0771:   validateSkillCommand(snippet) {
0772:     const commandText = normalizeSnippet(snippet);
0773:     if (!commandText) return { ok: false, reason: 'Empty snippet.' };
0774:     const lines = commandText.split('\n').map((l) => l.trim()).filter(Boolean);
0775:     if (lines.length !== 1) return { ok: false, reason: 'Only single-line shell skills are executable.' };
0776:     const line = lines[0];
0777:     if (BLOCKED_COMMAND_PATTERN.test(line)) {
0778:       return { ok: false, reason: 'Command contains blocked shell operators.' };
0779:     }
0780: 
0781:     const parsed = tokenizeCommandLine(line);
0782:     if (parsed.error) return { ok: false, reason: parsed.error };
0783:     const tokens = parsed.tokens || [];
0784:     if (!tokens.length) return { ok: false, reason: 'No command token found.' };
0785: 
0786:     const cmd = tokens[0];
0787:     if (!SAFE_SKILL_COMMANDS.has(cmd)) {
0788:       return { ok: false, reason: `Command '${cmd}' is not allowlisted.` };
0789:     }
0790:     if (cmd === 'git') {
0791:       const sub = (tokens[1] || '').toLowerCase();
0792:       if (!['status', 'diff', 'log', 'show', 'branch', 'rev-parse'].includes(sub)) {
0793:         return { ok: false, reason: `git '${sub || '(none)'}' is blocked.` };
0794:       }
0795:     }
0796: 
0797:     for (let i = 1; i < tokens.length; i += 1) {
0798:       const pathCheck = this.validatePathToken(tokens[i]);
0799:       if (!pathCheck.ok) return pathCheck;
0800:     }
0801:     return { ok: true, command: cmd, tokens };
0802:   }
0803: 
0804:   async runSkillCommand(action) {
0805:     const payload = action && action.payload ? action.payload : {};
0806:     const skillName = payload.skill_name || payload.skill_id || 'unknown';
0807:     const snippet = String(payload.snippet || '');
0808:     const validation = this.validateSkillCommand(snippet);
0809:     if (!validation.ok) {
0810:       this.print(`${style('Skill execution denied:', ANSI.bold, ANSI.red)} ${validation.reason}`);
0811:       this.logger.writeEvent('skill_run_denied', {
0812:         action_id: action.id,
0813:         skill: skillName,
0814:         reason: validation.reason
0815:       });
0816:       return;
0817:     }
0818: 
0819:     const tokens = validation.tokens;
0820:     const cmd = tokens[0];
0821:     const args = tokens.slice(1);
0822:     this.print(style(`[SKILL RUN] ${skillName}: ${snippet}`, ANSI.bold, ANSI.cyan));
0823: 
0824:     const result = await new Promise((resolve) => {
0825:       const child = spawn(cmd, args, {
0826:         cwd: process.cwd(),
0827:         stdio: ['ignore', 'pipe', 'pipe'],
0828:         shell: false
0829:       });
0830: 
0831:       let stdout = '';
0832:       let stderr = '';
0833:       let finished = false;
0834:       const timer = setTimeout(() => {
0835:         if (finished) return;
0836:         child.kill('SIGTERM');
0837:       }, 120000);
0838: 
0839:       child.stdout.on('data', (chunk) => {
0840:         if (stdout.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0841:         stdout += chunk.toString('utf8');
0842:       });
0843:       child.stderr.on('data', (chunk) => {
0844:         if (stderr.length >= MAX_COMMAND_OUTPUT_BYTES) return;
0845:         stderr += chunk.toString('utf8');
0846:       });
0847:       child.on('error', (error) => {
0848:         clearTimeout(timer);
0849:         finished = true;
0850:         resolve({ code: -1, signal: null, stdout, stderr: `${stderr}\n${error.message}`.trim() });
0851:       });
0852:       child.on('close', (code, signal) => {
0853:         clearTimeout(timer);
0854:         finished = true;
0855:         resolve({ code, signal, stdout, stderr });
0856:       });
0857:     });
0858: 
0859:     if (result.stdout) {
0860:       this.print(style('[STDOUT]', ANSI.dim));
0861:       this.print(truncateText(result.stdout, MAX_COMMAND_OUTPUT_BYTES));
0862:     }
0863:     if (result.stderr) {
0864:       this.print(style('[STDERR]', ANSI.dim));
0865:       this.print(truncateText(result.stderr, MAX_COMMAND_OUTPUT_BYTES));
0866:     }
0867:     this.print(style(`[SKILL EXIT] code=${result.code} signal=${result.signal || 'none'}`, ANSI.dim));
0868:     this.logger.writeEvent('skill_run_complete', {
0869:       action_id: action.id,
0870:       skill: skillName,
0871:       code: result.code,
0872:       signal: result.signal,
0873:       stdout_chars: result.stdout.length,
0874:       stderr_chars: result.stderr.length
0875:     });
0876:   }
0877: 
0878:   readDashboardRuntime() {
0879:     const runtimePaths = [WEB_DEBUG_RUNTIME_PATH_LOCAL, WEB_DEBUG_RUNTIME_PATH_APP];
0880:     for (const runtimePath of runtimePaths) {
0881:       if (!fs.existsSync(runtimePath)) continue;
0882:       try {
0883:         const parsed = JSON.parse(fs.readFileSync(runtimePath, 'utf8'));
0884:         if (!parsed || !parsed.port) continue;
0885:         return parsed;
0886:       } catch {
0887:         // try next runtime path
0888:       }
0889:     }
0890:     return null;
0891:   }
