1177:   safePrompt() {
1178:     if (this.isClosed) return;
1179:     try {
1180:       this.printFooter();
1181:       this.rl.prompt();
1182:     } catch (error) {
1183:       const message = error && error.message ? error.message : String(error);
1184:       if (!/readline was closed/i.test(message)) {
1185:         throw error;
1186:       }
1187:       this.isClosed = true;
1188:     }
1189:   }
